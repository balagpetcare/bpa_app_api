# =========================
# Rate Limit / Security (unchanged)
# =========================
RL_WINDOW_MS=900000
RL_GENERAL_MAX=300
RL_AUTH_MAX=20
RL_WITHDRAW_WINDOW_MS=60000
RL_WITHDRAW_MAX=10
RL_WEBHOOK_WINDOW_MS=60000
RL_WEBHOOK_MAX=120

ADMIN_2FA_REQUIRED=false
ADMIN_2FA_TOTP_SECRET=CHANGE_ME_BASE32_TOTP_SECRET
