# =========================
# Server Config
# =========================
HOST=0.0.0.0
PORT=3000
API_VERSION=v1

# =========================
# Database (Docker)
# =========================
DATABASE_URL="postgresql://bpa_admin:password123@localhost:5432/bpa_pet_db?schema=public"
SHADOW_DATABASE_URL="postgresql://bpa_admin:password123@localhost:5432/bpa_pet_db_shadow?schema=public"

# =========================
# JWT
# =========================
JWT_SECRET=CHANGE_ME_TO_A_LONG_RANDOM_SECRET_64CHARS_MIN
JWT_EXPIRES_IN=30d

# =========================
# MinIO / S3 Config (Docker)
# =========================
AWS_REGION=us-east-1
AWS_BUCKET_NAME=bpa-pets
AWS_ENDPOINT=http://bpa-storage:9000
AWS_ACCESS_KEY_ID=admin
AWS_SECRET_ACCESS_KEY=password123

# Public URL যদি ব্রাউজারে দেখাতে হয়
MINIO_PUBLIC_URL=http://127.0.0.1:9000

# =========================
# ✅ CORS Allowlist (FIXED)
# =========================
