# =========================
# Server Config
# =========================
HOST=localhost
PORT=3000

# ✅ API Version Control (ONE LINE CHANGE)
API_VERSION=v1


# =========================
# Database
# =========================
DATABASE_URL="postgresql://bpa_admin:password123@localhost:5432/bpa_pet_db?schema=public"


# =========================
# JWT
# =========================
JWT_SECRET="my_super_secret_key_12345"
JWT_EXPIRES_IN="30d"


# =========================
# MinIO / S3 Config
# =========================
AWS_REGION="us-east-1"
AWS_BUCKET_NAME="bpa-pets"
AWS_ENDPOINT="http://127.0.0.1:9000"

# ✅ AWS SDK v3 standard naming (Recommended)
AWS_ACCESS_KEY_ID="admin"
AWS_SECRET_ACCESS_KEY="password123"

# Public URL (app/browser ব্যবহার করবে)
MINIO_PUBLIC_URL="http://192.168.10.111:9000"

