PORT=3000
JWT_SECRET=change_me

# Social Login
# Google OAuth Client ID (Web / Android / iOS as applicable)
GOOGLE_CLIENT_ID=

# Facebook App (the backend only needs accessToken validation via Graph API)
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=

# PostgreSQL
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/bpa?schema=public"

# S3/Minio (optional - for media uploads)
S3_ENDPOINT=
S3_REGION=ap-southeast-1
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=
S3_PUBLIC_BASE_URL=
# ---- Media upload policy ----
MAX_UPLOAD_BYTES=104857600
IMAGE_MAX_SIDE=1600
IMAGE_JPEG_QUALITY=82
# VIDEO_TRANSCODE=true

