# Server
PORT=8080
JWT_SECRET=change_me_super_secret

# PostgreSQL
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/bpa_onboarding?schema=public
SHADOW_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/bpa_onboarding_shadow?schema=public

# Seed: create a SUPER_ADMIN platform user
SUPER_ADMIN_PHONE=017777889994,01701022274
SUPER_ADMIN_PASSWORD=123456

# Super Admin Panel Access (DB whitelist seed)
# Only these emails/phones will be allowed to login via /api/v1/admin/auth/login
# (comma-separated)
SUPER_ADMIN_WHITELIST_EMAILS=balag@bangladeshpetassociation.com,admin@bangladeshpetassociation.com
SUPER_ADMIN_WHITELIST_PHONES=017777889994,01701022274

# Verification rollout control
# false (default): soft mode (non-breaking). If an entity is under verification, legacy edit endpoints respond 200 with a `verification` warning.
# true: hard-lock mode. Legacy edit endpoints return 409 (VERIFICATION_LOCKED) for SUBMITTED/APPROVED entities.
VERIFICATION_HARD_LOCK=true

# ========== Global-Ready (Country-First) – API Phases ==========
# Phase 1: Country context default when X-Country-Code header is missing
COUNTRY_DEFAULT=BD
# Policy Engine Redis cache TTL (seconds); default 300
POLICY_CACHE_TTL_SEC=300

# Redis (BullMQ notifications + OTP + replay guards)
# - Prefer REDIS_URL in production (single source for BullMQ + ioredis).
# - REDIS_ENABLED=false disables Redis even when REDIS_URL is set (local dev default).
# - When disabled/unavailable: in-memory cache, queues off, campaign OTP sessions in-memory.
REDIS_ENABLED=false
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379
# REDIS_PASSWORD=
# REDIS_USERNAME=
# REDIS_CONNECT_TIMEOUT_MS=5000
# REDIS_MAX_CONNECT_RETRIES=10

# SMS gateway (SSL Wireless primary, BulkSMSBD fallback)
SMS_ENABLED=true
SMS_PRIMARY_PROVIDER=ssl_wireless
SMS_FALLBACK_PROVIDER=bulksmsbd
SMS_QUEUE_ATTEMPTS=3
SMS_QUEUE_BACKOFF_MS=5000
SMS_WORKER_CONCURRENCY=5
SMS_STUCK_RECOVERY_MINUTES=15
SMS_CHARS_PER_SEGMENT=160
SMS_COST_PER_SEGMENT_BDT=0.25
# SMS_ALLOW_MOCK=true  # production emergency only
# SMS_ALLOW_DEV_FAKE_SENT=true  # dev: mark SMS sent without gateway (never in prod)
# CAMPAIGN_SMS_WEBHOOK_SECRET=  # header x-campaign-sms-secret on delivery-callback

# SSL Wireless (https://smsplus.sslwireless.com)
SSL_WIRELESS_API_TOKEN=
SSL_WIRELESS_SENDER_ID=
SSL_WIRELESS_BASE_URL=https://smsplus.sslwireless.com

# BulkSMSBD (REST v3 or legacy)
BULKSMSBD_API_TOKEN=
BULKSMSBD_API_KEY=
BULKSMSBD_SENDER_ID=
BULKSMSBD_BASE_URL=https://app.bulksmsbd.xyz
BULKSMSBD_API_MODE=rest_v3
BULKSMSBD_LEGACY_URL=http://bulksmsbd.net/api/smsapi

# Campaign SMS sender fallback
CAMPAIGN_SMS_SENDER_ID=

# Public API base (payment gateway callback URLs)
API_PUBLIC_BASE_URL=https://api.yourdomain.com

# Campaign landing (bKash redirect after execute)
CAMPAIGN_LANDING_URL=https://vaccination.yourdomain.com

# Campaign payment webhook (optional shared secret header: x-campaign-payment-secret)
CAMPAIGN_PAYMENT_WEBHOOK_SECRET=

# Pending payment expiry (minutes) — failed bookings can retry after timeout
CAMPAIGN_PAYMENT_TIMEOUT_MINUTES=30

# Coupons — JSON array (keep in sync with vaccination_2026 NEXT_PUBLIC_BOOKING_COUPONS)
CAMPAIGN_BOOKING_COUPONS=[{"code":"BPA2026","label":"Campaign launch — 20% off","type":"PERCENT","value":20},{"code":"CATLOVE","label":"Community partner — ৳50 off","type":"FIXED","value":50}]

# Express 3-step booking (payment-first checkout)
CAMPAIGN_SIMPLIFIED_BOOKING=true

# Active gateway (sslcommerz | amarpay | bkash | nagad | eps) — switch without code changes
# Dev/QA: PAYMENT_PROVIDER=eps
PAYMENT_PROVIDER=sslcommerz

# Optional shared secret for POST /api/v1/payments/webhook (headers: x-payment-webhook-secret or x-campaign-payment-secret)
PAYMENT_WEBHOOK_SECRET=

# Payment recovery job interval (ms) — re-verify stale pending orders
PAYMENT_RECOVERY_INTERVAL_MS=600000

# AmarPay
AMARPAY_STORE_ID=
AMARPAY_SIGNATURE_KEY=
AMARPAY_SANDBOX=true
# AMARPAY_BASE_URL=
# AMARPAY_IPN_URL=

# bKash (tokenized checkout)
BKASH_APP_KEY=
BKASH_APP_SECRET=
BKASH_USERNAME=
BKASH_PASSWORD=
BKASH_SANDBOX=true
# BKASH_BASE_URL=
# BKASH_CALLBACK_URL=

# Nagad
NAGAD_MERCHANT_ID=
NAGAD_MERCHANT_NUMBER=
NAGAD_PRIVATE_KEY=
NAGAD_PUBLIC_KEY=
NAGAD_SANDBOX=true
# NAGAD_BASE_URL=
# NAGAD_CALLBACK_URL=

# SSLCommerz
SSLCOMMERZ_STORE_ID=
SSLCOMMERZ_STORE_PASSWORD=
SSLCOMMERZ_SANDBOX=true
# SSLCOMMERZ_SUCCESS_URL=
# SSLCOMMERZ_FAIL_URL=
# SSLCOMMERZ_CANCEL_URL=
# SSLCOMMERZ_IPN_URL=

# EPS (Easy Payment System) — sandbox / live via EPS_BASE_URL + EPS_SANDBOX
# PAYMENT_PROVIDER=eps
EPS_BASE_URL=https://sandboxpgapi.eps.com.bd
EPS_USERNAME=
EPS_PASSWORD=
EPS_HASH=
EPS_MERCHANT_ID=
EPS_STORE_ID=
EPS_SANDBOX=true
# EPS_SUCCESS_URL=
# EPS_FAIL_URL=
# EPS_CANCEL_URL=
# EPS_TIMEOUT_MS=30000

# AI Intelligence Phase 4: optional auto-create DRAFT stock requests from critical suggestions (default off)
AI_AUTO_DRAFT_STOCK_REQUEST=false

# Phase 2: Donation rate limit (per window)
RL_DONATION_WINDOW_MS=60000
RL_DONATION_MAX=30
# Phase 6: Donation fraud/abuse velocity limit
DONATION_FRAUD_MAX_PER_HOUR=5

# Phase 3: Storage per country (key prefix e.g. BD/, IN/)
STORAGE_USE_COUNTRY_PREFIX=true
# Phase 3: Geocode rate limit (Nominatim ~1 req/sec public)
RL_GEOCODE_WINDOW_MS=60000
RL_GEOCODE_MAX=60

# Warehouse / inventory stock mutations (POST /api/v1/inventory/stock/in|out, /transfers, /transfers/:id/dispatch)
RL_INVENTORY_WAREHOUSE_MUTATION_WINDOW_MS=60000
RL_INVENTORY_WAREHOUSE_MUTATION_MAX=120

# Phase 4: Govt reporting (donation threshold -> log + optional webhook)
GOVT_REPORTING_DONATION_THRESHOLD=50000
GOVT_REPORTING_WEBHOOK_URL=

# Cookie domain for auth cookie (share across localhost ports in dev)
# Development: localhost (share cookie across 3000, 3100-3106)
# Production: .yourdomain.com (leading dot for subdomains)
COOKIE_DOMAIN=localhost

# CORS (comma-separated; empty = allow all in dev)
# CORS_ORIGINS=http://localhost:3100,http://localhost:3101,http://localhost:3102,http://localhost:3103,http://localhost:3104,http://localhost:3105,http://localhost:3106,http://localhost:3110,http://127.0.0.1:3110

# Country panel base URL (invite links)
# COUNTRY_PANEL_PUBLIC_URL=http://localhost:3106

# Product Authenticity (MVP)
# Used to sign serial codes (HMAC). Keep secret in production.
AUTH_SERIAL_SIGNING_SECRET=change_me_serial_secret

# Producer/Auth Codes (HMAC + encryption)
AUTH_CODE_HMAC_SECRET=change_me_auth_code_hmac
AUTH_CODE_ENC_SECRET=change_me_auth_code_encrypt
