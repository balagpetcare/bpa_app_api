// AUTO-SPLIT from original schema.prisma
// Module: base

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// AUTO-SPLIT from original schema.prisma
// Module: core

enum Gender {
  MALE
  FEMALE
  UNKNOWN
}

enum PetStatus {
  ACTIVE
  DECEASED
  LOST
  ADOPTED
}

enum FamilyRelation {
  OWNER
  DAD
  MOM
  BROTHER
  SISTER
  OTHER
}

enum UserStatus {
  ACTIVE
  BLOCKED
  DELETED
}

enum ProfileVisibility {
  PUBLIC
  PRIVATE
  FOLLOWERS_ONLY
}

enum AuthProvider {
  LOCAL
  GOOGLE
  FACEBOOK
  APPLE
}

enum FriendRequestStatus {
  PENDING
  ACCEPTED
  REJECTED
  CANCELED
}

enum PostType {
  TEXT
  IMAGE
  VIDEO
  REEL
}

enum PostCategory {
  GENERAL
  FUNDRAISING
  FUNDRAISING_UPDATE
}

model AnimalType {
  id           Int           @id @default(autoincrement())
  name         String        @unique
  breeds       Breed[]
  pets         Pet[]
  vaccineTypes VaccineType[]

  @@map("animal_types")
}

model Breed {
  id           Int        @id @default(autoincrement())
  name         String
  animalTypeId Int
  animalType   AnimalType @relation(fields: [animalTypeId], references: [id])
  pets         Pet[]

  @@unique([name, animalTypeId])
  @@map("breeds")
}

model UserAuth {
  id     Int  @id @default(autoincrement())
  userId Int  @unique
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  provider AuthProvider @default(LOCAL)

  email        String? @unique
  phone        String? @unique
  passwordHash String? // LOCAL only

  passwordUpdatedAt DateTime?
  emailVerifiedAt   DateTime?
  phoneVerifiedAt   DateTime?

  lastLoginAt    DateTime?
  failedAttempts Int       @default(0)
  lockedUntil    DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email])
  @@index([phone])
  @@map("user_auth")
}

model UserProfile {
  id     Int  @id @default(autoincrement())
  userId Int  @unique
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  displayName String
  username    String  @unique
  bio         String? @db.Text

  visibility ProfileVisibility @default(PUBLIC)

  // privacy flags
  showEmail Boolean @default(false)
  showPhone Boolean @default(false)

  // Media: avatar & cover
  avatarMediaId Int?
  avatarMedia   Media? @relation("UserAvatar", fields: [avatarMediaId], references: [id])

  coverMediaId Int?
  coverMedia   Media? @relation("UserCover", fields: [coverMediaId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([username])
  @@map("user_profiles")
}

model UserStatsCache {
  userId Int  @id
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  followersCount Int @default(0)
  followingCount Int @default(0)
  petsCount      Int @default(0)

  // Mirror/cache for fast profile reads (source of truth: UserWallet.points)
  pawPoints Int @default(0)

  // Cached rank (optional)
  rankGlobal Int?

  updatedAt DateTime @updatedAt

  @@map("user_stats_cache")
}

model UserSession {
  id     Int  @id @default(autoincrement())
  userId Int
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Store hash only (never store raw refresh token)
  refreshTokenHash String @unique

  deviceId  String?
  userAgent String?
  ip        String?

  createdAt DateTime  @default(now())
  expiresAt DateTime
  revokedAt DateTime?

  @@index([userId])
  @@index([expiresAt])
  @@map("user_sessions")
}

model UserFollow {
  id          Int      @id @default(autoincrement())
  followerId  Int
  followingId Int
  createdAt   DateTime @default(now())

  follower  User @relation("UserFollowing", fields: [followerId], references: [id], onDelete: Cascade)
  following User @relation("UserFollowers", fields: [followingId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId])
  @@index([followingId])
  @@index([followerId])
  @@map("user_follows")
}

model UserProfileLike {
  id        Int      @id @default(autoincrement())
  userId    Int
  likedById Int
  createdAt DateTime @default(now())

  user    User @relation("UserProfileLiked", fields: [userId], references: [id], onDelete: Cascade)
  likedBy User @relation("UserProfileLiker", fields: [likedById], references: [id], onDelete: Cascade)

  @@unique([userId, likedById])
  @@index([userId])
  @@index([likedById])
  @@map("user_profile_likes")
}

model UserFriendRequest {
  id         Int                 @id @default(autoincrement())
  fromUserId Int
  toUserId   Int
  status     FriendRequestStatus @default(PENDING)
  createdAt  DateTime            @default(now())
  updatedAt  DateTime            @updatedAt

  fromUser User @relation("FriendRequestFrom", fields: [fromUserId], references: [id], onDelete: Cascade)
  toUser   User @relation("FriendRequestTo", fields: [toUserId], references: [id], onDelete: Cascade)

  @@unique([fromUserId, toUserId])
  @@index([toUserId])
  @@index([fromUserId])
  @@map("user_friend_requests")
}

model UserFriend {
  id        Int      @id @default(autoincrement())
  userAId   Int
  userBId   Int
  createdAt DateTime @default(now())

  userA User @relation("UserFriendA", fields: [userAId], references: [id], onDelete: Cascade)
  userB User @relation("UserFriendB", fields: [userBId], references: [id], onDelete: Cascade)

  @@unique([userAId, userBId])
  @@index([userAId])
  @@index([userBId])
  @@map("user_friends")
}

model Achievement {
  id             Int     @id @default(autoincrement())
  code           String  @unique
  title          String
  description    String?
  requiredPoints Int     @default(0)
  pointsReward   Int     @default(0)
  howTo          String?

  iconMediaId Int?
  iconMedia   Media? @relation("AchievementIcon", fields: [iconMediaId], references: [id])

  createdAt DateTime @default(now())

  users UserAchievement[]

  @@map("achievements")
}

model UserAchievement {
  id            Int      @id @default(autoincrement())
  userId        Int
  achievementId Int
  unlockedAt    DateTime @default(now())

  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  achievement Achievement @relation(fields: [achievementId], references: [id], onDelete: Cascade)

  @@unique([userId, achievementId])
  @@index([userId])
  @@map("user_achievements")
}

model UserGalleryItem {
  id     Int  @id @default(autoincrement())
  userId Int
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  mediaId Int
  media   Media @relation("UserGalleryMedia", fields: [mediaId], references: [id], onDelete: Cascade)

  caption   String?
  createdAt DateTime @default(now())
  deleted   Boolean  @default(false)

  @@index([userId, createdAt])
  @@map("user_gallery_items")
}

model User {
  id        Int        @id @default(autoincrement())
  status    UserStatus @default(ACTIVE)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  // Split tables (keep User thin)
  auth     UserAuth?
  profile  UserProfile?
  stats    UserStatsCache?
  sessions UserSession[]

  // Social graph
  followsFollowing UserFollow[] @relation("UserFollowing")
  followsFollowers UserFollow[] @relation("UserFollowers")

  profileLikesReceived UserProfileLike[] @relation("UserProfileLiked")
  profileLikesGiven    UserProfileLike[] @relation("UserProfileLiker")

  friendRequestsSent     UserFriendRequest[] @relation("FriendRequestFrom")
  friendRequestsReceived UserFriendRequest[] @relation("FriendRequestTo")

  friendsA UserFriend[] @relation("UserFriendA")
  friendsB UserFriend[] @relation("UserFriendB")

  // Existing relations
  pets                   Pet[]
  wallet                 UserWallet?
  walletWithdrawRequests WalletWithdrawRequest[]
  rewardHistories        RewardHistory[]

  // Home feed / posts
  posts                               Post[]
  postLikes                           PostLike[]
  postComments                        PostComment[]
  // postComments     PostComment[]
  postCommentLikes                    PostCommentLike[]
  // NEW: opposite side of Media.owner
  uploadedMedia                       Media[]                       @relation("UserUploadedMedia")
  fundraisingAccountStatusLogsAsAdmin FundraisingAccountStatusLog[] @relation("FundraisingAccountStatusLogAdminUser")
  fundraisingWithdrawRequestsAsAdmin  FundraisingWithdrawRequest[]  @relation("FundraisingWithdrawAdminUser")
  walletWithdrawRequestsAsAdmin       WalletWithdrawRequest[]       @relation("WalletWithdrawAdminUser")

  // Premium profile features
  achievements UserAchievement[]
  galleryItems UserGalleryItem[]

  // FUNDRAISING (Phase A) - opposite relation fields
  fundraisingAccount FundraisingAccount?
  donations          Donation[]

  // REPORTS (Phase B) - opposite relation field
  reports Report[] @relation("UserReports")

  // PARTNER ONBOARDING (Org/Branch)
  partnerApplications PartnerApplication[]
  ownedOrganizations  Organization[]
  ownerProfile        OwnerProfile?

  // PHASE-1 KYC / Verification
  ownerKyc                 OwnerKyc?
  ownerKycReviewed         OwnerKyc[]                 @relation("OwnerKycReviewedBy")
  orgLegalProfilesReviewed OrganizationLegalProfile[] @relation("OrgKycReviewedBy")
  branchProfilesReviewed   BranchProfileDetails[]     @relation("BranchKycReviewedBy")
  verificationLogsAsAdmin  VerificationLog[]          @relation("VerificationLogAdmin")

  // ============================
  // V3 VERIFICATION (opposites)
  // ============================

  verificationCasesReviewed   VerificationCase[]      @relation("VerificationCaseReviewedBy")
  verificationDocsChecked     VerificationDocument[]  @relation("VerificationDocCheckedBy")
  verificationCaseEventsAdmin VerificationCaseEvent[] @relation("VerificationCaseEventAdmin")

  notifications              Notification[]
  notificationsSent          Notification[] @relation("NotificationSender")
  notificationReads          NotificationRead[]
  notificationPrefs          UserNotificationPrefs?
  verificationLockedAttempts VerificationLockedUpdateAttempt[]

  // === BPA PATCH: memberships + product approval ===
  orgMemberships     OrgMember[]
  branchMemberships  BranchMember[]
  productsCreated    Product[]              @relation("ProductCreatedBy")
  productImportBatchesCreated ProductImportBatch[] @relation("ProductImportBatchCreatedBy")
  productCRRequested ProductChangeRequest[] @relation("ProductCRRequestedBy")
  productCRReviewed  ProductChangeRequest[] @relation("ProductCRReviewedBy")

  grnsReceived             Grn[]                 @relation("GrnReceivedBy")
  catalogEnableRequestsRequested CatalogEnableRequest[] @relation("CatalogEnableRequestedBy")
  catalogEnableRequestsReviewed  CatalogEnableRequest[] @relation("CatalogEnableReviewedBy")

  // === BPA PATCH: staff invites (token-based) ===
  staffInvitesSent      StaffInvite[]  @relation("StaffInviteInvitedBy")
  staffInvitesAccepted  StaffInvite[]  @relation("StaffInviteAcceptedBy")
  accessInvitesSent     AccessInvite[] @relation("AccessInviteInvitedBy")
  accessInvitesAccepted AccessInvite[] @relation("AccessInviteAcceptedBy")

  // ✅ invitedBy opposite relations
  orgMembersInvited    OrgMember[]    @relation("OrgMemberInvitedBy")
  branchMembersInvited BranchMember[] @relation("BranchMemberInvitedBy")

  // === MVP: Inventory & Orders ===
  stockTransactionsCreated StockTransaction[] @relation("StockTransactionCreatedBy")
  ordersCreated            Order[]            @relation("OrderCreatedBy")
  ordersAsCustomer         Order[]            @relation("OrderCustomer")
  servicesCreated          Service[]          @relation("ServiceCreatedBy")

  // === Products Module: Stock Ledger & Transfers ===
  stockLedgersCreated   StockLedger[]   @relation("StockLedgerCreatedBy")
  stockTransfersCreated StockTransfer[] @relation("StockTransferCreatedBy")
  returnRequestsCreated ReturnRequest[] @relation("ReturnRequestedBy")
  stockLotsCreated      StockLot[]      @relation("StockLotCreatedBy")
  stockAdjustmentRequestsRequested StockAdjustmentRequest[] @relation("StockAdjustmentRequestedBy")
  stockAdjustmentRequestsReviewed  StockAdjustmentRequest[] @relation("StockAdjustmentReviewedBy")
  stockDiscrepanciesResolved       StockDiscrepancy[]       @relation("StockDiscrepancyResolvedBy")
  stockRequestsRequested          StockRequest[]           @relation("StockRequestRequestedBy")
  stockRequestsDeclined          StockRequest[]           @relation("StockRequestDeclinedBy")
  stockRequestsApproved          StockRequest[]           @relation("StockRequestApprovedBy")

  // === Product Authenticity (MVP) ===
  productVersionsCreated ProductVersion[] @relation("ProductVersionCreatedBy")
  batchesCreated         Batch[]          @relation("BatchCreatedBy")
  serialRangesIssued     SerialRange[]    @relation("SerialRangeIssuedBy")

  // === Producer Auth (separate schema) ===
  producerOrgsOwned      ProducerOrg[]         @relation("ProducerOrgOwner")
  producerStaffRoles     ProducerOrgStaff[]    @relation("ProducerStaffUser")
  producerStaffInvited   ProducerOrgStaff[]    @relation("ProducerStaffInviter")
  authProductsCreated    AuthProduct[]         @relation("AuthProductCreatedBy")
  authBatchesCreated     AuthBatch[]           @relation("AuthBatchCreatedBy")
  authCodesGenerated     AuthCode[]            @relation("AuthCodeGeneratedBy")
  authVerifyLogs         AuthVerificationLog[]
  returnRequestsApproved ReturnRequest[]       @relation("ReturnApprovedBy")

  // === Multi-Branch Staff Permission System ===
  branchAccessPermissions         BranchAccessPermission[] @relation("BranchAccessPermissionUser")
  branchAccessPermissionsApproved BranchAccessPermission[] @relation("BranchAccessPermissionApprovedBy")
  branchAccessPermissionsRevoked  BranchAccessPermission[] @relation("BranchAccessPermissionRevokedBy")
  branchAccessPermissionsRequested BranchAccessPermission[] @relation("BranchAccessPermissionRequestedBy")

  // Phase 4: Global + Country RBAC
  globalRoles  UserGlobalRole[]
  countryRoles UserCountryRole[]
  stateRoles   UserStateRole[]

  // === Owner Delegation & Team Management ===
  ownerTeamsOwned          OwnerTeam[]
  ownerTeamMemberships     OwnerTeamMember[]
  ownerDelegationsGranted  OwnerDelegation[]  @relation("OwnerDelegationOwner")
  ownerDelegationsReceived OwnerDelegation[]  @relation("OwnerDelegationDelegate")
  ownerOverviewLogs        OwnerOverviewLog[] @relation("OwnerOverviewLogOwner")
  ownerOverviewLogsAsActor OwnerOverviewLog[] @relation("OwnerOverviewLogActor")
  userContexts             UserContext[]
  userContextsAsOwner      UserContext[]     @relation("UserContextOwner")
  teamInvitationsSent      TeamInvitation[]   @relation("TeamInvitationInvitedBy")
  teamInvitationsAccepted  TeamInvitation[]  @relation("TeamInvitationAcceptedBy")
  teamInvitationsAsOwner   TeamInvitation[]  @relation("TeamInvitationOwner")

  // === Workspace System ===
  workspaceTasksAssignedTo    WorkspaceTask[] @relation("WorkspaceTaskAssignedTo")
  workspaceTasksCreatedBy     WorkspaceTask[] @relation("WorkspaceTaskCreatedBy")
  workspaceTasksAssignedBy    WorkspaceTask[] @relation("WorkspaceTaskAssignedBy")
  workspaceTasksLastUpdatedBy WorkspaceTask[] @relation("WorkspaceTaskLastUpdatedBy")
  workspaceTaskComments      WorkspaceTaskComment[]
  workspaceAlertsAcknowledged WorkspaceAlert[]
  workspaceApprovalRequestsRequested WorkspaceApprovalRequest[] @relation("WorkspaceApprovalRequester")
  workspaceApprovalRequestsDecidedBy WorkspaceApprovalRequest[] @relation("WorkspaceApprovalDecidedBy")

  // Location: user's saved place (lat/lng-first; optional)
  currentPlaceId Int?
  currentPlace   Place?  @relation(fields: [currentPlaceId], references: [id], onDelete: SetNull)

  // Location profile and events
  locationProfile  UserLocationProfile?
  locationEvents   UserLocationEvent[]

  @@map("users")
}

// Place: lat/lng-first location (optional address snapshot). No removal of existing addressJson/hierarchy.
model Place {
  id        Int      @id @default(autoincrement())
  latitude  Float
  longitude Float
  countryCode    String?
  stateName      String?
  cityName       String?
  formattedAddress String?   @db.VarChar(1024)
  rawAddressJson  Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  usersWithCurrentPlace User[]

  @@index([latitude, longitude])
  @@map("places")
}

model LocationPlace {
  id              Int      @id @default(autoincrement())
  countryCode     String
  admin1         String?
  admin2         String?
  city           String?
  postalCode     String?
  formattedAddress String? @db.VarChar(1024)
  lat            Float?
  lng            Float?
  geoHash        String?
  source         LocationSource?
  sourcePlaceId  String?
  bdDivision     String?
  bdDistrict     String?
  bdUpazila      String?
  bdWard         String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  userLocationProfilesAsHome        UserLocationProfile[] @relation("HomePlace")
  userLocationProfilesAsCurrent     UserLocationProfile[] @relation("CurrentPlace")
  userLocationProfilesAsManual      UserLocationProfile[] @relation("ManualOverridePlace")
  userLocationEvents                UserLocationEvent[]

  @@index([countryCode, admin1, city])
  @@index([geoHash])
  @@map("location_places")
}

model UserLocationProfile {
  userId               Int      @unique
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  homePlaceId          Int?
  homePlace            LocationPlace? @relation("HomePlace", fields: [homePlaceId], references: [id], onDelete: SetNull)
  currentPlaceId       Int?
  currentPlace         LocationPlace? @relation("CurrentPlace", fields: [currentPlaceId], references: [id], onDelete: SetNull)
  manualOverridePlaceId Int?
  manualOverridePlace  LocationPlace? @relation("ManualOverridePlace", fields: [manualOverridePlaceId], references: [id], onDelete: SetNull)
  lastLat              Float?
  lastLng              Float?
  precisionLevel       LocationPrecisionLevel
  consentLevel         LocationConsentLevel
  lastUpdatedAt        DateTime @default(now())
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@map("user_location_profiles")
}

model UserLocationEvent {
  id            Int               @id @default(autoincrement())
  userId        Int
  user          User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  timestamp     DateTime
  lat           Float
  lng           Float
  placeId       Int?
  place         LocationPlace?    @relation(fields: [placeId], references: [id], onDelete: SetNull)
  accuracyMeters Float?
  source        LocationSource
  eventType     LocationEventType
  sessionId     String?
  deviceId      String?
  createdAt     DateTime          @default(now())

  @@index([userId, timestamp(sort: Desc)])
  @@map("user_location_events")
}

// Owner profile (separate from UserProfile). This keeps onboarding / KYC fields
// isolated and avoids breaking Flutter/public user profile flows.
model OwnerProfile {
  id     Int  @id @default(autoincrement())
  userId Int  @unique
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Minimal onboarding profile (fast, low-friction). KYC-grade fields live in OwnerKyc.
  // NOTE: All fields are OPTIONAL except name, to avoid breaking existing flows.
  name         String
  supportPhone String?
  supportEmail String?

  // Optional location pointers for quick filtering/search (full address stays in OwnerKyc.presentAddressJson)
  // DEPRECATED: Prefer addressJson for unified location (country/state/city/postal/addressLine/lat/lng)
  divisionId Int?
  districtId Int?
  upazilaId  Int?
  areaId     Int?

  // Unified address (country/state/city/postal/addressLine/formattedAddress/lat/lng)
  addressJson Json?

  nid         String?
  dateOfBirth DateTime?
  genderText  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([divisionId])
  @@index([districtId])
  @@index([upazilaId])
  @@index([areaId])
  @@map("owner_profiles")
}

// -----------------------------
// PHASE-1: Owner/Org/Branch KYC
// -----------------------------

model OwnerKyc {
  id     Int @id @default(autoincrement())
  userId Int @unique

  fullName    String
  fatherName  String?
  motherName  String?
  dateOfBirth DateTime?
  genderText  String?
  nationality String?   @default("Bangladeshi")

  nidNumber     String?
  nidIssueDate  DateTime?
  nidAddressRaw String?

  mobile String?
  email  String?

  presentAddressJson   Json?
  permanentAddressJson Json?

  emergencyContactName  String?
  emergencyContactPhone String?

  verificationStatus VerificationStatus @default(UNSUBMITTED)
  submittedAt        DateTime?
  reviewedAt         DateTime?
  reviewedByAdminId  Int?
  reviewNote         String?
  rejectionReason    String?
  riskScore          Int?               @default(0)

  // Owner KYC Upgrade: expiry + declarations + optional business intent
  expiresAt          DateTime?
  declarationsJson   Json?             // { termsAcceptedAt, dataProcessingConsentAt, infoTrueConfirmedAt, legalBusinessCategoryAt }
  businessIntentJson Json?             // optional pre-fill for first org: { preferredName, orgTypeCode, registrationType }
  // Progressive KYC: 0=pending, 1=verified basic (trade license), 2=verified+payout (bank etc.)
  kycLevel           Int?              @default(0)

  isLocked   Boolean   @default(false)
  lockReason String?
  deletedAt  DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user            User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  reviewedByAdmin User?              @relation("OwnerKycReviewedBy", fields: [reviewedByAdminId], references: [id], onDelete: SetNull)
  documents       OwnerKycDocument[]

  @@index([verificationStatus])
  @@index([reviewedByAdminId])
  @@index([expiresAt])
  @@map("owner_kyc")
}

model OwnerKycDocument {
  id         Int @id @default(autoincrement())
  ownerKycId Int

  type   DocumentType
  status DocumentStatus @default(SUBMITTED)

  mediaId Int
  media   Media @relation(fields: [mediaId], references: [id], onDelete: Cascade)

  docNumber  String?
  issueDate  DateTime?
  expiryDate DateTime?
  note       String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  ownerKyc OwnerKyc @relation(fields: [ownerKycId], references: [id], onDelete: Cascade)

  @@index([ownerKycId])
  @@index([type])
  @@map("owner_kyc_documents")
}

model OrganizationLegalProfile {
  id    Int @id @default(autoincrement())
  orgId Int @unique

  organizationName String
  registrationType RegistrationType @default(PROPRIETORSHIP)

  tradeLicenseNumber     String?
  tradeLicenseIssueDate  DateTime?
  tradeLicenseExpiryDate DateTime?
  issuingAuthority       String?

  tinNumber String?
  binNumber String?

  officialPhone String?
  officialEmail String?
  website       String?
  facebookPage  String?

  bankAccountName   String?
  bankAccountNumber String?
  bankName          String?
  bankBranchName    String?
  routingNumber     String?

  payoutBkash  String?
  payoutNagad  String?
  payoutRocket String?

  verificationStatus VerificationStatus @default(UNSUBMITTED)
  submittedAt        DateTime?
  reviewedAt         DateTime?
  reviewedByAdminId  Int?
  reviewNote         String?
  rejectionReason    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization    Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  reviewedByAdmin User?        @relation("OrgKycReviewedBy", fields: [reviewedByAdminId], references: [id], onDelete: SetNull)

  documents OrganizationDocument[]
  directors OrganizationDirector[]

  @@index([verificationStatus])
  @@index([reviewedByAdminId])
  @@map("org_legal_profiles")
}

model OrganizationDocument {
  id                Int @id @default(autoincrement())
  orgLegalProfileId Int

  type   DocumentType
  status DocumentStatus @default(SUBMITTED)

  mediaId Int
  media   Media @relation(fields: [mediaId], references: [id], onDelete: Cascade)

  docNumber  String?
  issueDate  DateTime?
  expiryDate DateTime?
  note       String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  orgLegalProfile OrganizationLegalProfile @relation(fields: [orgLegalProfileId], references: [id], onDelete: Cascade)

  @@index([orgLegalProfileId])
  @@index([type])
  @@map("org_documents")
}

model OrganizationDirector {
  id                Int @id @default(autoincrement())
  orgLegalProfileId Int

  name   String
  role   String?
  mobile String?
  email  String?

  nidNumber       String?
  sharePercentage Float?

  nidFrontMediaId  Int?
  nidBackMediaId   Int?
  signatureMediaId Int?

  nidFrontMedia  Media? @relation("DirectorNidFront", fields: [nidFrontMediaId], references: [id], onDelete: SetNull)
  nidBackMedia   Media? @relation("DirectorNidBack", fields: [nidBackMediaId], references: [id], onDelete: SetNull)
  signatureMedia Media? @relation("DirectorSignature", fields: [signatureMediaId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  orgLegalProfile OrganizationLegalProfile @relation(fields: [orgLegalProfileId], references: [id], onDelete: Cascade)

  @@index([orgLegalProfileId])
  @@map("org_directors")
}

model BranchProfileDetails {
  id       Int @id @default(autoincrement())
  branchId Int @unique

  branchPhone String?
  branchEmail String?

  managerName      String?
  managerPhone     String?
  managerNidNumber String?

  addressJson     Json?
  latitude        Float?
  longitude       Float?
  googleMapLink   String?
  // Phase 3: coverage area (GeoJSON polygon); optional max area validation
  coveragePolygon Json? // Phase 3: GeoJSON polygon
  // Service area: radius in km (used first; polygon optional later)
  coverageRadiusKm Float?

  openingHoursJson  Json?
  weeklyOffDaysJson Json?

  vetLicenseNumber  String?
  drugLicenseNumber String?

  verificationStatus VerificationStatus @default(UNSUBMITTED)
  submittedAt        DateTime?
  reviewedAt         DateTime?
  reviewedByAdminId  Int?
  reviewNote         String?
  rejectionReason    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  branch          Branch           @relation(fields: [branchId], references: [id], onDelete: Cascade)
  reviewedByAdmin User?            @relation("BranchKycReviewedBy", fields: [reviewedByAdminId], references: [id], onDelete: SetNull)
  documents       BranchDocument[]

  @@index([verificationStatus])
  @@index([reviewedByAdminId])
