  branch         Branch          @relation(fields: [branchId], references: [id], onDelete: Cascade)
  clinicalCase   ClinicalCase?   @relation(fields: [clinicalCaseId], references: [id], onDelete: SetNull)
  procedureOrder ProcedureOrder? @relation(fields: [procedureOrderId], references: [id], onDelete: SetNull)
  visit          Visit?          @relation(fields: [visitId], references: [id], onDelete: SetNull)
  variant        ProductVariant  @relation(fields: [variantId], references: [id], onDelete: Restrict)

  @@index([branchId])
  @@index([clinicalCaseId])
  @@index([returnDueAt])
  @@map("vial_return_controls")
}

model ClinicInvoice {
  id                Int      @id @default(autoincrement())
  orderId           Int      @unique
  clinicalCaseId    Int?
  surgeryPackageId  Int?
  doctorFeeAmount   Decimal? @db.Decimal(12, 2)
  clinicShareAmount Decimal? @db.Decimal(12, 2)
  supportFeeAmount  Decimal? @db.Decimal(12, 2)
  consumableCost    Decimal? @db.Decimal(12, 2)
  discountApplied   Decimal? @db.Decimal(12, 2)
  settlementRef     String?  @db.VarChar(64)
