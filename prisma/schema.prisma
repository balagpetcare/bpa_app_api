enum RoleScope {
  GLOBAL
  COUNTRY
  STATE
  ORG
  BRANCH
}

model Role {
  id        Int       @id @default(autoincrement())
  key       String    @unique
  label     String
  scope     RoleScope
  isSystem  Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  rolePermissions        RolePermission[]
  orgMemberRoles         OrgMemberRole[]
  branchMemberRoles      BranchMemberRole[]
  globalRoleAssignments  UserGlobalRole[]
  countryRoleAssignments UserCountryRole[]
  stateRoleAssignments   UserStateRole[]
  accessInvites          AccessInvite[]
  producerStaffRoles     ProducerOrgStaff[] @relation("ProducerStaffRole")

  @@index([scope])
  @@map("roles")
