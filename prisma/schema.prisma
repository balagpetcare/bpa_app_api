enum BranchAccessPermissionStatus {
  PENDING
  APPROVED
  REVOKED
  EXPIRED
  SUSPENDED
}

model BranchAccessPermission {
  id       Int                          @id @default(autoincrement())
  branchId Int
  userId   Int
  status   BranchAccessPermissionStatus @default(PENDING)
  role     MemberRole?

  // Approval tracking
  approvedByUserId Int?
  approvedAt       DateTime?
  revokedByUserId  Int?
  revokedAt        DateTime?
  expiresAt        DateTime? // Optional time-based expiration

  // Request metadata
  requestedAt       DateTime  @default(now())
  requestedByUserId Int?
  note              String?   @db.Text
  lastLoginAt       DateTime? // Track when staff last accessed this branch

  // Owner-only: restrict manager login to time window (e.g. "09:00", "18:00")
  loginWindowStart    String?
  loginWindowEnd      String?
  // Owner-only: custom permission keys override for this user at this branch (JSON array of strings)
  permissionOverrides Json?

  // Relations
  branch          Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)
  user            User   @relation("BranchAccessPermissionUser", fields: [userId], references: [id], onDelete: Cascade)
  approvedBy      User?  @relation("BranchAccessPermissionApprovedBy", fields: [approvedByUserId], references: [id], onDelete: SetNull)
  revokedBy       User?  @relation("BranchAccessPermissionRevokedBy", fields: [revokedByUserId], references: [id], onDelete: SetNull)
  requestedByUser User?  @relation("BranchAccessPermissionRequestedBy", fields: [requestedByUserId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([branchId, userId])
  @@index([userId, status])
  @@index([branchId, status])
  @@index([status, expiresAt])
  @@map("branch_access_permissions")
}

