  id          Int           @id @default(autoincrement())
  ownerUserId Int
  status      PartnerStatus @default(PENDING_REVIEW)
  // Global-Ready Phase 1: country binding for org scope
  countryId   Int?
  // Country controller: org acting as country chapter (set when assigned as Country.controllerOrg)
  orgType     OrgType?      @default(PARTNER)

  // Payout: NOT_CONFIGURED until banking is set up on /owner/organizations/[id]/payouts
  payoutStatus OrganizationPayoutStatus @default(NOT_CONFIGURED)

  name         String
  supportPhone String?
  addressJson  Json?
  /// Standardized location: { lat, lng, address, city, state, country, postalCode }
  location     Json    @default("{}")

  // Owner KYC Upgrade: soft-delete + grace before hard-delete (user kept; business data removed)
  deletedAt           DateTime?
  deletionScheduledAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  owner                User     @relation(fields: [ownerUserId], references: [id], onDelete: Restrict)
  country              Country? @relation(fields: [countryId], references: [id], onDelete: Restrict)
  controllerForCountry Country? @relation("CountryController")
  branches             Branch[]

  // PHASE-1 KYC / Verification
  legalProfile OrganizationLegalProfile?

  // === BPA PATCH: memberships + product approval ===
  members               OrgMember[]
  products              Product[]
  productChangeRequests ProductChangeRequest[]

  // === BPA PATCH: staff invites ===
  staffInvites  StaffInvite[]
  // ✅ BranchMember.org opposite
  branchMembers BranchMember[]
  // ✅ Service.org opposite
  services         Service[]
  serviceProposals ServiceProposal[]

  // Clinical Item Master
  clinicalItemCategories ClinicalItemCategory[]
  clinicalItems           ClinicalItem[]
  clinicalStockLedgerEntries ClinicalStockLedger[]
  clinicalSupplyRequests  ClinicalSupplyRequest[]
  clinicalStockTransfers  ClinicalStockTransfer[]
  sterilizationCycles     SterilizationCycle[]
  instrumentInstances     InstrumentInstance[]
  clinicalStockAudits     ClinicalStockAudit[]
  clinicalWastageLogs     ClinicalWastageLog[]
  replenishmentRecommendations ReplenishmentRecommendation[]
  clinicCatalogInstallBatches ClinicCatalogInstallBatch[]

  // === Clinic Phase 2: Appointment + Queue ===
  appointments             Appointment[]
  doctorScheduleExceptions DoctorScheduleException[]
  slotLocks                SlotLock[]
  queueSessions            QueueSession[]
  queueTickets             QueueTicket[]
  visits                   Visit[]
  clinicIntakes            ClinicIntake[]

  // === Products Module: Vendors & Commission Rules ===
  vendors             Vendor[]
  vendorAttachments   VendorAttachment[]
  vendorLedgerEntries VendorLedgerEntry[]
  commissionRules     CommissionRule[]

  // === Product Authenticity (MVP) ===
  factories Factory[]
  contracts Contract[]

  // === Inventory: Stock Lots & Adjustment Requests ===
  stockLots               StockLot[]
  stockAdjustmentRequests StockAdjustmentRequest[]

  // === Stock Request ===
  stockRequests StockRequest[]

  // === Stock Dispatch (Challan/DO) ===
  stockDispatches StockDispatch[]

  // === Stock Return (branch → warehouse) ===
  stockReturns StockReturn[]

  // === Stock Ledger (tenant-scoped) ===
  stockLedgers StockLedger[]

  // === GRN (Goods Received Note) & Catalog Enable ===
  grns                  Grn[]
  catalogEnableRequests CatalogEnableRequest[]

  // === Stock Count (cycle count) ===
  stockCountSessions StockCountSession[]

  // === Owner Delegation (scope-limited to org) ===
  ownerDelegations OwnerDelegation[]

  // === Workspace System ===
  workspaceTasks            WorkspaceTask[]
  workspaceAlerts           WorkspaceAlert[]
  workspaceApprovalRequests WorkspaceApprovalRequest[]

  // === Universal Product Import ===
  productImportBatches ProductImportBatch[]
  integrationMappings  IntegrationMapping[]

  // === Clinic: Branch Rooms (via Branch) ===
  branchRooms             BranchRoom[]
  // === Clinic: Staff profiles (via Branch) ===
  clinicStaffProfiles     ClinicStaffProfile[]
  doctorScheduleProposals DoctorScheduleProposal[]
  doctorAuditLogs         DoctorAuditLog[]
  doctorSettlementLedger  DoctorSettlementLedger[]
  doctorScheduleTemplates DoctorScheduleTemplate[]
  roomScheduleTemplates   RoomScheduleTemplate[]
  branchHolidays          BranchHoliday[]
  consultationTemplates   ConsultationTemplate[]
  medicinePolicies        MedicinePolicy[]
  dispenseRequests        DispenseRequest[]
  vialInstances           VialInstance[]
  surgeryPackageTemplates SurgeryPackageTemplate[]
  medicineApprovalRequests MedicineApprovalRequest[]
  medicineIncidents       MedicineIncident[]

  // Enterprise
  branchOverheadRules     BranchOverheadRule[]
  discountPolicies        DiscountPolicy[]
  discountApprovalRules   DiscountApprovalRule[]
  settlementAuditLogs     SettlementAuditLog[]
  approvalActionLogs     ApprovalActionLog[]
  doctorSettlementBatches DoctorSettlementBatch[]
  surgeryPackages         SurgeryPackage[]
  clinicalCases           ClinicalCase[]

  // Branch Manager Control: policy and escalations
  branchPolicies           BranchPolicy[]
  managerApprovalEscalations ManagerApprovalEscalation[]

  @@index([ownerUserId])
  @@index([countryId])
  @@index([deletedAt, deletionScheduledAt])
  @@index([orgType])
  @@map("organizations")
}

enum OrgType {
  PARTNER
  COUNTRY_CHAPTER
}

model Branch {
  id     Int          @id @default(autoincrement())
  orgId  Int
  name   String
  status BranchStatus @default(DRAFT)

  // what this branch IS (shop/clinic/delivery)
  capabilitiesJson Json @default("{}")

  // new: branch can have multiple types (hybrid supported)
  types              BranchToType[]
  // what modules are ENABLED (pos/ecommerce/appointments...) — admin unlocks on approval
  featuresJson       Json           @default("{}")
  // clinic hours, specializations, slot config (Owner Panel clinic setup)
  clinicSettingsJson Json           @default("{}")

  verificationStatus VerificationStatus @default(UNSUBMITTED)
  addressJson        Json?
  /// Standardized location: { lat, lng, address, city, state, country, postalCode }
  location           Json               @default("{}")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  org             Organization           @relation(fields: [orgId], references: [id], onDelete: Cascade)
  publishRequests BranchPublishRequest[]
  typeLinks       BranchTypeOnBranch[]
  // PHASE-1 KYC / Verification
  profileDetails  BranchProfileDetails?

  // === BPA PATCH: branch memberships + product change requests ===
  members               BranchMember[]
  productChangeRequests ProductChangeRequest[] @relation("ProductCRFromBranch")

  // === BPA PATCH: staff invites ===
  staffInvites StaffInvite[]

  // === MVP: Inventory & Orders ===
  inventory        Inventory[]
  orders           Order[]
  posInvoices      PosInvoice[]
  services         Service[]
  serviceProposals ServiceProposal[]

  // === Products Module: Inventory Locations ===
  inventoryLocations InventoryLocation[]

  // === Stock Request (branch requests stock from owner) ===
  stockRequests StockRequest[]

  catalogEnableRequests CatalogEnableRequest[]

  // === Multi-Branch Staff Permission System ===
  accessPermissions BranchAccessPermission[]

  // === Owner Delegation (scope-limited to branch) ===
  ownerDelegations OwnerDelegation[]
  userContexts     UserContext[]

  // === Workspace System ===
  workspaceTasks            WorkspaceTask[]
  workspaceAlerts           WorkspaceAlert[]
  workspaceApprovalRequests WorkspaceApprovalRequest[]

  // === Universal Product Import ===
  productImportBatches ProductImportBatch[]

  // === POS Retail-Grade: Shifts ===
  posShifts PosShift[]

  // === Clinic: Rooms/Chambers ===
  rooms                    BranchRoom[]
  // === Clinic: Staff profiles (per branch member) ===
  clinicStaffProfiles      ClinicStaffProfile[]
  doctorScheduleProposals  DoctorScheduleProposal[]
  doctorAuditLogs          DoctorAuditLog[]
  doctorSettlementLedger   DoctorSettlementLedger[]
  doctorScheduleTemplates  DoctorScheduleTemplate[]
  roomScheduleTemplates    RoomScheduleTemplate[]
  branchHolidays           BranchHoliday[]
  // === Clinic Phase 2: Appointment + Queue ===
  appointments             Appointment[]
  doctorScheduleExceptions DoctorScheduleException[]
  slotLocks                SlotLock[]
  queueSessions            QueueSession[]
  queueTickets             QueueTicket[]
  visits                   Visit[]
  consultationTemplates    ConsultationTemplate[]
  clinicIntakes            ClinicIntake[]
  dispenseRequests          DispenseRequest[]
  vialInstances             VialInstance[]
  vialSessions              VialSession[]
  auditBins                 AuditBin[]
  medicineApprovalRequests  MedicineApprovalRequest[]
  medicineIncidents         MedicineIncident[]
  medicineDiscrepancies     MedicineDiscrepancy[]
  dailyMedicineVariances   DailyMedicineVariance[]
  userMedicineRiskScores   UserMedicineRiskScore[]
  branchComplianceScores   BranchComplianceScore[]

  // Enterprise: Surgery Package + Discount + Settlement
  surgeryPackages          SurgeryPackage[]
  packagePriceRules       PackagePriceRule[]
  branchOverheadRules     BranchOverheadRule[]
  discountPolicies        DiscountPolicy[]
  discountApprovalRules   DiscountApprovalRule[]
  clinicalCases           ClinicalCase[]
  discountAuditLogs       DiscountAuditLog[]
  vialReturnControls     VialReturnControl[]
  clinicFinanceConfig    ClinicFinanceConfig?
  doctorSettlementBatches DoctorSettlementBatch[]
  settlementAuditLogs     SettlementAuditLog[]
  approvalActionLogs     ApprovalActionLog[]
  doctorContracts         DoctorContract[]

  // Clinical Item Master: branch stock and config
  branchItemStocks         BranchItemStock[]
  branchItemBatches        BranchItemBatch[]
  instrumentIssueLogs      InstrumentIssueLog[]
  clinicalItemBranchConfigs ClinicalItemBranchConfig[]
  clinicalStockLedgerEntries ClinicalStockLedger[]
  clinicalSupplyRequests    ClinicalSupplyRequest[]
  clinicalStockTransfersFrom ClinicalStockTransfer[] @relation("ClinicalTransferFrom")
  clinicalStockTransfersTo   ClinicalStockTransfer[] @relation("ClinicalTransferTo")
  sterilizationCycles       SterilizationCycle[]
  instrumentInstances       InstrumentInstance[]
  clinicalStockAudits       ClinicalStockAudit[]
  clinicalWastageLogs       ClinicalWastageLog[]
  replenishmentRecommendations ReplenishmentRecommendation[]

  // Branch Manager Control: policy and escalations
  branchPolicy             BranchPolicy?
  managerApprovalEscalations ManagerApprovalEscalation[]

  @@index([orgId])
  @@map("branches")
}

model BranchRoom {
  id        Int      @id @default(autoincrement())
  orgId     Int
  branchId  Int
  name      String   @db.VarChar(128)
  roomType  String   @db.VarChar(32)
  capacity  Int?
  status    String   @db.VarChar(16) // ACTIVE | INACTIVE
  notes     String?  @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  org                   Organization           @relation(fields: [orgId], references: [id], onDelete: Cascade)
  branch                Branch                 @relation(fields: [branchId], references: [id], onDelete: Cascade)
  roomScheduleTemplates RoomScheduleTemplate[]
  vialSessions          VialSession[]
  auditBins             AuditBin[]

  @@unique([branchId, name])
  @@index([orgId, branchId])
  @@index([branchId, status])
  @@map("branch_rooms")
}

// Branch Manager Control: owner-defined limits per branch
model BranchPolicy {
  id                   Int      @id @default(autoincrement())
  orgId                Int
  branchId             Int
  maxDiscountPercent   Float    @default(30)
  maxRefundAmount      Float    @default(5000)
  maxPurchaseAmount    Float    @default(50000)
  requireOwnerApproval Json     @default("[]") // e.g. ["STAFF_HIRE","PRICE_CHANGE","LARGE_PURCHASE","HIGH_DISCOUNT"]
  autoApproveStockBelow Float   @default(10000)
  allowManagerPricing  Boolean  @default(false)
  allowManagerRefund   Boolean  @default(true)
  shiftManagement      Boolean  @default(true)
  leaveApproval       Boolean  @default(true)
  customPoliciesJson   Json     @default("{}")
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  org    Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  branch Branch       @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@unique([branchId])
  @@index([orgId])
  @@map("branch_policies")
}

// Branch Manager Control: threshold-based approval escalation to owner
model ManagerApprovalEscalation {
  id               Int       @id @default(autoincrement())
  orgId            Int
  branchId         Int
  type             String    // DISCOUNT, REFUND, PURCHASE, STAFF_HIRE, PRICE_CHANGE, SERVICE_TOGGLE
  triggerCondition Json      // e.g. {"field":"discountPercent","operator":">","value":30}
  status           String    @default("PENDING") // PENDING, APPROVED, REJECTED
  requestedByUserId Int
  payload          Json
  decidedByUserId  Int?
  decidedAt        DateTime?
  rejectReason     String?   @db.Text
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  org         Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  branch      Branch       @relation(fields: [branchId], references: [id], onDelete: Cascade)
  requestedBy User         @relation("EscalationRequester", fields: [requestedByUserId], references: [id], onDelete: Restrict)
  decidedBy   User?        @relation("EscalationDecider", fields: [decidedByUserId], references: [id], onDelete: SetNull)

  @@index([branchId, status])
  @@index([orgId, status])
  @@index([requestedByUserId])
  @@map("manager_approval_escalations")
}

model BranchTypeOnBranch {
  branchId     Int
  branchTypeId Int
  isPrimary    Boolean  @default(false)
  createdAt    DateTime @default(now())

  branch     Branch     @relation(fields: [branchId], references: [id], onDelete: Cascade)
  branchType BranchType @relation(fields: [branchTypeId], references: [id], onDelete: Cascade)

  @@id([branchId, branchTypeId])
  @@index([branchTypeId])
}

model BranchPublishRequest {
  id                Int                  @id @default(autoincrement())
  branchId          Int
  status            PublishRequestStatus @default(PENDING)
  submittedAt       DateTime             @default(now())
  reviewedAt        DateTime?
  reviewedByAdminId Int?
  note              String?

  branch Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@index([branchId])
  @@map("branch_publish_requests")
}

model BranchType {
  id        Int      @id @default(autoincrement())
  code      String   @unique
  nameEn    String
  nameBn    String?
  isActive  Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  branches     BranchTypeOnBranch[]
  BranchToType BranchToType[]

  @@map("branch_types")
}

// Master: Organization Types (used by dropdowns for organization/branch creation)
// Kept independent from Organization model for backward compatibility.
model OrganizationType {
  id        Int      @id @default(autoincrement())
  code      String   @unique
  nameEn    String
  nameBn    String?
  isActive  Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("organization_types")
}

model BranchToType {
  branchId Int
  typeId   Int

  branch Branch     @relation(fields: [branchId], references: [id], onDelete: Cascade)
  type   BranchType @relation(fields: [typeId], references: [id], onDelete: Cascade)

  @@id([branchId, typeId])
  @@index([typeId])
  @@map("branch_to_types")
}

// ============================
// SUPER ADMIN ACCESS CONTROL
// ============================
// Only users whose email/phone exists here (and isActive=true)
// may access the Super Admin (Admin) web panel.
model SuperAdminWhitelist {
  id Int @id @default(autoincrement())

  // Store normalized values
  email String? @unique
  phone String? @unique

  isActive Boolean @default(true)
  note     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("super_admin_whitelist")
}

// === BPA PATCH: Membership + Product Approval (Branch-based) ===

enum MemberRole {
  OWNER
  ORG_ADMIN
  BRANCH_MANAGER
  BRANCH_STAFF
  SELLER
  DELIVERY_MANAGER
  DELIVERY_STAFF
}

enum MemberStatus {
  INVITED
  ACTIVE
  SUSPENDED
}

enum ChangeRequestType {
  CREATE_PRODUCT
  CREATE_VARIANT
  EDIT_PRODUCT
}

enum ChangeRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ProductStatus {
  ACTIVE
  INACTIVE
}

model OrgMember {
  id     Int @id @default(autoincrement())
  orgId  Int
  userId Int

  role   MemberRole
  status MemberStatus @default(ACTIVE)

  invitedByUserId Int?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  org       Organization    @relation(fields: [orgId], references: [id], onDelete: Cascade)
  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  invitedBy User?           @relation("OrgMemberInvitedBy", fields: [invitedByUserId], references: [id], onDelete: SetNull)
  roles     OrgMemberRole[]

  @@unique([orgId, userId])
  @@index([orgId, role])
  @@index([userId])
  @@map("org_members")
}

model BranchMember {
  id       Int @id @default(autoincrement())
  orgId    Int
  branchId Int
  userId   Int

  role   MemberRole
  status MemberStatus @default(ACTIVE)

  invitedByUserId Int?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  org                      Organization              @relation(fields: [orgId], references: [id], onDelete: Cascade)
  branch                   Branch                    @relation(fields: [branchId], references: [id], onDelete: Cascade)
  user                     User                      @relation(fields: [userId], references: [id], onDelete: Cascade)
  invitedBy                User?                     @relation("BranchMemberInvitedBy", fields: [invitedByUserId], references: [id], onDelete: SetNull)
  roles                    BranchMemberRole[]
  clinicStaffProfile       ClinicStaffProfile?
  doctorScheduleProposals  DoctorScheduleProposal[]
  doctorScheduleTemplates  DoctorScheduleTemplate[]
  // Clinic Phase 2: doctor on appointments, exceptions, slot locks, queue
  appointmentsAsDoctor     Appointment[]             @relation("AppointmentDoctor")
  doctorScheduleExceptions DoctorScheduleException[]
  slotLocks                SlotLock[]
  queueTicketsAsDoctor     QueueTicket[]             @relation("QueueTicketDoctor")
  visitsAsDoctor           Visit[]                   @relation("VisitDoctor")
  clinicalNotesCreated     ClinicalNote[]            @relation("ClinicalNoteCreatedBy")
  prescriptionsAsDoctor    Prescription[]            @relation("PrescriptionDoctor")
  procedureOrdersAsDoctor  ProcedureOrder[]         @relation("ProcedureOrderDoctor")
  clinicalCasesAsPrimaryDoctor ClinicalCase[]        @relation("ClinicalCasePrimaryDoctor")

  @@unique([branchId, userId])
  @@index([orgId, branchId, role])
  @@index([userId])
  @@map("branch_members")
}

// Global veterinary reference: countries where veterinary medicine is practiced
model VetCountry {
  id              Int     @id @default(autoincrement())
  code            String  @unique @db.VarChar(3) // ISO 3166-1 alpha-2 or alpha-3
  name            String  @db.VarChar(128)
  region          String? @db.VarChar(64) // Asia, Europe, Americas, Africa, Oceania
  hasVetLicensing Boolean @default(true)
  isActive        Boolean @default(true)

  regulatoryBodies VetRegulatoryBody[]

  @@map("vet_countries")
}

// Licensing/registration authorities per country
model VetRegulatoryBody {
  id                 Int     @id @default(autoincrement())
  countryId          Int
  name               String  @db.VarChar(256)
  abbreviation       String? @db.VarChar(32)
  bodyType           String  @db.VarChar(32) // NATIONAL | STATE | PROVINCIAL | REGIONAL
  jurisdiction       String? @db.VarChar(128) // e.g. California, Ontario, West Bengal
  websiteUrl         String? @db.Text
  verificationUrl    String? @db.Text // online license lookup URL
  verificationMethod String? @db.VarChar(32) // ONLINE_PORTAL | EMAIL | PHONE | NONE
  contactEmail       String? @db.VarChar(256)
  contactPhone       String? @db.VarChar(64)
  licenseFormat      String? @db.VarChar(128) // regex or description of license number format
  notes              String? @db.Text
  isActive           Boolean @default(true)

  country          VetCountry           @relation(fields: [countryId], references: [id], onDelete: Cascade)
  requiredDocTypes VetRequiredDocType[]
  doctorLicenses   DoctorLicense[]

  @@index([countryId])
  @@map("vet_regulatory_bodies")
}

// What documents each regulatory body requires
model VetRequiredDocType {
  id               Int     @id @default(autoincrement())
  regulatoryBodyId Int
  documentType     String  @db.VarChar(64) // e.g. VET_LICENSE, VET_DEGREE, GOV_ID_FRONT
  label            String  @db.VarChar(256)
  description      String? @db.Text
  isRequired       Boolean @default(true)
  sortOrder        Int     @default(0)

  regulatoryBody VetRegulatoryBody @relation(fields: [regulatoryBodyId], references: [id], onDelete: Cascade)

  @@index([regulatoryBodyId])
  @@map("vet_required_doc_types")
}

// Doctor verification: documents + admin approval before doctor panel access
model DoctorVerification {
  id     Int @id @default(autoincrement())
  userId Int @unique

  licenseNumber      String? @db.VarChar(128) // legacy; DoctorLicense is canonical
  registrationBody   String? @db.VarChar(128) // legacy
  primaryCountryCode String? @db.VarChar(3)
  specializationTags Json? // array of strings
  qualifications     Json? // array of { degree, university, year, country }
  nidNumber          String? @db.VarChar(32)
  metadataJson       Json? // expiry dates, etc.

  verificationStatus VerificationStatus @default(UNSUBMITTED)
  submittedAt        DateTime?
  reviewedAt         DateTime?
  reviewedByAdminId  Int?
  reviewNote         String?            @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user            User                         @relation(fields: [userId], references: [id], onDelete: Cascade)
  reviewedByAdmin User?                        @relation("DoctorVerificationReviewedBy", fields: [reviewedByAdminId], references: [id], onDelete: SetNull)
  documents       DoctorVerificationDocument[]
  licenses        DoctorLicense[]

  @@index([verificationStatus])
  @@index([reviewedByAdminId])
  @@index([primaryCountryCode])
  @@map("doctor_verifications")
}

// One per country/body the doctor is licensed in
model DoctorLicense {
  id                   Int       @id @default(autoincrement())
  doctorVerificationId Int
  regulatoryBodyId     Int
  licenseNumber        String    @db.VarChar(128)
  issueDate            DateTime?
  expiryDate           DateTime?
  licenseStatus        String    @default("ACTIVE") @db.VarChar(32) // ACTIVE | EXPIRED | SUSPENDED | REVOKED
  isPrimary            Boolean   @default(false)
  metadataJson         Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  doctorVerification DoctorVerification           @relation(fields: [doctorVerificationId], references: [id], onDelete: Cascade)
  regulatoryBody     VetRegulatoryBody            @relation(fields: [regulatoryBodyId], references: [id], onDelete: Restrict)
  documents          DoctorVerificationDocument[]

  @@unique([doctorVerificationId, regulatoryBodyId])
  @@index([doctorVerificationId])
  @@index([regulatoryBodyId])
  @@map("doctor_licenses")
}

model DoctorVerificationDocument {
  id                   Int    @id @default(autoincrement())
  doctorVerificationId Int
  doctorLicenseId      Int? // optional: document attached to a specific license
  documentType         String @db.VarChar(64) // DOCTOR_REGISTRATION | VET_LICENSE | VET_DEGREE | GOV_ID_FRONT | etc.
  fileUrl              String @db.Text
  metadataJson         Json? // docNumber, expiryDate, etc.

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  doctorVerification DoctorVerification @relation(fields: [doctorVerificationId], references: [id], onDelete: Cascade)
  doctorLicense      DoctorLicense?     @relation(fields: [doctorLicenseId], references: [id], onDelete: SetNull)

  @@index([doctorVerificationId])
  @@index([doctorLicenseId])
  @@map("doctor_verification_documents")
}

// Clinic-only extension: staff type, license, specialization, default fee (per branch)
model ClinicStaffProfile {
  id                     Int       @id @default(autoincrement())
  orgId                  Int
  branchId               Int
  branchMemberId         Int       @unique
  staffType              String    @db.VarChar(32) // DOCTOR | NURSE | RECEPTION | LAB | GROOMER | MANAGER
  licenseNumber          String?   @db.VarChar(64)
  specializationTags     Json? // array of strings
  defaultConsultationFee Decimal?  @db.Decimal(12, 2)
  roleInClinic           String?   @db.VarChar(32) // CONSULTANT | SURGEON | VISITING | INTERN | RESIDENT
  visitTypes             Json? // ["IN_PERSON", "TELE", "EMERGENCY"]
  followUpFee            Decimal?  @db.Decimal(12, 2)
  emergencyFee           Decimal?  @db.Decimal(12, 2)
  commissionPolicy       Json?
  scheduleEditPolicy     String    @default("BOTH") @db.VarChar(32) // CLINIC_ONLY | DOCTOR_ONLY | BOTH | DOCTOR_PROPOSE
  contractStatus         String    @default("ACTIVE") @db.VarChar(16) // INVITED | ACTIVE | PAUSED | ENDED
  contractStartDate      DateTime?
  contractEndDate        DateTime?
  contractNotes          String?   @db.Text
  maxPatientsPerDay      Int?
  allowEmergencyOverbook Boolean   @default(false)
  permissionOverrides    Json?
  travelBufferMinutes    Int       @default(0)
  visiting               Boolean   @default(false)
  status                 String    @default("ACTIVE") @db.VarChar(16)
  onboardingStatus       String    @default("PENDING") @db.VarChar(16) // PENDING | COMPLETED
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  org                    Organization             @relation(fields: [orgId], references: [id], onDelete: Cascade)
  branch                 Branch                   @relation(fields: [branchId], references: [id], onDelete: Cascade)
  branchMember           BranchMember             @relation(fields: [branchMemberId], references: [id], onDelete: Cascade)
  doctorServiceFees      DoctorServiceFee[]
  doctorAuditLogs        DoctorAuditLog[]
  doctorSettlementLedger DoctorSettlementLedger[]
  doctorContracts       DoctorContract[]
  doctorSettlementBatches DoctorSettlementBatch[]

  @@index([orgId, branchId])
  @@index([branchId, staffType])
  @@map("clinic_staff_profiles")
}

model DoctorServiceFee {
  id                   Int      @id @default(autoincrement())
  clinicStaffProfileId Int
  serviceId            Int
  species              String?  @db.VarChar(32) // if null = applies to all species
  fee                  Decimal  @db.Decimal(12, 2)
  durationMin          Int?
  isActive             Boolean  @default(true)
  notes                String?  @db.Text
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  clinicStaffProfile ClinicStaffProfile @relation(fields: [clinicStaffProfileId], references: [id], onDelete: Cascade)
  service            Service            @relation(fields: [serviceId], references: [id], onDelete: Restrict)

  @@unique([clinicStaffProfileId, serviceId, species])
  @@index([clinicStaffProfileId])
  @@index([serviceId])
  @@map("doctor_service_fees")
}

model DoctorScheduleProposal {
  id                Int       @id @default(autoincrement())
  orgId             Int
  branchId          Int
  branchMemberId    Int
  proposalPayload   Json
  status            String    @default("PENDING") @db.VarChar(16)
  requestedByUserId Int
  reviewedByUserId  Int?
  reviewedAt        DateTime?
  reviewNote        String?   @db.Text
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  org          Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  branch       Branch       @relation(fields: [branchId], references: [id], onDelete: Cascade)
  branchMember BranchMember @relation(fields: [branchMemberId], references: [id], onDelete: Cascade)

  @@index([branchId, status])
  @@index([branchMemberId])
  @@map("doctor_schedule_proposals")
}

model DoctorAuditLog {
  id                   Int      @id @default(autoincrement())
  orgId                Int
  branchId             Int
  clinicStaffProfileId Int
  action               String   @db.VarChar(64)
  field                String?  @db.VarChar(64)
  oldValue             Json?
  newValue             Json?
  changedByUserId      Int
  changedByRole        String?  @db.VarChar(32)
  ipAddress            String?  @db.VarChar(45)
  createdAt            DateTime @default(now())

  org                Organization       @relation(fields: [orgId], references: [id], onDelete: Cascade)
  branch             Branch             @relation(fields: [branchId], references: [id], onDelete: Cascade)
  clinicStaffProfile ClinicStaffProfile @relation(fields: [clinicStaffProfileId], references: [id], onDelete: Cascade)

  @@index([clinicStaffProfileId])
  @@index([branchId, action])
  @@map("doctor_audit_logs")
}

model DoctorSettlementLedger {
  id                   Int       @id @default(autoincrement())
  orgId                Int
  branchId             Int
  clinicStaffProfileId Int
  visitId              Int?
  orderId              Int?
  type                 String    @db.VarChar(32)
  grossAmount          Decimal   @db.Decimal(12, 2)
  clinicShare          Decimal   @db.Decimal(12, 2)
  doctorShare          Decimal   @db.Decimal(12, 2)
  settlementStatus     String    @default("PENDING") @db.VarChar(16)
  settledAt            DateTime?
  settledByUserId      Int?
  periodStart          DateTime?
  periodEnd            DateTime?
  notes                String?   @db.Text
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  // Enterprise: case/package linkage and breakdown
  caseId               Int?
  packageId            Int?
  discountImpact       Decimal?  @db.Decimal(12, 2)
  supportShare         Decimal?  @db.Decimal(12, 2)
  directCost           Decimal?  @db.Decimal(12, 2)
  netDoctorEarning     Decimal?  @db.Decimal(12, 2)
  batchId              Int?
  contractId           Int?

  org                Organization       @relation(fields: [orgId], references: [id], onDelete: Cascade)
  branch             Branch             @relation(fields: [branchId], references: [id], onDelete: Cascade)
  clinicStaffProfile ClinicStaffProfile @relation(fields: [clinicStaffProfileId], references: [id], onDelete: Cascade)
  clinicalCase       ClinicalCase?     @relation(fields: [caseId], references: [id], onDelete: SetNull)
  surgeryPackage     SurgeryPackage?   @relation(fields: [packageId], references: [id], onDelete: SetNull)
  settlementBatch    DoctorSettlementBatch? @relation(fields: [batchId], references: [id], onDelete: SetNull)
  doctorContract     DoctorContract?   @relation(fields: [contractId], references: [id], onDelete: SetNull)
  adjustments        SettlementAdjustment[]

  @@index([clinicStaffProfileId, settlementStatus])
  @@index([branchId, settlementStatus])
  @@index([caseId])
  @@index([batchId])
  @@map("doctor_settlement_ledger")
}

// Doctor weekly schedule template (per branch, per doctor)
model DoctorScheduleTemplate {
  id               Int      @id @default(autoincrement())
  orgId            Int
  branchId         Int
  branchMemberId   Int // doctor (BranchMember)
  dayOfWeek        Int // 0=Sunday .. 6=Saturday
  startTime        String   @db.VarChar(5) // "HH:mm"
  endTime          String   @db.VarChar(5)
  slotMinutes      Int      @default(15)
  maxSlots         Int?
  roomTypeRequired String?  @db.VarChar(32)
  status           String   @default("ACTIVE") @db.VarChar(16)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  org          Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  branch       Branch       @relation(fields: [branchId], references: [id], onDelete: Cascade)
  branchMember BranchMember @relation(fields: [branchMemberId], references: [id], onDelete: Cascade)

  @@index([branchId, branchMemberId, dayOfWeek])
  @@index([branchId, dayOfWeek])
  @@map("doctor_schedule_templates")
}

// Room weekly schedule template
model RoomScheduleTemplate {
  id           Int      @id @default(autoincrement())
  orgId        Int
  branchId     Int
  branchRoomId Int
  dayOfWeek    Int // 0..6
  startTime    String   @db.VarChar(5)
  endTime      String   @db.VarChar(5)
  status       String   @default("ACTIVE") @db.VarChar(16)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  org        Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  branch     Branch       @relation(fields: [branchId], references: [id], onDelete: Cascade)
  branchRoom BranchRoom   @relation(fields: [branchRoomId], references: [id], onDelete: Cascade)

  @@index([branchId, branchRoomId, dayOfWeek])
  @@map("room_schedule_templates")
}

// Branch holidays (date-based closure / partial)
model BranchHoliday {
  id        Int      @id @default(autoincrement())
  orgId     Int
  branchId  Int
  date      DateTime @db.Date
  name      String?  @db.VarChar(128)
  notes     String?  @db.Text
  isClosed  Boolean  @default(true)
  startTime String?  @db.VarChar(5)
  endTime   String?  @db.VarChar(5)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  org    Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  branch Branch       @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@unique([branchId, date])
  @@index([orgId, branchId, date])
  @@map("branch_holidays")
}

// ============================
// CLINIC: APPOINTMENT + QUEUE (Phase 2)
// ============================

enum AppointmentStatus {
  DRAFT
  PRE_BOOKED
  BOOKED
  CONFIRMED
  CHECKED_IN
  IN_QUEUE
  CALLED
  IN_CONSULT
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum AppointmentSource {
  MOBILE
  OWNER_PORTAL
  WALKIN
  STAFF
  PHONE
}

enum AppointmentPriority {
  NORMAL
  EMERGENCY
  VIP
}

enum QueueSessionStatus {
  OPEN
  PAUSED
  CLOSED
}

enum QueueSessionType {
  GENERAL
  DOCTOR_SPECIFIC
  SERVICE_SPECIFIC
}

enum QueueTicketStatus {
  CREATED
  WAITING
  CALLED
  SKIPPED
  IN_SERVICE
  DONE
  CANCELLED
  NO_SHOW
}

enum QueueTicketPriority {
  NORMAL
  EMERGENCY
  FOLLOWUP
}

enum DoctorScheduleExceptionType {
  OFF
  EXTRA_SHIFT
  CUSTOM_SLOTS
  LEAVE
  EMERGENCY_AVAILABLE
}

model Appointment {
  id                          Int                 @id @default(autoincrement())
  orgId                       Int
  branchId                    Int
  patientId                   Int? // pet owner (User); null for quick-call pre-booking
  petId                       Int?
  doctorId                    Int? // BranchMember.id (doctor); null when isAnyDoctor
  serviceId                   Int
  scheduledStartAt            DateTime
  scheduledEndAt              DateTime
  status                      AppointmentStatus   @default(BOOKED)
  source                      AppointmentSource   @default(STAFF)
  priority                    AppointmentPriority @default(NORMAL)
  notes                       String?             @db.Text
  channelMeta                 Json? // device/app info minimal
  cancellationReason          String?             @db.VarChar(256)
  cancelledByUserId           Int?
  cancelledAt                 DateTime?
  rescheduleFromAppointmentId Int?                @unique // at most one "new" appointment per rescheduled-from
  noShowMarkedByUserId        Int?
  noShowAt                    DateTime?
  createdByUserId             Int?
  intakeStatus                String              @default("NOT_STARTED") @db.VarChar(16) // NOT_STARTED | PARTIAL | COMPLETE
  visitType                   String              @default("WALK_IN") @db.VarChar(20) // WALK_IN | SCHEDULED | EMERGENCY
  isInstant                    Boolean             @default(false)
  isAnyDoctor                  Boolean             @default(false)
  paymentStatus                String              @default("UNPAID") @db.VarChar(16) // UNPAID | PARTIAL | PAID | WAIVED
  paymentMethod                String?             @db.VarChar(32)
  paidAmount                   Decimal?            @db.Decimal(12, 2)
  paidAt                       DateTime?
  paidByUserId                 Int?
  channel                      String              @default("COUNTER") @db.VarChar(20) // COUNTER | PHONE | ONLINE | REFERRAL
  tokenNo                       String?             @db.VarChar(20)
  // Snapshot fields for pre-registration (phone call) data
  ownerNameSnapshot           String?             @db.VarChar(128)
  mobileSnapshot              String?             @db.VarChar(20)
  petNameSnapshot             String?             @db.VarChar(128)
  petTypeSnapshot             String?             @db.VarChar(64)
  appointmentMode             String              @default("STANDARD") @db.VarChar(20) // QUICK_CALL | STANDARD | WALK_IN | ONLINE
  createdAt                   DateTime            @default(now())
  updatedAt                   DateTime            @updatedAt

  org            Organization       @relation(fields: [orgId], references: [id], onDelete: Cascade)
  branch         Branch             @relation(fields: [branchId], references: [id], onDelete: Cascade)
  patient        User?              @relation("AppointmentPatient", fields: [patientId], references: [id], onDelete: Restrict)
  pet            Pet?               @relation(fields: [petId], references: [id], onDelete: SetNull)
  doctor         BranchMember?      @relation("AppointmentDoctor", fields: [doctorId], references: [id], onDelete: SetNull)
  service        Service            @relation(fields: [serviceId], references: [id], onDelete: Restrict)
  rescheduleFrom Appointment?       @relation("AppointmentReschedule", fields: [rescheduleFromAppointmentId], references: [id], onDelete: SetNull)
  rescheduledTo  Appointment?       @relation("AppointmentReschedule")
  events         AppointmentEvent[]
  queueTickets   QueueTicket[]
  visit          Visit?
  intake         ClinicIntake?
  clinicalCase   ClinicalCase?

  // Uniqueness for (doctorId, slot) enforced in service when doctorId is set
  @@index([orgId, branchId])
  @@index([branchId, status])
  @@index([patientId])
  @@index([scheduledStartAt])
  @@index([branchId, tokenNo])
  @@map("appointments")
}

model AppointmentEvent {
  id            Int      @id @default(autoincrement())
  appointmentId Int
  eventType     String   @db.VarChar(64) // CREATED, CONFIRMED, CHECKED_IN, RESCHEDULED, CANCELLED, NO_SHOW_MARKED, STATUS_CHANGED, DOCTOR_CHANGED
  byUserId      Int?
  meta          Json?
  createdAt     DateTime @default(now())

  appointment Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)

  @@index([appointmentId])
  @@map("appointment_events")
}

model ClinicIntake {
  id            Int @id @default(autoincrement())
  orgId         Int
  branchId      Int
  appointmentId Int @unique

  chiefComplaint    String? @db.Text
  complaintDuration String? @db.VarChar(128)
  complaintOnset    String? @db.VarChar(32) // SUDDEN | GRADUAL

  symptomsJson       Json?
  additionalSymptoms String? @db.Text

  weightKg        Float?
  tempC           Float?
  heartRate       Int?
  respRate        Int?
  hydrationStatus String? @db.VarChar(32) // NORMAL | DEHYDRATED

  feedingJson   Json?
  historyJson   Json?
  riskFlagsJson Json?
  documentsJson Json?

  status          String   @default("NOT_STARTED") @db.VarChar(16) // NOT_STARTED | PARTIAL | COMPLETE
  createdByUserId Int?
  updatedByUserId Int?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  org         Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  branch      Branch       @relation(fields: [branchId], references: [id], onDelete: Cascade)
  appointment Appointment  @relation(fields: [appointmentId], references: [id], onDelete: Cascade)

  @@index([branchId, status])
  @@map("clinic_intakes")
}

model DoctorScheduleException {
  id        Int                         @id @default(autoincrement())
  orgId     Int
  branchId  Int
  doctorId  Int // BranchMember.id
  date      DateTime                    @db.Date
  type      DoctorScheduleExceptionType
  startTime String?                     @db.VarChar(5)
  endTime   String?                     @db.VarChar(5)
  note      String?                     @db.VarChar(256)
  createdAt DateTime                    @default(now())
  updatedAt DateTime                    @updatedAt

  org    Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  branch Branch       @relation(fields: [branchId], references: [id], onDelete: Cascade)
  doctor BranchMember @relation(fields: [doctorId], references: [id], onDelete: Cascade)

  @@unique([doctorId, date, type])
  @@index([orgId, branchId])
  @@index([branchId, date])
  @@map("doctor_schedule_exceptions")
}

model SlotLock {
  id              Int      @id @default(autoincrement())
  orgId           Int
  branchId        Int
  doctorId        Int // BranchMember.id
  startAt         DateTime
  endAt           DateTime
  lockOwnerUserId Int
  expiresAt       DateTime
  released        Boolean  @default(false)
  createdAt       DateTime @default(now())

  org    Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  branch Branch       @relation(fields: [branchId], references: [id], onDelete: Cascade)
  doctor BranchMember @relation(fields: [doctorId], references: [id], onDelete: Cascade)

  @@index([orgId, branchId])
  @@index([branchId, doctorId])
  @@index([expiresAt])
  @@map("slot_locks")
}

model QueueSession {
  id              Int                @id @default(autoincrement())
  orgId           Int
  branchId        Int
  date            DateTime           @db.Date
  type            QueueSessionType   @default(GENERAL)
  status          QueueSessionStatus @default(OPEN)
  lastTokenSeq    Int                @default(0)
  createdByUserId Int?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  org     Organization  @relation(fields: [orgId], references: [id], onDelete: Cascade)
  branch  Branch        @relation(fields: [branchId], references: [id], onDelete: Cascade)
  tickets QueueTicket[]

  @@unique([branchId, date, type])
  @@index([orgId, branchId])
  @@index([branchId, date])
  @@map("queue_sessions")
}

model QueueTicket {
  id              Int                 @id @default(autoincrement())
  orgId           Int
  branchId        Int
  queueSessionId  Int
  tokenNo         String              @db.VarChar(16) // e.g. A-001
  appointmentId   Int?
  patientId       Int? // User (owner); optional for walk-in
  petId           Int?
  doctorId        Int? // BranchMember.id; nullable until assigned
  priorityScore   Int                 @default(0)
  priorityTag     QueueTicketPriority @default(NORMAL)
  status          QueueTicketStatus   @default(CREATED)
  estimatedCallAt DateTime?
  checkInAt       DateTime?
  calledAt        DateTime?
  startedAt       DateTime?
  endedAt         DateTime?
  visitId         Int? // EMR Visit created when consultation started
  createdByUserId Int?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  org          Organization  @relation(fields: [orgId], references: [id], onDelete: Cascade)
  branch       Branch        @relation(fields: [branchId], references: [id], onDelete: Cascade)
  queueSession QueueSession  @relation(fields: [queueSessionId], references: [id], onDelete: Cascade)
  appointment  Appointment?  @relation(fields: [appointmentId], references: [id], onDelete: SetNull)
  doctor       BranchMember? @relation("QueueTicketDoctor", fields: [doctorId], references: [id], onDelete: SetNull)
  visit        Visit?        @relation(fields: [visitId], references: [id], onDelete: SetNull)
  events       QueueEvent[]

  @@unique([branchId, queueSessionId, tokenNo])
  @@index([orgId, branchId])
  @@index([queueSessionId, status])
  @@index([branchId])
  @@index([visitId])
  @@map("queue_tickets")
}

model QueueEvent {
  id        Int      @id @default(autoincrement())
  ticketId  Int
  eventType String   @db.VarChar(64) // ISSUED, ASSIGNED_DOCTOR, PRIORITY_CHANGED, CALLED, SKIPPED, COMPLETED, etc.
  byUserId  Int?
  meta      Json?
  createdAt DateTime @default(now())

  ticket QueueTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@index([ticketId])
  @@map("queue_events")
}

// ============================
// EMR (Electronic Medical Record)
// ============================

enum VisitStatus {
  CHECKED_IN
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum ClinicalNoteType {
  SOAP
  FOLLOW_UP
  DISCHARGE
  REFERRAL
}

model Visit {
  id            Int         @id @default(autoincrement())
  orgId         Int
  branchId      Int
  petId         Int
  patientId     Int // owner (User)
  doctorId      Int // BranchMember.id
  appointmentId Int?
  treatmentCode String?     @db.VarChar(32) // e.g. TRT-20260303-001
  status        VisitStatus @default(CHECKED_IN)
  startedAt     DateTime?
  completedAt   DateTime?
  followUpDate  DateTime?
  followUpNotes String?     @db.Text
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  org               Organization      @relation(fields: [orgId], references: [id], onDelete: Cascade)
  branch            Branch            @relation(fields: [branchId], references: [id], onDelete: Cascade)
  pet               Pet               @relation(fields: [petId], references: [id], onDelete: Restrict)
  patient           User              @relation("VisitPatient", fields: [patientId], references: [id], onDelete: Restrict)
  doctor            BranchMember      @relation("VisitDoctor", fields: [doctorId], references: [id], onDelete: Restrict)
  appointment       Appointment?      @relation(fields: [appointmentId], references: [id], onDelete: SetNull)
  vitals            VitalRecord[]
  notes             ClinicalNote[]
  attachments       VisitAttachment[]
  queueTickets      QueueTicket[]
  prescriptions     Prescription[]
  orders            Order[]
  labRequisitions   LabRequisition[]
  serviceDeliveries ServiceDelivery[]
  dispenseRequests   DispenseRequest[]
  medicationAdministrations MedicationAdministration[]
  surgeryPackageConsumptions SurgeryPackageConsumption[]
  treatmentCourses   TreatmentCourse[]
  clinicalCase       ClinicalCase?
  inventoryConsumptions InventoryConsumption[]
  vialReturnControls VialReturnControl[]

  @@unique([appointmentId])
  @@index([orgId, branchId])
  @@index([branchId, status])
  @@index([petId])
  @@index([patientId])
  @@index([doctorId])
  @@index([appointmentId])
  @@map("visits")
}

model VitalRecord {
  id        Int      @id @default(autoincrement())
  visitId   Int
  weightKg  Float?
  tempC     Float?
  heartRate Int?
  respRate  Int?
  notes     String?  @db.Text
  createdAt DateTime @default(now())

  visit Visit @relation(fields: [visitId], references: [id], onDelete: Cascade)

  @@index([visitId])
  @@map("vital_records")
}

model ClinicalNote {
  id          Int              @id @default(autoincrement())
  visitId     Int
  noteType    ClinicalNoteType
  contentJson Json // { subjective?, objective?, assessment?, plan? } for SOAP
  createdById Int // BranchMember.id (doctor/staff)
  createdAt   DateTime         @default(now())

  visit     Visit        @relation(fields: [visitId], references: [id], onDelete: Cascade)
  createdBy BranchMember @relation("ClinicalNoteCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)

  @@index([visitId])
  @@map("clinical_notes")
}

model VisitAttachment {
  id        Int      @id @default(autoincrement())
  visitId   Int
  fileUrl   String   @db.Text
  fileName  String?  @db.VarChar(256)
  fileType  String?  @db.VarChar(64) // e.g. image/png, application/pdf
  note      String?  @db.Text
  createdAt DateTime @default(now())

  visit Visit @relation(fields: [visitId], references: [id], onDelete: Cascade)

  @@index([visitId])
  @@map("visit_attachments")
}

model ConsultationTemplate {
  id          Int      @id @default(autoincrement())
  orgId       Int
  branchId    Int
  name        String   @db.VarChar(128)
  description String?  @db.Text
  contentJson Json // { subjective?, objective?, assessment?, plan? } pre-filled SOAP
  isDefault   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  org    Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  branch Branch       @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@index([branchId])
  @@map("consultation_templates")
}

model LabRequisition {
  id        Int      @id @default(autoincrement())
  visitId   Int
  branchId  Int
  petId     Int
  testsJson Json
  status    String   @db.VarChar(32)
  notes     String?  @db.Text
  createdAt DateTime @default(now())

  visit   Visit       @relation(fields: [visitId], references: [id], onDelete: Cascade)
  reports LabReport[]

  @@index([visitId])
  @@index([branchId])
  @@map("lab_requisitions")
}

model LabReport {
  id            Int      @id @default(autoincrement())
  requisitionId Int
  fileUrl       String?  @db.Text
  abnormalFlags Json?
  notes         String?  @db.Text
  createdAt     DateTime @default(now())

  requisition LabRequisition  @relation(fields: [requisitionId], references: [id], onDelete: Cascade)
  items       LabReportItem[]

  @@index([requisitionId])
  @@map("lab_reports")
}

model LabReportItem {
  id             Int      @id @default(autoincrement())
  labReportId    Int
  testCode       String   @db.VarChar(64)
  testName       String   @db.VarChar(256)
  value          String?  @db.Text
  unit           String?  @db.VarChar(32)
  referenceRange String?  @db.VarChar(128)
  isAbnormal     Boolean  @default(false)
  createdAt      DateTime @default(now())

  labReport LabReport @relation(fields: [labReportId], references: [id], onDelete: Cascade)

  @@index([labReportId])
  @@map("lab_report_items")
}

enum PrescriptionStatus {
  DRAFT
  FINALIZED
  DISPENSED
}

model Prescription {
  id        Int                @id @default(autoincrement())
  visitId   Int
  petId     Int
  doctorId  Int // BranchMember.id
  qrToken   String             @unique @db.VarChar(64)
  status    PrescriptionStatus @default(DRAFT)
  notes     String?            @db.Text
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt

  visit  Visit              @relation(fields: [visitId], references: [id], onDelete: Cascade)
  pet    Pet                @relation(fields: [petId], references: [id], onDelete: Restrict)
  doctor BranchMember       @relation("PrescriptionDoctor", fields: [doctorId], references: [id], onDelete: Restrict)
  items  PrescriptionItem[]

  @@index([visitId])
  @@index([petId])
  @@index([doctorId])
  @@index([qrToken])
  @@map("prescriptions")
}

model PrescriptionItem {
  id               Int      @id @default(autoincrement())
  prescriptionId   Int
  medicineName     String   @db.VarChar(256)
  dosage           String   @db.VarChar(128)
  frequency        String   @db.VarChar(128)
  duration         String   @db.VarChar(128)
  quantity         Int?
  instructions     String?  @db.Text
  productVariantId Int? // link to inventory if available
  createdAt        DateTime @default(now())

  prescription Prescription @relation(fields: [prescriptionId], references: [id], onDelete: Cascade)

  @@index([prescriptionId])
  @@map("prescription_items")
}

// ============================
// MULTI-BRANCH STAFF PERMISSION SYSTEM
// ============================

enum BranchAccessPermissionStatus {
  PENDING
  APPROVED
  REVOKED
  EXPIRED
  SUSPENDED
}

model BranchAccessPermission {
  id       Int                          @id @default(autoincrement())
  branchId Int
  userId   Int
  status   BranchAccessPermissionStatus @default(PENDING)
  role     MemberRole?

  // Approval tracking
  approvedByUserId Int?
  approvedAt       DateTime?
  revokedByUserId  Int?
  revokedAt        DateTime?
  expiresAt        DateTime? // Optional time-based expiration

  // Request metadata
  requestedAt       DateTime  @default(now())
  requestedByUserId Int?
  note              String?   @db.Text
  lastLoginAt       DateTime? // Track when staff last accessed this branch

  // Owner-only: restrict manager login to time window (e.g. "09:00", "18:00")
  loginWindowStart    String?
  loginWindowEnd      String?
  // Owner-only: custom permission keys override for this user at this branch (JSON array of strings)
  permissionOverrides Json?

  // Relations
  branch          Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)
  user            User   @relation("BranchAccessPermissionUser", fields: [userId], references: [id], onDelete: Cascade)
  approvedBy      User?  @relation("BranchAccessPermissionApprovedBy", fields: [approvedByUserId], references: [id], onDelete: SetNull)
  revokedBy       User?  @relation("BranchAccessPermissionRevokedBy", fields: [revokedByUserId], references: [id], onDelete: SetNull)
  requestedByUser User?  @relation("BranchAccessPermissionRequestedBy", fields: [requestedByUserId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([branchId, userId])
  @@index([userId, status])
  @@index([branchId, status])
  @@index([status, expiresAt])
  @@map("branch_access_permissions")
}

