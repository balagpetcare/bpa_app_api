  batchRecallsResolved     BatchRecall[]       @relation("RecallResolver")
  expiryWriteOffsPerformed ExpiryWriteOffLog[]

  // === Central Warehouse Module ===
  managedWarehouses             Warehouse[]                @relation("WarehouseManager")
  warehouseStaffAssignments     WarehouseStaffAssignment[]
  deliveryAssignmentsAssigned   DeliveryAssignment[]       @relation("DeliveryAssignedTo")
  deliveryAssignmentsCreated    DeliveryAssignment[]       @relation("DeliveryAssignedBy")
  purchaseOrdersCreated         PurchaseOrder[]            @relation("PurchaseOrderCreatedBy")
  purchaseOrdersApproved        PurchaseOrder[]            @relation("PurchaseOrderApprovedBy")
  purchaseOrdersRejected        PurchaseOrder[]            @relation("PurchaseOrderRejectedBy")
  allocationPlansCreated        AllocationPlan[]           @relation("AllocationPlanCreatedBy")
  allocationPlanEventsPerformed AllocationPlanEvent[]      @relation("AllocationPlanEventPerformedBy")
  pickListsAssigned             PickList[]                 @relation("PickListAssignedPicker")
  proofOfDeliveriesRecorded     ProofOfDelivery[]          @relation("ProofOfDeliveryRecordedBy")
  qcInspectionsPerformed        QcInspection[]             @relation("QcInspectionInspectedBy")
  warehouseAuditEvents          WarehouseAuditEvent[]      @relation("WarehouseAuditEventActor")
  batchRecallsAllocationReleased BatchRecall[]             @relation("RecallAllocationReleasedBy")
  writeOffRequestsRequested      WriteOffRequest[]         @relation("WriteOffRequestedBy")
  writeOffRequestsApproved       WriteOffRequest[]         @relation("WriteOffApprovedBy")
  vendorReturnsCreated           VendorReturn[]            @relation("VendorReturnCreatedBy")
  vendorReturnsApproved          VendorReturn[]            @relation("VendorReturnApprovedBy")
  warehouseTransferOrdersCreated WarehouseTransferOrder[]  @relation("WTOCreatedBy")
  warehouseTransferOrdersApproved WarehouseTransferOrder[] @relation("WTOApprovedBy")
  recallCampaignsCreated          RecallCampaign[]         @relation("RecallCampaignCreatedBy")
  networkRecoDismissed          NetworkTransferRecommendation[] @relation("NetworkRecoDismissedBy")
  networkRecoAccepted           NetworkTransferRecommendation[] @relation("NetworkRecoAcceptedBy")
  reverseLogisticsCasesCreated    ReverseLogisticsCase[]   @relation("ReverseLogisticsCaseCreatedBy")
  purchaseRequisitionsRequested   PurchaseRequisition[]     @relation("PurchaseRequisitionRequestedBy")
  purchaseRequisitionsApproved    PurchaseRequisition[]     @relation("PurchaseRequisitionApprovedBy")
  purchaseRequisitionsRejected    PurchaseRequisition[]     @relation("PurchaseRequisitionRejectedBy")
  putawayTasksCompleted           PutawayTask[]             @relation("PutawayTaskCompletedBy")
  inboundDiscrepanciesResolved    InboundDiscrepancy[]      @relation("InboundDiscrepancyResolvedBy")
  pricingAuditLogsAsActor         PricingAuditLog[]         @relation("PricingAuditActor")
  retailDiscountRequestsRequested RetailDiscountApprovalRequest[] @relation("RetailDiscountRequester")
  retailDiscountRequestsReviewed  RetailDiscountApprovalRequest[] @relation("RetailDiscountReviewer")

  @@map("users")
}

// Place: lat/lng-first location (optional address snapshot). No removal of existing addressJson/hierarchy.
model Place {
  id               Int      @id @default(autoincrement())
  latitude         Float
  longitude        Float
  countryCode      String?
  stateName        String?
  cityName         String?
  formattedAddress String?  @db.VarChar(1024)
  rawAddressJson   Json?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  usersWithCurrentPlace User[]

  @@index([latitude, longitude])
  @@map("places")
}

model LocationPlace {
  id               Int             @id @default(autoincrement())
  countryCode      String
  admin1           String?
  admin2           String?
  city             String?
  postalCode       String?
  formattedAddress String?         @db.VarChar(1024)
  lat              Float?
  lng              Float?
  geoHash          String?
  source           LocationSource?
  sourcePlaceId    String?
  bdDivision       String?
  bdDistrict       String?
  bdUpazila        String?
  bdWard           String?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  userLocationProfilesAsHome    UserLocationProfile[] @relation("HomePlace")
  userLocationProfilesAsCurrent UserLocationProfile[] @relation("CurrentPlace")
  userLocationProfilesAsManual  UserLocationProfile[] @relation("ManualOverridePlace")
  userLocationEvents            UserLocationEvent[]

  @@index([countryCode, admin1, city])
  @@index([geoHash])
  @@map("location_places")
}

model UserLocationProfile {
  userId                Int                    @unique
  user                  User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  homePlaceId           Int?
  homePlace             LocationPlace?         @relation("HomePlace", fields: [homePlaceId], references: [id], onDelete: SetNull)
  currentPlaceId        Int?
  currentPlace          LocationPlace?         @relation("CurrentPlace", fields: [currentPlaceId], references: [id], onDelete: SetNull)
  manualOverridePlaceId Int?
  manualOverridePlace   LocationPlace?         @relation("ManualOverridePlace", fields: [manualOverridePlaceId], references: [id], onDelete: SetNull)
  lastLat               Float?
  lastLng               Float?
  precisionLevel        LocationPrecisionLevel
  consentLevel          LocationConsentLevel
  lastUpdatedAt         DateTime               @default(now())
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt

  @@map("user_location_profiles")
}

model UserLocationEvent {
  id             Int               @id @default(autoincrement())
  userId         Int
  user           User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  timestamp      DateTime
  lat            Float
  lng            Float
  placeId        Int?
  place          LocationPlace?    @relation(fields: [placeId], references: [id], onDelete: SetNull)
  accuracyMeters Float?
  source         LocationSource
  eventType      LocationEventType
  sessionId      String?
  deviceId       String?
  createdAt      DateTime          @default(now())

  @@index([userId, timestamp(sort: Desc)])
  @@map("user_location_events")
}

// Owner profile (separate from UserProfile). This keeps onboarding / KYC fields
// isolated and avoids breaking Flutter/public user profile flows.
model OwnerProfile {
  id     Int  @id @default(autoincrement())
  userId Int  @unique
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Minimal onboarding profile (fast, low-friction). KYC-grade fields live in OwnerKyc.
  // NOTE: All fields are OPTIONAL except name, to avoid breaking existing flows.
  name         String
  supportPhone String?
  supportEmail String?

  // Optional location pointers for quick filtering/search (full address stays in OwnerKyc.presentAddressJson)
  // DEPRECATED: Prefer addressJson for unified location (country/state/city/postal/addressLine/lat/lng)
  divisionId Int?
  districtId Int?
  upazilaId  Int?
  areaId     Int?

  // Unified address (country/state/city/postal/addressLine/formattedAddress/lat/lng)
  addressJson Json?

  nid         String?
  dateOfBirth DateTime?
  genderText  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([divisionId])
  @@index([districtId])
  @@index([upazilaId])
  @@index([areaId])
  @@map("owner_profiles")
}

// -----------------------------
// PHASE-1: Owner/Org/Branch KYC
// -----------------------------

model OwnerKyc {
  id     Int @id @default(autoincrement())
  userId Int @unique

  fullName    String
  fatherName  String?
  motherName  String?
  dateOfBirth DateTime?
  genderText  String?
  nationality String?   @default("Bangladeshi")

  nidNumber     String?
  nidIssueDate  DateTime?
  nidAddressRaw String?

  mobile String?
  email  String?

  presentAddressJson   Json?
  permanentAddressJson Json?

  emergencyContactName  String?
  emergencyContactPhone String?

  verificationStatus VerificationStatus @default(UNSUBMITTED)
  submittedAt        DateTime?
  reviewedAt         DateTime?
  reviewedByAdminId  Int?
  reviewNote         String?
  rejectionReason    String?
  riskScore          Int?               @default(0)

  // Owner KYC Upgrade: expiry + declarations + optional business intent
  expiresAt          DateTime?
  declarationsJson   Json? // { termsAcceptedAt, dataProcessingConsentAt, infoTrueConfirmedAt, legalBusinessCategoryAt }
  businessIntentJson Json? // optional pre-fill for first org: { preferredName, orgTypeCode, registrationType }
  // Progressive KYC: 0=pending, 1=verified basic (trade license), 2=verified+payout (bank etc.)
  kycLevel           Int?      @default(0)

  isLocked   Boolean   @default(false)
  lockReason String?
  deletedAt  DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user            User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  reviewedByAdmin User?              @relation("OwnerKycReviewedBy", fields: [reviewedByAdminId], references: [id], onDelete: SetNull)
  documents       OwnerKycDocument[]

  @@index([verificationStatus])
  @@index([reviewedByAdminId])
  @@index([expiresAt])
  @@map("owner_kyc")
}

model OwnerKycDocument {
  id         Int @id @default(autoincrement())
  ownerKycId Int

  type   DocumentType
  status DocumentStatus @default(SUBMITTED)

  mediaId Int
  media   Media @relation(fields: [mediaId], references: [id], onDelete: Cascade)

  docNumber  String?
  issueDate  DateTime?
  expiryDate DateTime?
  note       String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  ownerKyc OwnerKyc @relation(fields: [ownerKycId], references: [id], onDelete: Cascade)

  @@index([ownerKycId])
  @@index([type])
  @@map("owner_kyc_documents")
}

model OrganizationLegalProfile {
  id    Int @id @default(autoincrement())
  orgId Int @unique

  organizationName String
  registrationType RegistrationType @default(PROPRIETORSHIP)

  tradeLicenseNumber     String?
  tradeLicenseIssueDate  DateTime?
  tradeLicenseExpiryDate DateTime?
  issuingAuthority       String?

  tinNumber String?
  binNumber String?

  officialPhone String?
  officialEmail String?
  website       String?
  facebookPage  String?

  bankAccountName   String?
  bankAccountNumber String?
  bankName          String?
  bankBranchName    String?
  routingNumber     String?

  payoutBkash  String?
  payoutNagad  String?
  payoutRocket String?

  verificationStatus VerificationStatus @default(UNSUBMITTED)
  submittedAt        DateTime?
  reviewedAt         DateTime?
  reviewedByAdminId  Int?
  reviewNote         String?
  rejectionReason    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization    Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  reviewedByAdmin User?        @relation("OrgKycReviewedBy", fields: [reviewedByAdminId], references: [id], onDelete: SetNull)

  documents OrganizationDocument[]
  directors OrganizationDirector[]

  @@index([verificationStatus])
  @@index([reviewedByAdminId])
  @@map("org_legal_profiles")
}

model OrganizationDocument {
  id                Int @id @default(autoincrement())
  orgLegalProfileId Int

  type   DocumentType
  status DocumentStatus @default(SUBMITTED)

  mediaId Int
  media   Media @relation(fields: [mediaId], references: [id], onDelete: Cascade)

  docNumber  String?
  issueDate  DateTime?
  expiryDate DateTime?
  note       String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  orgLegalProfile OrganizationLegalProfile @relation(fields: [orgLegalProfileId], references: [id], onDelete: Cascade)

  @@index([orgLegalProfileId])
  @@index([type])
  @@map("org_documents")
}

model OrganizationDirector {
  id                Int @id @default(autoincrement())
  orgLegalProfileId Int

  name   String
  role   String?
  mobile String?
  email  String?

  nidNumber       String?
  sharePercentage Float?

  nidFrontMediaId  Int?
  nidBackMediaId   Int?
  signatureMediaId Int?

  nidFrontMedia  Media? @relation("DirectorNidFront", fields: [nidFrontMediaId], references: [id], onDelete: SetNull)
  nidBackMedia   Media? @relation("DirectorNidBack", fields: [nidBackMediaId], references: [id], onDelete: SetNull)
  signatureMedia Media? @relation("DirectorSignature", fields: [signatureMediaId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  orgLegalProfile OrganizationLegalProfile @relation(fields: [orgLegalProfileId], references: [id], onDelete: Cascade)

  @@index([orgLegalProfileId])
  @@map("org_directors")
}

model BranchProfileDetails {
  id       Int @id @default(autoincrement())
  branchId Int @unique

  branchPhone String?
  branchEmail String?

  managerName      String?
  managerPhone     String?
  managerNidNumber String?

  addressJson      Json?
  latitude         Float?
  longitude        Float?
  googleMapLink    String?
  // Phase 3: coverage area (GeoJSON polygon); optional max area validation
  coveragePolygon  Json? // Phase 3: GeoJSON polygon
  // Service area: radius in km (used first; polygon optional later)
  coverageRadiusKm Float?

  openingHoursJson  Json?
  weeklyOffDaysJson Json?

  vetLicenseNumber  String?
  drugLicenseNumber String?

  verificationStatus VerificationStatus @default(UNSUBMITTED)
  submittedAt        DateTime?
  reviewedAt         DateTime?
  reviewedByAdminId  Int?
  reviewNote         String?
  rejectionReason    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  branch          Branch           @relation(fields: [branchId], references: [id], onDelete: Cascade)
  reviewedByAdmin User?            @relation("BranchKycReviewedBy", fields: [reviewedByAdminId], references: [id], onDelete: SetNull)
  documents       BranchDocument[]

  @@index([verificationStatus])
  @@index([reviewedByAdminId])
  @@map("branch_profile_details")
}

model BranchDocument {
  id              Int @id @default(autoincrement())
  branchProfileId Int

  type   DocumentType
  status DocumentStatus @default(SUBMITTED)

  mediaId Int
  media   Media @relation(fields: [mediaId], references: [id], onDelete: Cascade)

  docNumber  String?
  issueDate  DateTime?
  expiryDate DateTime?
  note       String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  branchProfile BranchProfileDetails @relation(fields: [branchProfileId], references: [id], onDelete: Cascade)

  @@index([branchProfileId])
  @@index([type])
  @@map("branch_documents")
}

model VerificationLog {
  id         Int                    @id @default(autoincrement())
  entityType VerificationEntityType
  entityId   Int

  action     VerificationAction
  fromStatus VerificationStatus?
  toStatus   VerificationStatus?

  adminUserId Int?
  adminUser   User? @relation("VerificationLogAdmin", fields: [adminUserId], references: [id], onDelete: SetNull)

  note      String?
  createdAt DateTime @default(now())

  @@index([entityType, entityId])
  @@index([adminUserId])
  @@map("verification_logs")
}

// ------------------------------
// Universal Verification (V1)
// ------------------------------
model VerificationCase {
  id         Int                    @id @default(autoincrement())
  entityType VerificationEntityType
  entityId   Int

  status VerificationCaseStatus @default(DRAFT)

  /// V2: Owner/Org/Branch draft data snapshot (non-breaking add-only)
  /// This keeps Flutter/public APIs untouched while Owner Panel uses a unified verification case payload.
  payloadJson Json?

  submittedAt DateTime?
  reviewedAt  DateTime?

  reviewedByAdminId Int?
  reviewedByAdmin   User? @relation("VerificationCaseReviewedBy", fields: [reviewedByAdminId], references: [id], onDelete: SetNull)

  reviewSummary String? @db.Text

  // optional "lock" for admin hold / compliance
  isLocked   Boolean @default(false)
  lockReason String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  documents VerificationDocument[]
  events    VerificationCaseEvent[]

  @@index([entityType, entityId])
  @@index([status])
  @@index([reviewedByAdminId])
  @@map("verification_cases")
}

model VerificationDocument {
  id     Int @id @default(autoincrement())
  caseId Int

  docType    DocumentType
  status     VerificationDocStatus @default(PENDING)
  isRequired Boolean               @default(true)

  // store file in Media table (MinIO/S3)
  mediaId Int
  media   Media @relation(fields: [mediaId], references: [id], onDelete: Cascade)

  version Int @default(1)

  docNumber  String?
  issueDate  DateTime?
  expiryDate DateTime?

  rejectReason String?
  instruction  String?

  checkedAt        DateTime?
  checkedByAdminId Int?
  checkedByAdmin   User?     @relation("VerificationDocCheckedBy", fields: [checkedByAdminId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  verificationCase VerificationCase @relation(fields: [caseId], references: [id], onDelete: Cascade)

  @@index([caseId])
  @@index([docType])
  @@index([status])
  @@index([checkedByAdminId])
  @@map("verification_documents")
}

model VerificationCaseEvent {
  id     Int @id @default(autoincrement())
  caseId Int

  action VerificationAction
  from   VerificationCaseStatus?
  to     VerificationCaseStatus?

  actorAdminId Int?
  actorAdmin   User? @relation("VerificationCaseEventAdmin", fields: [actorAdminId], references: [id], onDelete: SetNull)

  note String? @db.Text

  createdAt DateTime @default(now())

  verificationCase VerificationCase @relation(fields: [caseId], references: [id], onDelete: Cascade)

  @@index([caseId])
  @@index([actorAdminId])
  @@map("verification_case_events")
}

enum NotificationType {
  VERIFICATION_CASE_SUBMITTED
  VERIFICATION_CASE_APPROVED
  VERIFICATION_CASE_REJECTED
  VERIFICATION_DOCUMENT_APPROVED
  VERIFICATION_DOCUMENT_REJECTED
  OWNER_KYC_SUBMITTED
  SYSTEM
  STAFF_INVITE
  STAFF_BRANCH_ACCESS_REQUEST
  STAFF_BRANCH_ACCESS_APPROVED
  STAFF_BRANCH_ACCESS_REVOKED
  STAFF_BRANCH_ACCESS_EXPIRED
  INVENTORY_STOCK_REQUEST
  INVENTORY_LOW_STOCK
  INVENTORY_TRANSFER
  FINANCE_PAYMENT
  FINANCE_PAYOUT
  CLINIC_APPOINTMENT
  CLINIC_PRESCRIPTION
  BATCH_SUSPICIOUS_ACTIVITY
  PRODUCT_APPROVED
  PRODUCT_REJECTED
  ENFORCEMENT_CODE_BLOCKED
  ENFORCEMENT_BATCH_QUARANTINED
  ENFORCEMENT_PRODUCT_DEACTIVATED
  ENFORCEMENT_ORG_SUSPENDED
  ENFORCEMENT_ACTION_REVERTED
  TICKET_CREATED
  TICKET_REPLIED
  TICKET_STATUS_CHANGED
  TICKET_ASSIGNED
  TICKET_SLA_BREACH
}

enum NotificationPriority {
  P0
  P1
  P2
}

enum NotificationStatus {
  ACTIVE
  EXPIRED
  CANCELLED
}

enum NotificationRecipientScopeType {
  USER
  ORG
  BRANCH
  ROLE
}

enum NotificationDeliveryChannel {
  IN_APP
  EMAIL
  SMS
}

enum NotificationDeliveryStatus {
  QUEUED
  SENT
  DELIVERED
  FAILED
}

model Notification {
  id     Int  @id @default(autoincrement())
  userId Int
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  type    NotificationType
  title   String
  message String           @db.Text
  meta    Json?

  readAt DateTime?

  priority           NotificationPriority            @default(P2)
  status             NotificationStatus              @default(ACTIVE)
  actionUrl          String?                         @db.VarChar(1024)
  dedupeKey          String?                         @db.VarChar(255)
  expiresAt          DateTime?
  recipientScopeType NotificationRecipientScopeType?
  recipientScopeId   String?                         @db.VarChar(255)

  // Global Notification Center: org/branch scope for multi-tenant isolation
  orgId    Int?
  branchId Int?
  // severity: info|warn|error|success (maps from priority for display)
  severity String? @db.VarChar(32)
  // source: module name (auth|clinic|order|producer|wallet|branch_access|etc.)
  source   String? @db.VarChar(64)
  senderId Int?
  sender   User?   @relation("NotificationSender", fields: [senderId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  reads      NotificationRead[]
  deliveries NotificationDelivery[]

  @@index([userId, readAt])
  @@index([userId, createdAt])
  @@index([type])
  @@index([dedupeKey])
  @@index([orgId])
  @@index([branchId])
  @@map("notifications")
}

model NotificationRead {
  id             Int          @id @default(autoincrement())
  notificationId Int
  notification   Notification @relation(fields: [notificationId], references: [id], onDelete: Cascade)
  userId         Int
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  readAt         DateTime     @default(now())

  @@unique([notificationId, userId])
  @@index([userId, readAt])
  @@map("notification_reads")
}

model NotificationDelivery {
  id                Int                         @id @default(autoincrement())
  notificationId    Int
  notification      Notification                @relation(fields: [notificationId], references: [id], onDelete: Cascade)
  channel           NotificationDeliveryChannel
  toAddress         String?                     @db.VarChar(512)
  providerMessageId String?                     @db.VarChar(255)
  status            NotificationDeliveryStatus  @default(QUEUED)
  error             String?                     @db.Text
  attemptCount      Int                         @default(0)
  createdAt         DateTime                    @default(now())
  updatedAt         DateTime                    @updatedAt

  @@index([notificationId])
  @@index([channel, status])
  @@map("notification_deliveries")
}

model UserNotificationPrefs {
  id              Int      @id @default(autoincrement())
  userId          Int      @unique
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  allowEmail      Boolean  @default(true)
  allowSms        Boolean  @default(false)
  soundEnabled    Boolean  @default(true)
  quietHoursStart Int? // minutes from midnight (0-1439)
  quietHoursEnd   Int? // minutes from midnight (0-1439)
  enabledTypes    Json? // optional filter by type
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("user_notification_prefs")
}

// ------------------------------
// Universal Verification (V3.4)
// Monitoring: track legacy update attempts while an entity is locked for verification.
// Soft-mode friendly (no breaking changes).
// ------------------------------
model VerificationLockedUpdateAttempt {
  id Int @id @default(autoincrement())

  userId Int?
  user   User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  entityType VerificationEntityType
  entityId   Int

  reason String?

  endpoint  String
  method    String
  ip        String?
  userAgent String?

  payloadJson Json?

  createdAt DateTime @default(now())

  @@index([entityType, entityId, createdAt])
  @@index([createdAt])
  @@index([userId])
  @@map("verification_locked_update_attempts")
}

model Post {
  id       Int  @id @default(autoincrement())
  authorId Int
  author   User @relation(fields: [authorId], references: [id], onDelete: Cascade)

  type     PostType     @default(TEXT)
  category PostCategory @default(GENERAL)
  caption  String?      @db.Text

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  media    PostMedia[]
  likes    PostLike[]
  comments PostComment[]

  // FUNDRAISING (Phase A) - opposite relation field
  fundraisingCampaign FundraisingCampaign?

  // FUNDRAISING UPDATES (Phase B)
  fundraisingUpdate FundraisingUpdate?

  @@index([authorId, createdAt])
  @@map("posts")
}

model PostMedia {
  id     Int  @id @default(autoincrement())
  postId Int
  post   Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  mediaId Int
  media   Media @relation(fields: [mediaId], references: [id], onDelete: Cascade)

  order Int @default(0)

  @@unique([postId, order])
  @@index([postId])
  @@map("post_media")
}

model PostLike {
  id        Int      @id @default(autoincrement())
  postId    Int
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([postId, userId], name: "postId_userId")
  @@index([userId])
  @@map("post_likes")
}

model PostComment {
  id     Int  @id @default(autoincrement())
  postId Int
  post   Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  userId Int
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

