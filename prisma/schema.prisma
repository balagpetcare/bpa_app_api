}

model InventoryConsumption {
  id                Int            @id @default(autoincrement())
  clinicalCaseId    Int?
  procedureOrderId  Int?
  visitId           Int?           // optional link to visit for legacy
  mode              ConsumptionMode @default(PLANNED)
  status            String         @default("RECORDED") @db.VarChar(16)
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  clinicalCase   ClinicalCase?    @relation(fields: [clinicalCaseId], references: [id], onDelete: Cascade)
  procedureOrder ProcedureOrder?   @relation(fields: [procedureOrderId], references: [id], onDelete: Cascade)
  visit          Visit?           @relation(fields: [visitId], references: [id], onDelete: SetNull)
