generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ========================
// ১. ENUMS
// ========================

enum Gender {
  MALE
  FEMALE
  UNKNOWN
}

enum PetStatus {
  ACTIVE
  DECEASED
  LOST
  ADOPTED
}

enum TransactionType {
  DEPOSIT
  EXPENSE
  REFUND
  WITHDRAWAL
  ADJUSTMENT
}

enum TransactionStatus {
  INITIATED
  PENDING
  COMPLETED
  FAILED
  CANCELLED
}

enum PaymentMethod {
  BKASH
  NAGAD
  ROCKET
  BANK_CARD
  CASH_ON_DELIVERY
  WALLET_BALANCE
  SYSTEM
}

// ========================
// ২. রেফারেন্স টেবিল
// ========================

model AnimalType {
  id           Int           @id @default(autoincrement())
  name         String        @unique 
  breeds       Breed[]
  pets         Pet[]
  vaccineTypes VaccineType[]

  @@map("animal_types")
}

model Breed {
  id           Int        @id @default(autoincrement())
  name         String
  animalTypeId Int
  animalType   AnimalType @relation(fields: [animalTypeId], references: [id])
  pets         Pet[]

  @@unique([name, animalTypeId])
  @@map("breeds")
}

// ========================
// ৩. ব্যবহারকারী এবং মিডিয়া
// ========================

model User {
  id              Int      @id @default(autoincrement())
  name            String
  email           String   @unique
  password        String   
  phone           String?
  address         String?
  pets            Pet[]
  wallet          UserWallet? // প্রতি ইউজারের শুধু ১টি ওয়ালেট
  rewardHistories RewardHistory[]

  createdAt       DateTime @default(now())
  @@map("users")
}
model Media {
  id            Int   @id @default(autoincrement())
  url           String
  key           String? 
  type          String
  createdAt     DateTime @default(now())
  petProfilePic Pet?   @relation // optional inverse relation
}

model Pet {
  id              Int        @id @default(autoincrement())
  userId          Int
  user            User       @relation(fields: [userId], references: [id])

  animalTypeId    Int
  animalType      AnimalType @relation(fields: [animalTypeId], references: [id])

  breedId         Int?
  breed           Breed?     @relation(fields: [breedId], references: [id])

  profilePicId    Int?       @unique // ✅ এখানে @unique যোগ করুন
  profilePic      Media?     @relation(fields: [profilePicId], references: [id])

  name            String
  sex             Gender     @default(UNKNOWN) 
  dateOfBirth     DateTime?
  microchipNumber String?    @unique
  
  isRescue        Boolean    @default(false)
  isNeutered      Boolean    @default(false)
  
  foodHabits      String?    @db.Text
  healthDisorders String?    @db.Text
  notes           String?    @db.Text
  
  status          PetStatus  @default(ACTIVE)

  weights           PetWeight[]
  vaccinations      Vaccination[]
  dewormingRecords  DewormingRecord[]
  medicalHistories  MedicalHistory[]

  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  deleted         Boolean    @default(false)

  @@map("pets")
}
// ========================
// ৫. ওজন ট্র্যাকিং
// ========================

model PetWeight {
  id         Int      @id @default(autoincrement())
  petId      Int
  pet        Pet      @relation(fields: [petId], references: [id], onDelete: Cascade)
  
  weightKg   Float    
  notes      String?
  recordedAt DateTime @default(now())
  createdAt  DateTime @default(now())

  @@map("pet_weights")
}

// ========================
// ৬. ভ্যাকসিনেশন সিস্টেম
// ========================

model VaccineType {
  id                 Int           @id @default(autoincrement())
  name               String        @unique 
  targetAnimalTypeId Int?
  targetAnimalType   AnimalType?   @relation(fields: [targetAnimalTypeId], references: [id])
  defaultIntervalDays Int          @default(365)
  description        String?
  vaccinations       Vaccination[]

  @@map("vaccine_types")
}

model Vaccination {
  id             Int          @id @default(autoincrement())
  petId          Int
  pet            Pet          @relation(fields: [petId], references: [id], onDelete: Cascade)
  vaccineTypeId  Int
  vaccineType    VaccineType  @relation(fields: [vaccineTypeId], references: [id])
  administeredAt DateTime     @default(now()) 
  nextDueDate    DateTime?    
  batchNumber    String?
  vetClinic      String?
  notes          String?
  createdAt      DateTime     @default(now())

  @@map("vaccinations")
}

// ========================
// ৭. ডিওয়ার্মিং রেকর্ড
// ========================

model DewormingRecord {
  id             Int      @id @default(autoincrement())
  petId          Int
  pet            Pet      @relation(fields: [petId], references: [id], onDelete: Cascade)
  medicationName String
  dosage         String?  
  weightAtTime   Float?   
  administeredAt DateTime @default(now())
  nextDueDate    DateTime?
  notes          String?
  createdAt      DateTime @default(now())

  @@map("deworming_records")
}

// ========================
// ৮. মেডিকেল হিস্ট্রি
// ========================

model MedicalHistory {
  id           Int      @id @default(autoincrement())
  petId        Int
  pet          Pet      @relation(fields: [petId], references: [id], onDelete: Cascade)
  
  condition    String   // রোগের নাম বা কারণ
  treatment    String?  @db.Text 
  doctorName   String?
  clinicName   String?
  
  // --- নতুন যুক্ত করা ফিল্ড (Vitals) ---
  weightKg     Float?   // ভিসিটের সময় ওজন (e.g., 12.5)
  temperature  Float?   // শরীরের তাপমাত্রা (e.g., 102.5 F)
  // -----------------------------------

  visitDate    DateTime @default(now())
  followUpDate DateTime?
  
  createdAt    DateTime @default(now())
  
  @@map("medical_histories")
}

// ========================
// ৯. ওয়ালেট ও রিওয়ার্ড সিস্টেম
// ========================

model UserWallet {
  id        Int      @id @default(autoincrement())
  userId    Int      @unique // ✅ প্রতি ইউজারের শুধু ১টি ওয়ালেট
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  balance   Decimal  @default(0.00) @db.Decimal(10, 2)
  currency  String   @default("BDT")
  points    Int      @default(0)
  tier      String   @default("Bronze")
  isActive  Boolean  @default(true)
  updatedAt DateTime @updatedAt

  transactions WalletTransaction[] 
  @@map("user_wallets")
}

model WalletTransaction {
  id            Int               @id @default(autoincrement())
  walletId      Int
  wallet        UserWallet        @relation(fields: [walletId], references: [id], onDelete: Cascade)
  
  amount        Decimal           @db.Decimal(10, 2)
  type          TransactionType   
  status        TransactionStatus @default(INITIATED)
  paymentMethod PaymentMethod     @default(SYSTEM)
  transactionId String?           @unique
  description   String?
  referenceId   String?
  referenceType String?
  createdAt     DateTime          @default(now())

  @@map("wallet_transactions")
}

model RewardHistory {
  id          Int      @id @default(autoincrement())
  userId      Int
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade) // ✅ রিলেশন যোগ করা হয়েছে
  action      String
  points      Int
  description String?
  referenceId String?
  createdAt   DateTime @default(now())

  @@map("reward_histories")
}