// ============================
// Universal Product Import (batches, rows, mappings)
// ============================
enum ProductImportSourceType {
  CSV
  EXCEL
  API
}

enum ProductImportBatchStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  CANCELLED
}

enum ProductImportRowStatus {
  READY
  NEEDS_FIX
  ERROR
}

enum IntegrationMappingType {
  CATEGORY
  SUBCATEGORY
  BRAND
  UNIT
}

model ProductImportBatch {
  id              Int                      @id @default(autoincrement())
  orgId           Int
  branchId        Int?
  sourceType      ProductImportSourceType
  provider        String? // e.g. "pos_csv", "excel", "api_xyz"
  filename        String?
  status          ProductImportBatchStatus @default(PENDING)
  totals          Json? // { total, ready, needsFix, error }
  processedRows   Int                      @default(0)
  totalRows       Int                      @default(0)
  progressPercent Float? // 0-100
  startedAt       DateTime?
  finishedAt      DateTime?
  errorMessage    String?                  @db.Text
  createdBy       Int
  createdAt       DateTime                 @default(now())
  updatedAt       DateTime                 @updatedAt

  org           Organization       @relation(fields: [orgId], references: [id], onDelete: Cascade)
  branch        Branch?            @relation(fields: [branchId], references: [id], onDelete: SetNull)
  createdByUser User               @relation("ProductImportBatchCreatedBy", fields: [createdBy], references: [id], onDelete: Restrict)
  rows          ProductImportRow[]

  @@index([orgId, status])
  @@index([createdAt])
  @@map("product_import_batches")
}

model ProductImportRow {
  id                 Int                    @id @default(autoincrement())
  batchId            Int
  externalProductKey String // barcode/sku or external id for idempotency
  rawData            Json // original row/record
  normalizedData     Json? // after Normalizer
  status             ProductImportRowStatus @default(ERROR)
  issues             Json? // [{ code, message?, meta? }]
  matchedProductId   Int? // Product.id after upsert
  createdAt          DateTime               @default(now())
  updatedAt          DateTime               @updatedAt

  batch   ProductImportBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)
  product Product?           @relation(fields: [matchedProductId], references: [id], onDelete: SetNull)

  @@index([batchId, status])
  @@index([matchedProductId])
  @@map("product_import_rows")
}

model IntegrationMapping {
  id            Int                    @id @default(autoincrement())
  orgId         Int
  provider      String // e.g. "pos_csv", "excel", "api_xyz"
  type          IntegrationMappingType
  externalValue String // value from import (normalized)
  internalId    Int // Category.id, Brand.id, or Unit.id
  confidence    Float? // 0-1 for suggestions
  lastUsedAt    DateTime? // updated when mapping is used
  createdAt     DateTime               @default(now())
  updatedAt     DateTime               @updatedAt

  org Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([orgId, provider, type, externalValue])
  @@index([orgId, provider, type])
  @@map("integration_mappings")
}

model ProductChangeRequest {
  id     Int                 @id @default(autoincrement())
  orgId  Int
  type   ChangeRequestType
  status ChangeRequestStatus @default(PENDING)

  requestedByUserId     Int
  requestedFromBranchId Int?
  payload               Json

  reviewedByUserId Int?
  reviewedAt       DateTime?
  note             String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  org                 Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  requestedBy         User         @relation("ProductCRRequestedBy", fields: [requestedByUserId], references: [id], onDelete: Restrict)
  requestedFromBranch Branch?      @relation("ProductCRFromBranch", fields: [requestedFromBranchId], references: [id], onDelete: SetNull)
  reviewedBy          User?        @relation("ProductCRReviewedBy", fields: [reviewedByUserId], references: [id], onDelete: SetNull)

  @@index([orgId, status, type])
  @@index([requestedByUserId])
  @@index([requestedFromBranchId])
  @@map("product_change_requests")
}

