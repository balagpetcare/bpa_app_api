  @@index([branchId])
  @@index([type])
  @@index([acknowledgedAt])
  @@map("workspace_alerts")
}

model WorkspaceApprovalRequest {
  id              Int                     @id @default(autoincrement())
  orgId           Int
  branchId        Int?
  type            WorkspaceApprovalType
  status          WorkspaceApprovalStatus @default(PENDING)
  payloadJson     Json // type-specific payload
  requesterUserId Int
  decidedByUserId Int?
  decidedAt       DateTime?
  rejectReason    String?                 @db.Text
  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @updatedAt

  org       Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  branch    Branch?      @relation(fields: [branchId], references: [id], onDelete: SetNull)
  requester User         @relation("WorkspaceApprovalRequester", fields: [requesterUserId], references: [id], onDelete: Restrict)
