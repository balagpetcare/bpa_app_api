// ============================
// Clinical Item Master (separate from Product)
// ============================

model ClinicalItem {
  id                  Int                        @id @default(autoincrement())
  orgId               Int
  itemCode            String                     @db.VarChar(32)
  name                String                     @db.VarChar(256)
  slug                String                     @db.VarChar(256)
  domainType          ClinicalItemDomain
  categoryId          Int?
  baseUnit            String?                    @db.VarChar(32)
  description         String?                    @db.Text
  brandName           String?                    @db.VarChar(128)
  manufacturerName    String?                    @db.VarChar(128)
  isActive            Boolean                    @default(true)
  isClinicUse         Boolean                    @default(true)
  isSellable          Boolean                    @default(false)
  isPackageEligible   Boolean                    @default(true)
  isInventoryTracked  Boolean                    @default(true)
  requiresBatch       Boolean                    @default(false)
  requiresExpiry      Boolean                    @default(false)
  isReusable          Boolean                    @default(false)
  isHighRisk          Boolean                    @default(false)
  defaultCost         Decimal?                   @db.Decimal(12, 2)
  defaultSalePrice    Decimal?                   @db.Decimal(12, 2)
  lifecycleState      ClinicalItemLifecycleState @default(ACTIVE)
  deprecatedAt        DateTime?                  @db.Timestamptz
  replacementItemId   Int?
  masterCatalogItemId Int?
  createdByUserId     Int?
  updatedByUserId     Int?
  createdAt           DateTime                   @default(now())
  updatedAt           DateTime                   @updatedAt

  org                          Organization                  @relation(fields: [orgId], references: [id], onDelete: Cascade)
  category                     ClinicalItemCategory?         @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  replacementItem              ClinicalItem?                 @relation("ClinicalItemReplacement", fields: [replacementItemId], references: [id], onDelete: SetNull)
  replacementFor               ClinicalItem[]                @relation("ClinicalItemReplacement")
  masterCatalogItem            MasterClinicalCatalogItem?    @relation(fields: [masterCatalogItemId], references: [id], onDelete: SetNull)
  variants                     ClinicalItemVariant[]
  medicineProfile              MedicineItemProfile?
  consumableProfile            ConsumableItemProfile?
  instrumentProfile            InstrumentItemProfile?
  branchConfigs                ClinicalItemBranchConfig[]
  branchStocks                 BranchItemStock[]
  branchBatches                BranchItemBatch[]
  auditLogs                    ClinicalItemAuditLog[]
  approvalLogs                 ClinicalItemApprovalLog[]
  media                        ClinicalItemMedia[]
  packageItems                 PackageItem[]
  consumptionItems             ConsumptionItem[]
  clinicalStockLedgerEntries   ClinicalStockLedger[]
  clinicalSupplyRequestItems   ClinicalSupplyRequestItem[]
  clinicalStockTransferItems   ClinicalStockTransferItem[]
  sterilizationCycleItems      SterilizationCycleItem[]
  instrumentInstances          InstrumentInstance[]
  clinicalStockAuditLines      ClinicalStockAuditLine[]
  clinicalWastageLogs          ClinicalWastageLog[]
  replenishmentRecommendations ReplenishmentRecommendation[]

  @@unique([orgId, itemCode])
  @@unique([orgId, slug])
  @@index([orgId])
  @@index([categoryId])
  @@index([domainType])
  @@index([masterCatalogItemId])
  @@index([lifecycleState])
  @@map("clinical_items")
}

model ClinicalItemCategory {
  id                      Int                 @id @default(autoincrement())
  orgId                   Int
  name                    String              @db.VarChar(128)
  parentId                Int?
  domainType              ClinicalItemDomain?
  sortOrder               Int                 @default(0)
  isActive                Boolean             @default(true)
  description             String?             @db.Text
  isEssential             Boolean             @default(false)
  // Category-level policy (inherit to items or override at item level)
  inventoryTracked        Boolean?            @default(true)
  packageEligible         Boolean?            @default(true)
  prescriptionEligible    Boolean?            @default(false)
  supplyRequestable       Boolean?            @default(true)
  procedureUsable         Boolean?            @default(true)
  branchVisible           Boolean?            @default(true)
  pharmacyVisible         Boolean?            @default(true)
  otVisible               Boolean?            @default(true)
  masterCatalogCategoryId Int?
  createdAt               DateTime            @default(now())
  updatedAt               DateTime            @updatedAt

  org                   Organization                   @relation(fields: [orgId], references: [id], onDelete: Cascade)
  parent                ClinicalItemCategory?          @relation("CategoryTree", fields: [parentId], references: [id], onDelete: SetNull)
  children              ClinicalItemCategory[]         @relation("CategoryTree")
