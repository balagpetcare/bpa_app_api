model CountryMedicineBrand {
  id                    Int       @id @default(autoincrement())
  countryId             Int
  presentationId        Int
  brandId               Int
  packageMarkDisplay    String    @default("") @db.VarChar(512)
  packageMarkNormalized String    @default("") @db.VarChar(256)
  importFingerprint     String    @db.VarChar(64)
  firstImportBatchId    Int?
  lastImportBatchId     Int?
  isActive              Boolean   @default(true)
  archivedAt            DateTime?
  archivedByUserId      Int?
  deactivatedReason     String?   @db.VarChar(512)
  /// Extended medicine workspace fields (clinical, commercial, regulatory text, attachments metadata). Does not affect import fingerprint.
  workspaceProfileJson  Json?
  /// DRAFT | IN_REVIEW | PUBLISHED | REJECTED — optional governance lifecycle for manual listings.
  reviewStatus          String?   @db.VarChar(32)
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  country           Country              @relation(fields: [countryId], references: [id], onDelete: Cascade)
  presentation      MedicinePresentation @relation(fields: [presentationId], references: [id], onDelete: Restrict)
  brand             MedicineBrand        @relation(fields: [brandId], references: [id], onDelete: Restrict)
  firstBatch        MedicineImportBatch? @relation("CountryMedicineBrandFirstBatch", fields: [firstImportBatchId], references: [id], onDelete: SetNull)
  lastBatch         MedicineImportBatch? @relation("CountryMedicineBrandLastBatch", fields: [lastImportBatchId], references: [id], onDelete: SetNull)
  importRows        MedicineImportRow[]
  prescriptionItems PrescriptionItem[]

  // === Medicine Supply Chain (reverse relations) ===
  productListing               Product?                  @relation("ProductMedicineListing")
  requisitionItemsAsListing    MedicineRequisitionItem[] @relation("RequisitionItemListing")
  requisitionItemsAsSubstitute MedicineRequisitionItem[] @relation("RequisitionItemSubstitute")

  @@unique([countryId, importFingerprint])
  @@index([countryId])
  @@index([countryId, isActive])
  @@index([countryId, archivedAt])
  @@index([presentationId])
  @@index([brandId])
  @@index([reviewStatus])
  @@map("country_medicine_brands")
}

// ============================
// MEDICINE REQUISITION (Pharmacy Supply Chain)
// ============================

enum MedicineRequisitionStatus {
  DRAFT
  SUBMITTED
  UNDER_REVIEW
  APPROVED
  PARTIALLY_APPROVED
  REJECTED
  READY_TO_DISPATCH
  DISPATCHED
  IN_TRANSIT
  PARTIALLY_RECEIVED
  RECEIVED
  COMPLETED
  CANCELLED
}

enum MedicineRequisitionUrgency {
  NORMAL
  URGENT
  CRITICAL
}

model MedicineRequisition {
  id                Int                        @id @default(autoincrement())
  requisitionNumber String                     @unique
  orgId             Int
  branchId          Int
  requestedByUserId Int
  urgency           MedicineRequisitionUrgency @default(NORMAL)
  status            MedicineRequisitionStatus  @default(DRAFT)
  note              String?                    @db.Text

  reviewedByUserId Int?
  reviewedAt       DateTime?
  reviewNote       String?   @db.Text

  approvedByUserId Int?
  approvedAt       DateTime?

  rejectedByUserId Int?
  rejectedAt       DateTime?
  rejectionReason  String?   @db.Text

  stockDispatchId Int?
  stockTransferId Int?

  submittedAt       DateTime?
  completedAt       DateTime?
  cancelledAt       DateTime?
  cancelledByUserId Int?
  cancelReason      String?   @db.Text
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  org           Organization                  @relation(fields: [orgId], references: [id], onDelete: Cascade)
  branch        Branch                        @relation(fields: [branchId], references: [id], onDelete: Cascade)
  requestedBy   User                          @relation("MedicineRequisitionRequestedBy", fields: [requestedByUserId], references: [id], onDelete: Restrict)
  reviewedBy    User?                         @relation("MedicineRequisitionReviewedBy", fields: [reviewedByUserId], references: [id], onDelete: SetNull)
  approvedBy    User?                         @relation("MedicineRequisitionApprovedBy", fields: [approvedByUserId], references: [id], onDelete: SetNull)
  rejectedBy    User?                         @relation("MedicineRequisitionRejectedBy", fields: [rejectedByUserId], references: [id], onDelete: SetNull)
  cancelledBy   User?                         @relation("MedicineRequisitionCancelledBy", fields: [cancelledByUserId], references: [id], onDelete: SetNull)
  stockDispatch StockDispatch?                @relation(fields: [stockDispatchId], references: [id], onDelete: SetNull)
  stockTransfer StockTransfer?                @relation(fields: [stockTransferId], references: [id], onDelete: SetNull)
  items            MedicineRequisitionItem[]
  timeline         MedicineRequisitionTimeline[]
  allocationPlan   AllocationPlan?

  @@index([orgId])
  @@index([branchId])
  @@index([status])
  @@index([urgency])
  @@index([createdAt])
  @@map("medicine_requisitions")
}

model MedicineRequisitionItem {
  id                Int     @id @default(autoincrement())
  requisitionId     Int
  medicineListingId Int
  productId         Int?
  variantId         Int?
  requestedQty      Int
  approvedQty       Int?
  dispensedQty      Int?
  receivedQty       Int?
  unit              String? @db.VarChar(50)
  note              String? @db.VarChar(500)
  allowSubstitute   Boolean @default(false)

  substitutedListingId Int?
  substitutionReason   String? @db.VarChar(500)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  requisition        MedicineRequisition   @relation(fields: [requisitionId], references: [id], onDelete: Cascade)
  medicineListing    CountryMedicineBrand  @relation("RequisitionItemListing", fields: [medicineListingId], references: [id], onDelete: Restrict)
  substitutedListing CountryMedicineBrand? @relation("RequisitionItemSubstitute", fields: [substitutedListingId], references: [id], onDelete: SetNull)
  product            Product?              @relation(fields: [productId], references: [id], onDelete: SetNull)
  variant            ProductVariant?       @relation(fields: [variantId], references: [id], onDelete: SetNull)

  @@index([requisitionId])
  @@index([medicineListingId])
  @@map("medicine_requisition_items")
}

model MedicineRequisitionTimeline {
  id                Int      @id @default(autoincrement())
  requisitionId     Int
  action            String   @db.VarChar(50)
  performedByUserId Int?
  note              String?  @db.Text
  meta              Json?
  createdAt         DateTime @default(now())

  requisition MedicineRequisition @relation(fields: [requisitionId], references: [id], onDelete: Cascade)
  performedBy User?               @relation("MedicineRequisitionTimelineActor", fields: [performedByUserId], references: [id], onDelete: SetNull)

  @@index([requisitionId, createdAt])
  @@map("medicine_requisition_timeline")
}

// ============================
// Pharmacy Enterprise: Batch Recall & Expiry Management
// ============================

model BatchRecall {
  id            Int            @id @default(autoincrement())
  orgId         Int
  lotId         Int
  reason        String         @db.Text
  severity      RecallSeverity @default(STANDARD)
  status        RecallStatus   @default(ACTIVE)
  initiatedById Int
  resolvedAt    DateTime?
  resolvedById  Int?
  /// When set, lot may be allocated / dispatched again while recall remains ACTIVE (authorized release).
  allocationReleasedAt   DateTime?
  allocationReleasedByUserId Int?
  notes         String?        @db.Text
  /// Wave-3: optional campaign grouping (manufacturer multi-lot recall)
  campaignId    Int?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  org         Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  lot         StockLot     @relation(fields: [lotId], references: [id], onDelete: Cascade)
  campaign    RecallCampaign? @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  initiatedBy User         @relation("RecallInitiator", fields: [initiatedById], references: [id], onDelete: Restrict)
  resolvedBy  User?        @relation("RecallResolver", fields: [resolvedById], references: [id], onDelete: Restrict)
  allocationReleasedBy User? @relation("RecallAllocationReleasedBy", fields: [allocationReleasedByUserId], references: [id], onDelete: SetNull)

  @@index([orgId, status])
  @@index([lotId])
  @@index([severity, status])
  @@index([campaignId])
  @@map("batch_recalls")
}

model RecallCampaign {
  id              Int                 @id @default(autoincrement())
  orgId           Int
  title           String              @db.VarChar(500)
  externalRef     String?             @db.VarChar(200)
  severity        RecallSeverity      @default(STANDARD)
  status          RecallCampaignStatus @default(ACTIVE)
  metaJson        Json?
  createdByUserId Int
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  org       Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  createdBy User         @relation("RecallCampaignCreatedBy", fields: [createdByUserId], references: [id], onDelete: Restrict)
  recalls   BatchRecall[]

  @@index([orgId, status])
  @@map("recall_campaigns")
}

// ============================
// Wave-3: Network inventory balancing
// ============================

model NetworkTransferRoute {
  id               Int                   @id @default(autoincrement())
  orgId            Int
  fromLocationType InventoryLocationType
  toLocationType   InventoryLocationType
  allowed          Boolean               @default(true)
  priority         Int                   @default(0)
  maxQtyPerDay     Int?
  minMoveQty       Int                   @default(1)
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt

  org Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([orgId, fromLocationType, toLocationType])
  @@index([orgId])
  @@map("network_transfer_routes")
}

model NetworkBalanceSnapshot {
  id         Int      @id @default(autoincrement())
  orgId      Int
  branchId   Int?
  computedAt DateTime @default(now())
  rollupJson Json
  aiJobRunId Int?
  createdAt  DateTime @default(now())

  org    Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  branch Branch?      @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@index([orgId, computedAt])
  @@map("network_balance_snapshots")
}

model NetworkTransferRecommendation {
  id                 Int                               @id @default(autoincrement())
  orgId              Int
  variantId          Int
  lotId              Int?
  fromLocationId     Int
  toLocationId       Int
  recommendedQty     Int
  status             NetworkTransferRecommendationStatus @default(OPEN)
  targetEntityType   NetworkTransferTargetType?
  targetEntityId     Int?
  explainJson        Json                              @default("{}")
  dayBucket          DateTime
  suggestionHash     String                            @db.VarChar(64)
  dismissedByUserId  Int?
  acceptedByUserId   Int?
  acceptedAt         DateTime?
  dismissedAt        DateTime?
  createdAt          DateTime                          @default(now())
  updatedAt          DateTime                          @updatedAt

  org          Organization      @relation(fields: [orgId], references: [id], onDelete: Cascade)
  variant      ProductVariant    @relation(fields: [variantId], references: [id], onDelete: Cascade)
  lot          StockLot?         @relation(fields: [lotId], references: [id], onDelete: SetNull)
  fromLocation InventoryLocation @relation("NetRecoFrom", fields: [fromLocationId], references: [id], onDelete: Restrict)
  toLocation   InventoryLocation @relation("NetRecoTo", fields: [toLocationId], references: [id], onDelete: Restrict)
  dismissedBy  User?             @relation("NetworkRecoDismissedBy", fields: [dismissedByUserId], references: [id], onDelete: SetNull)
  acceptedBy   User?             @relation("NetworkRecoAcceptedBy", fields: [acceptedByUserId], references: [id], onDelete: SetNull)

  @@unique([orgId, suggestionHash])
  @@index([orgId, status, dayBucket])
  @@index([variantId, fromLocationId, toLocationId])
  @@map("network_transfer_recommendations")
}

model ReverseLogisticsCase {
  id                Int                       @id @default(autoincrement())
  orgId             Int
  caseType          ReverseLogisticsCaseType
  status            ReverseLogisticsCaseStatus @default(OPEN)
  primaryEntityType String                    @db.VarChar(32)
  primaryEntityId   Int
  metaJson          Json?
  createdByUserId   Int?
  createdAt         DateTime                  @default(now())
  updatedAt         DateTime                  @updatedAt

  org       Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  createdBy User?        @relation("ReverseLogisticsCaseCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)

  @@index([orgId, status])
  @@index([primaryEntityType, primaryEntityId])
  @@map("reverse_logistics_cases")
}

model ExpiryWriteOffLog {
  id          Int      @id @default(autoincrement())
  orgId       Int
  locationId  Int
  lotId       Int
  variantId   Int
  quantity    Int
  ledgerId    Int      @unique
  method      String   @default("AUTO")
  createdById Int?
  createdAt   DateTime @default(now())

  org       Organization      @relation(fields: [orgId], references: [id], onDelete: Cascade)
  location  InventoryLocation @relation(fields: [locationId], references: [id], onDelete: Cascade)
  lot       StockLot          @relation(fields: [lotId], references: [id], onDelete: Cascade)
  variant   ProductVariant    @relation(fields: [variantId], references: [id], onDelete: Cascade)
  ledger    StockLedger       @relation(fields: [ledgerId], references: [id], onDelete: Cascade)
  createdBy User?             @relation(fields: [createdById], references: [id], onDelete: SetNull)

  @@index([orgId, createdAt])
  @@index([lotId])
  @@index([locationId, createdAt])
  @@map("expiry_write_off_logs")
}

// ============================
// Central Warehouse Module (Phase 1)
// ============================

enum WarehouseType {
  CENTRAL
  REGIONAL
  TRANSIT
}

enum WarehouseStaffRole {
  WAREHOUSE_MANAGER
  RECEIVING_STAFF
  DISPATCH_STAFF
  INVENTORY_CONTROLLER
  QC_OFFICER
  AUDIT_OFFICER
}

enum DeliveryAssignmentStatus {
  ASSIGNED
  EN_ROUTE
  ARRIVED
  COMPLETED
  FAILED
}

model Warehouse {
  id          Int           @id @default(autoincrement())
  orgId       Int
  branchId    Int?          // Link to Branch for unified staff management
  name        String        @db.VarChar(200)
  code        String?       @db.VarChar(50)
  type        WarehouseType @default(CENTRAL)
  addressJson Json?
  location    Json          @default("{}")
  managerId   Int?
  isActive    Boolean       @default(true)
  /// When true, vendor GRN receive creates pending QC rows; stock is not allocatable until inspection completes.
  qcInboundEnabled               Boolean   @default(false)
  /// When set (>0) and failedQty meets threshold, inspection is flagged for escalation review.
  qcEscalationFailedQtyThreshold Int?
  /// Optional: when receiving against a PO whose grandTotal >= this, write an escalation audit row.
  poReceiveEscalationMinTotal    Decimal?  @db.Decimal(14, 2)
  /// Max over-receipt vs ordered line qty: null = unlimited (legacy); 0 = no over; 5 = 5% over allowed.
  poOverReceiptTolerancePercent Decimal?   @db.Decimal(5, 2)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  org       Organization              @relation(fields: [orgId], references: [id], onDelete: Cascade)
  branch    Branch?                   @relation(fields: [branchId], references: [id], onDelete: SetNull)
  manager   User?                     @relation("WarehouseManager", fields: [managerId], references: [id], onDelete: SetNull)
  staff            WarehouseStaffAssignment[]
  staffInvites     StaffInvite[]
  locations        InventoryLocation[]
  zones            WarehouseZone[]
  purchaseOrders   PurchaseOrder[]
  allocationPlans  AllocationPlan[]
  qcInspections    QcInspection[]
  inboundShipmentsShipTo InboundShipment[] @relation("InboundShipmentShipToWarehouse")
  putawayTasks     PutawayTask[]
  preferredByVendors Vendor[]          @relation("VendorPreferredWarehouse")
  purchaseRequisitions PurchaseRequisition[]

  @@index([orgId])
  @@index([orgId, isActive])
  @@index([branchId])
  @@index([isActive])
  @@index([managerId])
  @@map("warehouses")
}

model WarehouseStaffAssignment {
  id          Int                @id @default(autoincrement())
  warehouseId Int
  userId      Int
  role        WarehouseStaffRole
  isActive    Boolean            @default(true)
  assignedAt  DateTime           @default(now())
  removedAt   DateTime?

  warehouse Warehouse @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([warehouseId, userId, role])
  @@index([warehouseId, isActive])
  @@index([userId])
  @@map("warehouse_staff_assignments")
}

model DeliveryAssignment {
  id               Int                      @id @default(autoincrement())
  dispatchId       Int
  assignedToUserId Int
  assignedByUserId Int?
  status           DeliveryAssignmentStatus @default(ASSIGNED)
  note             String?                  @db.Text
  failureReason    String?                  @db.Text
  assignedAt       DateTime                 @default(now())
  startedAt        DateTime?
  arrivedAt        DateTime?
  completedAt      DateTime?
  // Basic POD fields (Phase 1)
  receivedByName   String?                  @db.VarChar(200)
  podNote          String?                  @db.Text
  gpsLat           Decimal?                 @db.Decimal(10, 7)
  gpsLng           Decimal?                 @db.Decimal(10, 7)
  createdAt        DateTime                 @default(now())
  updatedAt        DateTime                 @updatedAt

  dispatch        StockDispatch      @relation(fields: [dispatchId], references: [id], onDelete: Cascade)
  assignedTo      User             @relation("DeliveryAssignedTo", fields: [assignedToUserId], references: [id], onDelete: Restrict)
  assignedBy      User?            @relation("DeliveryAssignedBy", fields: [assignedByUserId], references: [id], onDelete: SetNull)
  proofOfDelivery ProofOfDelivery?

  @@index([dispatchId])
  @@index([assignedToUserId, status])
  @@index([status])
  @@index([assignedAt])
  @@map("delivery_assignments")
}

// ============================
// Central Warehouse Phase 3: PO → Allocation → Pick → POD
// ============================

enum PurchaseOrderStatus {
  DRAFT
  SUBMITTED
  APPROVED
  PARTIALLY_RECEIVED
  RECEIVED
  CANCELLED
  REJECTED
}

enum AllocationPlanStatus {
  DRAFT
  ALLOCATED
  PARTIALLY_ALLOCATED
  CONFIRMED
  PICKING
  PICKED
  DISPATCHED
  CANCELLED
  ON_HOLD
  FAILED
}

enum PickListStatus {
  DRAFT
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

model PurchaseOrder {
  id                   Int                 @id @default(autoincrement())
  orgId                Int
  vendorId             Int
  warehouseId          Int?
  /// Wave-2: optional link to internal purchase requisition that created this PO
  purchaseRequisitionId Int?
  poNumber             String              @db.VarChar(80)
  status               PurchaseOrderStatus @default(DRAFT)
  currency             String?             @db.VarChar(10)
  subtotal             Decimal?            @db.Decimal(14, 2)
  taxTotal             Decimal?            @db.Decimal(14, 2)
  grandTotal           Decimal?            @db.Decimal(14, 2)
  expectedDeliveryDate DateTime?
  notes                String?             @db.Text
  internalNote         String?             @db.Text
  createdByUserId      Int?
  submittedAt          DateTime?
  approvedByUserId     Int?
  approvedAt           DateTime?
  rejectedByUserId     Int?
  rejectedAt           DateTime?
  rejectionReason      String?             @db.Text
  cancelledAt          DateTime?
  cancelReason         String?             @db.Text
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt

  org         Organization        @relation(fields: [orgId], references: [id], onDelete: Cascade)
  vendor      Vendor              @relation(fields: [vendorId], references: [id], onDelete: Restrict)
  warehouse   Warehouse?          @relation(fields: [warehouseId], references: [id], onDelete: SetNull)
  purchaseRequisition PurchaseRequisition? @relation(fields: [purchaseRequisitionId], references: [id], onDelete: SetNull)
  createdBy   User?               @relation("PurchaseOrderCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  approvedBy  User?               @relation("PurchaseOrderApprovedBy", fields: [approvedByUserId], references: [id], onDelete: SetNull)
  rejectedBy  User?               @relation("PurchaseOrderRejectedBy", fields: [rejectedByUserId], references: [id], onDelete: SetNull)
  lines       PurchaseOrderLine[]
  grns        Grn[]
  inboundShipments InboundShipment[]
  stockRequests    StockRequest[]    @relation("StockRequestLinkedPO")

  @@unique([orgId, poNumber])
  @@index([orgId, status])
  @@index([vendorId])
  @@index([purchaseRequisitionId])
  @@map("purchase_orders")
}

model PurchaseOrderLine {
  id              Int      @id @default(autoincrement())
  purchaseOrderId Int
  variantId       Int
  orderedQty      Int
  receivedQty     Int      @default(0)
  unitCost        Decimal? @db.Decimal(12, 4)
  note            String?  @db.VarChar(500)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  purchaseOrder PurchaseOrder  @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  variant       ProductVariant @relation(fields: [variantId], references: [id], onDelete: Restrict)
  inboundShipmentLines InboundShipmentLine[]
  inboundDiscrepancies InboundDiscrepancy[]
  grnLines              GrnLine[]

  @@index([purchaseOrderId])
  @@index([variantId])
  @@map("purchase_order_lines")
}

// ============================
// Wave-2: Purchase requisitions, inbound shipments, putaway, inbound discrepancies
// ============================

enum PurchaseRequisitionStatus {
  DRAFT
  SUBMITTED
  APPROVED
  REJECTED
  CONVERTED
}

model PurchaseRequisition {
  id                   Int                       @id @default(autoincrement())
  orgId                Int
  prNumber             String                    @db.VarChar(80)
  status               PurchaseRequisitionStatus @default(DRAFT)
  warehouseId          Int?
  vendorId             Int?
  notes                String?                   @db.Text
  requestedByUserId    Int?
  submittedAt          DateTime?
  approvedByUserId     Int?
  approvedAt           DateTime?
  rejectedByUserId     Int?
  rejectedAt           DateTime?
  rejectionReason      String?                   @db.Text
  createdAt            DateTime                  @default(now())
  updatedAt            DateTime                  @updatedAt

  org          Organization              @relation(fields: [orgId], references: [id], onDelete: Cascade)
  warehouse    Warehouse?              @relation(fields: [warehouseId], references: [id], onDelete: SetNull)
  vendor       Vendor?                   @relation(fields: [vendorId], references: [id], onDelete: SetNull)
  requestedBy  User?                    @relation("PurchaseRequisitionRequestedBy", fields: [requestedByUserId], references: [id], onDelete: SetNull)
  approvedBy   User?                     @relation("PurchaseRequisitionApprovedBy", fields: [approvedByUserId], references: [id], onDelete: SetNull)
  rejectedBy   User?                     @relation("PurchaseRequisitionRejectedBy", fields: [rejectedByUserId], references: [id], onDelete: SetNull)
  lines        PurchaseRequisitionLine[]
  purchaseOrders PurchaseOrder[]

  @@unique([orgId, prNumber])
  @@index([orgId, status])
  @@map("purchase_requisitions")
}

model PurchaseRequisitionLine {
  id                    Int      @id @default(autoincrement())
  purchaseRequisitionId Int
  variantId             Int
  requestedQty          Int
  convertedQty          Int      @default(0)
  unitCost              Decimal? @db.Decimal(12, 4)
  note                  String?  @db.VarChar(500)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  purchaseRequisition PurchaseRequisition @relation(fields: [purchaseRequisitionId], references: [id], onDelete: Cascade)
  variant             ProductVariant      @relation(fields: [variantId], references: [id], onDelete: Restrict)

  @@index([purchaseRequisitionId])
  @@index([variantId])
  @@map("purchase_requisition_lines")
}

enum InboundShipmentStatus {
  ANNOUNCED
  IN_TRANSIT
  ARRIVED
  CLOSED
  CANCELLED
}

model InboundShipment {
  id                  Int                   @id @default(autoincrement())
  orgId               Int
  vendorId            Int
  purchaseOrderId     Int?
  reference           String                @db.VarChar(120)
  status              InboundShipmentStatus @default(ANNOUNCED)
  expectedArrivalAt   DateTime?
  shipToWarehouseId   Int?
  shipFromJson        Json?
  metaJson            Json?
  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt

  org           Organization       @relation(fields: [orgId], references: [id], onDelete: Cascade)
  vendor        Vendor             @relation(fields: [vendorId], references: [id], onDelete: Restrict)
  purchaseOrder PurchaseOrder?     @relation(fields: [purchaseOrderId], references: [id], onDelete: SetNull)
  shipToWarehouse Warehouse?       @relation("InboundShipmentShipToWarehouse", fields: [shipToWarehouseId], references: [id], onDelete: SetNull)
  lines         InboundShipmentLine[]
  grns          Grn[]

  @@index([orgId, status])
  @@index([vendorId])
  @@index([purchaseOrderId])
  @@unique([orgId, vendorId, reference])
  @@map("inbound_shipments")
}

model InboundShipmentLine {
  id                   Int      @id @default(autoincrement())
  inboundShipmentId    Int
  variantId            Int
  expectedQty          Int
  purchaseOrderLineId  Int?
  batchHint            String?  @db.VarChar(120)
  receivedQtySnapshot  Int      @default(0)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  inboundShipment   InboundShipment    @relation(fields: [inboundShipmentId], references: [id], onDelete: Cascade)
  variant           ProductVariant     @relation(fields: [variantId], references: [id], onDelete: Restrict)
  purchaseOrderLine PurchaseOrderLine? @relation(fields: [purchaseOrderLineId], references: [id], onDelete: SetNull)
  grnLines          GrnLine[]

  @@index([inboundShipmentId])
  @@index([variantId])
  @@map("inbound_shipment_lines")
}

enum PutawayTaskStatus {
  OPEN
  COMPLETED
  CANCELLED
}

model PutawayTask {
  id                   Int               @id @default(autoincrement())
  orgId                Int
  warehouseId          Int?
  grnId                Int?
  grnLineId            Int?              @unique
  variantId            Int
  lotId                Int
  fromLocationId       Int
  quantity             Int
  status               PutawayTaskStatus @default(OPEN)
  recommendationJson   Json?
  toLocationId         Int?
  stockTransferId      Int?              @unique
  completedAt          DateTime?
  completedByUserId    Int?
  metaJson             Json?
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt

  org            Organization      @relation(fields: [orgId], references: [id], onDelete: Cascade)
  warehouse      Warehouse?        @relation(fields: [warehouseId], references: [id], onDelete: SetNull)
  grn            Grn?              @relation(fields: [grnId], references: [id], onDelete: SetNull)
  grnLine        GrnLine?           @relation(fields: [grnLineId], references: [id], onDelete: SetNull)
  variant        ProductVariant    @relation(fields: [variantId], references: [id], onDelete: Restrict)
  lot            StockLot          @relation(fields: [lotId], references: [id], onDelete: Restrict)
  fromLocation   InventoryLocation @relation("PutawayFromLocation", fields: [fromLocationId], references: [id], onDelete: Restrict)
  toLocation     InventoryLocation? @relation("PutawayToLocation", fields: [toLocationId], references: [id], onDelete: SetNull)
  stockTransfer  StockTransfer?    @relation(fields: [stockTransferId], references: [id], onDelete: SetNull)
  completedBy    User?             @relation("PutawayTaskCompletedBy", fields: [completedByUserId], references: [id], onDelete: SetNull)

  @@index([orgId, status])
  @@index([warehouseId, status])
  @@map("putaway_tasks")
}

enum InboundDiscrepancyStatus {
  OPEN
  RESOLVED
  CANCELLED
}

model InboundDiscrepancy {
  id                  Int                      @id @default(autoincrement())
  orgId               Int
  grnId               Int
  grnLineId           Int?
  purchaseOrderLineId Int?
  variantId           Int
  discrepancyType     String                   @db.VarChar(32)
  quantity            Int
  reasonCode          String?                  @db.VarChar(64)
  notes               String?                  @db.Text
  status              InboundDiscrepancyStatus @default(OPEN)
  resolvedAt          DateTime?
  resolvedByUserId    Int?
  resolutionNote      String?                  @db.Text
  createdAt           DateTime                 @default(now())
  updatedAt           DateTime                 @updatedAt

  org               Organization      @relation(fields: [orgId], references: [id], onDelete: Cascade)
  grn               Grn               @relation(fields: [grnId], references: [id], onDelete: Cascade)
  grnLine           GrnLine?          @relation(fields: [grnLineId], references: [id], onDelete: SetNull)
  purchaseOrderLine PurchaseOrderLine? @relation(fields: [purchaseOrderLineId], references: [id], onDelete: SetNull)
  variant           ProductVariant    @relation(fields: [variantId], references: [id], onDelete: Restrict)
  resolvedBy        User?             @relation("InboundDiscrepancyResolvedBy", fields: [resolvedByUserId], references: [id], onDelete: SetNull)

  @@index([orgId, status])
  @@index([grnId])
  @@map("inbound_discrepancies")
}

model AllocationPlan {
  id                      Int                   @id @default(autoincrement())
  orgId                   Int
  stockRequestId          Int?                  @unique
  medicineRequisitionId   Int?                  @unique
  fromLocationId          Int
  warehouseId             Int?
  status                  AllocationPlanStatus  @default(DRAFT)
  /// Sum of requisition demand (variants); set after allocation run.
  totalDemandQty          Int?
  /// Sum of line quantityAllocated after allocation.
  totalAllocatedQty       Int?
  /// totalDemandQty - totalAllocatedQty (unmet demand).
  shortageQty             Int?
  /// Optimistic concurrency on confirm/reallocate.
  version                 Int                   @default(0)
  /// AUTO_FEFO | MANUAL | HYBRID
  allocationMethod        String?               @db.VarChar(32)
  createdByUserId         Int?
  confirmedAt             DateTime?
  cancelledAt             DateTime?
  cancelReason            String?               @db.Text
  createdAt               DateTime              @default(now())
  updatedAt               DateTime              @updatedAt

  org                   Organization         @relation(fields: [orgId], references: [id], onDelete: Cascade)
  stockRequest          StockRequest?        @relation(fields: [stockRequestId], references: [id], onDelete: Cascade)
  medicineRequisition   MedicineRequisition? @relation(fields: [medicineRequisitionId], references: [id], onDelete: Cascade)
  fromLocation          InventoryLocation    @relation("AllocationPlanFromLocation", fields: [fromLocationId], references: [id], onDelete: Restrict)
  warehouse             Warehouse?           @relation(fields: [warehouseId], references: [id], onDelete: SetNull)
  createdBy             User?                @relation("AllocationPlanCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  lines                 AllocationPlanLine[]
  pickList              PickList?
  events                AllocationPlanEvent[]

  @@index([orgId, status])
  @@map("allocation_plans")
}

/// Audit trail for allocation plan lifecycle (enterprise).
model AllocationPlanEvent {
  id                  Int      @id @default(autoincrement())
  orgId               Int
  allocationPlanId    Int
  action              String   @db.VarChar(64)
  fromStatus          String?  @db.VarChar(32)
  toStatus            String?  @db.VarChar(32)
  metadata            Json?
  performedByUserId   Int?
  createdAt           DateTime @default(now())

  org             Organization   @relation(fields: [orgId], references: [id], onDelete: Cascade)
  allocationPlan  AllocationPlan @relation(fields: [allocationPlanId], references: [id], onDelete: Cascade)
  performedBy     User?          @relation("AllocationPlanEventPerformedBy", fields: [performedByUserId], references: [id], onDelete: SetNull)

  @@index([orgId])
  @@index([allocationPlanId, createdAt])
  @@map("allocation_plan_events")
}

model AllocationPlanLine {
  id               Int      @id @default(autoincrement())
  allocationPlanId Int
  variantId        Int
  lotId            Int
  locationId       Int
  quantityAllocated Int
  /// Variant-level demand for this wave (set on first lot line per variant when applicable).
  demandQty        Int?
  /// Unmet quantity for this variant on the first line of that variant (0 on subsequent lot lines).
  quantityShort    Int      @default(0)
  /// ALLOCATED | PARTIAL | SHORT (informational)
  lineStatus       String?  @db.VarChar(32)
  /// FEFO | MANUAL | FIFO
  allocationMethod String?  @db.VarChar(32)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  allocationPlan AllocationPlan @relation(fields: [allocationPlanId], references: [id], onDelete: Cascade)
  variant        ProductVariant @relation(fields: [variantId], references: [id], onDelete: Restrict)
  lot            StockLot       @relation(fields: [lotId], references: [id], onDelete: Restrict)
  location       InventoryLocation @relation(fields: [locationId], references: [id], onDelete: Restrict)
  pickListLines  PickListLine[]

  @@index([allocationPlanId])
  @@index([variantId])
  @@index([lotId])
  @@map("allocation_plan_lines")
}

model PickList {
  id                   Int            @id @default(autoincrement())
  orgId                Int
  allocationPlanId     Int            @unique
  status               PickListStatus @default(DRAFT)
  assignedPickerUserId Int?
  fromLocationId       Int
  stockDispatchId      Int?           @unique
  startedAt            DateTime?
  completedAt          DateTime?
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt

  org             Organization      @relation(fields: [orgId], references: [id], onDelete: Cascade)
  allocationPlan  AllocationPlan    @relation(fields: [allocationPlanId], references: [id], onDelete: Cascade)
  fromLocation    InventoryLocation @relation("PickListFromLocation", fields: [fromLocationId], references: [id], onDelete: Restrict)
  assignedPicker  User?             @relation("PickListAssignedPicker", fields: [assignedPickerUserId], references: [id], onDelete: SetNull)
  dispatch        StockDispatch?    @relation(fields: [stockDispatchId], references: [id], onDelete: SetNull)
  lines           PickListLine[]

  @@index([orgId, status])
  @@index([assignedPickerUserId])
  @@map("pick_lists")
}

model PickListLine {
  id                     Int      @id @default(autoincrement())
  pickListId             Int
  allocationPlanLineId   Int?
  variantId              Int
  lotId                  Int
  locationId             Int
  quantityToPick         Int
  quantityPicked         Int      @default(0)
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  pickList             PickList             @relation(fields: [pickListId], references: [id], onDelete: Cascade)
  allocationPlanLine   AllocationPlanLine?  @relation(fields: [allocationPlanLineId], references: [id], onDelete: SetNull)
  variant              ProductVariant       @relation(fields: [variantId], references: [id], onDelete: Restrict)
  lot                  StockLot             @relation(fields: [lotId], references: [id], onDelete: Restrict)
  location             InventoryLocation    @relation(fields: [locationId], references: [id], onDelete: Restrict)

  @@index([pickListId])
  @@map("pick_list_lines")
}

model ProofOfDelivery {
  id                   Int      @id @default(autoincrement())
  orgId                Int
  dispatchId           Int      @unique
  deliveryAssignmentId Int?     @unique
  recipientName        String?  @db.VarChar(200)
  recipientPhone       String?  @db.VarChar(50)
  receivedAt           DateTime @default(now())
  note                 String?  @db.Text
  signatureFileKey     String?  @db.VarChar(512)
  photoFileKey         String?  @db.VarChar(512)
  gpsLat               Decimal? @db.Decimal(10, 7)
  gpsLng               Decimal? @db.Decimal(10, 7)
  recordedByUserId     Int?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  org        Organization        @relation(fields: [orgId], references: [id], onDelete: Cascade)
  dispatch   StockDispatch       @relation(fields: [dispatchId], references: [id], onDelete: Cascade)
  assignment DeliveryAssignment? @relation(fields: [deliveryAssignmentId], references: [id], onDelete: SetNull)
  recordedBy User?              @relation("ProofOfDeliveryRecordedBy", fields: [recordedByUserId], references: [id], onDelete: SetNull)

  @@index([orgId])
  @@index([receivedAt])
  @@map("proof_of_deliveries")
}

// ============================
// Central Warehouse Phase 4: zones, QC, quarantine audit, recall allocation release
// ============================

enum WarehouseZonePurpose {
  RECEIVING
  STORAGE
  PICKING
  PACKING
  DAMAGE
  RETURN_HOLD
  QUARANTINE
  STAGING
  GENERAL
}

enum QcInspectionStatus {
  PENDING
  PASSED
  FAILED
  PARTIAL
}

enum QcDisposition {
  ACCEPT
  QUARANTINE
  REJECT
  RETURN_TO_VENDOR
}

enum WarehouseAuditCategory {
  QC
  QUARANTINE
  RECALL
  ZONE
  ESCALATION
  OPERATIONS
}

model WarehouseZone {
  id          Int                  @id @default(autoincrement())
  warehouseId Int
  code        String               @db.VarChar(64)
  name        String               @db.VarChar(200)
  purpose     WarehouseZonePurpose @default(GENERAL)
  sortOrder   Int                  @default(0)
  isActive    Boolean              @default(true)
  note        String?              @db.Text
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt

  warehouse Warehouse           @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  locations InventoryLocation[]
  racks     WarehouseRack[]

  @@unique([warehouseId, code])
  @@index([warehouseId, isActive])
  @@map("warehouse_zones")
}

/// Rack aisle/shelving unit within a warehouse zone.
model WarehouseRack {
  id          Int      @id @default(autoincrement())
  zoneId      Int
  code        String   @db.VarChar(64)
  name        String   @db.VarChar(200)
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  note        String?  @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  zone WarehouseZone   @relation(fields: [zoneId], references: [id], onDelete: Cascade)
  bins WarehouseBin[]

  @@unique([zoneId, code])
  @@index([zoneId, isActive])
  @@map("warehouse_racks")
}

/// Bin/slot within a rack (optional link from InventoryLocation for pick face).
model WarehouseBin {
  id        Int      @id @default(autoincrement())
  rackId    Int
  code      String   @db.VarChar(64)
  name      String   @db.VarChar(200)
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  note      String?  @db.Text
  /// Wave-2 putaway: soft capacity limit (units); null = unlimited
  maxUnits        Int?
  allowMixedSku   Boolean  @default(true)
  storageClass    String?  @db.VarChar(32)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  rack      WarehouseRack       @relation(fields: [rackId], references: [id], onDelete: Cascade)
  locations InventoryLocation[]

  @@unique([rackId, code])
  @@index([rackId, isActive])
  @@map("warehouse_bins")
}

model QcInspection {
  id                   Int                 @id @default(autoincrement())
  orgId                Int
  warehouseId          Int?
  grnId                Int
  grnLineId            Int?
  locationId           Int
  variantId            Int
  lotId                Int
  expectedQty          Int
  status               QcInspectionStatus  @default(PENDING)
  inspectedQty         Int?
  passedQty            Int?
  failedQty            Int?
  failureReason        String?             @db.Text
  disposition          QcDisposition?
  quarantineLocationId Int?
  /// Remaining qty still held in quarantine from this inspection (decremented on release).
  quarantineRemainingQty Int?
  releasedFromQuarantineAt DateTime?
  inspectedByUserId    Int?
  inspectedAt          DateTime?
  escalationFlag       Boolean             @default(false)
  evidenceFileKey1     String?             @db.VarChar(512)
  evidenceFileKey2     String?             @db.VarChar(512)
  note                 String?             @db.Text
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt

  org                 Organization      @relation(fields: [orgId], references: [id], onDelete: Cascade)
  warehouse           Warehouse?        @relation(fields: [warehouseId], references: [id], onDelete: SetNull)
  grn                 Grn               @relation(fields: [grnId], references: [id], onDelete: Cascade)
  grnLine             GrnLine?          @relation(fields: [grnLineId], references: [id], onDelete: SetNull)
  location            InventoryLocation @relation("QcInspectionReceiveLocation", fields: [locationId], references: [id], onDelete: Restrict)
  variant             ProductVariant    @relation(fields: [variantId], references: [id], onDelete: Restrict)
  lot                 StockLot          @relation(fields: [lotId], references: [id], onDelete: Restrict)
  quarantineLocation  InventoryLocation? @relation("QcInspectionQuarantineLocation", fields: [quarantineLocationId], references: [id], onDelete: SetNull)
  inspectedBy         User?             @relation("QcInspectionInspectedBy", fields: [inspectedByUserId], references: [id], onDelete: SetNull)

  @@index([orgId, status])
  @@index([warehouseId, status])
  @@index([grnId])
  @@index([grnLineId])
  @@index([locationId, lotId])
  @@map("qc_inspections")
}

model WarehouseAuditEvent {
  id         Int                    @id @default(autoincrement())
  orgId      Int
  warehouseId Int?
  category   WarehouseAuditCategory
  action     String                 @db.VarChar(120)
  entityType String?                @db.VarChar(80)
  entityId   String?                @db.VarChar(64)
  metadata   Json?
  actorUserId Int?
  createdAt  DateTime               @default(now())

  org    Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  actor  User?        @relation("WarehouseAuditEventActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([orgId, createdAt])
  @@index([warehouseId, createdAt])
  @@index([category, createdAt])
  @@map("warehouse_audit_events")
}

// =============================================================================
// Wave-4: Financial intelligence, cost-to-serve, SLA, exception command center
// =============================================================================

enum FinIntelCostGrain {
  GRN_LINE
  VARIANT_BRANCH_PERIOD
  DISPATCH
}

enum FinIntelCostComponent {
  MATERIAL
  INBOUND_ALLOC
  TRANSFER_PROXY
  SHRINK
  LABOR_FACILITY
}

enum SloMeasurementDomain {
  INVENTORY
  SUPPORT
  RECALL
  PROCUREMENT
  CLINIC_QUEUE
}

enum SloTargetKind {
  TIME_TO_COMPLETE
  PERCENT_WITHIN_WINDOW
  COUNT_BREACH
}

enum OpsExceptionSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum OpsExceptionStatus {
  OPEN
  ACKNOWLEDGED
  IN_PROGRESS
  RESOLVED
  SNOOZED
}

enum OpsRcaPrimaryCause {
  DATA_ENTRY
  SYSTEM_BUG
  VENDOR_SHORT
  THEFT
  TRAINING
  UNKNOWN
  OTHER
}

/// Named allocation policy for reproducible cost runs (management accounting — not GL).
model CostAllocationPolicy {
  id             Int          @id @default(autoincrement())
  orgId          Int
  name           String       @db.VarChar(128)
  methodJson     Json         @default("{}")
  effectiveFrom  DateTime     @default(now())
  effectiveTo    DateTime?
  isActive       Boolean      @default(true)
  costModelVersion Int        @default(1)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  org       Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  costFacts CostFact[]

  @@index([orgId, isActive])
  @@map("cost_allocation_policies")
}

/// Optional monthly / period cost drivers (labor hours, facility) for allocation stubs.
model CostDriverInput {
  id               Int       @id @default(autoincrement())
  orgId            Int
  branchId         Int?
  periodStart      DateTime
  periodEnd        DateTime
  laborHours       Decimal?  @db.Decimal(12, 2)
  facilityCost     Decimal?  @db.Decimal(14, 2)
  currency         String    @default("BDT") @db.VarChar(8)
  notes            String?   @db.Text
  createdByUserId  Int?
  createdAt        DateTime  @default(now())

  org    Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  branch Branch?      @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@index([orgId, periodStart])
  @@index([branchId])
  @@map("cost_driver_inputs")
}

/// Atomic derived cost line (explainable; no ledger double-post).
model CostFact {
  id                       Int                 @id @default(autoincrement())
  orgId                    Int
  grain                    FinIntelCostGrain
  component                FinIntelCostComponent
  variantId                Int?
  locationId               Int?
  branchId                 Int?
  refType                  String              @db.VarChar(64)
  refId                    String              @db.VarChar(64)
  amount                   Decimal             @db.Decimal(16, 4)
  currency                 String              @default("BDT") @db.VarChar(8)
  periodStart              DateTime
  periodEnd                DateTime
  inputsJson               Json                @default("{}")
  methodVersion            Int                 @default(1)
  costAllocationPolicyId   Int?
  createdAt                DateTime            @default(now())

  org                  Organization         @relation(fields: [orgId], references: [id], onDelete: Cascade)
  variant              ProductVariant?      @relation(fields: [variantId], references: [id], onDelete: SetNull)
  location             InventoryLocation?   @relation(fields: [locationId], references: [id], onDelete: SetNull)
  branch               Branch?              @relation(fields: [branchId], references: [id], onDelete: SetNull)
  costAllocationPolicy CostAllocationPolicy? @relation(fields: [costAllocationPolicyId], references: [id], onDelete: SetNull)

  @@index([orgId, periodStart, periodEnd])
  @@index([orgId, variantId])
  @@index([orgId, variantId, branchId, periodStart, periodEnd])
  @@index([refType, refId])
  @@map("cost_facts")
}

/// Roll-up cache: cost-to-serve by variant × branch × period.
model CtsSummary {
  id              Int       @id @default(autoincrement())
  orgId           Int
  branchId        Int
  variantId       Int
  periodStart     DateTime
  periodEnd       DateTime
  totalMaterial   Decimal   @default(0) @db.Decimal(16, 4)
  totalAllocated  Decimal   @default(0) @db.Decimal(16, 4)
  unitsBasis      Int?
  unitCts         Decimal?  @db.Decimal(16, 6)
  confidence      Decimal?  @db.Decimal(5, 4)
  methodVersion   Int       @default(1)
  breakdownJson   Json      @default("{}")
  updatedAt       DateTime  @updatedAt

  org     Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  branch  Branch       @relation(fields: [branchId], references: [id], onDelete: Cascade)
  variant ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@unique([orgId, branchId, variantId, periodStart, periodEnd])
  @@index([orgId, periodStart])
  @@map("cts_summaries")
}

/// Per-org SLO definition (targets are management KPIs, not contractual unless configured).
model ServiceLevelObjective {
  id               Int                 @id @default(autoincrement())
  orgId            Int
  sloKey           String              @db.VarChar(80)
  domain           SloMeasurementDomain
  targetKind       SloTargetKind
  /// Hours for time-based, 0–100 for percent targets, or max breach count — interpret via targetKind
  targetValue      Decimal             @db.Decimal(12, 4)
  windowDays       Int                 @default(7)
  isActive         Boolean             @default(true)
  metaJson         Json                @default("{}")
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt

  org          Organization    @relation(fields: [orgId], references: [id], onDelete: Cascade)
  measurements SloMeasurement[]

  @@unique([orgId, sloKey])
  @@index([orgId, domain])
  @@map("service_level_objectives")
}

model SloMeasurement {
  id                Int       @id @default(autoincrement())
  orgId             Int
  sloId             Int
  periodStart       DateTime
  periodEnd         DateTime
  measuredValue     Decimal?  @db.Decimal(14, 6)
  breachCount       Int       @default(0)
  sampleCount       Int       @default(0)
  calculationTrace  Json      @default("{}")
  createdAt         DateTime  @default(now())

  org Organization           @relation(fields: [orgId], references: [id], onDelete: Cascade)
  slo ServiceLevelObjective  @relation(fields: [sloId], references: [id], onDelete: Cascade)

  @@index([orgId, periodStart])
  @@index([sloId])
  @@map("slo_measurements")
}

/// Threshold rules for mapping source signals → unified severity (optional; JSON fallback).
model ExceptionSeverityRule {
  id            Int       @id @default(autoincrement())
  orgId         Int
  exceptionCode String    @db.VarChar(80)
  ruleJson      Json      @default("{}")
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  org Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId, exceptionCode])
  @@map("exception_severity_rules")
}

/// Unified operational exception inbox (projection; source rows remain canonical).
model OperationalExceptionIndex {
  id                 Int                 @id @default(autoincrement())
  orgId              Int
  exceptionCode      String              @db.VarChar(80)
  title              String              @db.VarChar(512)
  severity           OpsExceptionSeverity @default(MEDIUM)
  status             OpsExceptionStatus   @default(OPEN)
  branchId           Int?
  sourceRefType      String              @db.VarChar(64)
  sourceRefId        String              @db.VarChar(64)
  openedAt           DateTime            @default(now())
  dueAt              DateTime?
  assignedToUserId   Int?
  acknowledgedAt     DateTime?
  snoozedUntil       DateTime?
  resolvedAt         DateTime?
  resolutionNote     String?             @db.Text
  timelineJson       Json                @default("[]")
  version            Int                 @default(1)
  breachFlag         Boolean             @default(false)
  updatedAt          DateTime            @updatedAt

  org          Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  branch       Branch?      @relation(fields: [branchId], references: [id], onDelete: SetNull)
  assignedTo   User?        @relation("OpsExceptionAssignee", fields: [assignedToUserId], references: [id], onDelete: SetNull)
  rca          OperationalExceptionRca?

  @@unique([orgId, sourceRefType, sourceRefId])
  @@index([orgId, status, severity])
  @@index([orgId, branchId, openedAt])
  @@index([assignedToUserId])
  @@map("operational_exception_indices")
}

model OperationalExceptionRca {
  id                      Int                 @id @default(autoincrement())
  operationalExceptionId  Int                 @unique
  primaryCause            OpsRcaPrimaryCause  @default(UNKNOWN)
  contributingFactorsJson Json                @default("[]")
  notes                   String?             @db.Text
  createdByUserId         Int?
  createdAt               DateTime            @default(now())
  updatedAt               DateTime            @updatedAt

  exception OperationalExceptionIndex @relation(fields: [operationalExceptionId], references: [id], onDelete: Cascade)
  createdBy User?                     @relation("OpsExceptionRcaAuthor", fields: [createdByUserId], references: [id], onDelete: SetNull)

  @@map("operational_exception_rcas")
}
