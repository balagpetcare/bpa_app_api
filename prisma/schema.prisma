  inventory Inventory @relation(fields: [inventoryId], references: [id], onDelete: Cascade)
  createdBy User?     @relation("StockTransactionCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)

  @@index([inventoryId])
  @@index([createdAt])
  @@map("stock_transactions")
