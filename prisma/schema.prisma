  updatedAt             DateTime        @updatedAt

  surgeryPackage      SurgeryPackage       @relation(fields: [surgeryPackageId], references: [id], onDelete: Cascade)
  product             Product?             @relation(fields: [productId], references: [id], onDelete: SetNull)
  variant             ProductVariant?      @relation(fields: [variantId], references: [id], onDelete: SetNull)
  clinicalItem        ClinicalItem?        @relation(fields: [clinicalItemId], references: [id], onDelete: SetNull)
  clinicalItemVariant ClinicalItemVariant? @relation(fields: [clinicalItemVariantId], references: [id], onDelete: SetNull)

  @@index([surgeryPackageId])
  @@map("package_items")
}

model PackagePriceRule {
  id               Int       @id @default(autoincrement())
  surgeryPackageId Int
  branchId         Int?
  species          String?   @db.VarChar(32)
  weightBandJson   Json? // e.g. { minKg, maxKg }
