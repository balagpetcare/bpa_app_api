  approvedBy      User?        @relation("ClinicalWastageApprovedBy", fields: [approvedById], references: [id], onDelete: SetNull)

  @@index([orgId])
  @@index([branchId])
  @@index([clinicalItemId])
  @@index([status])
  @@map("clinical_wastage_logs")
}

model ReplenishmentRecommendation {
  id               Int       @id @default(autoincrement())
  orgId            Int
  branchId         Int
