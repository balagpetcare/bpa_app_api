  producerOrg ProducerOrg @relation(fields: [producerOrgId], references: [id], onDelete: Cascade)
  createdBy   User?       @relation("ProducerEmailRecipientCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)

  @@unique([producerOrgId, email])
  @@index([producerOrgId])
