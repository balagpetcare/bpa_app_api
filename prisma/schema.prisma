  // relations
  petProfilePic                    Pet?                              @relation("PetProfilePic")
  userAvatars                      UserProfile[]                     @relation("UserAvatar")
  userCovers                       UserProfile[]                     @relation("UserCover")
  galleryItems                     UserGalleryItem[]                 @relation("UserGalleryMedia")
  achievementIcons                 Achievement[]                     @relation("AchievementIcon")
  // NEW: posts can reference uploaded media (images/videos/reels)
  postMedia                        PostMedia[]
  // FUNDRAISING (Phase A) - opposite relation field
  fundraisingVerificationDocuments FundraisingVerificationDocument[]
  // FUNDRAISING PAYOUT - proof uploads (optional)
  fundraisingPayoutProofLogs       FundraisingPayoutTransferLog[]
  // Pet profile: family member avatar (optional)
  petFamilyAvatars                 PetFamilyMember[]                 @relation("PetFamilyAvatar")

  // PHASE-1 KYC / Verification (opposite relations)
  ownerKycDocuments     OwnerKycDocument[]
  organizationDocuments OrganizationDocument[]
  branchDocuments       BranchDocument[]
  directorNidFronts     OrganizationDirector[] @relation("DirectorNidFront")
  directorNidBacks      OrganizationDirector[] @relation("DirectorNidBack")
  directorSignatures    OrganizationDirector[] @relation("DirectorSignature")

  // V3 VERIFICATION
  verificationDocuments VerificationDocument[]

  // Producer KYC (ProducerOrgDocument)
  producerOrgDocuments ProducerOrgDocument[]

  // Producer product proof (AuthProductProof)
  authProductProofs AuthProductProof[]

  // === Products Module: Product Media ===
  productMedia ProductMedia[]

  // === Master Product Catalog: Media Relations ===
  // Primary display media for master catalog products
  masterProductPrimaryFor MasterProductCatalog[] @relation("MasterProductPrimaryMedia")
  // Additional gallery media entries
  masterProductMedia      MasterProductMedia[]

  // Phase 4: Ads
  ads Ad[]

  @@index([ownerUserId])
  @@map("media")
}

