model Inventory {
  id         Int       @id @default(autoincrement())
  branchId   Int
  productId  Int
  variantId  Int?
  quantity   Int       @default(0)
  minStock   Int       @default(10)
  expiryDate DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  branch  Branch          @relation(fields: [branchId], references: [id], onDelete: Cascade)
  product Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  variant ProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)

  transactions StockTransaction[]

  @@index([branchId])
  @@index([productId])
  @@index([variantId])
  @@map("inventory")
}

model StockTransaction {
  id              Int      @id @default(autoincrement())
  inventoryId     Int
  type            String // 'IN', 'OUT', 'ADJUST', 'TRANSFER'
  quantity        Int
  reason          String?
  createdByUserId Int?
  createdAt       DateTime @default(now())

  inventory Inventory @relation(fields: [inventoryId], references: [id], onDelete: Cascade)
  createdBy User?     @relation("StockTransactionCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)

  @@index([inventoryId])
  @@index([createdAt])
  @@map("stock_transactions")
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

enum OrderSource {
  ONLINE
  POS
  CLINIC
  OTHER
}

model Order {
  id                            Int            @id @default(autoincrement())
  orderNumber                   String         @unique
  branchId                      Int
  customerId                    Int?
  status                        OrderStatus    @default(PENDING)
  totalAmount                   Decimal        @default(0)
  paymentMethod                 PaymentMethod?
  paymentStatus                 PaymentStatus  @default(PENDING)
  notes                         String?        @db.Text
  createdByUserId               Int?
  fulfilmentInventoryLocationId Int?
  orderSource                   OrderSource?
  visitId                       Int? // EMR Visit when order is from clinic billing

  // POS financial breakdown
  subtotalAmount  Decimal? @db.Decimal(12, 2)
  discountPercent Decimal? @db.Decimal(5, 2)
  discountAmount  Decimal? @db.Decimal(12, 2)
  taxPercent      Decimal? @db.Decimal(5, 2)
  taxAmount       Decimal? @db.Decimal(12, 2)
  invoiceNumber   String?  @unique
  posShiftId      Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  branch                      Branch             @relation(fields: [branchId], references: [id], onDelete: Cascade)
  customer                    User?              @relation("OrderCustomer", fields: [customerId], references: [id], onDelete: SetNull)
  visit                       Visit?             @relation(fields: [visitId], references: [id], onDelete: SetNull)
  createdBy                   User?              @relation("OrderCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  fulfilmentInventoryLocation InventoryLocation? @relation("OrderFulfilmentLocation", fields: [fulfilmentInventoryLocationId], references: [id], onDelete: SetNull)
  posShift                    PosShift?          @relation(fields: [posShiftId], references: [id], onDelete: SetNull)
  items                       OrderItem[]
  posInvoice                  PosInvoice?
  serviceDeliveries           ServiceDelivery[]
  clinicInvoice               ClinicInvoice?
  appliedDiscounts            AppliedDiscount[]
  injectionTokens             InjectionToken[]
  retailDiscountApprovalsConsumed RetailDiscountApprovalRequest[] @relation("RetailDiscountConsumedOrder")

  @@index([branchId])
  @@index([posShiftId])
  @@index([customerId])
  @@index([status])
  @@index([orderNumber])
  @@index([fulfilmentInventoryLocationId])
  @@index([orderSource])
  @@index([visitId])
  @@map("orders")
}

model PosInvoice {
  id            Int       @id @default(autoincrement())
  orderId       Int       @unique
  invoiceNumber String    @unique
  branchId      Int
  subtotal      Decimal   @db.Decimal(12, 2)
  discountPct   Decimal?  @db.Decimal(5, 2)
  discountAmt   Decimal   @default(0) @db.Decimal(12, 2)
  taxPct        Decimal?  @db.Decimal(5, 2)
  taxAmt        Decimal   @default(0) @db.Decimal(12, 2)
  grandTotal    Decimal   @db.Decimal(12, 2)
  paymentMethod String
  paidAt        DateTime?
  createdAt     DateTime  @default(now())

  order  Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)
  branch Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@index([branchId])
  @@map("pos_invoices")
}

model OrderItem {
  id        Int      @id @default(autoincrement())
  orderId   Int
  productId Int?
  variantId Int?
  serviceId Int?
  quantity  Int
  price     Decimal
  total     Decimal
  createdAt DateTime @default(now())

  retailDiscountApprovalRequestId Int?
  retailDiscountApprovalRequest   RetailDiscountApprovalRequest? @relation(fields: [retailDiscountApprovalRequestId], references: [id], onDelete: SetNull)

  order   Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product?        @relation(fields: [productId], references: [id], onDelete: Restrict)
  variant ProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)
  service Service?        @relation(fields: [serviceId], references: [id], onDelete: SetNull)

  @@unique([retailDiscountApprovalRequestId])
  @@index([orderId])
  @@index([productId])
  @@index([serviceId])
  @@map("order_items")
}

