  mediaId Int
  media   Media @relation(fields: [mediaId], references: [id], onDelete: Cascade)

  version Int @default(1)

  docNumber  String?
  issueDate  DateTime?
  expiryDate DateTime?

  rejectReason String?
  instruction  String?

  checkedAt        DateTime?
  checkedByAdminId Int?
