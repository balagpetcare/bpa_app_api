// ===============================
// Workspace System (task, alerts, approvals)
// ===============================

enum WorkspaceTaskStatus {
  TODO
  IN_PROGRESS
  BLOCKED
  DONE
}

enum WorkspaceTaskType {
  INVENTORY
  STAFF
  ORDER
  COMPLIANCE
  SYSTEM
}

enum WorkspaceTaskPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum WorkspaceAlertType {
  LOW_STOCK
  HIGH_CANCEL_RATE
  STAFF_INACTIVITY
  LOGIN_OUTSIDE_SHIFT
  PERMISSION_VIOLATION
  OVERDUE_TASK
  OTHER
}

enum WorkspaceApprovalType {
  STAFF_INVITE
  ROLE_CHANGE
  BRANCH_TRANSFER
  REFUND_OVERRIDE
  DISCOUNT_EXCEPTION
  OTHER
}

enum WorkspaceApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

model WorkspaceTask {
  id          Int                  @id @default(autoincrement())
  orgId       Int
  branchId    Int?                 // null = global/org-level
  title       String               @db.VarChar(512)
  description String?              @db.Text
  status      WorkspaceTaskStatus  @default(TODO)
  type        WorkspaceTaskType
  priority    WorkspaceTaskPriority @default(MEDIUM)
  assignedToUserId Int?
  createdByUserId  Int
  assignedByUserId Int?
  lastUpdatedByUserId Int?
  deadline    DateTime?
  linkedEntityJson Json?           // { orderId?, staffId?, productId?, etc. }
  resolutionNotes String?          @db.Text
  deletedAt   DateTime?           // soft delete only
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt

  org         Organization         @relation(fields: [orgId], references: [id], onDelete: Cascade)
  branch      Branch?              @relation(fields: [branchId], references: [id], onDelete: SetNull)
  assignedTo  User?                @relation("WorkspaceTaskAssignedTo", fields: [assignedToUserId], references: [id], onDelete: SetNull)
  createdBy   User                 @relation("WorkspaceTaskCreatedBy", fields: [createdByUserId], references: [id], onDelete: Restrict)
  assignedBy  User?                @relation("WorkspaceTaskAssignedBy", fields: [assignedByUserId], references: [id], onDelete: SetNull)
  lastUpdatedBy User?              @relation("WorkspaceTaskLastUpdatedBy", fields: [lastUpdatedByUserId], references: [id], onDelete: SetNull)
  comments    WorkspaceTaskComment[]

  @@index([orgId])
  @@index([branchId])
  @@index([assignedToUserId])
  @@index([status])
  @@index([createdAt])
  @@index([deletedAt])
  @@map("workspace_tasks")
}

model WorkspaceTaskComment {
  id        Int      @id @default(autoincrement())
  taskId    Int
  actorId   Int
  actorRole String  @db.VarChar(32)  // OWNER, STAFF, etc.
  body      String   @db.Text
  isPrivate Boolean  @default(false) // owner -> manager only
  deletedAt DateTime?
  createdAt DateTime @default(now())

  task  WorkspaceTask @relation(fields: [taskId], references: [id], onDelete: Cascade)
  actor User          @relation(fields: [actorId], references: [id], onDelete: Restrict)

  @@index([taskId])
  @@index([actorId])
  @@map("workspace_task_comments")
}

model WorkspaceAlert {
  id           Int               @id @default(autoincrement())
  orgId        Int
  branchId     Int?
  type         WorkspaceAlertType
  title        String            @db.VarChar(512)
  detailJson   Json?             // entity ref, counts, etc.
  acknowledgedAt DateTime?
  acknowledgedByUserId Int?
  convertedToTaskId Int?         // set when converted to task
  createdAt    DateTime         @default(now())

  org              Organization  @relation(fields: [orgId], references: [id], onDelete: Cascade)
  branch           Branch?       @relation(fields: [branchId], references: [id], onDelete: SetNull)
  acknowledgedBy   User?         @relation(fields: [acknowledgedByUserId], references: [id], onDelete: SetNull)

  @@index([orgId])
  @@index([branchId])
  @@index([type])
  @@index([acknowledgedAt])
  @@map("workspace_alerts")
}

model WorkspaceApprovalRequest {
  id          Int                     @id @default(autoincrement())
  orgId       Int
  branchId    Int?
  type        WorkspaceApprovalType
  status      WorkspaceApprovalStatus @default(PENDING)
  payloadJson Json                    // type-specific payload
  requesterUserId Int
  decidedByUserId Int?
  decidedAt   DateTime?
  rejectReason String?                @db.Text
  createdAt   DateTime                @default(now())
  updatedAt   DateTime                @updatedAt

  org       Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  branch    Branch?      @relation(fields: [branchId], references: [id], onDelete: SetNull)
  requester User         @relation("WorkspaceApprovalRequester", fields: [requesterUserId], references: [id], onDelete: Restrict)
  decidedBy User?        @relation("WorkspaceApprovalDecidedBy", fields: [decidedByUserId], references: [id], onDelete: SetNull)

  @@index([orgId])
  @@index([branchId])
  @@index([status])
  @@index([createdAt])
  @@map("workspace_approval_requests")
}

// ===============================
// Partner Onboarding (V21)
// ===============================

enum PartnerStatus {
  NOT_APPLIED
  PENDING_REVIEW
  APPROVED
  REJECTED
  SUSPENDED
}

// Organization payout configuration status (banking collected on separate payouts page)
enum OrganizationPayoutStatus {
  NOT_CONFIGURED
  PENDING_APPROVAL
  CONFIGURED
  REJECTED
}

enum BranchStatus {
  DRAFT
  PENDING_REVIEW
  ACTIVE
  INACTIVE
  BLOCKED
}

enum BranchTypeCode {
  CLINIC
  PET_SHOP
  DELIVERY_HUB
  WAREHOUSE_DC
  GROOMING_SPA
  BOARDING_DAYCARE
  FOSTER_SHELTER
  TRAINING_BEHAVIOR
  PHARMACY_DIAGNOSTICS
}

enum VerificationStatus {
  UNSUBMITTED
  SUBMITTED
  VERIFIED
  REJECTED
  EXPIRED
}

// Phase-1 KYC / Verification enums (add-only)
enum VerificationEntityType {
  OWNER
  ORGANIZATION
  BRANCH
  PRODUCER_ORG
}

enum VerificationAction {
  SUBMIT
  APPROVE
  REJECT
  NOTE
  LOCK
  UNLOCK
}

// Universal Verification Workflow (Phase-1, add-only)
// This is a new, generic workflow that will run in parallel with existing KYC tables.
// هدف: Flutter/public API না ভেঙে ধীরে ধীরে Owner/Org/Branch verification কে standardize করা।
enum VerificationCaseStatus {
  DRAFT
  SUBMITTED
  REJECTED
  APPROVED
}

enum VerificationDocStatus {
  PENDING
  APPROVED
  REJECTED
}

enum DocumentType {
  // Owner KYC
  NID_FRONT
  NID_BACK
  SELFIE_WITH_NID

  // Organization legal
  TRADE_LICENSE
  TIN_CERT
  BIN_CERT
  INCORPORATION_CERT
  PARTNERSHIP_DEED
  BOARD_RESOLUTION
  BANK_CHEQUE_LEAF

  // Branch photos / licenses
  STORE_FRONT_PHOTO
  STORE_INSIDE_PHOTO
  SIGNBOARD_PHOTO
  VET_LICENSE
  DRUG_LICENSE

  OTHER
}

enum DocumentStatus {
  SUBMITTED
  VERIFIED
  REJECTED
}

enum RegistrationType {
  PROPRIETORSHIP
  PARTNERSHIP
  LIMITED_COMPANY
  NGO
}

enum PublishRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

model PartnerApplication {
  id     Int           @id @default(autoincrement())
  userId Int
  status PartnerStatus @default(PENDING_REVIEW)

  businessName   String
  nidNumber      String
  tradeLicenseNo String?
  docsJson       Json?

  submittedAt       DateTime  @default(now())
  reviewedAt        DateTime?
  reviewNote        String?
  reviewedByAdminId Int?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("partner_applications")
}

model Organization {
  id          Int           @id @default(autoincrement())
  ownerUserId Int
  status      PartnerStatus @default(PENDING_REVIEW)
  // Global-Ready Phase 1: country binding for org scope
  countryId   Int?

  // Payout: NOT_CONFIGURED until banking is set up on /owner/organizations/[id]/payouts
  payoutStatus OrganizationPayoutStatus @default(NOT_CONFIGURED)

  name         String
  supportPhone String?
  addressJson  Json?
  /// Standardized location: { lat, lng, address, city, state, country, postalCode }
  location     Json     @default("{}")

  // Owner KYC Upgrade: soft-delete + grace before hard-delete (user kept; business data removed)
  deletedAt           DateTime?
  deletionScheduledAt  DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  owner    User     @relation(fields: [ownerUserId], references: [id], onDelete: Restrict)
  country  Country? @relation(fields: [countryId], references: [id], onDelete: Restrict)
  branches Branch[]

  // PHASE-1 KYC / Verification
  legalProfile OrganizationLegalProfile?

  // === BPA PATCH: memberships + product approval ===
  members               OrgMember[]
  products              Product[]
  productChangeRequests ProductChangeRequest[]

  // === BPA PATCH: staff invites ===
  staffInvites  StaffInvite[]
  // ✅ BranchMember.org opposite
  branchMembers BranchMember[]
  // ✅ Service.org opposite
  services      Service[]

  // === Products Module: Vendors & Commission Rules ===
  vendors         Vendor[]
  commissionRules CommissionRule[]

  // === Product Authenticity (MVP) ===
  factories Factory[]
  contracts Contract[]

  // === Inventory: Stock Lots & Adjustment Requests ===
  stockLots             StockLot[]
  stockAdjustmentRequests StockAdjustmentRequest[]

  // === Stock Request ===
  stockRequests StockRequest[]

  // === GRN (Goods Received Note) & Catalog Enable ===
  grns                 Grn[]
  catalogEnableRequests CatalogEnableRequest[]

  // === Owner Delegation (scope-limited to org) ===
  ownerDelegations OwnerDelegation[]

  // === Workspace System ===
  workspaceTasks            WorkspaceTask[]
  workspaceAlerts           WorkspaceAlert[]
  workspaceApprovalRequests WorkspaceApprovalRequest[]

  // === Universal Product Import ===
  productImportBatches ProductImportBatch[]
  integrationMappings IntegrationMapping[]

  @@index([ownerUserId])
  @@index([countryId])
  @@index([deletedAt, deletionScheduledAt])
  @@map("organizations")
}

model Branch {
  id     Int          @id @default(autoincrement())
  orgId  Int
  name   String
  status BranchStatus @default(DRAFT)

  // what this branch IS (shop/clinic/delivery)
  capabilitiesJson Json @default("{}")

  // new: branch can have multiple types (hybrid supported)
  types        BranchToType[]
  // what modules are ENABLED (pos/ecommerce/appointments...) — admin unlocks on approval
  featuresJson Json           @default("{}")

  verificationStatus VerificationStatus @default(UNSUBMITTED)
  addressJson        Json?
  /// Standardized location: { lat, lng, address, city, state, country, postalCode }
  location           Json               @default("{}")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  org             Organization           @relation(fields: [orgId], references: [id], onDelete: Cascade)
  publishRequests BranchPublishRequest[]
  typeLinks       BranchTypeOnBranch[]
  // PHASE-1 KYC / Verification
  profileDetails  BranchProfileDetails?

  // === BPA PATCH: branch memberships + product change requests ===
  members               BranchMember[]
  productChangeRequests ProductChangeRequest[] @relation("ProductCRFromBranch")

  // === BPA PATCH: staff invites ===
  staffInvites StaffInvite[]

  // === MVP: Inventory & Orders ===
  inventory Inventory[]
  orders    Order[]
  services  Service[]

  // === Products Module: Inventory Locations ===
  inventoryLocations InventoryLocation[]

  // === Stock Request (branch requests stock from owner) ===
  stockRequests StockRequest[]

  catalogEnableRequests CatalogEnableRequest[]

  // === Multi-Branch Staff Permission System ===
  accessPermissions BranchAccessPermission[]

  // === Owner Delegation (scope-limited to branch) ===
  ownerDelegations OwnerDelegation[]
  userContexts     UserContext[]

  // === Workspace System ===
  workspaceTasks            WorkspaceTask[]
  workspaceAlerts           WorkspaceAlert[]
  workspaceApprovalRequests WorkspaceApprovalRequest[]

  // === Universal Product Import ===
  productImportBatches ProductImportBatch[]

  @@index([orgId])
  @@map("branches")
}

model BranchTypeOnBranch {
  branchId     Int
  branchTypeId Int
  isPrimary    Boolean  @default(false)
  createdAt    DateTime @default(now())

  branch     Branch     @relation(fields: [branchId], references: [id], onDelete: Cascade)
  branchType BranchType @relation(fields: [branchTypeId], references: [id], onDelete: Cascade)

  @@id([branchId, branchTypeId])
  @@index([branchTypeId])
}

model BranchPublishRequest {
  id                Int                  @id @default(autoincrement())
  branchId          Int
  status            PublishRequestStatus @default(PENDING)
  submittedAt       DateTime             @default(now())
  reviewedAt        DateTime?
  reviewedByAdminId Int?
  note              String?

  branch Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@index([branchId])
  @@map("branch_publish_requests")
}

model BranchType {
  id        Int      @id @default(autoincrement())
  code      String   @unique
  nameEn    String
  nameBn    String?
  isActive  Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  branches     BranchTypeOnBranch[]
  BranchToType BranchToType[]

  @@map("branch_types")
}

// Master: Organization Types (used by dropdowns for organization/branch creation)
// Kept independent from Organization model for backward compatibility.
model OrganizationType {
  id        Int      @id @default(autoincrement())
  code      String   @unique
  nameEn    String
  nameBn    String?
  isActive  Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("organization_types")
}

model BranchToType {
  branchId Int
  typeId   Int

  branch Branch     @relation(fields: [branchId], references: [id], onDelete: Cascade)
  type   BranchType @relation(fields: [typeId], references: [id], onDelete: Cascade)

