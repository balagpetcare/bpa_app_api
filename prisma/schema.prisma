model ConsumptionItem {
  id                     Int      @id @default(autoincrement())
  inventoryConsumptionId Int
  productId              Int?
  variantId              Int?
  lotId                  Int?
  quantityPlanned        Decimal? @db.Decimal(12, 4)
  quantityActual         Decimal? @db.Decimal(12, 4)
  unitCost               Decimal? @db.Decimal(12, 2)
  wastageFlag            Boolean  @default(false)
  clinicalItemId         Int?
  clinicalItemVariantId  Int?
  batchId                Int?
  consumptionSource      String?  @db.VarChar(32)
  createdAt              DateTime @default(now())

  inventoryConsumption InventoryConsumption @relation(fields: [inventoryConsumptionId], references: [id], onDelete: Cascade)
  product              Product?             @relation(fields: [productId], references: [id], onDelete: SetNull)
  variant              ProductVariant?      @relation(fields: [variantId], references: [id], onDelete: Restrict)
  lot                  StockLot?            @relation(fields: [lotId], references: [id], onDelete: SetNull)
  clinicalItem         ClinicalItem?        @relation(fields: [clinicalItemId], references: [id], onDelete: SetNull)
  clinicalItemVariant  ClinicalItemVariant? @relation(fields: [clinicalItemVariantId], references: [id], onDelete: SetNull)
  batch                BranchItemBatch?     @relation(fields: [batchId], references: [id], onDelete: SetNull)

  @@index([inventoryConsumptionId])
  @@index([variantId])
  @@index([clinicalItemId])
  @@index([clinicalItemVariantId])
  @@map("consumption_items")
}

model VialReturnControl {
  id               Int       @id @default(autoincrement())
  branchId         Int
  clinicalCaseId   Int?
  procedureOrderId Int?
  visitId          Int?
  variantId        Int
  issuedQty        Int
  returnDueAt      DateTime?
  returnedAt       DateTime?
  auditHoldDays    Int       @default(7)
  missingAlertAt   DateTime?
  nextIssueBlocked Boolean   @default(false)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  branch         Branch          @relation(fields: [branchId], references: [id], onDelete: Cascade)
  clinicalCase   ClinicalCase?   @relation(fields: [clinicalCaseId], references: [id], onDelete: SetNull)
  procedureOrder ProcedureOrder? @relation(fields: [procedureOrderId], references: [id], onDelete: SetNull)
  visit          Visit?          @relation(fields: [visitId], references: [id], onDelete: SetNull)
  variant        ProductVariant  @relation(fields: [variantId], references: [id], onDelete: Restrict)

  @@index([branchId])
  @@index([clinicalCaseId])
  @@index([returnDueAt])
  @@map("vial_return_controls")
}

model ClinicInvoice {
  id                Int      @id @default(autoincrement())
  orderId           Int      @unique
  clinicalCaseId    Int?
  surgeryPackageId  Int?
  surgeryCaseId     Int?     @unique
  doctorFeeAmount   Decimal? @db.Decimal(12, 2)
  clinicShareAmount Decimal? @db.Decimal(12, 2)
  supportFeeAmount  Decimal? @db.Decimal(12, 2)
  consumableCost    Decimal? @db.Decimal(12, 2)
  discountApplied   Decimal? @db.Decimal(12, 2)
  anesthesiaCharge  Decimal? @db.Decimal(12, 2)
  otCharge          Decimal? @db.Decimal(12, 2)
  equipmentCharge   Decimal? @db.Decimal(12, 2)
  labCharge         Decimal? @db.Decimal(12, 2)
  billingStatus     String?  @db.VarChar(16)
  settlementRef     String?  @db.VarChar(64)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  order          Order              @relation(fields: [orderId], references: [id], onDelete: Cascade)
  clinicalCase   ClinicalCase?      @relation(fields: [clinicalCaseId], references: [id], onDelete: SetNull)
  surgeryPackage SurgeryPackage?    @relation(fields: [surgeryPackageId], references: [id], onDelete: SetNull)
  surgeryCase    SurgeryCase?       @relation(fields: [surgeryCaseId], references: [id], onDelete: SetNull)
  costSheets     InvoiceCostSheet[]

  @@index([clinicalCaseId])
  @@index([surgeryCaseId])
  @@map("clinic_invoices")
}

model InvoiceCostSheet {
  id                  Int      @id @default(autoincrement())
  clinicInvoiceId     Int
  revenue             Decimal  @db.Decimal(12, 2)
  directCost          Decimal  @db.Decimal(12, 2)
  distributableMargin Decimal  @db.Decimal(12, 2)
  doctorShare         Decimal  @db.Decimal(12, 2)
  clinicShare         Decimal  @db.Decimal(12, 2)
  supportShare        Decimal  @db.Decimal(12, 2)
  grossProfit         Decimal? @db.Decimal(12, 2)
  snapshotJson        Json?
  createdAt           DateTime @default(now())

  clinicInvoice ClinicInvoice @relation(fields: [clinicInvoiceId], references: [id], onDelete: Cascade)

  @@index([clinicInvoiceId])
  @@map("invoice_cost_sheets")
}

model DoctorContract {
  id                     Int                @id @default(autoincrement())
  clinicStaffProfileId   Int
  branchId               Int
  contractType           DoctorContractType
  effectiveFrom          DateTime           @db.Date
  effectiveTo            DateTime?          @db.Date
  consultationRule       Json? // e.g. { sharePct: 60 } or { fixedFee: 350 }
  surgeryRule            Json?
  emergencyRule          Json?
  discountImpactRule     Json? // how discount affects doctor share
  payoutFrequency        SettlementCycle    @default(MONTHLY)
  thresholdIncentiveJson Json? // salary+incentive thresholds
  serviceApplicability   Json? // null = all; or array of service ids
  status                 String             @default("ACTIVE") @db.VarChar(16)
  createdAt              DateTime           @default(now())
  updatedAt              DateTime           @updatedAt

  clinicStaffProfile ClinicStaffProfile       @relation(fields: [clinicStaffProfileId], references: [id], onDelete: Cascade)
  branch             Branch                   @relation(fields: [branchId], references: [id], onDelete: Cascade)
  rules              DoctorContractRule[]
  settlementLedger   DoctorSettlementLedger[]
  settlementBatches  DoctorSettlementBatch[]

  @@index([clinicStaffProfileId])
  @@index([branchId])
  @@map("doctor_contracts")
}

model DoctorContractRule {
  id               Int      @id @default(autoincrement())
  doctorContractId Int
  serviceId        Int?
  category         String?  @db.VarChar(32) // ServiceCategory or custom
  rateType         String   @db.VarChar(32) // SHARE_PCT | FIXED_FEE | PER_CASE
  rateValue        Decimal  @db.Decimal(12, 2)
  notes            String?  @db.Text
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  doctorContract DoctorContract @relation(fields: [doctorContractId], references: [id], onDelete: Cascade)
  service        Service?       @relation(fields: [serviceId], references: [id], onDelete: SetNull)

  @@index([doctorContractId])
  @@index([serviceId])
  @@map("doctor_contract_rules")
}

model DoctorSettlementBatch {
  id                   Int       @id @default(autoincrement())
  orgId                Int
  branchId             Int
  clinicStaffProfileId Int
  contractId           Int?
  periodStart          DateTime  @db.Date
  periodEnd            DateTime  @db.Date
  totalAccrued         Decimal   @db.Decimal(12, 2)
  totalAdjustments     Decimal   @default(0) @db.Decimal(12, 2)
  totalDeductions      Decimal   @default(0) @db.Decimal(12, 2)
  netPayable           Decimal   @db.Decimal(12, 2)
  status               String    @default("DRAFT") @db.VarChar(16) // DRAFT | UNDER_REVIEW | APPROVED | PAID
  approvedByUserId     Int?
  approvedAt           DateTime?
  paidAt               DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  org                Organization             @relation(fields: [orgId], references: [id], onDelete: Cascade)
  branch             Branch                   @relation(fields: [branchId], references: [id], onDelete: Cascade)
  clinicStaffProfile ClinicStaffProfile       @relation(fields: [clinicStaffProfileId], references: [id], onDelete: Cascade)
  doctorContract     DoctorContract?          @relation(fields: [contractId], references: [id], onDelete: SetNull)
  ledgerEntries      DoctorSettlementLedger[]
  payments           SettlementPayment[]
  adjustments        SettlementAdjustment[]

  @@index([clinicStaffProfileId])
  @@index([branchId, periodStart, periodEnd])
  @@map("doctor_settlement_batches")
}

model SettlementPayment {
  id                Int      @id @default(autoincrement())
  settlementBatchId Int
  paymentMethod     String   @db.VarChar(32)
  amount            Decimal  @db.Decimal(12, 2)
  paidByUserId      Int?
  receiptRef        String?  @db.VarChar(128)
  paidAt            DateTime @default(now())
  createdAt         DateTime @default(now())

  settlementBatch DoctorSettlementBatch @relation(fields: [settlementBatchId], references: [id], onDelete: Cascade)
  paidBy          User?                 @relation("SettlementPaymentBy", fields: [paidByUserId], references: [id], onDelete: SetNull)

  @@index([settlementBatchId])
  @@map("settlement_payments")
}

model SettlementAdjustment {
  id                Int      @id @default(autoincrement())
  settlementBatchId Int
  ledgerId          Int?
  adjustmentType    String   @db.VarChar(32) // CLAWBACK | REFUND_REVERSAL | DISPUTE | BONUS
  amount            Decimal  @db.Decimal(12, 2)
  reason            String?  @db.Text
  createdByUserId   Int?
  createdAt         DateTime @default(now())

  settlementBatch DoctorSettlementBatch   @relation(fields: [settlementBatchId], references: [id], onDelete: Cascade)
  ledger          DoctorSettlementLedger? @relation(fields: [ledgerId], references: [id], onDelete: SetNull)
  createdBy       User?                   @relation("SettlementAdjustmentBy", fields: [createdByUserId], references: [id], onDelete: SetNull)

  @@index([settlementBatchId])
  @@map("settlement_adjustments")
}

model SettlementAuditLog {
  id                Int      @id @default(autoincrement())
  orgId             Int
  branchId          Int
  action            String   @db.VarChar(64) // ACCRUED | BATCH_CREATED | APPROVED | PAID | REVERSED
  settlementBatchId Int?
  ledgerId          Int?
  byUserId          Int?
  meta              Json?
  createdAt         DateTime @default(now())

  org    Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  branch Branch       @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@index([branchId])
  @@index([createdAt])
  @@map("settlement_audit_logs")
}

model InventoryVarianceLog {
  id                     Int      @id @default(autoincrement())
  inventoryConsumptionId Int
  variantId              Int
  quantityPlanned        Decimal  @db.Decimal(12, 4)
  quantityActual         Decimal  @db.Decimal(12, 4)
  variance               Decimal  @db.Decimal(12, 4)
  varianceCost           Decimal? @db.Decimal(12, 2)
  notes                  String?  @db.Text
  createdAt              DateTime @default(now())

  inventoryConsumption InventoryConsumption @relation(fields: [inventoryConsumptionId], references: [id], onDelete: Cascade)
  variant              ProductVariant       @relation(fields: [variantId], references: [id], onDelete: Restrict)

  @@index([inventoryConsumptionId])
  @@map("inventory_variance_logs")
}

model ApprovalActionLog {
  id         Int      @id @default(autoincrement())
  orgId      Int
  branchId   Int
  entityType String   @db.VarChar(32) // DISCOUNT | SETTLEMENT | PACKAGE
  entityId   Int
  action     String   @db.VarChar(32) // APPROVE | REJECT | REQUEST
  byUserId   Int
  roleKey    String?  @db.VarChar(64)
  reason     String?  @db.Text
  meta       Json?
  createdAt  DateTime @default(now())

  org    Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  branch Branch       @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@index([branchId, entityType])
  @@map("approval_action_logs")
}

model ClinicFinanceConfig {
  id                            Int             @id @default(autoincrement())
  branchId                      Int             @unique
  settlementCycle               SettlementCycle @default(MONTHLY)
  discountLimitDefaultPct       Decimal?        @db.Decimal(5, 2)
  overheadAllocationMethod      String?         @db.VarChar(32)
  caseCompletionRule            String?         @db.VarChar(64)
  vialReturnDays                Int?            @default(7)
  stockIssueAuditLock           Boolean         @default(false)
  billEditRestrictionAfterClose Boolean         @default(true)
  doctorFeeEditRestricted       Boolean         @default(true)
  configJson                    Json?
  createdAt                     DateTime        @default(now())
  updatedAt                     DateTime        @updatedAt

  branch Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@map("clinic_finance_configs")
}

model TreatmentCourse {
  id                   Int      @id @default(autoincrement())
  patientId            Int
  visitId              Int?
  variantId            Int
  totalPrescribedDoses Int
  expectedDatesJson    Json? // array of date strings (legacy)
  status               String   @db.VarChar(32) // ACTIVE, HOLD, COMPLETED, STOPPED, DISCONTINUED
  branchId             Int? // prescription branch
  prescribedByDoctorId Int?
  durationDays         Int?
  crossBranchAllowed   Boolean  @default(false)
  treatmentBranchId    Int? // where treatment is happening (Module 13)
  holdReason           String?  @db.Text
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  patient                   User                       @relation("TreatmentCoursePatient", fields: [patientId], references: [id], onDelete: Restrict)
  visit                     Visit?                     @relation(fields: [visitId], references: [id], onDelete: SetNull)
  variant                   ProductVariant             @relation(fields: [variantId], references: [id], onDelete: Restrict)
  prescriptionBranch        Branch?                    @relation("TreatmentCoursePrescriptionBranch", fields: [branchId], references: [id], onDelete: SetNull)
  treatmentBranch           Branch?                    @relation("TreatmentCourseTreatmentBranch", fields: [treatmentBranchId], references: [id], onDelete: SetNull)
  prescribedBy              User?                      @relation("TreatmentCoursePrescribedBy", fields: [prescribedByDoctorId], references: [id], onDelete: SetNull)
  doses                     TreatmentCourseDose[]
  days                      TreatmentDay[]
  revisions                 TreatmentRevision[]
  injectionTokens           InjectionToken[]
  medicationAdministrations MedicationAdministration[]

  @@index([patientId])
  @@index([visitId])
  @@index([variantId])
  @@index([status])
  @@index([branchId])
  @@index([treatmentBranchId])
  @@index([prescribedByDoctorId])
  @@map("treatment_courses")
}

model TreatmentCourseDose {
  id                   Int      @id @default(autoincrement())
  courseId             Int
  vialSessionId        Int?
  doseQty              Decimal  @db.Decimal(12, 4)
  administeredAt       DateTime @default(now())
  administeredByUserId Int?

  course      TreatmentCourse @relation(fields: [courseId], references: [id], onDelete: Cascade)
  vialSession VialSession?    @relation(fields: [vialSessionId], references: [id], onDelete: SetNull)

  @@index([courseId])
  @@index([vialSessionId])
  @@map("treatment_course_doses")
}

enum TreatmentDayStatus {
  PENDING
  COMPLETED
  SKIPPED
  MISSED
}

enum TreatmentDayItemStatus {
  DUE
  ADMINISTERED
  SKIPPED
  HELD
}

enum TreatmentRevisionChangeType {
  MEDICINE_ADDED
  MEDICINE_REMOVED
  DOSE_CHANGED
  DAY_MODIFIED
  HOLD
  RESUME
  STOP
}

model TreatmentDay {
  id            Int                @id @default(autoincrement())
  courseId      Int
  dayNumber     Int
  scheduledDate DateTime           @db.Date
  status        TreatmentDayStatus @default(PENDING)
  completedAt   DateTime?
  note          String?            @db.Text
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  course          TreatmentCourse    @relation(fields: [courseId], references: [id], onDelete: Cascade)
  items           TreatmentDayItem[]
  injectionTokens InjectionToken[]

  @@unique([courseId, dayNumber])
  @@index([courseId])
  @@index([scheduledDate])
  @@index([status])
  @@map("treatment_days")
}

model TreatmentDayItem {
  id             Int                    @id @default(autoincrement())
  treatmentDayId Int
  variantId      Int
  medicineName   String                 @db.VarChar(255)
  dosageMl       Decimal                @db.Decimal(12, 4)
  route          String?                @db.VarChar(64)
  frequency      String?                @db.VarChar(64)
  expectedNote   String?                @db.Text
  status         TreatmentDayItemStatus @default(DUE)
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt

  treatmentDay              TreatmentDay               @relation(fields: [treatmentDayId], references: [id], onDelete: Cascade)
  variant                   ProductVariant             @relation(fields: [variantId], references: [id], onDelete: Restrict)
  dispenseRequests          DispenseRequest[]
  medicationAdministrations MedicationAdministration[]

  @@index([treatmentDayId])
  @@index([variantId])
  @@index([status])
  @@map("treatment_day_items")
}

model TreatmentRevision {
  id              Int                         @id @default(autoincrement())
  courseId        Int
  revisionNumber  Int
  changedByUserId Int
  changeType      TreatmentRevisionChangeType
  changeDetails   Json?
  createdAt       DateTime                    @default(now())

  course    TreatmentCourse @relation(fields: [courseId], references: [id], onDelete: Cascade)
  changedBy User            @relation("TreatmentRevisionChangedBy", fields: [changedByUserId], references: [id], onDelete: Restrict)

  @@index([courseId])
  @@index([changedByUserId])
  @@map("treatment_revisions")
}

model VialReturn {
  id                 Int                          @id @default(autoincrement())
  vialSessionId      Int
  returnedAt         DateTime                     @default(now())
  returnedByUserId   Int
  condition          VialReturnCondition
  approxRemainingQty Int?
  returnPhotoUrl     String?                      @db.Text
  receivedByUserId   Int?
  verificationStatus VialReturnVerificationStatus @default(PENDING)
  createdAt          DateTime                     @default(now())
  updatedAt          DateTime                     @updatedAt

  vialSession   VialSession    @relation(fields: [vialSessionId], references: [id], onDelete: Cascade)
  returnedBy    User           @relation("VialReturnReturnedBy", fields: [returnedByUserId], references: [id], onDelete: Restrict)
  receivedBy    User?          @relation("VialReturnReceivedBy", fields: [receivedByUserId], references: [id], onDelete: SetNull)
  auditBinItems AuditBinItem[]

  @@index([vialSessionId])
  @@index([returnedAt])
  @@index([verificationStatus])
  @@map("vial_returns")
}

model AuditBin {
  id               Int            @id @default(autoincrement())
  branchId         Int
  roomId           Int?
  binType          AuditBinType
  sealNo           String?        @db.VarChar(64)
  startDate        DateTime       @default(now())
  closeDate        DateTime?
  retentionUntil   DateTime?
  currentItemCount Int            @default(0)
  status           AuditBinStatus @default(OPEN)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  branch             Branch              @relation(fields: [branchId], references: [id], onDelete: Cascade)
  room               BranchRoom?         @relation(fields: [roomId], references: [id], onDelete: SetNull)
  items              AuditBinItem[]
  destructionRecords DestructionRecord[]

  @@index([branchId])
  @@index([binType])
  @@index([status])
  @@map("audit_bins")
}

model AuditBinItem {
  id             Int                @id @default(autoincrement())
  auditBinId     Int
  vialReturnId   Int
  storedAt       DateTime           @default(now())
  retentionUntil DateTime?
  itemStatus     AuditBinItemStatus @default(HELD)
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  auditBin   AuditBin   @relation(fields: [auditBinId], references: [id], onDelete: Cascade)
  vialReturn VialReturn @relation(fields: [vialReturnId], references: [id], onDelete: Cascade)

  @@unique([vialReturnId])
  @@index([auditBinId])
  @@index([retentionUntil])
  @@map("audit_bin_items")
}

model DestructionRecord {
  id                Int      @id @default(autoincrement())
  auditBinId        Int
  destroyedAt       DateTime @default(now())
  destroyedByUserId Int
  witnessUserId     Int?
  approvalRequestId Int?
  itemCount         Int      @default(0)
  photoUrl          String?  @db.Text
  createdAt         DateTime @default(now())

  auditBin    AuditBin @relation(fields: [auditBinId], references: [id], onDelete: Cascade)
  destroyedBy User     @relation("DestructionRecordBy", fields: [destroyedByUserId], references: [id], onDelete: Restrict)
  witness     User?    @relation("DestructionRecordWitness", fields: [witnessUserId], references: [id], onDelete: SetNull)

  @@index([auditBinId])
  @@index([destroyedAt])
  @@map("destruction_records")
}

// ============================
// Phase 3: Approval & Incident governance
// ============================

enum MedicineApprovalRequestType {
  NO_RETURN_OVERRIDE
  BREAKAGE
  EMERGENCY_ISSUE
  STOCK_VARIANCE
  SUSPICIOUS_RETURN
  DESTRUCTION
}

enum MedicineApprovalStatus {
  PENDING
  APPROVED
  REJECTED
  ESCALATED
}

enum MedicineApprovalActionType {
  APPROVE
  REJECT
  ESCALATE
  COMMENT
}

enum MedicineIncidentType {
  MISSING_VIAL
  SUSPECTED_THEFT
  TAMPERED_RETURN
  STOCK_VARIANCE
  EXCESSIVE_BREAKAGE
  REPEATED_VIAL_MISMATCH
  FREQUENT_OVERRIDE
  TOKEN_UNUSED_INJECTIONS
  EXPIRED_VIAL_USE
}

enum MedicineIncidentSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum MedicineIncidentStatus {
  OPEN
  INVESTIGATING
  RESOLVED
  CLOSED
}

model MedicineApprovalRequest {
  id                Int                         @id @default(autoincrement())
  orgId             Int
  branchId          Int
  requestType       MedicineApprovalRequestType
  relatedEntityType String?                     @db.VarChar(64)
  relatedEntityId   String?                     @db.VarChar(64)
  reason            String?                     @db.Text
  evidenceUrls      Json? // string[]
  requestedByUserId Int
  status            MedicineApprovalStatus      @default(PENDING)
  approvedByUserId  Int?
  approvedAt        DateTime?
  createdAt         DateTime                    @default(now())
  updatedAt         DateTime                    @updatedAt

  org                       Organization               @relation(fields: [orgId], references: [id], onDelete: Cascade)
  branch                    Branch                     @relation(fields: [branchId], references: [id], onDelete: Cascade)
  requestedBy               User                       @relation("MedicineApprovalRequestedBy", fields: [requestedByUserId], references: [id], onDelete: Restrict)
  approvedBy                User?                      @relation("MedicineApprovalApprovedBy", fields: [approvedByUserId], references: [id], onDelete: SetNull)
  actions                   MedicineApprovalAction[]
  medicationAdministrations MedicationAdministration[]

  @@index([branchId])
  @@index([status])
  @@index([requestType])
  @@map("medicine_approval_requests")
}

model MedicineApprovalAction {
  id                Int                        @id @default(autoincrement())
  approvalRequestId Int
  actionByUserId    Int
  action            MedicineApprovalActionType
  comments          String?                    @db.Text
  actionAt          DateTime                   @default(now())

  approvalRequest MedicineApprovalRequest @relation(fields: [approvalRequestId], references: [id], onDelete: Cascade)
  actionBy        User                    @relation("MedicineApprovalActionBy", fields: [actionByUserId], references: [id], onDelete: Restrict)

  @@index([approvalRequestId])
  @@map("medicine_approval_actions")
}

model MedicineIncident {
  id                Int                      @id @default(autoincrement())
  orgId             Int
  branchId          Int
  incidentType      MedicineIncidentType
  relatedEntityType String?                  @db.VarChar(64)
  relatedEntityId   String?                  @db.VarChar(64)
  severity          MedicineIncidentSeverity @default(MEDIUM)
  status            MedicineIncidentStatus   @default(OPEN)
  assignedToUserId  Int?
  resolutionNotes   String?                  @db.Text
  createdAt         DateTime                 @default(now())
  updatedAt         DateTime                 @updatedAt

  org           Organization          @relation(fields: [orgId], references: [id], onDelete: Cascade)
  branch        Branch                @relation(fields: [branchId], references: [id], onDelete: Cascade)
  assignedTo    User?                 @relation("MedicineIncidentAssignedTo", fields: [assignedToUserId], references: [id], onDelete: SetNull)
  discrepancies MedicineDiscrepancy[]

  @@index([branchId])
  @@index([status])
  @@index([incidentType])
  @@map("medicine_incidents")
}

model MedicineDiscrepancy {
  id               Int      @id @default(autoincrement())
  branchId         Int
  variantId        Int
  expectedQty      Int
  actualQty        Int
  varianceQty      Int
  detectedAt       DateTime @default(now())
  detectedByUserId Int?
  status           String   @db.VarChar(32)
  incidentId       Int?

  branch   Branch            @relation(fields: [branchId], references: [id], onDelete: Cascade)
  variant  ProductVariant    @relation(fields: [variantId], references: [id], onDelete: Restrict)
  incident MedicineIncident? @relation(fields: [incidentId], references: [id], onDelete: SetNull)

  @@index([branchId])
  @@index([incidentId])
  @@map("medicine_discrepancies")
}

// ============================
// Phase 4: Analytics
// ============================

model DailyMedicineVariance {
  id          Int      @id @default(autoincrement())
  branchId    Int
  variantId   Int
  date        DateTime @db.Date
  issuedQty   Int      @default(0)
  consumedQty Int      @default(0)
  returnedQty Int      @default(0)
  varianceQty Int      @default(0)
  variancePct Decimal? @db.Decimal(8, 2)
  createdAt   DateTime @default(now())

  branch  Branch         @relation(fields: [branchId], references: [id], onDelete: Cascade)
  variant ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@unique([branchId, variantId, date])
  @@index([branchId])
  @@index([date])
  @@map("daily_medicine_variances")
}

