  DOCTOR_SCHEDULE
  DISCOUNT_CHANGE
  SERVICE_CREATE
  INVENTORY_PURCHASE
  DOCTOR_FEE_CHANGE
  DOCTOR_ACTIVATION
  DOCTOR_DEACTIVATION
  DOCTOR_SERVICE_PRIVILEGE
  DOCTOR_PACKAGE_PRIVILEGE
  DOCTOR_LEAVE
  DOCTOR_CREDENTIAL
}

enum DoctorLeaveType {
  FULL_DAY
  HALF_DAY
  EMERGENCY
  HOLIDAY_EXEMPTION
}

enum DoctorLeaveStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum DoctorPackageRole {
  PRIMARY
  ASSISTANT
  CONSULTANT
  SURGEON
  BACKUP
}

enum DoctorServiceMappingStatus {
  ACTIVE
  INACTIVE
  PENDING_APPROVAL
}

model ClinicApprovalRequest {
  id                Int                       @id @default(autoincrement())
  orgId             Int
  branchId          Int
  requestType       ClinicApprovalRequestType
  entityType        String                    @db.VarChar(32) // PACKAGE, DOCTOR, etc.
  entityId          Int? // set after apply
