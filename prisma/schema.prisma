model SterilizationCycle {
  id              Int       @id @default(autoincrement())
  orgId           Int
  branchId        Int
  cycleNo         String    @unique @db.VarChar(32)
  method          String    @db.VarChar(32)
  machineName     String?   @db.VarChar(128)
  operatorId      Int
  status          String    @default("IN_PROGRESS") @db.VarChar(24)
  startedAt       DateTime  @default(now())
  completedAt     DateTime?
  remarks         String?   @db.VarChar(512)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  items           SterilizationCycleItem[]
  org             Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  branch          Branch       @relation(fields: [branchId], references: [id], onDelete: Cascade)
  operator        User         @relation("SterilizationCycleOperator", fields: [operatorId], references: [id], onDelete: Restrict)

  @@index([orgId])
  @@index([branchId])
  @@index([status])
  @@map("sterilization_cycles")
}

model SterilizationCycleItem {
  id              Int       @id @default(autoincrement())
  cycleId         Int
  instrumentId    Int
  preCleanStatus  String    @db.VarChar(32)
  postCycleStatus String?   @db.VarChar(32)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  cycle           SterilizationCycle @relation(fields: [cycleId], references: [id], onDelete: Cascade)
  instrument      ClinicalItem       @relation(fields: [instrumentId], references: [id], onDelete: Cascade)

  @@index([cycleId])
  @@index([instrumentId])
  @@map("sterilization_cycle_items")
}

model InstrumentInstance {
  id                    Int       @id @default(autoincrement())
  orgId                 Int
  branchId              Int
  clinicalItemId        Int
  serialNo              String?   @db.VarChar(64)
  conditionStatus      String    @default("GOOD") @db.VarChar(24)
  sterilizationStatus  String    @default("NOT_APPLICABLE") @db.VarChar(24)
  lastSterilizedAt      DateTime?
  sterilizationExpiryAt DateTime?
  usageCount            Int       @default(0)
  purchasedAt           DateTime? @db.Date
  active                Boolean   @default(true)
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  clinicalItem          ClinicalItem @relation(fields: [clinicalItemId], references: [id], onDelete: Cascade)
  branch                Branch       @relation(fields: [branchId], references: [id], onDelete: Cascade)
  org                   Organization  @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId])
  @@index([branchId])
  @@index([clinicalItemId])
  @@map("instrument_instances")
}

model InstrumentIssueLog {
  id                  Int       @id @default(autoincrement())
  branchId            Int
  itemId              Int
  variantId           Int
  issuedToUserId      Int?
  procedureId         Int?
  issuedQty           Decimal   @db.Decimal(12, 4)
  issuedAt            DateTime  @default(now())
  returnedQty         Decimal?  @db.Decimal(12, 4)
  returnedAt          DateTime?
  sterilizationStatus String?   @db.VarChar(32)
  conditionNote       String?   @db.VarChar(256)
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  branch Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@index([branchId])
  @@index([itemId])
  @@index([issuedToUserId])
  @@map("instrument_issue_logs")
}

model ClinicalItemAuditLog {
  id           Int            @id @default(autoincrement())
  itemId       Int
  branchId     Int?
  actionType   ItemAuditAction
  oldDataJson  Json?
  newDataJson  Json?
  performedBy  Int?
  performedRole String?       @db.VarChar(64)
  performedAt DateTime       @default(now())
  remarks      String?        @db.VarChar(512)

  item   ClinicalItem @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@index([itemId])
  @@index([branchId])
  @@index([performedAt])
  @@map("clinical_item_audit_logs")
}

model ClinicalItemApprovalLog {
  id          Int               @id @default(autoincrement())
  itemId      Int
  requestType String            @db.VarChar(64)
  requestedBy Int?
  approvedBy  Int?
  status      ItemApprovalStatus @default(PENDING)
  remarks     String?           @db.VarChar(512)
  createdAt   DateTime          @default(now())
  resolvedAt  DateTime?

  item ClinicalItem @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@index([itemId])
  @@index([status])
  @@map("clinical_item_approval_logs")
}

model ClinicalItemMedia {
  id        Int      @id @default(autoincrement())
  itemId    Int
  mediaUrl  String   @db.VarChar(512)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  item ClinicalItem @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@index([itemId])
  @@map("clinical_item_media")
}

model ClinicalItemBranchConfig {
  id              Int      @id @default(autoincrement())
  branchId        Int
  itemId          Int
  isActive        Boolean  @default(true)
  isVisible       Boolean  @default(true)
  reorderLevel    Decimal? @db.Decimal(12, 4)
  maxLevel        Decimal? @db.Decimal(12, 4)
  minLevel        Decimal? @db.Decimal(12, 4)
  preferredVendorId Int?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  branch Branch         @relation(fields: [branchId], references: [id], onDelete: Cascade)
  item   ClinicalItem   @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@unique([branchId, itemId])
  @@index([branchId])
  @@index([itemId])
  @@map("clinical_item_branch_configs")
}
