  @@index([patientId])
  @@index([visitId])
  @@index([appointmentId])
  @@map("clinical_cases")
}

// ============================
// Enterprise Surgery Module: Surgery Case lifecycle
// ============================

model SurgeryCase {
  id               Int  @id @default(autoincrement())
  orgId            Int
  branchId         Int
  clinicalCaseId   Int? @unique
  appointmentId    Int? @unique
  visitId          Int? @unique
  patientId        Int
  petId            Int
  serviceId        Int
  surgeryPackageId Int?
  roomId           Int?
  primaryDoctorId  Int

  caseNumber  String              @unique @db.VarChar(32)
  surgeryType String?             @db.VarChar(64)
  priority    SurgeryCasePriority @default(NORMAL)
  status      SurgeryCaseStatus   @default(DRAFT)

  scheduledStartAt DateTime?
  scheduledEndAt   DateTime?
  actualStartAt    DateTime?
  actualEndAt      DateTime?

  preopNotes        String?   @db.Text
  operativeNotes    String?   @db.Text
  postopNotes       String?   @db.Text
  complicationNotes String?   @db.Text
  dischargeNotes    String?   @db.Text
  followUpDate      DateTime? @db.Date

  pricingSnapshotJson Json?
  feeRuleSnapshotJson Json?

  estimatedAmount Decimal? @db.Decimal(12, 2)
  advancePaid     Decimal? @db.Decimal(12, 2)

  createdByUserId Int
  updatedByUserId Int?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  org            Organization    @relation(fields: [orgId], references: [id], onDelete: Cascade)
  branch         Branch          @relation(fields: [branchId], references: [id], onDelete: Cascade)
  clinicalCase   ClinicalCase?   @relation(fields: [clinicalCaseId], references: [id], onDelete: SetNull)
  appointment    Appointment?    @relation(fields: [appointmentId], references: [id], onDelete: SetNull)
  visit          Visit?          @relation(fields: [visitId], references: [id], onDelete: SetNull)
  patient        User            @relation("SurgeryCasePatient", fields: [patientId], references: [id], onDelete: Restrict)
  pet            Pet             @relation(fields: [petId], references: [id], onDelete: Restrict)
  service        Service         @relation(fields: [serviceId], references: [id], onDelete: Restrict)
  surgeryPackage SurgeryPackage? @relation(fields: [surgeryPackageId], references: [id], onDelete: SetNull)
  room           BranchRoom?     @relation(fields: [roomId], references: [id], onDelete: SetNull)
  primaryDoctor  BranchMember    @relation("SurgeryCasePrimaryDoctor", fields: [primaryDoctorId], references: [id], onDelete: Restrict)
  createdBy      User            @relation("SurgeryCaseCreatedBy", fields: [createdByUserId], references: [id], onDelete: Restrict)
  updatedBy      User?           @relation("SurgeryCaseUpdatedBy", fields: [updatedByUserId], references: [id], onDelete: SetNull)

  staff                     SurgeryCaseStaff[]
  statusLogs                SurgeryCaseStatusLog[]
  checklistItems            SurgeryCaseChecklist[]
  inventoryConsumptions     InventoryConsumption[]
  clinicInvoices            ClinicInvoice[]
  doctorSettlementLedger    DoctorSettlementLedger[]
  dispenseRequests          DispenseRequest[]
  medicationAdministrations MedicationAdministration[]

