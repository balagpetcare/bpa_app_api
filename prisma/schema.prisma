  variant          ClinicalItemVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)

  @@index([orgId])
  @@index([branchId])
  @@index([clinicalItemId])
  @@index([status])
  @@map("replenishment_recommendations")
