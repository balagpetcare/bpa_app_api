}

// Producer-scoped factory (verified manufacturing facility for product approval)
model ProducerFactory {
  id            Int      @id @default(autoincrement())
  producerOrgId Int
  name          String
  addressJson   Json?
  countryCode   String?
  isVerified    Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  producerOrg  ProducerOrg   @relation(fields: [producerOrgId], references: [id], onDelete: Cascade)
  authProducts AuthProduct[]

  @@index([producerOrgId])
  @@map("producer_factories")
