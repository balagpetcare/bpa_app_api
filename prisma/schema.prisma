// Producer KYC: formal document model (unified with VerificationCase + VerificationDocument)
model ProducerOrgDocument {
  id            Int            @id @default(autoincrement())
  producerOrgId Int
  type          DocumentType
  status        DocumentStatus @default(SUBMITTED)

  mediaId Int
  media   Media @relation(fields: [mediaId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  producerOrg ProducerOrg @relation(fields: [producerOrgId], references: [id], onDelete: Cascade)

  @@index([producerOrgId])
  @@index([type])
  @@map("producer_org_documents")
}

enum ProducerOrgStaffStatus {
  INVITED
  ACTIVE
  SUSPENDED
  DISABLED
  REMOVED
}

model ProducerOrgStaff {
  id            Int                    @id @default(autoincrement())
  producerOrgId Int
  userId        Int
  roleId        Int
  invitedBy     Int?
  status        ProducerOrgStaffStatus @default(ACTIVE)
  createdAt     DateTime               @default(now())
  updatedAt     DateTime               @updatedAt

