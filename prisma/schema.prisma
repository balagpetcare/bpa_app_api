model PackagePriceChangeLog {
  id               Int      @id @default(autoincrement())
  surgeryPackageId Int
  oldPrice         Decimal  @db.Decimal(12, 2)
  newPrice         Decimal  @db.Decimal(12, 2)
  changedByUserId  Int
