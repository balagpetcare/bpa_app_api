// ===============================
// Partner Onboarding (V21)
// ===============================

enum PartnerStatus {
  NOT_APPLIED
  PENDING_REVIEW
  APPROVED
  REJECTED
  SUSPENDED
}

enum BranchStatus {
  DRAFT
  PENDING_REVIEW
  ACTIVE
  INACTIVE
  BLOCKED
}

enum VerificationStatus {
  UNSUBMITTED
  SUBMITTED
  VERIFIED
  REJECTED
}

enum PublishRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

model PartnerApplication {
  id        Int           @id @default(autoincrement())
  userId    Int
  status    PartnerStatus @default(PENDING_REVIEW)

  businessName    String
  nidNumber       String
  tradeLicenseNo  String?
  docsJson        Json?

  submittedAt DateTime @default(now())
  reviewedAt  DateTime?
  reviewNote  String?
  reviewedByAdminId Int?

  user      User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("partner_applications")
}

model Organization {
  id          Int           @id @default(autoincrement())
  ownerUserId Int
  status      PartnerStatus @default(PENDING_REVIEW)

  name         String
  supportPhone String?
  addressJson  Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  owner    User    @relation(fields: [ownerUserId], references: [id], onDelete: Restrict)
  branches Branch[]

  @@index([ownerUserId])
  @@map("organizations")
}

model Branch {
  id        Int @id @default(autoincrement())
  orgId     Int
  name      String
  status    BranchStatus @default(DRAFT)

  // what this branch IS (shop/clinic/delivery)
  capabilitiesJson Json @default("{}")
  // what modules are ENABLED (pos/ecommerce/appointments...) — admin unlocks on approval
  featuresJson     Json @default("{}")

  verificationStatus VerificationStatus @default(UNSUBMITTED)
  addressJson Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  org       Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  publishRequests BranchPublishRequest[]

  @@index([orgId])
  @@map("branches")
}

model BranchPublishRequest {
  id        Int @id @default(autoincrement())
  branchId  Int
  status    PublishRequestStatus @default(PENDING)
  submittedAt DateTime @default(now())
  reviewedAt  DateTime?
  reviewedByAdminId Int?
  note      String?

  branch    Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@index([branchId])
  @@map("branch_publish_requests")
}
