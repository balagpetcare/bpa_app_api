model Service {
  id          Int             @id @default(autoincrement())
  orgId       Int
  branchId    Int
  name        String
  description String?         @db.Text
  category    ServiceCategory
  status      ServiceStatus   @default(ACTIVE)
  price       Decimal
  duration    Int? // Duration in minutes
  isRecurring Boolean         @default(false)

  department            ServiceDepartment      @default(DOCTOR_DESK)
  paymentGateRule       PaymentGateRule        @default(PAY_BEFORE_SERVICE)
  serviceCode           String?                @unique @db.VarChar(32)
  prerequisiteRule      Json?
  allowDiscount         Boolean                @default(true)
  maxDiscountPct        Decimal?               @db.Decimal(5, 2)
  discountNeedsApproval Boolean                @default(false)
  taxRuleJson           Json?
  applicableSpecies     Json?
  isCustom              Boolean                @default(false)
  proposedByUserId      Int?
  approvalStatus        ServiceApprovalStatus?

  // Enterprise: Module A enhanced service master
  otRequired            Boolean @default(false)
  inventoryLinked       Boolean @default(false)
  packageAllowed        Boolean @default(false)
  specialtyTag          String? @db.VarChar(64)
  doctorRequired        Boolean @default(true)
  estimatedCostJson     Json?
  allowedRoomTypes      Json?   @default("[]") // ["CONSULTATION","SURGERY",...] - empty = any
  ownerDiscountEligible Boolean @default(false) // Only eligible services can use Owner Discount Card

  // Centralized pricing & public content (enterprise services hub)
  baseCost           Decimal? @db.Decimal(12, 2)
  minSafePrice       Decimal? @db.Decimal(12, 2)
  staffInstructions  String?  @db.Text
  pricingExplanation String?  @db.Text
  visibleToPublic    Boolean  @default(true)
  preparationNotes   String?  @db.Text
  aftercareNotes     String?  @db.Text
  faqJson            Json?

  createdByUserId Int
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  org                      Organization              @relation(fields: [orgId], references: [id], onDelete: Cascade)
  branch                   Branch                    @relation(fields: [branchId], references: [id], onDelete: Cascade)
  createdBy                User                      @relation("ServiceCreatedBy", fields: [createdByUserId], references: [id], onDelete: Restrict)
  appointments             Appointment[]
  serviceDeliveries        ServiceDelivery[]
  doctorServiceFees        DoctorServiceFee[]
  doctorServiceMappings    DoctorServiceMapping[]
  pricingVariants          ServicePricingVariant[]
  serviceMedia             ServiceMedia[]
  servicePricingChangeLogs ServicePricingChangeLog[]
  orderItems               OrderItem[]
  surgeryPackageTemplates  SurgeryPackageTemplate[]
  surgeryPackages          SurgeryPackage[]
  surgeryCases             SurgeryCase[]
  doctorContractRules      DoctorContractRule[]

  @@index([orgId, branchId])
  @@index([branchId, status])
  @@index([category])
  @@map("services")
}

model ServicePricingVariant {
  id        Int      @id @default(autoincrement())
  serviceId Int
  species   String   @db.VarChar(32)
  sex       String?  @db.VarChar(16)
  price     Decimal  @db.Decimal(12, 2)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  service Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@unique([serviceId, species, sex])
  @@index([serviceId])
  @@map("service_pricing_variants")
}

/// Links clinic services to uploaded media (hero, gallery, video).
model ServiceMedia {
  id        Int              @id @default(autoincrement())
  serviceId Int
  mediaId   Int
  kind      ServiceMediaKind @default(GALLERY)
  sortOrder Int              @default(0)
  createdAt DateTime         @default(now())

  service Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  media   Media   @relation(fields: [mediaId], references: [id], onDelete: Cascade)

  @@index([serviceId, sortOrder])
  @@index([mediaId])
  @@map("service_media")
}

/// Append-only audit of branch service pricing / content field changes.
model ServicePricingChangeLog {
  id          Int      @id @default(autoincrement())
  branchId    Int
  serviceId   Int
  actorUserId Int
  beforeJson  Json
  afterJson   Json
  reason      String?  @db.VarChar(512)
  createdAt   DateTime @default(now())

  service Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@index([serviceId, createdAt])
  @@index([branchId, createdAt])
  @@map("service_pricing_change_logs")
}

/// Append-only audit of doctor service fee row changes.
/// FK uses ON DELETE SET NULL so history survives row removal (fee row id cleared on parent delete).
model DoctorServiceFeeChangeLog {
  id                 Int      @id @default(autoincrement())
  doctorServiceFeeId Int?
  actorUserId        Int
  beforeJson         Json
  afterJson          Json
  changeReason       String?  @db.VarChar(512)
  createdAt          DateTime @default(now())

  doctorServiceFee DoctorServiceFee? @relation(fields: [doctorServiceFeeId], references: [id], onDelete: SetNull)

  @@index([doctorServiceFeeId, createdAt])
  @@map("doctor_service_fee_change_logs")
}

model ServiceProposal {
  id               Int               @id @default(autoincrement())
  orgId            Int
  branchId         Int
  title            String            @db.VarChar(128)
  category         ServiceCategory
  department       ServiceDepartment
  suggestedPrice   Decimal?          @db.Decimal(12, 2)
  reason           String?           @db.Text
  status           String            @default("PENDING") @db.VarChar(16)
  proposedByUserId Int
  reviewedByUserId Int?
  reviewedAt       DateTime?
  reviewNote       String?           @db.Text
  createdServiceId Int?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  org    Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  branch Branch       @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@index([branchId, status])
  @@map("service_proposals")
}

model ServiceDelivery {
  id                Int       @id @default(autoincrement())
  visitId           Int
  serviceId         Int
  status            String    @db.VarChar(32)
  deliveredAt       DateTime?
  checklistJson     Json?
  consumablesJson   Json?
  notes             String?   @db.Text
  orderId           Int?
  paymentVerified   Boolean   @default(false)
  paymentVerifiedAt DateTime?
  verifiedByUserId  Int?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  visit   Visit   @relation(fields: [visitId], references: [id], onDelete: Cascade)
  service Service @relation(fields: [serviceId], references: [id], onDelete: Restrict)
  order   Order?  @relation(fields: [orderId], references: [id], onDelete: SetNull)

  @@index([visitId])
  @@index([serviceId])
  @@index([orderId])
  @@map("service_deliveries")
}

// ============================
// PRODUCTS DOMAIN MODELS
// ============================

model Category {
  id        Int      @id @default(autoincrement())
  parentId  Int?
  name      String
  slug      String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  parent         Category?              @relation("CategoryTree", fields: [parentId], references: [id], onDelete: Cascade)
  children       Category[]             @relation("CategoryTree")
  products       Product[]
  masterProducts MasterProductCatalog[]

  @@unique([parentId, slug])
  @@index([parentId])
  @@index([slug])
  @@map("categories")
}

model Brand {
  id        Int      @id @default(autoincrement())
  companyId Int?
  name      String
  slug      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company        Company?               @relation(fields: [companyId], references: [id], onDelete: SetNull)
  products       Product[]
  masterProducts MasterProductCatalog[]

  @@index([slug])
  @@index([companyId])
  @@map("brands")
}

// Global manufacturer/importer (e.g., Royal Canin)
model Company {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  country     String?
  website     String?
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  brands         Brand[]
  masterProducts MasterProductCatalog[]

  @@map("companies")
}

// === Global-Ready Phase 1: Country + Policy (BPA) ===
// Reference: docs/GLOBAL_READY_FULL_PLANNING.md
model Country {
  id              Int      @id @default(autoincrement())
  code            String   @unique // ISO 3166-1 alpha-2: BD, IN, US, LK, MY, SG
  name            String
  currencyCode    String?  @default("USD")
  timezoneDefault String?  @default("UTC")
  phoneCode       String? // E.164 prefix e.g. +880
  latitude        Decimal? @db.Decimal(10, 8)
  longitude       Decimal? @db.Decimal(11, 8)
  isActive        Boolean  @default(true)
  controllerOrgId Int?     @unique // Optional: org designated as country controller (chapter)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  controllerOrg         Organization?          @relation("CountryController", fields: [controllerOrgId], references: [id], onDelete: SetNull)
  policies              CountryPolicy[]
  ads                   Ad[]
  userCountryRoles      UserCountryRole[]
  organizations         Organization[]
  states                State[]
  accessInvites         AccessInvite[]
  medicineImportBatches MedicineImportBatch[]
  countryMedicineBrands CountryMedicineBrand[]

  @@index([controllerOrgId])
  @@map("countries")
}

// Phase 5: State/Province layer (override system)
model State {
  id        Int      @id @default(autoincrement())
  countryId Int
  code      String
  name      String
  latitude  Decimal? @db.Decimal(10, 8)
  longitude Decimal? @db.Decimal(11, 8)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  country        Country         @relation(fields: [countryId], references: [id], onDelete: Cascade)
  policies       StatePolicy[]
  userStateRoles UserStateRole[]
  accessInvites  AccessInvite[]
  locationCities LocationCity[]

  @@unique([countryId, code])
  @@index([countryId])
  @@map("states")
}

// Global location hierarchy: state -> city (district) -> sub-district (upazila/area)
// Reference: docs/location/world/GLOBAL_LOCATION_SYSTEM.md
model LocationCity {
  id        Int      @id @default(autoincrement())
  stateId   Int
  name      String
  code      String? // optional admin code
  latitude  Decimal? @db.Decimal(10, 8)
  longitude Decimal? @db.Decimal(11, 8)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  state        State                 @relation(fields: [stateId], references: [id], onDelete: Cascade)
  subDistricts LocationSubDistrict[]

  @@unique([stateId, name])
  @@index([stateId])
  @@map("location_cities")
}

model LocationSubDistrict {
  id        Int      @id @default(autoincrement())
  cityId    Int
  name      String
  latitude  Decimal? @db.Decimal(10, 8)
  longitude Decimal? @db.Decimal(11, 8)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  city LocationCity @relation(fields: [cityId], references: [id], onDelete: Cascade)

  @@unique([cityId, name])
  @@index([cityId])
  @@map("location_sub_districts")
}

model CountryPolicy {
  id            Int       @id @default(autoincrement())
  countryId     Int
  name          String // e.g. "Bangladesh Default Policy"
  status        String // DRAFT | ACTIVE | ARCHIVED
  effectiveFrom DateTime  @default(now())
  effectiveTo   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  country        Country               @relation(fields: [countryId], references: [id], onDelete: Cascade)
  features       PolicyFeature[]
  donationRules  PolicyDonationRule[]
  paymentMethods PolicyPaymentMethod[]
  adsRules       PolicyAdsRule[]
  rules          PolicyRule[]

  @@index([countryId, status])
  @@map("country_policies")
}

model PolicyFeature {
  id              Int      @id @default(autoincrement())
  countryPolicyId Int
  featureCode     String // DONATION, PRODUCTS, ADS, etc.
  enabled         Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  countryPolicy CountryPolicy @relation(fields: [countryPolicyId], references: [id], onDelete: Cascade)

  @@unique([countryPolicyId, featureCode])
  @@index([countryPolicyId])
  @@map("policy_features")
}

model PolicyDonationRule {
  id              Int      @id @default(autoincrement())
  countryPolicyId Int
  ruleType        String // INBOUND, OUTBOUND
  maxAmountSingle Decimal? @db.Decimal(18, 2)
  maxAmountDaily  Decimal? @db.Decimal(18, 2)
  enabled         Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  countryPolicy CountryPolicy @relation(fields: [countryPolicyId], references: [id], onDelete: Cascade)

  @@index([countryPolicyId])
  @@map("policy_donation_rules")
}

// Phase 3: Policy-driven payment methods per country
model PolicyPaymentMethod {
  id              Int      @id @default(autoincrement())
  countryPolicyId Int
  providerCode    String // e.g. BKASH, NAGAD, STRIPE
  enabled         Boolean  @default(false)
  configJson      Json? // provider-specific config (keys, webhook URL, etc.)
  sortOrder       Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  countryPolicy CountryPolicy @relation(fields: [countryPolicyId], references: [id], onDelete: Cascade)

  @@unique([countryPolicyId, providerCode])
  @@index([countryPolicyId])
  @@map("policy_payment_methods")
}

// Phase 4: Ads policy rules (e.g. max daily spend, require KYC per country)
model PolicyAdsRule {
  id              Int      @id @default(autoincrement())
  countryPolicyId Int
  ruleType        String // MAX_DAILY_SPEND, REQUIRE_KYC, etc.
  valueJson       Json? // e.g. {"maxAmount": 10000}
  enabled         Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  countryPolicy CountryPolicy @relation(fields: [countryPolicyId], references: [id], onDelete: Cascade)

  @@index([countryPolicyId])
  @@map("policy_ads_rules")
}

// Phase 4: Generic policy rules (key/value)
model PolicyRule {
  id              Int      @id @default(autoincrement())
  countryPolicyId Int
  ruleKey         String
  valueJson       Json?
  enabled         Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  countryPolicy CountryPolicy @relation(fields: [countryPolicyId], references: [id], onDelete: Cascade)

  @@unique([countryPolicyId, ruleKey])
  @@index([countryPolicyId])
  @@map("policy_rules")
}

// Phase 5: State policy override
model StatePolicy {
  id            Int       @id @default(autoincrement())
  stateId       Int
  name          String
  status        String // DRAFT | ACTIVE | ARCHIVED
  effectiveFrom DateTime  @default(now())
  effectiveTo   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  state    State                @relation(fields: [stateId], references: [id], onDelete: Cascade)
  features StatePolicyFeature[]
  rules    StatePolicyRule[]

  @@index([stateId, status])
  @@map("state_policies")
}

model StatePolicyFeature {
  id            Int      @id @default(autoincrement())
  statePolicyId Int
  featureCode   String
  enabled       Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  statePolicy StatePolicy @relation(fields: [statePolicyId], references: [id], onDelete: Cascade)

  @@unique([statePolicyId, featureCode])
  @@index([statePolicyId])
  @@map("state_policy_features")
}

model StatePolicyRule {
  id            Int      @id @default(autoincrement())
  statePolicyId Int
  ruleKey       String
  valueJson     Json?
  enabled       Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  statePolicy StatePolicy @relation(fields: [statePolicyId], references: [id], onDelete: Cascade)

  @@unique([statePolicyId, ruleKey])
  @@index([statePolicyId])
  @@map("state_policy_rules")
}

// Phase 4: Ads model (country targeting)
model Ad {
  id                 Int       @id @default(autoincrement())
  countryId          Int
  title              String
  body               String?   @db.Text
  mediaId            Int?
  linkUrl            String?   @db.VarChar(512)
  status             String    @default("DRAFT") // DRAFT | ACTIVE | PAUSED
  startAt            DateTime?
  endAt              DateTime?
  targetCountryCodes String?   @db.VarChar(255) // comma-separated e.g. BD,IN or null = primary country only
  sortOrder          Int       @default(0)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  country Country @relation(fields: [countryId], references: [id], onDelete: Cascade)
  media   Media?  @relation(fields: [mediaId], references: [id], onDelete: SetNull)

  @@index([countryId, status])
  @@index([status, startAt, endAt])
  @@map("ads")
}

model Flavor {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  variants ProductVariant[]

  @@map("flavors")
}

model Unit {
  id        Int      @id @default(autoincrement())
  code      String   @unique
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  variants ProductVariant[]

  @@index([code])
  @@map("units")
}

model ProductMedia {
  id        Int      @id @default(autoincrement())
  productId Int
  mediaId   Int
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  media   Media   @relation(fields: [mediaId], references: [id], onDelete: Cascade)

  @@index([productId, sortOrder])
  @@map("product_media")
}

// ============================
// MASTER PRODUCT CATALOG
// ============================
// Global catalog of pet food products that shop owners can browse and clone
model MasterProductCatalog {
  id   Int    @id @default(autoincrement())
  name String
  slug String @unique

  // Core relations
  companyId  Int?
  company    Company?  @relation(fields: [companyId], references: [id], onDelete: SetNull)
  brandId    Int?
  brand      Brand?    @relation(fields: [brandId], references: [id], onDelete: SetNull)
  categoryId Int?
  category   Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  // Identifiers
  barcode String? @unique // Acts as global SKU / barcode for the product

  // Product titles & descriptions
  shortName        String?
  shortDescription String?
  description      String? @db.Text

  // Rich structured description fields
  bulletPoints        Json? // JSON array of key bullet points
  usageInstructions   String? @db.Text
  storageInstructions String? @db.Text
  safetyWarning       String? @db.Text
  countryOfOrigin     String?

  // SEO (optional)
  metaTitle       String?
  metaDescription String?

  // Variants information (stored as JSON array)
  // Shape: [{ title, unit, flavor, packSize, packUnit, barcode, mrp, attributes }]
  variantsJson Json?

  // Normalized variants (per size/flavour/pack) for richer querying
  variants MasterProductVariant[]

  // Suggested pricing (optional)
  suggestedPrice Decimal? @db.Decimal(10, 2)
  currency       String   @default("BDT")

  // Media (reusable, points to global Media table)
  primaryMediaId Int?
  primaryMedia   Media? @relation("MasterProductPrimaryMedia", fields: [primaryMediaId], references: [id], onDelete: SetNull)

  // Legacy / fallback image URL (e.g. direct manufacturer URL)
  imageUrl String?

  // Additional structured fields (e.g. nutrition, composition)
  metaJson Json? // Additional metadata (ingredients, nutritional info, etc.)

  // Status
  isActive   Boolean @default(true)
  isVerified Boolean @default(false) // Admin verified products

  // Source tracking
  sourceType String? // "SEED", "CSV", "API", "MANUAL"
  sourceRef  String? // Reference to source

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  clonedProducts Product[]            @relation("MasterProductCloned")
  galleryMedia   MasterProductMedia[]

  @@index([companyId])
  @@index([brandId])
  @@index([categoryId])
  @@index([isActive, isVerified])
  @@index([slug])
  @@index([barcode])
  @@map("master_product_catalog")
}

// Normalized variants for MasterProductCatalog.
// This complements variantsJson and will gradually become the primary source.
model MasterProductVariant {
  id       Int                  @id @default(autoincrement())
  masterId Int
  master   MasterProductCatalog @relation(fields: [masterId], references: [id], onDelete: Cascade)

  // Identifiers
  variantSku  String? // CSV: variant_sku
  variantName String // e.g. "2kg bag"

  // Pack / size
  packSize Float?
  packUnit String?

  // Attributes
  flavour  String?
  ageGroup String?
  petType  String?

  // Pricing hints from catalog (not shop-specific)
  mrp      Decimal? @db.Decimal(10, 2)
  minPrice Decimal? @db.Decimal(10, 2)
  maxPrice Decimal? @db.Decimal(10, 2)

  // Extra description for this specific variant
  variantDescription String? @db.Text

  // UI / default flags
  isDefault Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([masterId, variantSku])
  @@index([masterId])
  @@map("master_product_variants")
}

model MasterProductMedia {
  id        Int      @id @default(autoincrement())
  masterId  Int
  mediaId   Int
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  master MasterProductCatalog @relation(fields: [masterId], references: [id], onDelete: Cascade)
  media  Media                @relation(fields: [mediaId], references: [id], onDelete: Cascade)

  @@index([masterId, sortOrder])
  @@index([mediaId])
  @@map("master_product_media")
}

model InventoryLocation {
  id          Int                   @id @default(autoincrement())
  branchId    Int
  warehouseId Int?
  zoneId      Int?
  /// Optional pick-face bin (rack/bin hierarchy under WarehouseZone).
  binId       Int?
  type        InventoryLocationType
  name        String
  code        String?
  isActive    Boolean               @default(true)
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt

  branch                  Branch                   @relation(fields: [branchId], references: [id], onDelete: Cascade)
  warehouse               Warehouse?               @relation(fields: [warehouseId], references: [id], onDelete: SetNull)
  zone                    WarehouseZone?           @relation(fields: [zoneId], references: [id], onDelete: SetNull)
  bin                     WarehouseBin?            @relation(fields: [binId], references: [id], onDelete: SetNull)
  variantConfigs          LocationVariantConfig[]
  stockBalances           StockBalance[]
  stockLedgers            StockLedger[]
  locationPrices          LocationPrice[]
  transfersFrom           StockTransfer[]          @relation("TransferFrom")
  transfersTo             StockTransfer[]          @relation("TransferTo")
  dispatchesFrom          StockDispatch[]          @relation("DispatchFrom")
  dispatchesTo            StockDispatch[]          @relation("DispatchTo")
  stockReturnsFrom        StockReturn[]            @relation("StockReturnFrom")
  stockReturnsTo          StockReturn[]            @relation("StockReturnTo")
  returnItems             ReturnItem[]
  stockLotBalances        StockLotBalance[]
  stockAdjustmentRequests StockAdjustmentRequest[]
  stockCountSessions      StockCountSession[]
  ordersFulfilled         Order[]                  @relation("OrderFulfilmentLocation")
  grns                    Grn[]
  catalogEnableRequests   CatalogEnableRequest[]
  vialInstances           VialInstance[]
  expiryWriteOffs         ExpiryWriteOffLog[]
  allocationPlansFrom     AllocationPlan[]       @relation("AllocationPlanFromLocation")
  pickListsFrom           PickList[]             @relation("PickListFromLocation")
  allocationPlanLines     AllocationPlanLine[]
  pickListLines           PickListLine[]
  qcInspectionsAt         QcInspection[]           @relation("QcInspectionReceiveLocation")
  qcQuarantineLocations   QcInspection[]           @relation("QcInspectionQuarantineLocation")
  writeOffRequests        WriteOffRequest[]
  vendorReturns           VendorReturn[]
  wtoFrom                 WarehouseTransferOrder[] @relation("WTOFromLocation")
  wtoTo                   WarehouseTransferOrder[] @relation("WTOToLocation")
  aiReplenishmentSuggestions AiReplenishmentSuggestion[]
  putawayTasksFrom        PutawayTask[]            @relation("PutawayFromLocation")
  putawayTasksTo          PutawayTask[]            @relation("PutawayToLocation")
  networkTransferRecoFrom NetworkTransferRecommendation[] @relation("NetRecoFrom")
  networkTransferRecoTo   NetworkTransferRecommendation[] @relation("NetRecoTo")
  costFacts               CostFact[]

  @@index([type])
  @@index([branchId])
  @@index([warehouseId])
  @@index([warehouseId, isActive])
  @@index([branchId, warehouseId])
  @@index([zoneId])
  @@index([binId])
  @@index([isActive])
  @@map("inventory_locations")
}

model LocationVariantConfig {
  locationId   Int
  variantId    Int
  channel      LocationChannel
  isEnabled    Boolean         @default(true)
  minStock     Int? // Minimum stock level (reorder alert trigger)
  maxStock     Int? // Maximum stock level (overstock alert)
  reorderPoint Int? // Reorder point (can differ from minStock for lead time)
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  location InventoryLocation @relation(fields: [locationId], references: [id], onDelete: Cascade)
  variant  ProductVariant    @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@id([locationId, variantId])
  @@index([variantId])
  @@map("location_variant_configs")
}

model LocationPrice {
  locationId    Int
  variantId     Int
  price         Decimal   @db.Decimal(10, 2)
  effectiveFrom DateTime  @default(now())
  effectiveTo   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  location InventoryLocation @relation(fields: [locationId], references: [id], onDelete: Cascade)
  variant  ProductVariant    @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@id([locationId, variantId])
  @@index([variantId])
  @@index([effectiveFrom, effectiveTo])
  @@map("location_prices")
}

/// Org-level catalog pricing (base + optional markup bounds). Used with pricing engine before LocationPrice.
model ProductPricing {
  id              Int       @id @default(autoincrement())
  orgId           Int
  variantId       Int
  basePrice       Decimal?  @db.Decimal(12, 2)
  markupPercent   Decimal?  @db.Decimal(8, 4)
  minPrice        Decimal?  @db.Decimal(12, 2)
  maxPrice        Decimal?  @db.Decimal(12, 2)
  effectiveFrom   DateTime  @default(now())
  effectiveTo     DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  org     Organization   @relation(fields: [orgId], references: [id], onDelete: Cascade)
  variant ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@unique([orgId, variantId])
  @@index([orgId])
  @@index([variantId])
  @@map("product_pricings")
}

/// Branch-level selling price override (optional). Takes precedence over ProductPricing-derived and LocationPrice when effective.
model BranchPricing {
  id             Int       @id @default(autoincrement())
  branchId       Int
  variantId      Int
  overridePrice  Decimal   @db.Decimal(12, 2)
  effectiveFrom  DateTime  @default(now())
  effectiveTo    DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  branch  Branch         @relation(fields: [branchId], references: [id], onDelete: Cascade)
  variant ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@unique([branchId, variantId])
  @@index([branchId])
  @@index([variantId])
  @@map("branch_pricings")
}

/// Org-level switches for pricing governance (central vs branch bounds, retail approval).
model OrgPricingPolicy {
  orgId                                  Int      @id
  enforceBranchOverrideWithinCentralBand Boolean  @default(true)
  retailDiscountApprovalEnabled          Boolean  @default(true)
  /// When true, POS commits enforce floor, retail rules, and approval linkage (server-side).
  posPricingGovernanceEnabled            Boolean  @default(false)
  createdAt                              DateTime @default(now())
  updatedAt                              DateTime @updatedAt

  org Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@map("org_pricing_policies")
}

enum PricingAuditEntityType {
  PRODUCT_PRICING
  BRANCH_PRICING
  LOCATION_PRICE
  RETAIL_DISCOUNT_RULE
  ORG_PRICING_POLICY
}

model PricingAuditLog {
  id            Int                    @id @default(autoincrement())
  orgId         Int
  entityType    PricingAuditEntityType
  entityKey     String                 @db.VarChar(128)
  actorUserId   Int?
  action        String                 @db.VarChar(64)
  payloadBefore Json?
  payloadAfter  Json?
  createdAt     DateTime               @default(now())

  org   Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  actor User?        @relation("PricingAuditActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([orgId, createdAt])
  @@map("pricing_audit_logs")
}

/// Retail (inventory selling) discount caps per variant; optional branch scope.
model RetailDiscountRule {
  id                           Int       @id @default(autoincrement())
  orgId                        Int
  branchId                     Int?
  variantId                    Int
  maxDiscountPercent           Decimal?  @db.Decimal(5, 2)
  maxDiscountAmount            Decimal?  @db.Decimal(12, 2)
  requiresApprovalAbovePercent Decimal?  @db.Decimal(5, 2)
  status                       String    @default("ACTIVE") @db.VarChar(16)
  validFrom                    DateTime? @db.Date
  validTo                      DateTime? @db.Date
  createdAt                    DateTime  @default(now())
  updatedAt                    DateTime  @updatedAt

  org     Organization   @relation(fields: [orgId], references: [id], onDelete: Cascade)
  branch  Branch?        @relation(fields: [branchId], references: [id], onDelete: Cascade)
  variant ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@index([orgId, variantId])
  @@index([branchId])
  @@map("retail_discount_rules")
}

enum RetailDiscountApprovalStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

model RetailDiscountApprovalRequest {
  id                         Int                          @id @default(autoincrement())
  orgId                      Int
  branchId                   Int
  variantId                  Int
  listPriceSnapshot          Decimal                      @db.Decimal(12, 2)
  requestedUnitPrice         Decimal                      @db.Decimal(12, 2)
  requestedDiscountPercent   Decimal?                     @db.Decimal(5, 2)
  reason                     String?                      @db.Text
  status                     RetailDiscountApprovalStatus @default(PENDING)
  requestedByUserId          Int
  reviewedByUserId           Int?
  reviewedAt                 DateTime?
  reviewNote                 String?                      @db.Text
  consumedOrderId            Int?
  consumedAt                 DateTime?
  createdAt                  DateTime                     @default(now())
  updatedAt                  DateTime                     @updatedAt

  org         Organization   @relation(fields: [orgId], references: [id], onDelete: Cascade)
  branch      Branch         @relation(fields: [branchId], references: [id], onDelete: Cascade)
  variant     ProductVariant @relation(fields: [variantId], references: [id], onDelete: Restrict)
  requestedBy User           @relation("RetailDiscountRequester", fields: [requestedByUserId], references: [id], onDelete: Restrict)
  reviewedBy  User?          @relation("RetailDiscountReviewer", fields: [reviewedByUserId], references: [id], onDelete: SetNull)
  consumedOrder Order?       @relation("RetailDiscountConsumedOrder", fields: [consumedOrderId], references: [id], onDelete: SetNull)
  orderItems    OrderItem[]

  @@index([orgId, status])
  @@index([branchId, status])
  @@index([consumedOrderId])
  @@map("retail_discount_approval_requests")
}

model StockBalance {
  locationId  Int
  variantId   Int
  onHandQty   Int      @default(0)
  reservedQty Int      @default(0)
  updatedAt   DateTime @updatedAt

  location InventoryLocation @relation(fields: [locationId], references: [id], onDelete: Cascade)
  variant  ProductVariant    @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@id([locationId, variantId])
  @@index([variantId])
  @@map("stock_balances")
}

/// Immutable stock movements (receive, transfer, sale, adjustment, expiry, etc.). One row = one movement line.
model StockLedger {
  id              Int             @id @default(autoincrement())
  orgId           Int? // Tenant isolation; backfilled from location.branch
  locationId      Int
  variantId       Int
  lotId           Int? // Batch/lot reference for batch-wise stock
  type            StockLedgerType
  quantityDelta   Int // Positive for IN, negative for OUT
  unitCost        Decimal?        @db.Decimal(12, 4) // Optional for reporting
  refType         String? // ORDER, TRANSFER, RETURN, DISPATCH, GRN, etc.
  refId           String?
  createdByUserId Int?
  createdAt       DateTime        @default(now())

  org               Organization?      @relation(fields: [orgId], references: [id], onDelete: SetNull)
  location          InventoryLocation  @relation(fields: [locationId], references: [id], onDelete: Cascade)
  variant           ProductVariant     @relation(fields: [variantId], references: [id], onDelete: Cascade)
  lot               StockLot?          @relation(fields: [lotId], references: [id], onDelete: SetNull)
  createdBy         User?              @relation("StockLedgerCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  expiryWriteOffLog ExpiryWriteOffLog?
  writeOffLines     WriteOffRequestLine[]
  vendorReturnLines VendorReturnLine[]    @relation("VendorReturnLedger")
  wtoOutboundLines  WarehouseTransferOrderLine[] @relation("WTOOutboundLedger")
  wtoInboundLines   WarehouseTransferOrderLine[] @relation("WTOInboundLedger")

  @@index([orgId])
  @@index([orgId, locationId, createdAt])
  @@index([orgId, variantId, createdAt])
  @@index([locationId, variantId, createdAt])
  @@index([lotId])
  @@index([orgId, lotId])
  @@index([refType, refId])
  @@index([type, createdAt])
  @@map("stock_ledgers")
}

model StockTransfer {
  id              Int                 @id @default(autoincrement())
  fromLocationId  Int
  toLocationId    Int
  status          StockTransferStatus @default(DRAFT)
  stockRequestId  Int? // Optional link to Stock Request (multi-wave dispatch enabled)
  createdByUserId Int?
  sentAt          DateTime?
  receivedAt      DateTime?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  fromLocation         InventoryLocation     @relation("TransferFrom", fields: [fromLocationId], references: [id], onDelete: Restrict)
  toLocation           InventoryLocation     @relation("TransferTo", fields: [toLocationId], references: [id], onDelete: Restrict)
  stockRequest         StockRequest?         @relation(fields: [stockRequestId], references: [id], onDelete: SetNull)
  createdBy            User?                 @relation("StockTransferCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  items                StockTransferItem[]
  discrepancies        StockDiscrepancy[]
  medicineRequisitions MedicineRequisition[]
  putawayTask          PutawayTask?

  @@index([fromLocationId])
  @@index([toLocationId])
  @@index([status])
  @@index([stockRequestId])
  @@index([stockRequestId, status])
  @@index([stockRequestId, status, createdAt])
  @@map("stock_transfers")
}

model StockTransferItem {
  id                  Int      @id @default(autoincrement())
  transferId          Int
  variantId           Int
  lotId               Int? // Batch/lot for this line
  /// When created from a stock request wave, links the physical line to the request line.
  stockRequestItemId  Int?
  quantitySent        Int
  quantityReceived    Int      @default(0)
  quantityDamaged     Int      @default(0)
  quantityExpired     Int      @default(0)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  transfer         StockTransfer     @relation(fields: [transferId], references: [id], onDelete: Cascade)
  variant          ProductVariant    @relation(fields: [variantId], references: [id], onDelete: Restrict)
  lot              StockLot?         @relation(fields: [lotId], references: [id], onDelete: SetNull)
  stockRequestItem StockRequestItem? @relation(fields: [stockRequestItemId], references: [id], onDelete: SetNull)

  @@index([transferId])
  @@index([variantId])
  @@index([lotId])
  @@index([stockRequestItemId])
  @@map("stock_transfer_items")
}

// === Stock Dispatch (Challan/DO) – from fulfill plan; transport + status CREATED→PACKED→IN_TRANSIT→DELIVERED ===
model StockDispatch {
  id              Int                 @id @default(autoincrement())
  orgId           Int
  stockRequestId  Int?
  fromLocationId  Int
  toLocationId    Int
  status          StockDispatchStatus @default(CREATED)
  // Transport
  carrierType     String?             @db.VarChar(50) // own | courier
  vehicleNo       String?             @db.VarChar(100)
  driverName      String?             @db.VarChar(200)
  driverPhone     String?             @db.VarChar(50)
  trackingId      String?             @db.VarChar(200)
  eta             DateTime?
  shippingCost    Decimal?            @db.Decimal(12, 2)
  note            String?             @db.Text
  packedAt        DateTime?
  inTransitAt     DateTime?
  deliveredAt     DateTime?
  createdByUserId Int?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  org                  Organization          @relation(fields: [orgId], references: [id], onDelete: Cascade)
  stockRequest         StockRequest?         @relation(fields: [stockRequestId], references: [id], onDelete: Cascade)
  fromLocation         InventoryLocation     @relation("DispatchFrom", fields: [fromLocationId], references: [id], onDelete: Restrict)
  toLocation           InventoryLocation     @relation("DispatchTo", fields: [toLocationId], references: [id], onDelete: Restrict)
  createdBy            User?                 @relation("StockDispatchCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  items                StockDispatchItem[]
  grns                 Grn[]
  medicineRequisitions MedicineRequisition[]
  deliveryAssignments  DeliveryAssignment[]
  pickList             PickList?
  proofOfDelivery      ProofOfDelivery?
  dispatchDiscrepancies StockDispatchDiscrepancy[]
  dispatchReceiveSession DispatchReceiveSession?

  @@index([orgId])
  @@index([stockRequestId])
  @@index([fromLocationId])
  @@index([toLocationId])
  @@index([status])
  @@index([createdAt])
  @@map("stock_dispatches")
}

model DispatchReceiveSession {
  id                 Int                         @id @default(autoincrement())
  orgId              Int
  stockDispatchId    Int                         @unique
  status             DispatchReceiveSessionStatus @default(DRAFT)
  verifiedAt         DateTime?
  verifiedByUserId   Int?
  submittedAt        DateTime?
  submittedByUserId  Int?
  confirmedAt        DateTime?
  confirmedByUserId  Int?
  notes              String?                     @db.Text
  idempotencyKey     String?                     @db.VarChar(64)
  createdAt          DateTime                    @default(now())
  updatedAt          DateTime                    @updatedAt

  org           Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  stockDispatch StockDispatch @relation(fields: [stockDispatchId], references: [id], onDelete: Cascade)
  verifiedBy    User?         @relation("DispatchReceiveSessionVerifiedBy", fields: [verifiedByUserId], references: [id], onDelete: SetNull)
  submittedBy   User?         @relation("DispatchReceiveSessionSubmittedBy", fields: [submittedByUserId], references: [id], onDelete: SetNull)
  confirmedBy   User?         @relation("DispatchReceiveSessionConfirmedBy", fields: [confirmedByUserId], references: [id], onDelete: SetNull)
  lines         DispatchReceiveSessionLine[]

  @@index([orgId])
  @@index([status])
  @@map("dispatch_receive_sessions")
}

model DispatchReceiveSessionLine {
  id                  Int @id @default(autoincrement())
  sessionId           Int
  stockDispatchItemId Int
  quantityReceived    Int @default(0)
  quantityDamaged     Int @default(0)
  quantityShort       Int @default(0)
  reasonCode          String? @db.VarChar(64)
  lineNote            String? @db.Text

  session           DispatchReceiveSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  stockDispatchItem StockDispatchItem      @relation(fields: [stockDispatchItemId], references: [id], onDelete: Cascade)

  @@unique([sessionId, stockDispatchItemId])
  @@index([stockDispatchItemId])
  @@map("dispatch_receive_session_lines")
}

/// Branch/ops reported mismatch on a dispatch (receive/short/damage) — complements transfer-scoped StockDiscrepancy.
model StockDispatchDiscrepancy {
  id               Int                    @id @default(autoincrement())
  orgId            Int
  stockDispatchId  Int
  variantId        Int
  lotId            Int?
  reasonCode       String                 @db.VarChar(64)
  quantity         Int
  notes            String?                @db.Text
  status           StockDiscrepancyStatus @default(PENDING)
  resolvedByUserId Int?
  resolvedAt       DateTime?
  resolutionNote   String?                @db.Text
  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @updatedAt

  org           Organization   @relation(fields: [orgId], references: [id], onDelete: Cascade)
  stockDispatch StockDispatch  @relation(fields: [stockDispatchId], references: [id], onDelete: Cascade)
  variant       ProductVariant @relation(fields: [variantId], references: [id], onDelete: Restrict)
  lot           StockLot?      @relation(fields: [lotId], references: [id], onDelete: SetNull)
  resolvedBy    User?          @relation("StockDispatchDiscrepancyResolvedBy", fields: [resolvedByUserId], references: [id], onDelete: SetNull)

  @@index([orgId])
  @@index([stockDispatchId])
  @@index([status])
  @@map("stock_dispatch_discrepancies")
}

model StockDispatchItem {
  id                 Int      @id @default(autoincrement())
  stockDispatchId    Int
  variantId          Int
  lotId              Int
  quantityDispatched Int
  quantityReceived   Int      @default(0)
  quantityDamaged    Int      @default(0)
  quantityShort      Int      @default(0)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  stockDispatch StockDispatch  @relation(fields: [stockDispatchId], references: [id], onDelete: Cascade)
  variant       ProductVariant @relation(fields: [variantId], references: [id], onDelete: Restrict)
  lot           StockLot       @relation(fields: [lotId], references: [id], onDelete: Restrict)
  dispatchReceiveSessionLines DispatchReceiveSessionLine[]

  @@index([stockDispatchId])
  @@index([variantId])
  @@index([lotId])
  @@map("stock_dispatch_items")
}

// === Stock Request (branch requests stock; owner fulfills → dispatch) ===
model StockRequest {
  id              Int                @id @default(autoincrement())
  orgId           Int
  branchId        Int
  requesterUserId Int
  status          StockRequestStatus @default(DRAFT)
  submittedAt     DateTime?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  // Owner decline (auditable)
  declinedAt       DateTime?
  declineReason    String?   @db.Text
  declineSource    String?   @db.VarChar(100)
  declinedByUserId Int?

  // Owner approve (partial qty + extra items): [{ variantId, approvedQty }], [{ variantId, quantity }]
  approvedItems    Json?
  extraItems       Json?
  approvedAt       DateTime?
  approvedByUserId Int?

  // Procurement routing: warehouse demand vs branch transfer
  requestIntent        StockRequestIntent @default(INTERNAL_TRANSFER)
  linkedPurchaseOrderId Int?
  procurementNote      String?  @db.Text
  preferredVendorId    Int?
  urgency              String?  @db.VarChar(20)

  org        Organization       @relation(fields: [orgId], references: [id], onDelete: Cascade)
  branch     Branch             @relation(fields: [branchId], references: [id], onDelete: Cascade)
  requester  User               @relation("StockRequestRequestedBy", fields: [requesterUserId], references: [id], onDelete: Restrict)
  declinedBy User?              @relation("StockRequestDeclinedBy", fields: [declinedByUserId], references: [id], onDelete: SetNull)
  approvedBy User?              @relation("StockRequestApprovedBy", fields: [approvedByUserId], references: [id], onDelete: SetNull)
  linkedPurchaseOrder PurchaseOrder? @relation("StockRequestLinkedPO", fields: [linkedPurchaseOrderId], references: [id], onDelete: SetNull)
  preferredVendor     Vendor?        @relation("StockRequestPreferredVendor", fields: [preferredVendorId], references: [id], onDelete: SetNull)
  items          StockRequestItem[]
  transfers      StockTransfer[] // Multi-wave dispatch: multiple transfers per request
  dispatches     StockDispatch[]
  allocationPlan AllocationPlan?
  aiReplenishmentSuggestions AiReplenishmentSuggestion[]

  @@index([orgId])
  @@index([branchId])
  @@index([status])
  @@index([requesterUserId])
  @@index([requestIntent])
  @@index([linkedPurchaseOrderId])
  @@map("stock_requests")
}

model StockRequestItem {
  id                Int                      @id @default(autoincrement())
  stockRequestId    Int
  productId         Int
  variantId         Int
  requestedQty      Int
  fulfilledQty      Int                      @default(0)
  cancelledQty      Int                      @default(0)
  lineKind          StockRequestItemLineKind @default(REQUESTED)
  note              String?                  @db.VarChar(500)
  cancelReason      String?                  @db.VarChar(500)
  cancelledAt       DateTime?
  cancelledByUserId Int?
  createdAt         DateTime                 @default(now())
  updatedAt         DateTime                 @updatedAt

  stockRequest  StockRequest   @relation(fields: [stockRequestId], references: [id], onDelete: Cascade)
  product       Product        @relation(fields: [productId], references: [id], onDelete: Restrict)
  variant       ProductVariant @relation(fields: [variantId], references: [id], onDelete: Restrict)
  cancelledBy           User?               @relation("StockRequestItemCancelledBy", fields: [cancelledByUserId], references: [id], onDelete: SetNull)
  stockTransferItems    StockTransferItem[]

  @@index([stockRequestId])
  @@index([productId])
  @@index([variantId])
  @@index([cancelledByUserId])
  @@map("stock_request_items")
}

// === AI Intelligence Phase 4 (forecast / replenishment / procurement / control tower) ===
enum AiReplenishmentSuggestionStatus {
  OPEN
  ACCEPTED
  DISMISSED
}

enum AiJobRunStatus {
  RUNNING
  SUCCESS
  FAILED
}

enum AiOverrideScope {
  VARIANT
  BRANCH
  ORG
}

/// BRANCH = all active locations for the branch; WAREHOUSE = locations tied to scopeWarehouseId only (scopeWarehouseId 0 with BRANCH = whole branch).
enum AiPlanningScope {
  BRANCH
  WAREHOUSE
}

model AiForecastSnapshot {
  id               Int             @id @default(autoincrement())
  orgId            Int
  branchId         Int
  variantId        Int
  horizonDays      Int
  windowDays       Int             @default(90)
  forecastUnits    Decimal         @db.Decimal(14, 4)
  avgDailyDemand   Decimal         @db.Decimal(14, 6)
  method           String          @db.VarChar(64)
  confidence       Float
  inputsJson       Json
  factorsJson      Json            @default("[]")
  computedAt       DateTime        @default(now())
  planningScope    AiPlanningScope @default(BRANCH)
  /// When planningScope is WAREHOUSE, matches Warehouse.id; 0 when BRANCH scope.
  scopeWarehouseId   Int             @default(0)

  org     Organization   @relation(fields: [orgId], references: [id], onDelete: Cascade)
  branch  Branch         @relation(fields: [branchId], references: [id], onDelete: Cascade)
  variant ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@unique([orgId, branchId, variantId, horizonDays, planningScope, scopeWarehouseId])
  @@index([orgId, branchId, planningScope, scopeWarehouseId, computedAt])
  @@index([variantId])
  @@map("ai_forecast_snapshots")
}

model AiReplenishmentSuggestion {
  id               Int                           @id @default(autoincrement())
  orgId            Int
  branchId         Int
  locationId       Int?
  variantId        Int
  productId        Int
  suggestedQty     Int
  onHand           Int
  rop              Int
  orderUpTo        Int?
  reasonCodes      Json                          @default("[]")
  severity         String?                       @db.VarChar(24)
  status           AiReplenishmentSuggestionStatus @default(OPEN)
  stockRequestId   Int?
  suggestionHash   String                        @db.VarChar(64)
  dayBucket        DateTime
  metaJson         Json?
  createdAt        DateTime                      @default(now())
  updatedAt        DateTime                      @updatedAt

  org          Organization    @relation(fields: [orgId], references: [id], onDelete: Cascade)
  branch       Branch          @relation(fields: [branchId], references: [id], onDelete: Cascade)
  location     InventoryLocation? @relation(fields: [locationId], references: [id], onDelete: SetNull)
  variant      ProductVariant  @relation(fields: [variantId], references: [id], onDelete: Cascade)
  product      Product         @relation(fields: [productId], references: [id], onDelete: Restrict)
  stockRequest StockRequest?   @relation(fields: [stockRequestId], references: [id], onDelete: SetNull)

  @@unique([orgId, branchId, variantId, dayBucket])
  @@index([orgId, branchId, status])
  @@index([suggestionHash])
  @@map("ai_replenishment_suggestions")
}

model AiProcurementRecommendation {
  id                 Int      @id @default(autoincrement())
  orgId              Int
  branchId           Int
  variantId          Int
  rankedVendorsJson  Json
  scoresJson         Json
  weightsJson        Json     @default("{}")
  computedAt         DateTime @default(now())

  org     Organization   @relation(fields: [orgId], references: [id], onDelete: Cascade)
  branch  Branch         @relation(fields: [branchId], references: [id], onDelete: Cascade)
  variant ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@unique([orgId, branchId, variantId])
  @@index([orgId, computedAt])
  @@map("ai_procurement_recommendations")
}

model AiJobRun {
  id         Int           @id @default(autoincrement())
  jobType    String        @db.VarChar(64)
  startedAt  DateTime      @default(now())
  finishedAt DateTime?
  status     AiJobRunStatus @default(RUNNING)
  statsJson  Json?
  error      String?       @db.Text

  @@index([jobType, startedAt])
  @@map("ai_job_runs")
}

model AiRecommendationOverride {
  id              Int             @id @default(autoincrement())
  orgId           Int
  branchId      Int?
  userId        Int?
  variantId     Int?
  scope         AiOverrideScope @default(VARIANT)
  leadTimeDays  Int?
  safetyDays    Int?
  dismissedUntil DateTime?
  notes         String?         @db.VarChar(500)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  org     Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  branch  Branch?      @relation(fields: [branchId], references: [id], onDelete: Cascade)
  user    User?        @relation(fields: [userId], references: [id], onDelete: SetNull)
  variant ProductVariant? @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@index([orgId, branchId])
  @@index([userId])
  @@map("ai_recommendation_overrides")
}

// === Wave-5: Executive Control Tower, Decision Assist, Scenario Planning ===
enum DecisionPackageStatus {
  PROPOSED
  PENDING_APPROVAL
  APPROVED
  REJECTED
  DEFERRED
  SUPERSEDED
}

enum DecisionPackageItemState {
  OPEN
  APPROVED
  REJECTED
  SUPERSEDED
}

enum DecisionApprovalEventType {
  SUBMITTED
  APPROVED
  REJECTED
  DEFERRED
  OVERRIDE
  ESCALATED
}

enum ScenarioRunStatus {
  DRAFT
  QUEUED
  RUNNING
  SUCCEEDED
  FAILED
  CANCELLED
}

model DecisionPackage {
  id                    Int                   @id @default(autoincrement())
  orgId                 Int
  status                DecisionPackageStatus @default(PROPOSED)
  priority              Int                   @default(0)
  summary               String?               @db.VarChar(500)
  policyVersion         String                @default("wave5.policy.v1") @db.VarChar(64)
  createdByUserId       Int?
  approvedByUserId      Int?
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt

  org          Organization           @relation(fields: [orgId], references: [id], onDelete: Cascade)
  createdBy    User?                  @relation("DecisionPackageCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  approvedBy   User?                  @relation("DecisionPackageApprovedBy", fields: [approvedByUserId], references: [id], onDelete: SetNull)
  items        DecisionPackageItem[]
  approvalEvents DecisionApprovalEvent[]

  @@index([orgId, status, updatedAt])
  @@map("decision_packages")
}

model DecisionPackageItem {
  id                Int                      @id @default(autoincrement())
  decisionPackageId Int
  actionType        String                   @db.VarChar(64)
  title             String                   @db.VarChar(255)
  score             Float
  rank              Int                      @default(0)
  evidenceJson      Json
  constraintsJson   Json                     @default("[]")
  confidence        Float?
  state             DecisionPackageItemState @default(OPEN)
  targetRefs        Json?

  decisionPackage DecisionPackage @relation(fields: [decisionPackageId], references: [id], onDelete: Cascade)

  @@index([decisionPackageId])
  @@map("decision_package_items")
}

model DecisionApprovalEvent {
  id                Int                     @id @default(autoincrement())
  decisionPackageId Int
  eventType         DecisionApprovalEventType
  actorUserId       Int?
  comment           String?                 @db.Text
  clientRequestId   String?                 @db.VarChar(128)
  payloadJson       Json?

  decisionPackage DecisionPackage @relation(fields: [decisionPackageId], references: [id], onDelete: Cascade)
  actor           User?           @relation("DecisionApprovalActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  @@index([decisionPackageId, createdAt])
  @@index([decisionPackageId, clientRequestId])
  @@map("decision_approval_events")
}

model ScenarioRun {
  id              Int               @id @default(autoincrement())
  orgId           Int
  templateKey     String            @db.VarChar(64)
  parametersJson  Json
  horizonDays     Int               @default(28)
  status          ScenarioRunStatus @default(QUEUED)
  engineVersion   String            @default("wave5.sim.v1") @db.VarChar(64)
  inputsHash      String?           @db.VarChar(128)
  baselineAt      DateTime?
  errorMessage    String?           @db.Text
  createdByUserId Int?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  org       Organization            @relation(fields: [orgId], references: [id], onDelete: Cascade)
  createdBy User?                   @relation("ScenarioRunCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  result    ScenarioResultSnapshot?

  @@index([orgId, status, createdAt])
  @@index([orgId, templateKey, createdAt])
  @@map("scenario_runs")
}

model ScenarioResultSnapshot {
  id            Int      @id @default(autoincrement())
  scenarioRunId Int      @unique
  outputsJson   Json
  driversJson   Json     @default("[]")
  createdAt     DateTime @default(now())

  scenarioRun ScenarioRun @relation(fields: [scenarioRunId], references: [id], onDelete: Cascade)

  @@map("scenario_result_snapshots")
}

// === Batch-wise inventory (StockLot) - separate from authenticity Batch ===
model StockLot {
  id              Int      @id @default(autoincrement())
  orgId           Int
  variantId       Int
  lotCode         String
  mfgDate         DateTime
  expDate         DateTime
  /// Optional supplier / scan barcode captured at GRN receive (searchable).
  supplierBarcode String?  @db.VarChar(128)
  createdByUserId Int?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  org       Organization   @relation(fields: [orgId], references: [id], onDelete: Cascade)
  variant   ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)
  createdBy User?          @relation("StockLotCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)

  stockLedgers            StockLedger[]
  stockLotBalances        StockLotBalance[]
  transferItems           StockTransferItem[]
  stockDispatchItems      StockDispatchItem[]
  stockDiscrepancies      StockDiscrepancy[]
  stockDispatchDiscrepancies StockDispatchDiscrepancy[]
  stockAdjustmentRequests StockAdjustmentRequest[]
  stockReturnItems        StockReturnItem[]
  grnLines                GrnLine[]
  stockCountLines         StockCountLine[]
  vialInstances           VialInstance[]
  vialSessions            VialSession[]
  consumptionItems        ConsumptionItem[]
  recalls                 BatchRecall[]
  expiryWriteOffs         ExpiryWriteOffLog[]
  allocationPlanLines     AllocationPlanLine[]
  pickListLines           PickListLine[]
  qcInspections           QcInspection[]
  writeOffRequestLines    WriteOffRequestLine[]
  vendorReturnLines       VendorReturnLine[]
  warehouseTransferOrderLines WarehouseTransferOrderLine[]
  putawayTasks            PutawayTask[]
  networkTransferRecommendations NetworkTransferRecommendation[]

  @@unique([orgId, variantId, lotCode])
  @@index([orgId])
  @@index([variantId])
  @@index([orgId, variantId])
  @@index([orgId, variantId, expDate])
  @@index([expDate])
  @@map("stock_lots")
}

model StockLotBalance {
  locationId  Int
  lotId       Int
  onHandQty   Int      @default(0)
  reservedQty Int      @default(0)
  updatedAt   DateTime @updatedAt

  location InventoryLocation @relation(fields: [locationId], references: [id], onDelete: Cascade)
  lot      StockLot          @relation(fields: [lotId], references: [id], onDelete: Cascade)

  @@id([locationId, lotId])
  @@index([lotId])
  @@index([locationId])
  @@map("stock_lot_balances")
}

model StockDiscrepancy {
  id               Int                    @id @default(autoincrement())
  transferId       Int
  transferItemId   Int?
  variantId        Int
  lotId            Int?
  expectedQty      Int
  receivedQty      Int
  damagedQty       Int                    @default(0)
  missingQty       Int                    @default(0)
  notes            String?                @db.Text
  evidenceMediaIds Json?
  status           StockDiscrepancyStatus @default(PENDING)
  resolvedByUserId Int?
  resolvedAt       DateTime?
  resolutionNote   String?                @db.Text
  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @updatedAt

  transfer   StockTransfer  @relation(fields: [transferId], references: [id], onDelete: Cascade)
  variant    ProductVariant @relation(fields: [variantId], references: [id], onDelete: Restrict)
  lot        StockLot?      @relation(fields: [lotId], references: [id], onDelete: SetNull)
  resolvedBy User?          @relation("StockDiscrepancyResolvedBy", fields: [resolvedByUserId], references: [id], onDelete: SetNull)

  @@index([transferId])
  @@index([status])
  @@map("stock_discrepancies")
}

model StockAdjustmentRequest {
  id                 Int                   @id @default(autoincrement())
  orgId              Int
  locationId         Int
  variantId          Int
  lotId              Int?
  quantityDelta      Int // positive = add, negative = deduct
  reason             String?               @db.Text
  adjustmentCategory String?               @db.VarChar(32) // DAMAGE | LOSS | CORRECTION → ledger type
  payload            Json?
  status             StockAdjustmentStatus @default(PENDING)
  requestedByUserId  Int
  reviewedByUserId   Int?
  reviewedAt         DateTime?
  reviewNote         String?               @db.Text
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt

  org         Organization      @relation(fields: [orgId], references: [id], onDelete: Cascade)
  location    InventoryLocation @relation(fields: [locationId], references: [id], onDelete: Cascade)
  variant     ProductVariant    @relation(fields: [variantId], references: [id], onDelete: Restrict)
  lot         StockLot?         @relation(fields: [lotId], references: [id], onDelete: SetNull)
  requestedBy User              @relation("StockAdjustmentRequestedBy", fields: [requestedByUserId], references: [id], onDelete: Restrict)
  reviewedBy  User?             @relation("StockAdjustmentReviewedBy", fields: [reviewedByUserId], references: [id], onDelete: SetNull)

  @@index([orgId, status])
  @@index([locationId])
  @@map("stock_adjustment_requests")
}

/// General-purpose write-off request (damage, theft, obsolete, etc.) with approval workflow.
model WriteOffRequest {
  id              Int                   @id @default(autoincrement())
  orgId           Int
  locationId      Int
  reason          WriteOffReason
  status          WriteOffRequestStatus @default(PENDING)
  note            String?               @db.Text
  totalQty        Int                   @default(0)
  totalCost       Decimal?              @db.Decimal(12, 2)
  requestedByUserId Int
  approvedByUserId  Int?
  approvedAt      DateTime?
  rejectedAt      DateTime?
  rejectionNote   String?               @db.Text
  postedAt        DateTime?
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt

  org         Organization      @relation(fields: [orgId], references: [id], onDelete: Cascade)
  location    InventoryLocation @relation(fields: [locationId], references: [id], onDelete: Cascade)
  requestedBy User              @relation("WriteOffRequestedBy", fields: [requestedByUserId], references: [id], onDelete: Restrict)
  approvedBy  User?             @relation("WriteOffApprovedBy", fields: [approvedByUserId], references: [id], onDelete: SetNull)
  lines       WriteOffRequestLine[]

  @@index([orgId, status])
  @@index([locationId])
  @@index([requestedByUserId])
  @@map("write_off_requests")
}

model WriteOffRequestLine {
  id                Int             @id @default(autoincrement())
  writeOffRequestId Int
  variantId         Int
  lotId             Int?
  quantity          Int
  unitCost          Decimal?        @db.Decimal(12, 4)
  note              String?         @db.Text
  ledgerId          Int?             // Linked ledger entry after posting
  createdAt         DateTime        @default(now())

  writeOffRequest WriteOffRequest @relation(fields: [writeOffRequestId], references: [id], onDelete: Cascade)
  variant         ProductVariant @relation(fields: [variantId], references: [id], onDelete: Restrict)
  lot             StockLot?      @relation(fields: [lotId], references: [id], onDelete: SetNull)
  ledger          StockLedger?   @relation(fields: [ledgerId], references: [id], onDelete: SetNull)

  @@index([writeOffRequestId])
  @@index([variantId])
  @@index([lotId])
  @@map("write_off_request_lines")
}

/// Vendor return request - return stock to supplier with credit/replacement tracking
model VendorReturn {
  id                Int                @id @default(autoincrement())
  orgId             Int
  vendorId          Int
  locationId        Int
  status            VendorReturnStatus @default(DRAFT)
  reason            String             @db.VarChar(500)
  note              String?            @db.Text
  creditExpected    Decimal?           @db.Decimal(12, 2)
  creditReceived    Decimal?           @db.Decimal(12, 2)
  referenceNumber   String?            @db.VarChar(100)
  dispatchedAt      DateTime?
  receivedByVendorAt DateTime?
  creditedAt        DateTime?
  createdByUserId   Int
  approvedByUserId  Int?
  approvedAt        DateTime?
  cancelledAt       DateTime?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  org         Organization      @relation(fields: [orgId], references: [id], onDelete: Cascade)
  vendor      Vendor            @relation(fields: [vendorId], references: [id], onDelete: Restrict)
  location    InventoryLocation @relation(fields: [locationId], references: [id], onDelete: Restrict)
  createdBy   User              @relation("VendorReturnCreatedBy", fields: [createdByUserId], references: [id], onDelete: Restrict)
  approvedBy  User?             @relation("VendorReturnApprovedBy", fields: [approvedByUserId], references: [id], onDelete: SetNull)
  lines       VendorReturnLine[]
  stockReturnsLinked StockReturn[] @relation("StockReturnVendorReturn")

  @@index([orgId, status])
  @@index([vendorId])
  @@index([locationId])
  @@map("vendor_returns")
}

model VendorReturnLine {
  id              Int      @id @default(autoincrement())
  vendorReturnId  Int
  variantId       Int
  lotId           Int?
  quantity        Int
  unitCost        Decimal? @db.Decimal(12, 4)
  condition       String   @default("RESELLABLE") @db.VarChar(50)
  note            String?  @db.VarChar(500)
  ledgerId        Int?
  createdAt       DateTime @default(now())

  vendorReturn VendorReturn   @relation(fields: [vendorReturnId], references: [id], onDelete: Cascade)
  variant      ProductVariant @relation(fields: [variantId], references: [id], onDelete: Restrict)
  lot          StockLot?      @relation(fields: [lotId], references: [id], onDelete: SetNull)
  ledger       StockLedger?   @relation("VendorReturnLedger", fields: [ledgerId], references: [id], onDelete: SetNull)

  @@index([vendorReturnId])
  @@index([variantId])
  @@map("vendor_return_lines")
}

/// Inter-warehouse transfer order for warehouse-to-warehouse movements
model WarehouseTransferOrder {
  id                Int                          @id @default(autoincrement())
  orgId             Int
  fromLocationId    Int
  toLocationId      Int
  status            WarehouseTransferOrderStatus @default(DRAFT)
  note              String?                      @db.Text
  createdByUserId   Int
  approvedByUserId  Int?
  approvedAt        DateTime?
  dispatchedAt      DateTime?
  receivedAt        DateTime?
  closedAt          DateTime?
  createdAt         DateTime                     @default(now())
  updatedAt         DateTime                     @updatedAt

  org          Organization      @relation(fields: [orgId], references: [id], onDelete: Cascade)
  fromLocation InventoryLocation @relation("WTOFromLocation", fields: [fromLocationId], references: [id], onDelete: Restrict)
  toLocation   InventoryLocation @relation("WTOToLocation", fields: [toLocationId], references: [id], onDelete: Restrict)
  createdBy    User              @relation("WTOCreatedBy", fields: [createdByUserId], references: [id], onDelete: Restrict)
  approvedBy   User?             @relation("WTOApprovedBy", fields: [approvedByUserId], references: [id], onDelete: SetNull)
  lines        WarehouseTransferOrderLine[]

  @@index([orgId, status])
  @@index([fromLocationId])
  @@index([toLocationId])
  @@map("warehouse_transfer_orders")
}

model WarehouseTransferOrderLine {
  id                       Int      @id @default(autoincrement())
  warehouseTransferOrderId Int
  variantId                Int
  lotId                    Int?
  requestedQty             Int
  pickedQty                Int      @default(0)
  receivedQty              Int      @default(0)
  note                     String?  @db.VarChar(500)
  outboundLedgerId         Int?
  inboundLedgerId          Int?
  createdAt                DateTime @default(now())

  warehouseTransferOrder WarehouseTransferOrder @relation(fields: [warehouseTransferOrderId], references: [id], onDelete: Cascade)
  variant                ProductVariant         @relation(fields: [variantId], references: [id], onDelete: Restrict)
  lot                    StockLot?              @relation(fields: [lotId], references: [id], onDelete: SetNull)
  outboundLedger         StockLedger?           @relation("WTOOutboundLedger", fields: [outboundLedgerId], references: [id], onDelete: SetNull)
  inboundLedger          StockLedger?           @relation("WTOInboundLedger", fields: [inboundLedgerId], references: [id], onDelete: SetNull)

  @@index([warehouseTransferOrderId])
  @@index([variantId])
  @@map("warehouse_transfer_order_lines")
}

model StockCountSession {
  id              Int                     @id @default(autoincrement())
  orgId           Int
  locationId      Int
  status          StockCountSessionStatus @default(DRAFT)
  note            String?                 @db.Text
  createdByUserId Int?
  frozenAt        DateTime?
  postedAt        DateTime?
  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @updatedAt

  org       Organization      @relation(fields: [orgId], references: [id], onDelete: Cascade)
  location  InventoryLocation @relation(fields: [locationId], references: [id], onDelete: Cascade)
  createdBy User?             @relation("StockCountSessionCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  lines     StockCountLine[]

  @@index([orgId])
  @@index([locationId])
  @@index([status])
  @@map("stock_count_sessions")
}

model StockCountLine {
  id          Int      @id @default(autoincrement())
  sessionId   Int
  variantId   Int
  lotId       Int? // optional for lot-level count later; variant-level uses null
  systemQty   Int      @default(0)
  countedQty  Int      @default(0)
  varianceQty Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  session StockCountSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  variant ProductVariant    @relation(fields: [variantId], references: [id], onDelete: Restrict)
  lot     StockLot?         @relation(fields: [lotId], references: [id], onDelete: SetNull)

  @@unique([sessionId, variantId])
  @@index([sessionId])
  @@index([variantId])
  @@map("stock_count_lines")
}

model ReturnRequest {
  id                Int                 @id @default(autoincrement())
  orderId           Int? // Can reference Order or other sale ref
  status            ReturnRequestStatus @default(PENDING)
  requestedByUserId Int?
  approvedByUserId  Int?
  receivedAt        DateTime?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt

  requestedBy   User?          @relation("ReturnRequestedBy", fields: [requestedByUserId], references: [id], onDelete: SetNull)
  approvedBy    User?          @relation("ReturnApprovedBy", fields: [approvedByUserId], references: [id], onDelete: SetNull)
  items         ReturnItem[]
  posCreditNote PosCreditNote?

  @@index([orderId])
  @@index([status])
  @@map("return_requests")
}

model ReturnItem {
  id              Int             @id @default(autoincrement())
  returnRequestId Int
  variantId       Int
  quantity        Int
  condition       ReturnCondition
  locationId      Int? // For restock location
  createdAt       DateTime        @default(now())

  returnRequest ReturnRequest      @relation(fields: [returnRequestId], references: [id], onDelete: Cascade)
  variant       ProductVariant     @relation(fields: [variantId], references: [id], onDelete: Restrict)
  location      InventoryLocation? @relation(fields: [locationId], references: [id], onDelete: SetNull)

  @@index([returnRequestId])
  @@index([variantId])
  @@map("return_items")
}

model PosCreditNote {
  id              Int      @id @default(autoincrement())
  returnRequestId Int      @unique
  orderId         Int
  branchId        Int
  creditNumber    String   @unique
  amount          Decimal  @db.Decimal(12, 2)
  createdAt       DateTime @default(now())

  returnRequest ReturnRequest @relation(fields: [returnRequestId], references: [id], onDelete: Cascade)

  @@index([branchId])
  @@index([orderId])
  @@map("pos_credit_notes")
}

// === POS Retail-Grade: Cash drawer shift ===
enum PosShiftStatus {
  OPEN
  CLOSED
}

model PosShift {
  id                    Int            @id @default(autoincrement())
  branchId              Int
  openedByUserId        Int
  openedAt              DateTime       @default(now())
  closedAt              DateTime?
  status                PosShiftStatus @default(OPEN)
  startingCash          Decimal        @default(0) @db.Decimal(12, 2)
  closingCash           Decimal?       @db.Decimal(12, 2)
  variance              Decimal?       @db.Decimal(12, 2)
  closedByUserId        Int?
  managerOverrideReason String?        @db.Text
  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt

  branch   Branch  @relation(fields: [branchId], references: [id], onDelete: Cascade)
  openedBy User    @relation("PosShiftOpenedBy", fields: [openedByUserId], references: [id], onDelete: Restrict)
  closedBy User?   @relation("PosShiftClosedBy", fields: [closedByUserId], references: [id], onDelete: SetNull)
  orders   Order[]

  @@index([branchId, status])
  @@index([branchId, openedAt])
  @@map("pos_shifts")
}

// === Stock Return (branch → warehouse): damaged, wrong item, near-expiry, overstock ===
enum StockReturnReason {
  DAMAGED
  WRONG_ITEM
  NEAR_EXPIRY
  OVERSTOCK
  OTHER
}

enum StockReturnStatus {
  CREATED
  IN_TRANSIT
  RECEIVED
  CANCELLED
}

model StockReturn {
  id               Int               @id @default(autoincrement())
  orgId            Int
  fromLocationId   Int // branch
  toLocationId     Int // warehouse
  reason           StockReturnReason
  status           StockReturnStatus @default(CREATED)
  note             String?           @db.Text
  /// Wave-3: dispute notes, inspection, linked vendor return id, etc.
  metaJson         Json?
  disposition      StockReturnDisposition @default(PENDING)
  disputedAt       DateTime?
  linkedVendorReturnId Int?
  createdByUserId  Int?
  receivedAt       DateTime?
  receivedByUserId Int?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  org          Organization      @relation(fields: [orgId], references: [id], onDelete: Cascade)
  fromLocation InventoryLocation @relation("StockReturnFrom", fields: [fromLocationId], references: [id], onDelete: Restrict)
  toLocation   InventoryLocation @relation("StockReturnTo", fields: [toLocationId], references: [id], onDelete: Restrict)
  linkedVendorReturn VendorReturn? @relation("StockReturnVendorReturn", fields: [linkedVendorReturnId], references: [id], onDelete: SetNull)
  createdBy    User?             @relation("StockReturnCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  receivedBy   User?             @relation("StockReturnReceivedBy", fields: [receivedByUserId], references: [id], onDelete: SetNull)
  items        StockReturnItem[]

  @@index([orgId])
  @@index([fromLocationId])
  @@index([toLocationId])
  @@index([status])
  @@index([createdAt])
  @@index([disposition])
  @@map("stock_returns")
}

model StockReturnItem {
  id               Int      @id @default(autoincrement())
  stockReturnId    Int
  variantId        Int
  lotId            Int?
  quantityReturned Int
  quantityReceived Int      @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  stockReturn StockReturn    @relation(fields: [stockReturnId], references: [id], onDelete: Cascade)
  variant     ProductVariant @relation(fields: [variantId], references: [id], onDelete: Restrict)
  lot         StockLot?      @relation(fields: [lotId], references: [id], onDelete: SetNull)

  @@index([stockReturnId])
  @@index([variantId])
  @@index([lotId])
  @@map("stock_return_items")
}

// === Vendor Module (enterprise) ===
enum VendorType {
  DISTRIBUTOR
  WHOLESALER
  IMPORTER
  LOCAL
  MANUFACTURER
  OTHER
}

enum VendorStatus {
  ACTIVE
  INACTIVE
  BLACKLISTED
}

enum VendorAttachmentType {
  TRADE_LICENSE
  INVOICE
  CHALLAN
  OTHER
}

enum VendorLedgerSourceType {
  PURCHASE_ORDER
  GRN
  PAYMENT
  ADJUSTMENT
  RETURN
}

model Vendor {
  id                      Int          @id @default(autoincrement())
  orgId                   Int
  code                    String? // unique per org, human-friendly e.g. VEN-0001
  name                    String
  phone                   String?
  email                   String?
  addressLine1            String?
  addressLine2            String?
  district                String?
  city                    String?
  country                 String?
  vendorType              VendorType?  @default(OTHER)
  status                  VendorStatus @default(ACTIVE)
  defaultPaymentTermsDays Int?
  creditLimit             Decimal?     @db.Decimal(12, 2)
  openingBalance          Decimal      @default(0) @db.Decimal(12, 2)
  notes                   String?      @db.Text
  contactJson             Json? // legacy / extra
  /// Wave-2: default lead time for procurement planning (days)
  defaultLeadTimeDays     Int?
  minOrderValue           Decimal?     @db.Decimal(14, 2)
  currencyPreference      String?      @db.VarChar(10)
  asnSupported            Boolean      @default(false)
  deliveryWindowsJson     Json?
  preferredWarehouseId    Int?
  createdAt               DateTime     @default(now())
  updatedAt               DateTime     @updatedAt

  org               Organization           @relation(fields: [orgId], references: [id], onDelete: Cascade)
  preferredWarehouse Warehouse?            @relation("VendorPreferredWarehouse", fields: [preferredWarehouseId], references: [id], onDelete: SetNull)
  listings          VendorProductListing[]
  payoutAccounts    PayoutAccount[]
  grns              Grn[]
  purchaseOrders    PurchaseOrder[]
  purchaseRequisitions PurchaseRequisition[]
  inboundShipments  InboundShipment[]
  contacts          VendorContact[]
  attachments       VendorAttachment[]
  ledgerEntries     VendorLedgerEntry[]
  productsPreferred Product[]              @relation("ProductPreferredVendor")
  vendorReturns     VendorReturn[]
  stockRequestsPreferred StockRequest[]   @relation("StockRequestPreferredVendor")

  @@unique([orgId, code])
  @@index([orgId])
  @@index([orgId, name])
  @@map("vendors")
}

model VendorContact {
  id          Int      @id @default(autoincrement())
  vendorId    Int
  name        String?
  phone       String?
  email       String?
  designation String?
  isPrimary   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  vendor Vendor @relation(fields: [vendorId], references: [id], onDelete: Cascade)

  @@index([vendorId])
  @@map("vendor_contacts")
}

model VendorAttachment {
  id        Int                  @id @default(autoincrement())
  vendorId  Int
  orgId     Int
  fileKey   String // MinIO key
  type      VendorAttachmentType @default(OTHER)
  note      String?              @db.Text
  createdAt DateTime             @default(now())
  updatedAt DateTime             @updatedAt

  vendor Vendor       @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  org    Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([vendorId])
  @@index([orgId])
  @@map("vendor_attachments")
}

model VendorLedgerEntry {
  id           Int                    @id @default(autoincrement())
  vendorId     Int
  orgId        Int
  sourceType   VendorLedgerSourceType
  sourceId     String? // reference to GRN id, payment id, etc.
  debit        Decimal                @default(0) @db.Decimal(12, 2)
  credit       Decimal                @default(0) @db.Decimal(12, 2)
  balanceAfter Decimal?               @db.Decimal(12, 2)
  createdAt    DateTime               @default(now())

  vendor Vendor       @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  org    Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([vendorId])
  @@index([orgId])
  @@index([vendorId, createdAt])
  @@map("vendor_ledger_entries")
}

model VendorProductListing {
  id               Int                 @id @default(autoincrement())
  vendorId         Int
  productId        Int
  variantId        Int?
  status           VendorListingStatus @default(DRAFT)
  commissionRuleId Int?
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt

  vendor         Vendor          @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  product        Product         @relation(fields: [productId], references: [id], onDelete: Restrict)
  variant        ProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)
  commissionRule CommissionRule? @relation(fields: [commissionRuleId], references: [id], onDelete: SetNull)

  @@index([vendorId])
  @@index([productId])
  @@index([status])
  @@map("vendor_product_listings")
}

model CommissionRule {
  id        Int                @id @default(autoincrement())
  name      String
  type      CommissionRuleType
  value     Decimal            @db.Decimal(10, 2)
  orgId     Int?
  isDefault Boolean            @default(false)
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt

  org      Organization?          @relation(fields: [orgId], references: [id], onDelete: SetNull)
  listings VendorProductListing[]

  @@index([orgId])
  @@index([isDefault])
  @@map("commission_rules")
}

model PayoutAccount {
  id          Int               @id @default(autoincrement())
  vendorId    Int
  type        PayoutAccountType
  detailsJson Json
  isDefault   Boolean           @default(false)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  vendor Vendor @relation(fields: [vendorId], references: [id], onDelete: Cascade)

  @@index([vendorId])
  @@index([isDefault])
  @@map("payout_accounts")
}

// === GRN (Goods Received Note) - stock-in to location via vendor invoice ===
enum GrnStatus {
  DRAFT
  RECEIVED
  VOIDED
}

/// Vendor/PO warehouse receive — draft and confirmation before GRN_IN ledger post.
enum VendorReceiveSessionStatus {
  DRAFT
  AWAITING_CONFIRMATION
  POSTED
  CANCELLED
}

/// Internal dispatch branch receive — verification draft before TRANSFER_IN ledger post.
enum DispatchReceiveSessionStatus {
  DRAFT
  AWAITING_CONFIRMATION
  POSTED
  CANCELLED
}

model Grn {
  id               Int       @id @default(autoincrement())
  orgId            Int
  vendorId         Int? // Null when GRN is for transfer receive (stockDispatchId set)
  purchaseOrderId  Int? // Optional link to formal PO (vendor inbound)
  stockDispatchId  Int? // Set when receiving a stock dispatch at branch
  idempotencyKey   String?   @db.VarChar(64) // Optional: duplicate receive with same key returns 409
  locationId       Int
  status           GrnStatus @default(DRAFT)
  invoiceNo        String?   @db.VarChar(120) // Enterprise: vendor invoice number
  invoiceDate      DateTime? // Enterprise: vendor invoice date
  notes            String?   @db.Text
  receivedAt       DateTime?
  receivedByUserId Int?
  inboundShipmentId Int?
  /// When set with POST bulk receive, duplicate key returns existing GRN (idempotent retry).
  receiveIdempotencyKey String?   @db.VarChar(64)
  voidedAt          DateTime?
  voidReason        String?     @db.Text
  voidedByUserId    Int?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  org             Organization      @relation(fields: [orgId], references: [id], onDelete: Cascade)
  vendor          Vendor?           @relation(fields: [vendorId], references: [id], onDelete: SetNull)
  purchaseOrder   PurchaseOrder?    @relation(fields: [purchaseOrderId], references: [id], onDelete: SetNull)
  inboundShipment InboundShipment?  @relation(fields: [inboundShipmentId], references: [id], onDelete: SetNull)
  stockDispatch   StockDispatch?    @relation(fields: [stockDispatchId], references: [id], onDelete: SetNull)
  location        InventoryLocation @relation(fields: [locationId], references: [id], onDelete: Restrict)
  receivedBy    User?             @relation("GrnReceivedBy", fields: [receivedByUserId], references: [id], onDelete: SetNull)
  voidedBy      User?             @relation("GrnVoidedBy", fields: [voidedByUserId], references: [id], onDelete: SetNull)
  lines         GrnLine[]
  qcInspections QcInspection[]
  inboundDiscrepancies InboundDiscrepancy[]
  putawayTasks  PutawayTask[]
  vendorReceiveSession VendorReceiveSession?

  @@unique([stockDispatchId, idempotencyKey])
  @@index([orgId])
  @@index([orgId, status])
  @@index([vendorId])
  @@index([stockDispatchId])
  @@index([purchaseOrderId])
  @@index([inboundShipmentId])
  @@index([locationId])
  @@index([status])
  @@index([createdAt])
  @@unique([orgId, receiveIdempotencyKey])
  @@map("grns")
}

model VendorReceiveSession {
  id                Int                        @id @default(autoincrement())
  orgId             Int
  grnId             Int                        @unique
  status            VendorReceiveSessionStatus @default(DRAFT)
  createdByUserId   Int?
  submittedAt       DateTime?
  submittedByUserId Int?
  confirmedAt       DateTime?
  confirmedByUserId Int?
  notes             String?                    @db.Text
  createdAt         DateTime                   @default(now())
  updatedAt         DateTime                   @updatedAt

  org         Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  grn         Grn          @relation(fields: [grnId], references: [id], onDelete: Cascade)
  createdBy   User?        @relation("VendorReceiveSessionCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  submittedBy User?        @relation("VendorReceiveSessionSubmittedBy", fields: [submittedByUserId], references: [id], onDelete: SetNull)
  confirmedBy User?        @relation("VendorReceiveSessionConfirmedBy", fields: [confirmedByUserId], references: [id], onDelete: SetNull)

  @@index([orgId])
  @@index([status])
  @@map("vendor_receive_sessions")
}

model GrnLine {
  id              Int       @id @default(autoincrement())
  grnId           Int
  variantId       Int
  purchaseOrderLineId Int?
  quantity        Int // received qty (good)
  quantityDamaged Int       @default(0) // discrepancy: damaged (DAMAGE ledger)
  quantityShort   Int       @default(0) // discrepancy: short (no stock movement, audit only)
  /// Over-receipt / surplus quantity recorded for reporting (not added to good qty twice).
  quantityExtra   Int       @default(0)
  unitCost        Decimal?  @db.Decimal(12, 4) // Enterprise: cost per unit at receive
  /// Landed cost per unit if different from PO line (optional variance capture).
  landedUnitCost  Decimal?  @db.Decimal(12, 4)
  lotId           Int? // set when received (created or existing)
  lotCode         String? // optional: for new lot at receive
  mfgDate         DateTime?
  expDate         DateTime?
  supplierBarcode String?   @db.VarChar(128)
  receiveBarcode  String?   @db.VarChar(128)
  inboundShipmentLineId Int?
  lineDiscrepancyNote   String? @db.VarChar(500)
  lineRemarks     String?   @db.Text
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  grn     Grn            @relation(fields: [grnId], references: [id], onDelete: Cascade)
  variant ProductVariant @relation(fields: [variantId], references: [id], onDelete: Restrict)
  purchaseOrderLine PurchaseOrderLine? @relation(fields: [purchaseOrderLineId], references: [id], onDelete: SetNull)
  lot     StockLot?      @relation(fields: [lotId], references: [id], onDelete: SetNull)
  inboundShipmentLine InboundShipmentLine? @relation(fields: [inboundShipmentLineId], references: [id], onDelete: SetNull)
  qcInspections QcInspection[]
  putawayTask          PutawayTask?
  inboundDiscrepancies InboundDiscrepancy[]

  @@index([grnId])
  @@index([variantId])
  @@index([lotId])
  @@index([inboundShipmentLineId])
  @@index([purchaseOrderLineId])
  @@map("grn_lines")
}

// === Catalog Enable Request: branch asks to enable product/variant for selling (no stock movement) ===
enum CatalogEnableRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

model CatalogEnableRequest {
  id                Int                        @id @default(autoincrement())
  orgId             Int
  branchId          Int
  productId         Int
  variantId         Int
  locationId        Int? // optional: specific location; else branch default
  requestedPrice    Decimal?                   @db.Decimal(10, 2)
  status            CatalogEnableRequestStatus @default(PENDING)
  requestedByUserId Int
  reviewedByUserId  Int?
  reviewedAt        DateTime?
  reviewNote        String?                    @db.Text
  createdAt         DateTime                   @default(now())
  updatedAt         DateTime                   @updatedAt

  org         Organization       @relation(fields: [orgId], references: [id], onDelete: Cascade)
  branch      Branch             @relation(fields: [branchId], references: [id], onDelete: Cascade)
  product     Product            @relation(fields: [productId], references: [id], onDelete: Restrict)
  variant     ProductVariant     @relation(fields: [variantId], references: [id], onDelete: Restrict)
  location    InventoryLocation? @relation(fields: [locationId], references: [id], onDelete: SetNull)
  requestedBy User               @relation("CatalogEnableRequestedBy", fields: [requestedByUserId], references: [id], onDelete: Restrict)
  reviewedBy  User?              @relation("CatalogEnableReviewedBy", fields: [reviewedByUserId], references: [id], onDelete: SetNull)

  @@index([orgId])
  @@index([branchId])
  @@index([status])
  @@index([createdAt])
  @@map("catalog_enable_requests")
}

// ============================
// Producer/Auth Authentication System (Separate schema)
// ============================

enum ProducerOrgStatus {
  PENDING
  VERIFIED
  REJECTED
  SUSPENDED
}

enum AuthProductStatus {
  DRAFT
  SUBMITTED
  UNDER_REVIEW
  CHANGES_REQUESTED
  APPROVED
  REJECTED
  ACTIVE
  INACTIVE
  ARCHIVED
}

enum AuthBatchStatus {
  DRAFT
  SUBMITTED
  UNDER_REVIEW
  APPROVED
  REJECTED
  GENERATED
  CODES_ALLOCATED
  PRINTED
  VOIDED
  ARCHIVED
}

enum AuthCodeStatus {
  UNUSED
  VERIFIED
  SOLD
  BLOCKED
  EXPIRED
}

enum AuthVerifyResult {
  GENUINE
  ALREADY_VERIFIED
  INVALID
  BLOCKED
}

model ProducerOrg {
  id             Int               @id @default(autoincrement())
  ownerUserId    Int
  name           String
  countryCode    String?
  docsJson       Json? // deprecated: use VerificationCase + ProducerOrgDocument; kept for backward compat
  legacyDocsJson Json? // migrated from docsJson when using legacy submitKyc; do not rely on file refs
  status         ProducerOrgStatus @default(PENDING)
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  owner                User                     @relation("ProducerOrgOwner", fields: [ownerUserId], references: [id], onDelete: Cascade)
  products             AuthProduct[]
  factories            ProducerFactory[]
  staff                ProducerOrgStaff[]
  staffInvites         ProducerStaffInvite[]
  documents            ProducerOrgDocument[]
  auditLogs            ProducerAuditLog[]
  approvals            ProducerApproval[]
  printEmailRecipients ProducerEmailRecipient[]
  featureFlags         OrgFeatureFlag[]
  quotas               OrgQuota[]
  governanceIncidents  GovernanceIncident[]
  complaintCases       ComplaintCase[]
  supportTickets       SupportTicket[]

  @@index([ownerUserId])
  @@map("producer_orgs")
}

// Governance incidents (Phase 4: enforcement audit trail)
model GovernanceIncident {
  id               Int       @id @default(autoincrement())
  entityType       String    @db.VarChar(64)
  entityId         Int
  producerOrgId    Int
  incidentType     String    @db.VarChar(64)
  severity         String    @db.VarChar(16)
  actionTaken      String    @db.VarChar(64)
  reason           String    @db.Text
  ticketId         String?   @db.VarChar(128)
  createdByUserId  Int
  resolvedAt       DateTime?
  resolvedByUserId Int?
  resolutionNote   String?   @db.Text
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  producerOrg ProducerOrg @relation(fields: [producerOrgId], references: [id], onDelete: Cascade)

  @@index([producerOrgId])
  @@index([entityType, entityId])
  @@index([incidentType])
  @@map("governance_incidents")
}

// Trust & Safety / Enforcement: case-centric complaint and enforcement
model ComplaintCase {
  id               Int       @id @default(autoincrement())
  caseNo           String    @unique @db.VarChar(32)
  source           String    @db.VarChar(32) // CONSUMER | ADMIN | PARTNER | AUTO
  entityType       String    @db.VarChar(32) // CODE | BATCH | PRODUCT | ORG
  entityId         String    @db.VarChar(128)
  producerOrgId    Int
  status           String    @default("OPEN") @db.VarChar(32)
  severity         String    @default("MEDIUM") @db.VarChar(16)
  summary          String    @db.VarChar(256)
  details          String?   @db.Text
  assignedToUserId Int?
  resolvedAt       DateTime?
  resolvedByUserId Int?
  resolutionNote   String?   @db.Text
  createdByUserId  Int
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  producerOrg      ProducerOrg         @relation(fields: [producerOrgId], references: [id])
  evidence         CaseEvidence[]
  actions          EnforcementAction[]
  escalatedTickets SupportTicket[]     @relation("TicketEscalatedToCase")

  @@index([producerOrgId])
  @@index([entityType, entityId])
  @@index([status])
  @@index([severity])
  @@index([caseNo])
  @@map("complaint_cases")
}

model CaseEvidence {
  id              Int      @id @default(autoincrement())
  caseId          Int
  type            String   @db.VarChar(16)
  url             String?  @db.Text
  note            String?  @db.Text
  createdByUserId Int
  createdAt       DateTime @default(now())

  case ComplaintCase @relation(fields: [caseId], references: [id], onDelete: Cascade)

  @@index([caseId])
  @@map("case_evidence")
}

model EnforcementAction {
  id               Int       @id @default(autoincrement())
  caseId           Int
  targetType       String    @db.VarChar(32)
  targetId         String    @db.VarChar(128)
  actionType       String    @db.VarChar(64)
  reason           String    @db.Text
  meta             Json?
  status           String    @default("APPLIED") @db.VarChar(16)
  appliedByUserId  Int
  appliedAt        DateTime  @default(now())
  revertedByUserId Int?
  revertedAt       DateTime?
  revertNote       String?   @db.Text

  case ComplaintCase @relation(fields: [caseId], references: [id])

  @@index([caseId])
  @@index([targetType, targetId])
  @@index([actionType])
  @@map("enforcement_actions")
}

// Support ticketing (Phase 1 MVP)
enum TicketCategory {
  BATCH_CODE
  PRODUCT_GOVERNANCE
  ACCOUNT_KYC
  PAYMENT
  TECHNICAL
  FRAUD_ABUSE
  OTHER
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  WAITING_ON_PRODUCER
  RESOLVED
  CLOSED
  ESCALATED
}

enum TicketMessageSenderType {
  PRODUCER
  ADMIN
  SYSTEM
}

enum TicketAuditEventType {
  STATUS_CHANGED
  ASSIGNED
  PRIORITY_CHANGED
  CATEGORY_CHANGED
  ESCALATED
  CLOSED
  REOPENED
}

model SupportTicket {
  id                Int            @id @default(autoincrement())
  ticketNo          String         @unique @db.VarChar(32)
  producerOrgId     Int
  createdByUserId   Int
  category          TicketCategory
  priority          TicketPriority
  subject           String         @db.VarChar(512)
  description       String         @db.Text
  status            TicketStatus   @default(OPEN)
  assignedToUserId  Int?
  relatedEntityType String?        @db.VarChar(32)
  relatedEntityId   String?        @db.VarChar(128)
  consentToViewData Boolean        @default(false)
  slaBreachedAt     DateTime?
  escalatedCaseId   Int?
  closedAt          DateTime?
  resolvedAt        DateTime?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  producerOrg   ProducerOrg        @relation(fields: [producerOrgId], references: [id], onDelete: Cascade)
  createdBy     User               @relation("SupportTicketCreatedBy", fields: [createdByUserId], references: [id], onDelete: Restrict)
  assignedTo    User?              @relation("SupportTicketAssignedTo", fields: [assignedToUserId], references: [id], onDelete: SetNull)
  escalatedCase ComplaintCase?     @relation("TicketEscalatedToCase", fields: [escalatedCaseId], references: [id], onDelete: SetNull)
  messages      TicketMessage[]
  auditEvents   TicketAuditEvent[]

  @@index([producerOrgId])
  @@index([status, priority])
  @@index([ticketNo])
  @@index([relatedEntityType, relatedEntityId])
  @@index([assignedToUserId])
  @@map("support_tickets")
}

model TicketMessage {
  id           Int                     @id @default(autoincrement())
  ticketId     Int
  senderType   TicketMessageSenderType
  senderUserId Int?
  message      String                  @db.Text
  isInternal   Boolean                 @default(false)
  createdAt    DateTime                @default(now())

  ticket      SupportTicket      @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  sender      User?              @relation(fields: [senderUserId], references: [id], onDelete: SetNull)
  attachments TicketAttachment[]

  @@index([ticketId])
  @@map("ticket_messages")
}

model TicketAttachment {
  id               Int      @id @default(autoincrement())
  ticketMessageId  Int
  fileKey          String   @db.VarChar(512)
  fileName         String   @db.VarChar(255)
  mimeType         String?  @db.VarChar(128)
  fileSize         Int?
  uploadedByUserId Int?
  createdAt        DateTime @default(now())

  ticketMessage TicketMessage @relation(fields: [ticketMessageId], references: [id], onDelete: Cascade)
  uploadedBy    User?         @relation(fields: [uploadedByUserId], references: [id], onDelete: SetNull)

  @@index([ticketMessageId])
  @@map("ticket_attachments")
}

model TicketAuditEvent {
  id          Int                  @id @default(autoincrement())
  ticketId    Int
  eventType   TicketAuditEventType
  meta        Json?
  actorUserId Int?
  createdAt   DateTime             @default(now())

  ticket SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  actor  User?         @relation(fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([ticketId])
  @@index([actorUserId])
  @@map("ticket_audit_events")
}

// Saved email recipients for Producer Print (Email CSV export)
model ProducerEmailRecipient {
  id              Int      @id @default(autoincrement())
  producerOrgId   Int
  email           String
  label           String?
  createdByUserId Int?
