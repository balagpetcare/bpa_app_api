model BranchTypeOnBranch {
  branchId     Int
  branchTypeId Int
  isPrimary    Boolean  @default(false)
  createdAt    DateTime @default(now())

  branch     Branch     @relation(fields: [branchId], references: [id], onDelete: Cascade)
  branchType BranchType @relation(fields: [branchTypeId], references: [id], onDelete: Cascade)

  @@id([branchId, branchTypeId])
  @@index([branchTypeId])
}

model BranchPublishRequest {
  id                Int                  @id @default(autoincrement())
  branchId          Int
  status            PublishRequestStatus @default(PENDING)
  submittedAt       DateTime             @default(now())
  reviewedAt        DateTime?
  reviewedByAdminId Int?
  note              String?

  branch Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@index([branchId])
  @@map("branch_publish_requests")
}

model BranchType {
  id        Int      @id @default(autoincrement())
  code      String   @unique
  nameEn    String
  nameBn    String?
  isActive  Boolean  @default(true)
  sortOrder Int      @default(0)
