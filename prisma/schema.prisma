  strengthNormalizedKey String    @db.VarChar(256)
  isActive              Boolean   @default(true)
  archivedAt            DateTime?
  archivedByUserId      Int?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  generic       MedicineGeneric        @relation(fields: [genericId], references: [id], onDelete: Restrict)
  dosageForm    MedicineDosageForm     @relation(fields: [dosageFormId], references: [id], onDelete: Restrict)
  countryBrands CountryMedicineBrand[]

  @@unique([genericId, dosageFormId, strengthNormalizedKey])
  @@index([genericId])
  @@index([dosageFormId])
  @@index([isActive])
  @@map("medicine_presentations")
