  masterProducts MasterProductCatalog[]

  @@index([slug])
  @@index([companyId])
  @@map("brands")
}

// Global manufacturer/importer (e.g., Royal Canin)
model Company {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  country     String?
  website     String?
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  brands         Brand[]
  masterProducts MasterProductCatalog[]

  @@map("companies")
}

// === Global-Ready Phase 1: Country + Policy (BPA) ===
// Reference: docs/GLOBAL_READY_FULL_PLANNING.md
model Country {
  id              Int      @id @default(autoincrement())
  code            String   @unique // ISO 3166-1 alpha-2: BD, IN, US, LK, MY, SG
  name            String
  currencyCode    String?  @default("USD")
  timezoneDefault String?  @default("UTC")
  phoneCode       String?  // E.164 prefix e.g. +880
  latitude        Decimal? @db.Decimal(10, 8)
  longitude       Decimal? @db.Decimal(11, 8)
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  policies         CountryPolicy[]
  ads              Ad[]
  userCountryRoles UserCountryRole[]
  organizations    Organization[]
  states           State[]
  accessInvites    AccessInvite[]

  @@map("countries")
}

// Phase 5: State/Province layer (override system)
model State {
  id        Int      @id @default(autoincrement())
  countryId Int
  code      String
  name      String
  latitude  Decimal? @db.Decimal(10, 8)
  longitude Decimal? @db.Decimal(11, 8)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  country           Country            @relation(fields: [countryId], references: [id], onDelete: Cascade)
  policies          StatePolicy[]
  userStateRoles    UserStateRole[]
  accessInvites     AccessInvite[]
  locationCities    LocationCity[]

  @@unique([countryId, code])
  @@index([countryId])
  @@map("states")
}

// Global location hierarchy: state -> city (district) -> sub-district (upazila/area)
// Reference: docs/location/world/GLOBAL_LOCATION_SYSTEM.md
model LocationCity {
  id        Int      @id @default(autoincrement())
  stateId   Int
  name      String
  code      String?  // optional admin code
  latitude  Decimal? @db.Decimal(10, 8)
  longitude Decimal? @db.Decimal(11, 8)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  state          State                @relation(fields: [stateId], references: [id], onDelete: Cascade)
  subDistricts   LocationSubDistrict[]

  @@unique([stateId, name])
  @@index([stateId])
  @@map("location_cities")
}

model LocationSubDistrict {
  id        Int      @id @default(autoincrement())
  cityId    Int
  name      String
  latitude  Decimal? @db.Decimal(10, 8)
  longitude Decimal? @db.Decimal(11, 8)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  city LocationCity @relation(fields: [cityId], references: [id], onDelete: Cascade)

  @@unique([cityId, name])
  @@index([cityId])
  @@map("location_sub_districts")
}

model CountryPolicy {
  id            Int       @id @default(autoincrement())
  countryId     Int
  name          String // e.g. "Bangladesh Default Policy"
  status        String // DRAFT | ACTIVE | ARCHIVED
  effectiveFrom DateTime  @default(now())
  effectiveTo   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  country        Country               @relation(fields: [countryId], references: [id], onDelete: Cascade)
  features       PolicyFeature[]
  donationRules  PolicyDonationRule[]
  paymentMethods PolicyPaymentMethod[]
  adsRules       PolicyAdsRule[]
  rules          PolicyRule[]

  @@index([countryId, status])
  @@map("country_policies")
}

model PolicyFeature {
  id              Int      @id @default(autoincrement())
  countryPolicyId Int
  featureCode     String // DONATION, PRODUCTS, ADS, etc.
  enabled         Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  countryPolicy CountryPolicy @relation(fields: [countryPolicyId], references: [id], onDelete: Cascade)

  @@unique([countryPolicyId, featureCode])
  @@index([countryPolicyId])
  @@map("policy_features")
}

model PolicyDonationRule {
  id              Int      @id @default(autoincrement())
  countryPolicyId Int
  ruleType        String // INBOUND, OUTBOUND
  maxAmountSingle Decimal? @db.Decimal(18, 2)
  maxAmountDaily  Decimal? @db.Decimal(18, 2)
  enabled         Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  countryPolicy CountryPolicy @relation(fields: [countryPolicyId], references: [id], onDelete: Cascade)

  @@index([countryPolicyId])
  @@map("policy_donation_rules")
}

// Phase 3: Policy-driven payment methods per country
model PolicyPaymentMethod {
  id              Int      @id @default(autoincrement())
  countryPolicyId Int
  providerCode    String // e.g. BKASH, NAGAD, STRIPE
  enabled         Boolean  @default(false)
  configJson      Json? // provider-specific config (keys, webhook URL, etc.)
  sortOrder       Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  countryPolicy CountryPolicy @relation(fields: [countryPolicyId], references: [id], onDelete: Cascade)

  @@unique([countryPolicyId, providerCode])
  @@index([countryPolicyId])
  @@map("policy_payment_methods")
}

// Phase 4: Ads policy rules (e.g. max daily spend, require KYC per country)
model PolicyAdsRule {
  id              Int      @id @default(autoincrement())
  countryPolicyId Int
  ruleType        String // MAX_DAILY_SPEND, REQUIRE_KYC, etc.
  valueJson       Json? // e.g. {"maxAmount": 10000}
  enabled         Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  countryPolicy CountryPolicy @relation(fields: [countryPolicyId], references: [id], onDelete: Cascade)

  @@index([countryPolicyId])
  @@map("policy_ads_rules")
}

// Phase 4: Generic policy rules (key/value)
model PolicyRule {
  id              Int      @id @default(autoincrement())
  countryPolicyId Int
  ruleKey         String
  valueJson       Json?
  enabled         Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  countryPolicy CountryPolicy @relation(fields: [countryPolicyId], references: [id], onDelete: Cascade)

  @@unique([countryPolicyId, ruleKey])
  @@index([countryPolicyId])
  @@map("policy_rules")
}

// Phase 5: State policy override
model StatePolicy {
  id            Int       @id @default(autoincrement())
  stateId       Int
  name          String
  status        String // DRAFT | ACTIVE | ARCHIVED
  effectiveFrom DateTime  @default(now())
  effectiveTo   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  state    State                @relation(fields: [stateId], references: [id], onDelete: Cascade)
  features StatePolicyFeature[]
  rules    StatePolicyRule[]

  @@index([stateId, status])
  @@map("state_policies")
}

model StatePolicyFeature {
  id            Int      @id @default(autoincrement())
  statePolicyId Int
  featureCode   String
  enabled       Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  statePolicy StatePolicy @relation(fields: [statePolicyId], references: [id], onDelete: Cascade)

  @@unique([statePolicyId, featureCode])
  @@index([statePolicyId])
  @@map("state_policy_features")
}

model StatePolicyRule {
  id            Int      @id @default(autoincrement())
  statePolicyId Int
  ruleKey       String
  valueJson     Json?
  enabled       Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  statePolicy StatePolicy @relation(fields: [statePolicyId], references: [id], onDelete: Cascade)

  @@unique([statePolicyId, ruleKey])
  @@index([statePolicyId])
  @@map("state_policy_rules")
}

// Phase 4: Ads model (country targeting)
model Ad {
  id                 Int       @id @default(autoincrement())
  countryId          Int
  title              String
  body               String?   @db.Text
  mediaId            Int?
  linkUrl            String?   @db.VarChar(512)
  status             String    @default("DRAFT") // DRAFT | ACTIVE | PAUSED
  startAt            DateTime?
  endAt              DateTime?
  targetCountryCodes String?   @db.VarChar(255) // comma-separated e.g. BD,IN or null = primary country only
  sortOrder          Int       @default(0)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  country Country @relation(fields: [countryId], references: [id], onDelete: Cascade)
  media   Media?  @relation(fields: [mediaId], references: [id], onDelete: SetNull)

  @@index([countryId, status])
  @@index([status, startAt, endAt])
  @@map("ads")
}

model Flavor {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  variants ProductVariant[]

  @@map("flavors")
}

model Unit {
  id        Int      @id @default(autoincrement())
  code      String   @unique
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  variants ProductVariant[]

  @@index([code])
  @@map("units")
}

model ProductMedia {
  id        Int      @id @default(autoincrement())
  productId Int
  mediaId   Int
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  media   Media   @relation(fields: [mediaId], references: [id], onDelete: Cascade)

  @@index([productId, sortOrder])
  @@map("product_media")
}

// ============================
// MASTER PRODUCT CATALOG
// ============================
// Global catalog of pet food products that shop owners can browse and clone
model MasterProductCatalog {
  id   Int    @id @default(autoincrement())
  name String
  slug String @unique

  // Core relations
  companyId  Int?
  company    Company?  @relation(fields: [companyId], references: [id], onDelete: SetNull)
  brandId    Int?
  brand      Brand?    @relation(fields: [brandId], references: [id], onDelete: SetNull)
  categoryId Int?
  category   Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  // Identifiers
  barcode String? @unique // Acts as global SKU / barcode for the product

  // Product titles & descriptions
  shortName        String?
  shortDescription String?
  description      String? @db.Text

  // Rich structured description fields
  bulletPoints        Json? // JSON array of key bullet points
  usageInstructions   String? @db.Text
  storageInstructions String? @db.Text
  safetyWarning       String? @db.Text
  countryOfOrigin     String?

  // SEO (optional)
  metaTitle       String?
  metaDescription String?

  // Variants information (stored as JSON array)
  // Shape: [{ title, unit, flavor, packSize, packUnit, barcode, mrp, attributes }]
  variantsJson Json?

  // Normalized variants (per size/flavour/pack) for richer querying
  variants MasterProductVariant[]

  // Suggested pricing (optional)
  suggestedPrice Decimal? @db.Decimal(10, 2)
  currency       String   @default("BDT")

  // Media (reusable, points to global Media table)
  primaryMediaId Int?
  primaryMedia   Media? @relation("MasterProductPrimaryMedia", fields: [primaryMediaId], references: [id], onDelete: SetNull)

  // Legacy / fallback image URL (e.g. direct manufacturer URL)
  imageUrl String?

  // Additional structured fields (e.g. nutrition, composition)
  metaJson Json? // Additional metadata (ingredients, nutritional info, etc.)

  // Status
  isActive   Boolean @default(true)
  isVerified Boolean @default(false) // Admin verified products

  // Source tracking
  sourceType String? // "SEED", "CSV", "API", "MANUAL"
  sourceRef  String? // Reference to source

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  clonedProducts Product[]            @relation("MasterProductCloned")
  galleryMedia   MasterProductMedia[]

  @@index([companyId])
  @@index([brandId])
  @@index([categoryId])
  @@index([isActive, isVerified])
  @@index([slug])
  @@index([barcode])
  @@map("master_product_catalog")
}

// Normalized variants for MasterProductCatalog.
// This complements variantsJson and will gradually become the primary source.
model MasterProductVariant {
  id       Int                  @id @default(autoincrement())
  masterId Int
  master   MasterProductCatalog @relation(fields: [masterId], references: [id], onDelete: Cascade)

  // Identifiers
  variantSku  String? // CSV: variant_sku
  variantName String // e.g. "2kg bag"

  // Pack / size
  packSize Float?
  packUnit String?

  // Attributes
  flavour  String?
  ageGroup String?
  petType  String?

  // Pricing hints from catalog (not shop-specific)
  mrp      Decimal? @db.Decimal(10, 2)
  minPrice Decimal? @db.Decimal(10, 2)
  maxPrice Decimal? @db.Decimal(10, 2)

  // Extra description for this specific variant
  variantDescription String? @db.Text

  // UI / default flags
  isDefault Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([masterId, variantSku])
  @@index([masterId])
  @@map("master_product_variants")
}

model MasterProductMedia {
  id        Int      @id @default(autoincrement())
  masterId  Int
  mediaId   Int
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  master MasterProductCatalog @relation(fields: [masterId], references: [id], onDelete: Cascade)
  media  Media                @relation(fields: [mediaId], references: [id], onDelete: Cascade)

  @@index([masterId, sortOrder])
  @@index([mediaId])
  @@map("master_product_media")
}

model InventoryLocation {
  id        Int                   @id @default(autoincrement())
  branchId  Int
  type      InventoryLocationType
  name      String
  code      String?
  isActive  Boolean               @default(true)
  createdAt DateTime              @default(now())
  updatedAt DateTime              @updatedAt

  branch         Branch                  @relation(fields: [branchId], references: [id], onDelete: Cascade)
  variantConfigs LocationVariantConfig[]
  stockBalances  StockBalance[]
  stockLedgers   StockLedger[]
  locationPrices LocationPrice[]
  transfersFrom  StockTransfer[]         @relation("TransferFrom")
  transfersTo    StockTransfer[]         @relation("TransferTo")
  returnItems    ReturnItem[]
  stockLotBalances StockLotBalance[]
  stockAdjustmentRequests StockAdjustmentRequest[]
  ordersFulfilled Order[]                @relation("OrderFulfilmentLocation")
  grns            Grn[]
  catalogEnableRequests CatalogEnableRequest[]

  @@index([type])
  @@index([branchId])
  @@index([isActive])
  @@map("inventory_locations")
}

model LocationVariantConfig {
  locationId Int
  variantId  Int
  channel    LocationChannel
  isEnabled  Boolean         @default(true)
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt

  location InventoryLocation @relation(fields: [locationId], references: [id], onDelete: Cascade)
  variant  ProductVariant    @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@id([locationId, variantId])
  @@index([variantId])
  @@map("location_variant_configs")
}

model LocationPrice {
  locationId    Int
  variantId     Int
  price         Decimal   @db.Decimal(10, 2)
  effectiveFrom DateTime  @default(now())
  effectiveTo   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  location InventoryLocation @relation(fields: [locationId], references: [id], onDelete: Cascade)
  variant  ProductVariant    @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@id([locationId, variantId])
  @@index([variantId])
  @@index([effectiveFrom, effectiveTo])
  @@map("location_prices")
}

model StockBalance {
  locationId  Int
  variantId   Int
  onHandQty   Int      @default(0)
  reservedQty Int      @default(0)
  updatedAt   DateTime @updatedAt

  location InventoryLocation @relation(fields: [locationId], references: [id], onDelete: Cascade)
  variant  ProductVariant    @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@id([locationId, variantId])
  @@index([variantId])
  @@map("stock_balances")
}

model StockLedger {
  id              Int             @id @default(autoincrement())
  locationId      Int
  variantId       Int
  lotId           Int? // Batch/lot reference for batch-wise stock
  type            StockLedgerType
  quantityDelta   Int // Positive for IN, negative for OUT
  refType         String? // ORDER, TRANSFER, RETURN, etc.
  refId           String?
  createdByUserId Int?
  createdAt       DateTime        @default(now())

  location  InventoryLocation @relation(fields: [locationId], references: [id], onDelete: Cascade)
  variant   ProductVariant    @relation(fields: [variantId], references: [id], onDelete: Cascade)
  lot       StockLot?         @relation(fields: [lotId], references: [id], onDelete: SetNull)
  createdBy User?             @relation("StockLedgerCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)

  @@index([locationId, variantId, createdAt])
  @@index([lotId])
  @@index([refType, refId])
  @@index([type, createdAt])
  @@map("stock_ledgers")
}

model StockTransfer {
  id              Int                 @id @default(autoincrement())
  fromLocationId  Int
  toLocationId    Int
  status          StockTransferStatus @default(DRAFT)
  stockRequestId  Int?                @unique // Optional link to Stock Request (one transfer per request)
  createdByUserId Int?
  sentAt          DateTime?
  receivedAt      DateTime?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  fromLocation InventoryLocation   @relation("TransferFrom", fields: [fromLocationId], references: [id], onDelete: Restrict)
  toLocation   InventoryLocation   @relation("TransferTo", fields: [toLocationId], references: [id], onDelete: Restrict)
  stockRequest StockRequest?       @relation(fields: [stockRequestId], references: [id], onDelete: SetNull)
  createdBy    User?               @relation("StockTransferCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  items        StockTransferItem[]
  discrepancies StockDiscrepancy[]

  @@index([fromLocationId])
  @@index([toLocationId])
  @@index([status])
  @@index([stockRequestId])
  @@map("stock_transfers")
}

model StockTransferItem {
  id               Int      @id @default(autoincrement())
  transferId       Int
  variantId        Int
  lotId            Int? // Batch/lot for this line
  quantitySent     Int
  quantityReceived Int      @default(0)
  quantityDamaged  Int      @default(0)
  quantityExpired  Int      @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  transfer StockTransfer  @relation(fields: [transferId], references: [id], onDelete: Cascade)
  variant  ProductVariant @relation(fields: [variantId], references: [id], onDelete: Restrict)
  lot      StockLot?      @relation(fields: [lotId], references: [id], onDelete: SetNull)

  @@index([transferId])
  @@index([variantId])
  @@index([lotId])
  @@map("stock_transfer_items")
}

// === Stock Request (branch requests stock; owner fulfills → dispatch) ===
model StockRequest {
  id              Int                 @id @default(autoincrement())
  orgId           Int
  branchId        Int
  requesterUserId Int
  status          StockRequestStatus  @default(DRAFT)
  submittedAt     DateTime?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  // Owner decline (auditable)
  declinedAt       DateTime?
  declineReason    String?             @db.Text
  declineSource    String?             @db.VarChar(100)
  declinedByUserId Int?

  // Owner approve (partial qty + extra items): [{ variantId, approvedQty }], [{ variantId, quantity }]
  approvedItems    Json?
  extraItems       Json?
  approvedAt       DateTime?
  approvedByUserId Int?

  org      Organization   @relation(fields: [orgId], references: [id], onDelete: Cascade)
  branch   Branch         @relation(fields: [branchId], references: [id], onDelete: Cascade)
  requester User          @relation("StockRequestRequestedBy", fields: [requesterUserId], references: [id], onDelete: Restrict)
  declinedBy User?        @relation("StockRequestDeclinedBy", fields: [declinedByUserId], references: [id], onDelete: SetNull)
  approvedBy User?        @relation("StockRequestApprovedBy", fields: [approvedByUserId], references: [id], onDelete: SetNull)
  items    StockRequestItem[]
  transfer StockTransfer?

  @@index([orgId])
  @@index([branchId])
  @@index([status])
  @@index([requesterUserId])
  @@map("stock_requests")
}

model StockRequestItem {
  id             Int    @id @default(autoincrement())
  stockRequestId Int
  productId      Int
  variantId      Int
  requestedQty   Int
  note           String? @db.VarChar(500)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  stockRequest StockRequest   @relation(fields: [stockRequestId], references: [id], onDelete: Cascade)
  product     Product        @relation(fields: [productId], references: [id], onDelete: Restrict)
  variant     ProductVariant @relation(fields: [variantId], references: [id], onDelete: Restrict)

  @@index([stockRequestId])
  @@index([productId])
  @@index([variantId])
  @@map("stock_request_items")
}

// === Batch-wise inventory (StockLot) - separate from authenticity Batch ===
model StockLot {
  id               Int      @id @default(autoincrement())
  orgId            Int
  variantId        Int
  lotCode          String
  mfgDate          DateTime
  expDate          DateTime
  createdByUserId  Int?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  org     Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  variant ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)
  createdBy User?       @relation("StockLotCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)

  stockLedgers    StockLedger[]
  stockLotBalances StockLotBalance[]
  transferItems   StockTransferItem[]
  stockDiscrepancies StockDiscrepancy[]
  stockAdjustmentRequests StockAdjustmentRequest[]
  grnLines        GrnLine[]

  @@unique([orgId, variantId, lotCode])
  @@index([orgId])
  @@index([variantId])
  @@index([expDate])
  @@map("stock_lots")
}

model StockLotBalance {
  locationId   Int
  lotId        Int
  onHandQty    Int      @default(0)
  reservedQty  Int      @default(0)
  updatedAt    DateTime @updatedAt

  location InventoryLocation @relation(fields: [locationId], references: [id], onDelete: Cascade)
  lot      StockLot          @relation(fields: [lotId], references: [id], onDelete: Cascade)

  @@id([locationId, lotId])
  @@index([lotId])
  @@map("stock_lot_balances")
}

model StockDiscrepancy {
  id              Int                    @id @default(autoincrement())
  transferId      Int
  transferItemId  Int?
  variantId       Int
  lotId           Int?
  expectedQty     Int
  receivedQty     Int
  damagedQty      Int      @default(0)
  missingQty      Int      @default(0)
  notes           String?  @db.Text
  evidenceMediaIds Json?
  status          StockDiscrepancyStatus @default(PENDING)
  resolvedByUserId Int?
  resolvedAt      DateTime?
  resolutionNote  String?  @db.Text
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  transfer      StockTransfer @relation(fields: [transferId], references: [id], onDelete: Cascade)
  variant       ProductVariant @relation(fields: [variantId], references: [id], onDelete: Restrict)
  lot           StockLot?      @relation(fields: [lotId], references: [id], onDelete: SetNull)
  resolvedBy    User?          @relation("StockDiscrepancyResolvedBy", fields: [resolvedByUserId], references: [id], onDelete: SetNull)

  @@index([transferId])
  @@index([status])
  @@map("stock_discrepancies")
}

model StockAdjustmentRequest {
  id               Int                   @id @default(autoincrement())
  orgId            Int
  locationId       Int
  variantId        Int
  lotId            Int?
  quantityDelta    Int // positive = add, negative = deduct
  reason           String?               @db.Text
  payload          Json?
  status           StockAdjustmentStatus @default(PENDING)
  requestedByUserId Int
  reviewedByUserId Int?
  reviewedAt       DateTime?
  reviewNote       String?               @db.Text
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt

  org         Organization       @relation(fields: [orgId], references: [id], onDelete: Cascade)
  location    InventoryLocation  @relation(fields: [locationId], references: [id], onDelete: Cascade)
  variant     ProductVariant     @relation(fields: [variantId], references: [id], onDelete: Restrict)
  lot         StockLot?          @relation(fields: [lotId], references: [id], onDelete: SetNull)
  requestedBy User               @relation("StockAdjustmentRequestedBy", fields: [requestedByUserId], references: [id], onDelete: Restrict)
  reviewedBy  User?              @relation("StockAdjustmentReviewedBy", fields: [reviewedByUserId], references: [id], onDelete: SetNull)

  @@index([orgId, status])
  @@index([locationId])
  @@map("stock_adjustment_requests")
}

model ReturnRequest {
  id                Int                 @id @default(autoincrement())
  orderId           Int? // Can reference Order or other sale ref
  status            ReturnRequestStatus @default(PENDING)
  requestedByUserId Int?
  approvedByUserId  Int?
  receivedAt        DateTime?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt

  requestedBy User?        @relation("ReturnRequestedBy", fields: [requestedByUserId], references: [id], onDelete: SetNull)
  approvedBy  User?        @relation("ReturnApprovedBy", fields: [approvedByUserId], references: [id], onDelete: SetNull)
  items       ReturnItem[]

  @@index([orderId])
  @@index([status])
  @@map("return_requests")
}

model ReturnItem {
  id              Int             @id @default(autoincrement())
  returnRequestId Int
  variantId       Int
  quantity        Int
  condition       ReturnCondition
  locationId      Int? // For restock location
  createdAt       DateTime        @default(now())

  returnRequest ReturnRequest      @relation(fields: [returnRequestId], references: [id], onDelete: Cascade)
  variant       ProductVariant     @relation(fields: [variantId], references: [id], onDelete: Restrict)
  location      InventoryLocation? @relation(fields: [locationId], references: [id], onDelete: SetNull)

  @@index([returnRequestId])
  @@index([variantId])
  @@map("return_items")
}

model Vendor {
  id          Int      @id @default(autoincrement())
  orgId       Int
  name        String
  contactJson Json?
  status      String   @default("ACTIVE")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  org            Organization           @relation(fields: [orgId], references: [id], onDelete: Cascade)
  listings       VendorProductListing[]
  payoutAccounts PayoutAccount[]
  grns           Grn[]

  @@index([orgId])
  @@map("vendors")
}

model VendorProductListing {
  id               Int                 @id @default(autoincrement())
  vendorId         Int
  productId        Int
  variantId        Int?
  status           VendorListingStatus @default(DRAFT)
  commissionRuleId Int?
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt

  vendor         Vendor          @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  product        Product         @relation(fields: [productId], references: [id], onDelete: Restrict)
  variant        ProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)
  commissionRule CommissionRule? @relation(fields: [commissionRuleId], references: [id], onDelete: SetNull)

  @@index([vendorId])
  @@index([productId])
  @@index([status])
  @@map("vendor_product_listings")
}

model CommissionRule {
  id        Int                @id @default(autoincrement())
  name      String
  type      CommissionRuleType
  value     Decimal            @db.Decimal(10, 2)
  orgId     Int?
  isDefault Boolean            @default(false)
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt

  org      Organization?          @relation(fields: [orgId], references: [id], onDelete: SetNull)
  listings VendorProductListing[]

  @@index([orgId])
  @@index([isDefault])
  @@map("commission_rules")
}

model PayoutAccount {
  id          Int               @id @default(autoincrement())
  vendorId    Int
  type        PayoutAccountType
  detailsJson Json
  isDefault   Boolean           @default(false)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  vendor Vendor @relation(fields: [vendorId], references: [id], onDelete: Cascade)

  @@index([vendorId])
  @@index([isDefault])
  @@map("payout_accounts")
}

// === GRN (Goods Received Note) - stock-in to location via vendor invoice ===
enum GrnStatus {
  DRAFT
  RECEIVED
}

model Grn {
  id          Int       @id @default(autoincrement())
  orgId       Int
  vendorId    Int
  locationId  Int
  status      GrnStatus @default(DRAFT)
  notes       String?   @db.Text
  receivedAt  DateTime?
  receivedByUserId Int?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  org      Organization     @relation(fields: [orgId], references: [id], onDelete: Cascade)
  vendor   Vendor           @relation(fields: [vendorId], references: [id], onDelete: Restrict)
  location InventoryLocation @relation(fields: [locationId], references: [id], onDelete: Restrict)
  receivedBy User?           @relation("GrnReceivedBy", fields: [receivedByUserId], references: [id], onDelete: SetNull)
  lines    GrnLine[]

  @@index([orgId])
  @@index([vendorId])
  @@index([locationId])
  @@index([status])
  @@index([createdAt])
  @@map("grns")
}

model GrnLine {
  id        Int   @id @default(autoincrement())
  grnId     Int
  variantId Int
  quantity  Int
  lotId     Int?  // set when received (created or existing)
  lotCode   String?  // optional: for new lot at receive
  mfgDate   DateTime?
  expDate   DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  grn    Grn            @relation(fields: [grnId], references: [id], onDelete: Cascade)
  variant ProductVariant @relation(fields: [variantId], references: [id], onDelete: Restrict)
  lot    StockLot?      @relation(fields: [lotId], references: [id], onDelete: SetNull)

  @@index([grnId])
  @@index([variantId])
  @@index([lotId])
  @@map("grn_lines")
}

// === Catalog Enable Request: branch asks to enable product/variant for selling (no stock movement) ===
enum CatalogEnableRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

model CatalogEnableRequest {
  id         Int                      @id @default(autoincrement())
  orgId      Int
  branchId   Int
  productId  Int
  variantId  Int
  locationId Int?                     // optional: specific location; else branch default
  requestedPrice Decimal?             @db.Decimal(10, 2)
  status     CatalogEnableRequestStatus @default(PENDING)
  requestedByUserId Int
  reviewedByUserId Int?
  reviewedAt DateTime?
  reviewNote String?                  @db.Text
  createdAt  DateTime                 @default(now())
  updatedAt  DateTime                 @updatedAt

  org         Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  branch      Branch       @relation(fields: [branchId], references: [id], onDelete: Cascade)
  product     Product      @relation(fields: [productId], references: [id], onDelete: Restrict)
  variant     ProductVariant @relation(fields: [variantId], references: [id], onDelete: Restrict)
  location    InventoryLocation? @relation(fields: [locationId], references: [id], onDelete: SetNull)
  requestedBy User         @relation("CatalogEnableRequestedBy", fields: [requestedByUserId], references: [id], onDelete: Restrict)
  reviewedBy  User?        @relation("CatalogEnableReviewedBy", fields: [reviewedByUserId], references: [id], onDelete: SetNull)

  @@index([orgId])
  @@index([branchId])
  @@index([status])
  @@index([createdAt])
  @@map("catalog_enable_requests")
}

// ============================
// Producer/Auth Authentication System (Separate schema)
// ============================

enum ProducerOrgStatus {
  PENDING
  VERIFIED
  REJECTED
  SUSPENDED
}

enum AuthProductStatus {
  DRAFT
  ACTIVE
  INACTIVE
}

enum AuthBatchStatus {
  DRAFT
  APPROVED
  GENERATED
}

enum AuthCodeStatus {
  UNUSED
  VERIFIED
  SOLD
  BLOCKED
  EXPIRED
}

enum AuthVerifyResult {
  GENUINE
  ALREADY_VERIFIED
  INVALID
  BLOCKED
}

model ProducerOrg {
  id          Int               @id @default(autoincrement())
  ownerUserId Int
  name        String
  countryCode String?
  docsJson    Json?             // deprecated: use VerificationCase + ProducerOrgDocument; kept for backward compat
  legacyDocsJson Json?          // migrated from docsJson when using legacy submitKyc; do not rely on file refs
  status      ProducerOrgStatus @default(PENDING)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  owner     User                    @relation("ProducerOrgOwner", fields: [ownerUserId], references: [id], onDelete: Cascade)
  products  AuthProduct[]
  staff     ProducerOrgStaff[]
  documents ProducerOrgDocument[]

  @@index([ownerUserId])
  @@map("producer_orgs")
}

// Producer KYC: formal document model (unified with VerificationCase + VerificationDocument)
model ProducerOrgDocument {
  id            Int          @id @default(autoincrement())
  producerOrgId Int
  type          DocumentType
  status        DocumentStatus @default(SUBMITTED)

  mediaId Int
  media   Media @relation(fields: [mediaId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  producerOrg ProducerOrg @relation(fields: [producerOrgId], references: [id], onDelete: Cascade)

  @@index([producerOrgId])
  @@index([type])
  @@map("producer_org_documents")
}

model ProducerOrgStaff {
  id            Int      @id @default(autoincrement())
  producerOrgId Int
  userId        Int
  roleId        Int
  invitedBy     Int?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  producerOrg ProducerOrg @relation(fields: [producerOrgId], references: [id], onDelete: Cascade)
  user        User        @relation("ProducerStaffUser", fields: [userId], references: [id], onDelete: Cascade)
  role        Role        @relation("ProducerStaffRole", fields: [roleId], references: [id])
  inviter     User?       @relation("ProducerStaffInviter", fields: [invitedBy], references: [id], onDelete: SetNull)

  @@unique([producerOrgId, userId])
  @@index([userId])
  @@index([roleId])
  @@map("producer_org_staff")
}

model AuthProduct {
  id              Int               @id @default(autoincrement())
  producerOrgId   Int
  brandName       String
  productName     String
  sku             String
  packSize        String?
  description     String?
  status          AuthProductStatus @default(DRAFT)
  createdByUserId Int?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  producerOrg ProducerOrg @relation(fields: [producerOrgId], references: [id], onDelete: Cascade)
  createdBy   User?       @relation("AuthProductCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  batches     AuthBatch[]

  @@unique([producerOrgId, sku])
  @@index([producerOrgId])
  @@map("auth_products")
}

model AuthBatch {
  id              Int             @id @default(autoincrement())
  authProductId   Int
  batchNo         String
  mfgDate         DateTime?
  expDate         DateTime?
  qtyPlanned      Int
  qtyGenerated    Int             @default(0)
  status          AuthBatchStatus @default(DRAFT)
  createdByUserId Int?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  authProduct AuthProduct @relation(fields: [authProductId], references: [id], onDelete: Cascade)
  createdBy   User?       @relation("AuthBatchCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  codes       AuthCode[]

  @@index([authProductId])
  @@index([status])
  @@map("auth_batches")
}

model AuthCode {
  id                   Int            @id @default(autoincrement())
  batchId              Int
  codeHash             String         @unique
  codeLength           Int            @default(12)
  customPrefix         String?
  customSuffix         String?
  codeCipher           String
  codeIv               String
  codeTag              String
  status               AuthCodeStatus @default(UNUSED)
  printedAt            DateTime?
  exportedAt           DateTime?
  verifyCount          Int            @default(0)
  firstVerifiedAt      DateTime?
  firstVerifiedIp      String?
  firstVerifiedCountry String?
  generatedByUserId    Int?
  createdAt            DateTime       @default(now())

  batch       AuthBatch             @relation(fields: [batchId], references: [id], onDelete: Cascade)
  generatedBy User?                 @relation("AuthCodeGeneratedBy", fields: [generatedByUserId], references: [id], onDelete: SetNull)
  logs        AuthVerificationLog[]

  @@index([batchId])
  @@index([status])
  @@map("auth_codes")
}

model AuthVerificationLog {
  id               Int              @id @default(autoincrement())
  codeId           Int?
  publicCodeMasked String
  deviceId         String?
  ip               String?
  country          String?
  userId           Int?
  result           AuthVerifyResult
  createdAt        DateTime         @default(now())

  code AuthCode? @relation(fields: [codeId], references: [id], onDelete: SetNull)
  user User?     @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([codeId])
  @@map("auth_verification_logs")
}

// ============================
// Product Authenticity + Serial Issuance (MVP)
// ============================

enum ProductVersionStatus {
  DRAFT
  PENDING
  APPROVED
  REJECTED
}

enum BatchStatus {
  PENDING
  APPROVED
  ISSUED
  CLOSED
}

enum SerialStatus {
  ISSUED
  ACTIVATED
  SOLD
  VOID
  RECALLED
}

enum ScanAction {
  PRODUCED
  SHIPPED
  RECEIVED
  SOLD
  VERIFY
}

enum ScanActorRole {
  FACTORY
  DISTRIBUTOR
  RETAILER
  CUSTOMER
  ADMIN
}

enum LocationPrecisionLevel {
  COARSE
  MEDIUM
  PRECISE
}

enum LocationConsentLevel {
  NONE
  COARSE
  PRECISE_WHEN_USING
  ALWAYS
}

enum LocationSource {
  GPS
  IP
  MANUAL
  WIFI
  CELL
}

enum LocationEventType {
  PING
  SIGNIFICANT_MOVE
  MANUAL_SET
  HOME_SET
}

model Factory {
  id          Int      @id @default(autoincrement())
  orgId       Int
  name        String
  countryCode String?
  addressJson Json?
  isVerified  Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  org     Organization     @relation(fields: [orgId], references: [id], onDelete: Cascade)
  lines   ProductionLine[]
  batches Batch[]

  @@index([orgId])
  @@map("factories")
}

model ProductionLine {
  id        Int      @id @default(autoincrement())
  factoryId Int
  lineCode  String
  deviceId  String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  factory Factory @relation(fields: [factoryId], references: [id], onDelete: Cascade)
  batches Batch[]

  @@unique([factoryId, lineCode])
  @@index([factoryId])
  @@map("production_lines")
}

model ProductVersion {
  id              Int                  @id @default(autoincrement())
  productId       Int
  version         Int
  status          ProductVersionStatus @default(DRAFT)
  description     String?
  specJson        Json?
  createdByUserId Int?
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt

  product     Product             @relation(fields: [productId], references: [id], onDelete: Cascade)
  packaging   PackagingTemplate?
  fingerprint ProductFingerprint?
  batches     Batch[]
  createdBy   User?               @relation("ProductVersionCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)

  @@unique([productId, version])
  @@index([productId, status])
  @@map("product_versions")
}

model PackagingTemplate {
  id               Int      @id @default(autoincrement())
  productVersionId Int      @unique
  templateJson     Json
  status           String   @default("DRAFT")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  productVersion ProductVersion @relation(fields: [productVersionId], references: [id], onDelete: Cascade)

  @@map("packaging_templates")
}

model ProductFingerprint {
  id               Int      @id @default(autoincrement())
  productVersionId Int      @unique
  textHash         String?
  imageHash        String?
  specHash         String?
  similarityScore  Decimal? @db.Decimal(5, 2)
  createdAt        DateTime @default(now())

  productVersion ProductVersion @relation(fields: [productVersionId], references: [id], onDelete: Cascade)

  @@map("product_fingerprints")
}

model Contract {
  id               Int       @id @default(autoincrement())
  orgId            Int
  startDate        DateTime?
  endDate          DateTime?
  allowedCountries Json?
  channels         Json?
  status           String    @default("ACTIVE")
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  org        Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  quotaPlans QuotaPlan[]

  @@index([orgId])
  @@map("contracts")
}

model QuotaPlan {
  id         Int      @id @default(autoincrement())
  contractId Int
  productId  Int
  perMonth   Int?
  perBatch   Int?
  createdAt  DateTime @default(now())

  contract Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)
  product  Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([contractId])
  @@index([productId])
  @@map("quota_plans")
}

model QuotaUsage {
  id           Int      @id @default(autoincrement())
  batchId      Int      @unique
  issuedQty    Int      @default(0)
  remainingQty Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  batch Batch @relation(fields: [batchId], references: [id], onDelete: Cascade)

  @@map("quota_usages")
}

model Batch {
  id               Int         @id @default(autoincrement())
  productVersionId Int
  factoryId        Int
  lineId           Int?
  status           BatchStatus @default(PENDING)
  requestedQty     Int
  approvedQty      Int?
  mfgDate          DateTime?
  expDate          DateTime?
  createdByUserId  Int?
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  productVersion ProductVersion  @relation(fields: [productVersionId], references: [id], onDelete: Cascade)
  factory        Factory         @relation(fields: [factoryId], references: [id], onDelete: Restrict)
  line           ProductionLine? @relation(fields: [lineId], references: [id], onDelete: SetNull)
  createdBy      User?           @relation("BatchCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  serialRanges   SerialRange[]
  serials        Serial[]
  quotaUsage     QuotaUsage?

  @@index([productVersionId])
  @@index([factoryId])
  @@index([status])
  @@map("batches")
}

model SerialRange {
  id             Int      @id @default(autoincrement())
  batchId        Int
  qty            Int
  issuedAt       DateTime @default(now())
  issuedByUserId Int?
  status         String   @default("ISSUED")

  batch    Batch @relation(fields: [batchId], references: [id], onDelete: Cascade)
  issuedBy User? @relation("SerialRangeIssuedBy", fields: [issuedByUserId], references: [id], onDelete: SetNull)

  @@index([batchId])
  @@map("serial_ranges")
}

model Serial {
  id               Int          @id @default(autoincrement())
  batchId          Int
  serialCode       String       @unique
  signature        String
  status           SerialStatus @default(ISSUED)
  firstScanAt      DateTime?
  firstScanCountry String?
  firstScanDevice  String?
  createdAt        DateTime     @default(now())

  batch      Batch       @relation(fields: [batchId], references: [id], onDelete: Cascade)
  scanEvents ScanEvent[]

  @@index([batchId])
  @@map("serials")
}

model ScanEvent {
  id          Int           @id @default(autoincrement())
  serialId    Int
  actorRole   ScanActorRole
  action      ScanAction
  countryCode String?
  deviceId    String?
  metaJson    Json?
  createdAt   DateTime      @default(now())

  serial Serial @relation(fields: [serialId], references: [id], onDelete: Cascade)

  @@index([serialId, createdAt])
  @@map("scan_events")
}

// ============================
// OWNER DELEGATION & TEAM MANAGEMENT
// ============================
// Extends owner capabilities: teams, delegated scopes, overview/audit.
// No modifications to existing tables. Backward compatible.

model OwnerTeam {
  id          Int      @id @default(autoincrement())
  ownerUserId Int
  name        String   @db.VarChar(255)
  description String?  @db.Text
  scopes      Json?    // optional array of scope keys: products, inventory, staff, branches, etc.
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  owner      User              @relation(fields: [ownerUserId], references: [id], onDelete: Cascade)
  members    OwnerTeamMember[]
  delegations OwnerDelegation[]
  teamInvitations TeamInvitation[]
  userContexts   UserContext[]

  @@unique([ownerUserId, name])
  @@index([ownerUserId])
  @@map("owner_teams")
}

model OwnerTeamMember {
  id       Int      @id @default(autoincrement())
  teamId   Int
  userId   Int
  roleInTeam String? @db.VarChar(64) // LEAD, MEMBER, etc. (optional)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  team OwnerTeam @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([teamId, userId])
  @@index([userId])
  @@index([teamId])
  @@map("owner_team_members")
}

/// Reference table for delegation scopes: products, clinics, inventory, staff, branches, finance_read
model OwnerPermissionScope {
  id         Int      @id @default(autoincrement())
  key        String   @unique @db.VarChar(64)
  label      String   @db.VarChar(255)
  isReadOnly Boolean  @default(false) // finance_read is read-only
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("owner_permission_scopes")
}

model OwnerDelegation {
  id              Int      @id @default(autoincrement())
  ownerUserId     Int
  delegatedUserId Int
  scopeKey        String   @db.VarChar(64) // products, clinics, inventory, staff, branches, finance_read
  orgId           Int?     // null = all orgs under owner
  branchId        Int?     // null = all branches in org
  teamId          Int?     // optional: which team this delegation belongs to
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  owner       User        @relation("OwnerDelegationOwner", fields: [ownerUserId], references: [id], onDelete: Cascade)
  delegatedUser User      @relation("OwnerDelegationDelegate", fields: [delegatedUserId], references: [id], onDelete: Cascade)
  org         Organization? @relation(fields: [orgId], references: [id], onDelete: Cascade)
  branch      Branch?      @relation(fields: [branchId], references: [id], onDelete: Cascade)
  team        OwnerTeam?   @relation(fields: [teamId], references: [id], onDelete: SetNull)

  @@unique([ownerUserId, delegatedUserId, scopeKey, orgId, branchId])
  @@index([ownerUserId])
  @@index([delegatedUserId])
  @@index([scopeKey])
  @@map("owner_delegations")
}

model OwnerOverviewLog {
  id          Int      @id @default(autoincrement())
  ownerUserId Int
  actorUserId Int?
  action      String   @db.VarChar(128) // DELEGATION_ASSIGNED, DELEGATION_REVOKED, TEAM_CREATED, etc.
  meta        Json?
  createdAt   DateTime @default(now())

  owner User  @relation("OwnerOverviewLogOwner", fields: [ownerUserId], references: [id], onDelete: Cascade)
  actor User? @relation("OwnerOverviewLogActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([ownerUserId])
  @@index([actorUserId])
  @@index([createdAt])
  @@map("owner_overview_logs")
}

// Multi-context: user's active contexts (branch, team, owner, roles, scopes)
model UserContext {
  id               Int      @id @default(autoincrement())
  userId           Int
  ownerUserId      Int?     // null = user is the owner; set when delegate
  branchId         Int?
  teamId           Int?
  roles            Json?    // string[] e.g. ["BRANCH_MANAGER", "STAFF"]
  scopes           Json?    // string[] e.g. ["products", "inventory"]
  defaultDashboard String?  @db.VarChar(64) // owner | branch | staff
  isDefault        Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user   User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  owner  User?      @relation("UserContextOwner", fields: [ownerUserId], references: [id], onDelete: Cascade)
  branch Branch?   @relation(fields: [branchId], references: [id], onDelete: Cascade)
  team   OwnerTeam? @relation(fields: [teamId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([ownerUserId])
  @@index([branchId])
  @@map("user_contexts")
}

enum TeamInvitationStatus {
  PENDING
  ACCEPTED
  REVOKED
  EXPIRED
}

// Team email invitation: owner invites by email to a team; token one-time use, hashed
model TeamInvitation {
  id        Int                  @id @default(autoincrement())
  ownerUserId Int
  teamId    Int
  email     String               @db.VarChar(255)
  tokenHash String               @unique
  status    TeamInvitationStatus @default(PENDING)
  expiresAt DateTime
  scopes    Json?                // string[] scope keys to assign on accept
  branchIds Json?                // number[] optional branch IDs to link
  invitedByUserId Int
  acceptedByUserId Int?
  createdAt DateTime             @default(now())
  updatedAt DateTime             @updatedAt

  owner     User      @relation("TeamInvitationOwner", fields: [ownerUserId], references: [id], onDelete: Cascade)
  team      OwnerTeam @relation(fields: [teamId], references: [id], onDelete: Cascade)
  invitedBy User      @relation("TeamInvitationInvitedBy", fields: [invitedByUserId], references: [id], onDelete: Restrict)
  acceptedBy User?    @relation("TeamInvitationAcceptedBy", fields: [acceptedByUserId], references: [id], onDelete: SetNull)

  @@index([ownerUserId])
  @@index([teamId])
  @@index([email])
  @@index([status])
  @@map("team_invitations")
}
