// ============================
// PRODUCTS DOMAIN MODELS
// ============================

model Category {
  id        Int      @id @default(autoincrement())
  parentId  Int?
  name      String
  slug      String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  parent         Category?              @relation("CategoryTree", fields: [parentId], references: [id], onDelete: Cascade)
  children       Category[]             @relation("CategoryTree")
  products       Product[]
  masterProducts MasterProductCatalog[]

  @@unique([parentId, slug])
  @@index([parentId])
  @@index([slug])
  @@map("categories")
}

model Brand {
  id        Int      @id @default(autoincrement())
  companyId Int?
  name      String
  slug      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company        Company?               @relation(fields: [companyId], references: [id], onDelete: SetNull)
  products       Product[]
  masterProducts MasterProductCatalog[]

  @@index([slug])
  @@index([companyId])
  @@map("brands")
}

// Global manufacturer/importer (e.g., Royal Canin)
model Company {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  country     String?
  website     String?
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  brands         Brand[]
  masterProducts MasterProductCatalog[]

  @@map("companies")
}

// === Global-Ready Phase 1: Country + Policy (BPA) ===
// Reference: docs/GLOBAL_READY_FULL_PLANNING.md
model Country {
  id              Int      @id @default(autoincrement())
  code            String   @unique // ISO 3166-1 alpha-2: BD, IN, US, LK, MY, SG
  name            String
  currencyCode    String?  @default("USD")
  timezoneDefault String?  @default("UTC")
  phoneCode       String? // E.164 prefix e.g. +880
  latitude        Decimal? @db.Decimal(10, 8)
  longitude       Decimal? @db.Decimal(11, 8)
  isActive        Boolean  @default(true)
  controllerOrgId Int?     @unique // Optional: org designated as country controller (chapter)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  controllerOrg    Organization?     @relation("CountryController", fields: [controllerOrgId], references: [id], onDelete: SetNull)
  policies         CountryPolicy[]
  ads              Ad[]
  userCountryRoles UserCountryRole[]
  organizations    Organization[]
  states           State[]
  accessInvites    AccessInvite[]

  @@index([controllerOrgId])
  @@map("countries")
}

// Phase 5: State/Province layer (override system)
model State {
  id        Int      @id @default(autoincrement())
  countryId Int
  code      String
  name      String
  latitude  Decimal? @db.Decimal(10, 8)
  longitude Decimal? @db.Decimal(11, 8)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  country        Country         @relation(fields: [countryId], references: [id], onDelete: Cascade)
  policies       StatePolicy[]
  userStateRoles UserStateRole[]
  accessInvites  AccessInvite[]
  locationCities LocationCity[]

  @@unique([countryId, code])
  @@index([countryId])
  @@map("states")
}

// Global location hierarchy: state -> city (district) -> sub-district (upazila/area)
// Reference: docs/location/world/GLOBAL_LOCATION_SYSTEM.md
model LocationCity {
  id        Int      @id @default(autoincrement())
  stateId   Int
  name      String
  code      String? // optional admin code
  latitude  Decimal? @db.Decimal(10, 8)
  longitude Decimal? @db.Decimal(11, 8)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  state        State                 @relation(fields: [stateId], references: [id], onDelete: Cascade)
  subDistricts LocationSubDistrict[]

  @@unique([stateId, name])
  @@index([stateId])
  @@map("location_cities")
}

model LocationSubDistrict {
  id        Int      @id @default(autoincrement())
  cityId    Int
  name      String
  latitude  Decimal? @db.Decimal(10, 8)
  longitude Decimal? @db.Decimal(11, 8)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  city LocationCity @relation(fields: [cityId], references: [id], onDelete: Cascade)

  @@unique([cityId, name])
  @@index([cityId])
  @@map("location_sub_districts")
}

model CountryPolicy {
  id            Int       @id @default(autoincrement())
  countryId     Int
  name          String // e.g. "Bangladesh Default Policy"
  status        String // DRAFT | ACTIVE | ARCHIVED
  effectiveFrom DateTime  @default(now())
  effectiveTo   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  country        Country               @relation(fields: [countryId], references: [id], onDelete: Cascade)
  features       PolicyFeature[]
  donationRules  PolicyDonationRule[]
  paymentMethods PolicyPaymentMethod[]
  adsRules       PolicyAdsRule[]
  rules          PolicyRule[]

  @@index([countryId, status])
  @@map("country_policies")
}

model PolicyFeature {
  id              Int      @id @default(autoincrement())
  countryPolicyId Int
  featureCode     String // DONATION, PRODUCTS, ADS, etc.
  enabled         Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  countryPolicy CountryPolicy @relation(fields: [countryPolicyId], references: [id], onDelete: Cascade)

  @@unique([countryPolicyId, featureCode])
  @@index([countryPolicyId])
  @@map("policy_features")
}

model PolicyDonationRule {
  id              Int      @id @default(autoincrement())
  countryPolicyId Int
  ruleType        String // INBOUND, OUTBOUND
  maxAmountSingle Decimal? @db.Decimal(18, 2)
  maxAmountDaily  Decimal? @db.Decimal(18, 2)
  enabled         Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  countryPolicy CountryPolicy @relation(fields: [countryPolicyId], references: [id], onDelete: Cascade)

  @@index([countryPolicyId])
  @@map("policy_donation_rules")
}

// Phase 3: Policy-driven payment methods per country
model PolicyPaymentMethod {
  id              Int      @id @default(autoincrement())
  countryPolicyId Int
  providerCode    String // e.g. BKASH, NAGAD, STRIPE
  enabled         Boolean  @default(false)
  configJson      Json? // provider-specific config (keys, webhook URL, etc.)
  sortOrder       Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  countryPolicy CountryPolicy @relation(fields: [countryPolicyId], references: [id], onDelete: Cascade)

  @@unique([countryPolicyId, providerCode])
  @@index([countryPolicyId])
  @@map("policy_payment_methods")
}

// Phase 4: Ads policy rules (e.g. max daily spend, require KYC per country)
model PolicyAdsRule {
  id              Int      @id @default(autoincrement())
  countryPolicyId Int
  ruleType        String // MAX_DAILY_SPEND, REQUIRE_KYC, etc.
  valueJson       Json? // e.g. {"maxAmount": 10000}
  enabled         Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  countryPolicy CountryPolicy @relation(fields: [countryPolicyId], references: [id], onDelete: Cascade)

  @@index([countryPolicyId])
  @@map("policy_ads_rules")
}

// Phase 4: Generic policy rules (key/value)
model PolicyRule {
  id              Int      @id @default(autoincrement())
  countryPolicyId Int
  ruleKey         String
  valueJson       Json?
  enabled         Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  countryPolicy CountryPolicy @relation(fields: [countryPolicyId], references: [id], onDelete: Cascade)

  @@unique([countryPolicyId, ruleKey])
  @@index([countryPolicyId])
  @@map("policy_rules")
}

// Phase 5: State policy override
model StatePolicy {
  id            Int       @id @default(autoincrement())
  stateId       Int
  name          String
  status        String // DRAFT | ACTIVE | ARCHIVED
  effectiveFrom DateTime  @default(now())
  effectiveTo   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  state    State                @relation(fields: [stateId], references: [id], onDelete: Cascade)
  features StatePolicyFeature[]
  rules    StatePolicyRule[]

  @@index([stateId, status])
  @@map("state_policies")
}

model StatePolicyFeature {
  id            Int      @id @default(autoincrement())
  statePolicyId Int
  featureCode   String
  enabled       Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  statePolicy StatePolicy @relation(fields: [statePolicyId], references: [id], onDelete: Cascade)

  @@unique([statePolicyId, featureCode])
  @@index([statePolicyId])
  @@map("state_policy_features")
}

model StatePolicyRule {
  id            Int      @id @default(autoincrement())
  statePolicyId Int
  ruleKey       String
  valueJson     Json?
  enabled       Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  statePolicy StatePolicy @relation(fields: [statePolicyId], references: [id], onDelete: Cascade)

  @@unique([statePolicyId, ruleKey])
  @@index([statePolicyId])
  @@map("state_policy_rules")
}

// Phase 4: Ads model (country targeting)
model Ad {
  id                 Int       @id @default(autoincrement())
  countryId          Int
  title              String
  body               String?   @db.Text
  mediaId            Int?
  linkUrl            String?   @db.VarChar(512)
  status             String    @default("DRAFT") // DRAFT | ACTIVE | PAUSED
  startAt            DateTime?
  endAt              DateTime?
  targetCountryCodes String?   @db.VarChar(255) // comma-separated e.g. BD,IN or null = primary country only
  sortOrder          Int       @default(0)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  country Country @relation(fields: [countryId], references: [id], onDelete: Cascade)
  media   Media?  @relation(fields: [mediaId], references: [id], onDelete: SetNull)

  @@index([countryId, status])
  @@index([status, startAt, endAt])
  @@map("ads")
}

model Flavor {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  variants ProductVariant[]

  @@map("flavors")
}

model Unit {
  id        Int      @id @default(autoincrement())
  code      String   @unique
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  variants ProductVariant[]

  @@index([code])
  @@map("units")
}

model ProductMedia {
  id        Int      @id @default(autoincrement())
  productId Int
  mediaId   Int
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  media   Media   @relation(fields: [mediaId], references: [id], onDelete: Cascade)

  @@index([productId, sortOrder])
  @@map("product_media")
}

// ============================
// MASTER PRODUCT CATALOG
// ============================
// Global catalog of pet food products that shop owners can browse and clone
model MasterProductCatalog {
  id   Int    @id @default(autoincrement())
  name String
  slug String @unique

  // Core relations
  companyId  Int?
  company    Company?  @relation(fields: [companyId], references: [id], onDelete: SetNull)
  brandId    Int?
  brand      Brand?    @relation(fields: [brandId], references: [id], onDelete: SetNull)
  categoryId Int?
  category   Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  // Identifiers
  barcode String? @unique // Acts as global SKU / barcode for the product

  // Product titles & descriptions
  shortName        String?
  shortDescription String?
  description      String? @db.Text

  // Rich structured description fields
  bulletPoints        Json? // JSON array of key bullet points
  usageInstructions   String? @db.Text
  storageInstructions String? @db.Text
  safetyWarning       String? @db.Text
  countryOfOrigin     String?

  // SEO (optional)
  metaTitle       String?
  metaDescription String?

  // Variants information (stored as JSON array)
  // Shape: [{ title, unit, flavor, packSize, packUnit, barcode, mrp, attributes }]
  variantsJson Json?

  // Normalized variants (per size/flavour/pack) for richer querying
  variants MasterProductVariant[]

  // Suggested pricing (optional)
  suggestedPrice Decimal? @db.Decimal(10, 2)
  currency       String   @default("BDT")

  // Media (reusable, points to global Media table)
  primaryMediaId Int?
  primaryMedia   Media? @relation("MasterProductPrimaryMedia", fields: [primaryMediaId], references: [id], onDelete: SetNull)

  // Legacy / fallback image URL (e.g. direct manufacturer URL)
  imageUrl String?

  // Additional structured fields (e.g. nutrition, composition)
  metaJson Json? // Additional metadata (ingredients, nutritional info, etc.)

  // Status
  isActive   Boolean @default(true)
  isVerified Boolean @default(false) // Admin verified products

  // Source tracking
  sourceType String? // "SEED", "CSV", "API", "MANUAL"
  sourceRef  String? // Reference to source

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  clonedProducts Product[]            @relation("MasterProductCloned")
  galleryMedia   MasterProductMedia[]

  @@index([companyId])
  @@index([brandId])
  @@index([categoryId])
  @@index([isActive, isVerified])
  @@index([slug])
  @@index([barcode])
  @@map("master_product_catalog")
}

// Normalized variants for MasterProductCatalog.
// This complements variantsJson and will gradually become the primary source.
model MasterProductVariant {
  id       Int                  @id @default(autoincrement())
  masterId Int
  master   MasterProductCatalog @relation(fields: [masterId], references: [id], onDelete: Cascade)

  // Identifiers
  variantSku  String? // CSV: variant_sku
  variantName String // e.g. "2kg bag"

  // Pack / size
  packSize Float?
  packUnit String?

  // Attributes
  flavour  String?
  ageGroup String?
  petType  String?

  // Pricing hints from catalog (not shop-specific)
  mrp      Decimal? @db.Decimal(10, 2)
  minPrice Decimal? @db.Decimal(10, 2)
  maxPrice Decimal? @db.Decimal(10, 2)

  // Extra description for this specific variant
  variantDescription String? @db.Text

  // UI / default flags
  isDefault Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([masterId, variantSku])
  @@index([masterId])
  @@map("master_product_variants")
}

model MasterProductMedia {
  id        Int      @id @default(autoincrement())
  masterId  Int
  mediaId   Int
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  master MasterProductCatalog @relation(fields: [masterId], references: [id], onDelete: Cascade)
  media  Media                @relation(fields: [mediaId], references: [id], onDelete: Cascade)

  @@index([masterId, sortOrder])
  @@index([mediaId])
  @@map("master_product_media")
}

model InventoryLocation {
  id        Int                   @id @default(autoincrement())
  branchId  Int
  type      InventoryLocationType
  name      String
  code      String?
  isActive  Boolean               @default(true)
  createdAt DateTime              @default(now())
  updatedAt DateTime              @updatedAt

  branch                  Branch                   @relation(fields: [branchId], references: [id], onDelete: Cascade)
  variantConfigs          LocationVariantConfig[]
  stockBalances           StockBalance[]
  stockLedgers            StockLedger[]
  locationPrices          LocationPrice[]
  transfersFrom           StockTransfer[]          @relation("TransferFrom")
  transfersTo             StockTransfer[]          @relation("TransferTo")
  dispatchesFrom          StockDispatch[]          @relation("DispatchFrom")
  dispatchesTo            StockDispatch[]          @relation("DispatchTo")
  stockReturnsFrom        StockReturn[]            @relation("StockReturnFrom")
  stockReturnsTo          StockReturn[]            @relation("StockReturnTo")
  returnItems             ReturnItem[]
  stockLotBalances        StockLotBalance[]
  stockAdjustmentRequests StockAdjustmentRequest[]
  stockCountSessions      StockCountSession[]
  ordersFulfilled         Order[]                  @relation("OrderFulfilmentLocation")
  grns                    Grn[]
  catalogEnableRequests   CatalogEnableRequest[]
  vialInstances           VialInstance[]

  @@index([type])
  @@index([branchId])
  @@index([isActive])
  @@map("inventory_locations")
}

model LocationVariantConfig {
  locationId Int
  variantId  Int
  channel    LocationChannel
  isEnabled  Boolean         @default(true)
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt

  location InventoryLocation @relation(fields: [locationId], references: [id], onDelete: Cascade)
  variant  ProductVariant    @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@id([locationId, variantId])
  @@index([variantId])
  @@map("location_variant_configs")
}

model LocationPrice {
  locationId    Int
  variantId     Int
  price         Decimal   @db.Decimal(10, 2)
  effectiveFrom DateTime  @default(now())
  effectiveTo   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  location InventoryLocation @relation(fields: [locationId], references: [id], onDelete: Cascade)
  variant  ProductVariant    @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@id([locationId, variantId])
  @@index([variantId])
  @@index([effectiveFrom, effectiveTo])
  @@map("location_prices")
}

model StockBalance {
  locationId  Int
  variantId   Int
  onHandQty   Int      @default(0)
  reservedQty Int      @default(0)
  updatedAt   DateTime @updatedAt

  location InventoryLocation @relation(fields: [locationId], references: [id], onDelete: Cascade)
  variant  ProductVariant    @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@id([locationId, variantId])
  @@index([variantId])
  @@map("stock_balances")
}

model StockLedger {
  id              Int             @id @default(autoincrement())
  orgId           Int? // Tenant isolation; backfilled from location.branch
  locationId      Int
  variantId       Int
  lotId           Int? // Batch/lot reference for batch-wise stock
  type            StockLedgerType
  quantityDelta   Int // Positive for IN, negative for OUT
  unitCost        Decimal?        @db.Decimal(12, 4) // Optional for reporting
  refType         String? // ORDER, TRANSFER, RETURN, DISPATCH, GRN, etc.
  refId           String?
  createdByUserId Int?
  createdAt       DateTime        @default(now())

  org       Organization?     @relation(fields: [orgId], references: [id], onDelete: SetNull)
  location  InventoryLocation @relation(fields: [locationId], references: [id], onDelete: Cascade)
  variant   ProductVariant    @relation(fields: [variantId], references: [id], onDelete: Cascade)
  lot       StockLot?         @relation(fields: [lotId], references: [id], onDelete: SetNull)
  createdBy User?             @relation("StockLedgerCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)

  @@index([orgId])
  @@index([locationId, variantId, createdAt])
  @@index([lotId])
  @@index([refType, refId])
  @@index([type, createdAt])
  @@map("stock_ledgers")
}

model StockTransfer {
  id              Int                 @id @default(autoincrement())
  fromLocationId  Int
  toLocationId    Int
  status          StockTransferStatus @default(DRAFT)
  stockRequestId  Int?                @unique // Optional link to Stock Request (one transfer per request)
  createdByUserId Int?
  sentAt          DateTime?
  receivedAt      DateTime?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  fromLocation  InventoryLocation   @relation("TransferFrom", fields: [fromLocationId], references: [id], onDelete: Restrict)
  toLocation    InventoryLocation   @relation("TransferTo", fields: [toLocationId], references: [id], onDelete: Restrict)
  stockRequest  StockRequest?       @relation(fields: [stockRequestId], references: [id], onDelete: SetNull)
  createdBy     User?               @relation("StockTransferCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  items         StockTransferItem[]
  discrepancies StockDiscrepancy[]

  @@index([fromLocationId])
  @@index([toLocationId])
  @@index([status])
  @@index([stockRequestId])
  @@map("stock_transfers")
}

model StockTransferItem {
  id               Int      @id @default(autoincrement())
  transferId       Int
  variantId        Int
  lotId            Int? // Batch/lot for this line
  quantitySent     Int
  quantityReceived Int      @default(0)
  quantityDamaged  Int      @default(0)
  quantityExpired  Int      @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  transfer StockTransfer  @relation(fields: [transferId], references: [id], onDelete: Cascade)
  variant  ProductVariant @relation(fields: [variantId], references: [id], onDelete: Restrict)
  lot      StockLot?      @relation(fields: [lotId], references: [id], onDelete: SetNull)

  @@index([transferId])
  @@index([variantId])
  @@index([lotId])
  @@map("stock_transfer_items")
}

// === Stock Dispatch (Challan/DO) – from fulfill plan; transport + status CREATED→PACKED→IN_TRANSIT→DELIVERED ===
model StockDispatch {
  id              Int                 @id @default(autoincrement())
  orgId           Int
  stockRequestId  Int
  fromLocationId  Int
  toLocationId    Int
  status          StockDispatchStatus @default(CREATED)
  // Transport
  carrierType     String?             @db.VarChar(50) // own | courier
  vehicleNo       String?             @db.VarChar(100)
  driverName      String?             @db.VarChar(200)
  driverPhone     String?             @db.VarChar(50)
  trackingId      String?             @db.VarChar(200)
  eta             DateTime?
  shippingCost    Decimal?            @db.Decimal(12, 2)
  note            String?             @db.Text
  packedAt        DateTime?
  inTransitAt     DateTime?
  deliveredAt     DateTime?
  createdByUserId Int?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  org          Organization        @relation(fields: [orgId], references: [id], onDelete: Cascade)
  stockRequest StockRequest        @relation(fields: [stockRequestId], references: [id], onDelete: Cascade)
  fromLocation InventoryLocation   @relation("DispatchFrom", fields: [fromLocationId], references: [id], onDelete: Restrict)
  toLocation   InventoryLocation   @relation("DispatchTo", fields: [toLocationId], references: [id], onDelete: Restrict)
  createdBy    User?               @relation("StockDispatchCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  items        StockDispatchItem[]
  grns         Grn[]

  @@index([orgId])
  @@index([stockRequestId])
  @@index([fromLocationId])
  @@index([toLocationId])
  @@index([status])
  @@index([createdAt])
  @@map("stock_dispatches")
}

model StockDispatchItem {
  id                 Int      @id @default(autoincrement())
  stockDispatchId    Int
  variantId          Int
  lotId              Int
  quantityDispatched Int
  quantityReceived   Int      @default(0)
  quantityDamaged    Int      @default(0)
  quantityShort      Int      @default(0)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  stockDispatch StockDispatch  @relation(fields: [stockDispatchId], references: [id], onDelete: Cascade)
  variant       ProductVariant @relation(fields: [variantId], references: [id], onDelete: Restrict)
  lot           StockLot       @relation(fields: [lotId], references: [id], onDelete: Restrict)

  @@index([stockDispatchId])
  @@index([variantId])
  @@index([lotId])
  @@map("stock_dispatch_items")
}

// === Stock Request (branch requests stock; owner fulfills → dispatch) ===
model StockRequest {
  id              Int                @id @default(autoincrement())
  orgId           Int
  branchId        Int
  requesterUserId Int
  status          StockRequestStatus @default(DRAFT)
  submittedAt     DateTime?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  // Owner decline (auditable)
  declinedAt       DateTime?
  declineReason    String?   @db.Text
  declineSource    String?   @db.VarChar(100)
  declinedByUserId Int?

  // Owner approve (partial qty + extra items): [{ variantId, approvedQty }], [{ variantId, quantity }]
  approvedItems    Json?
  extraItems       Json?
  approvedAt       DateTime?
  approvedByUserId Int?

  org        Organization       @relation(fields: [orgId], references: [id], onDelete: Cascade)
  branch     Branch             @relation(fields: [branchId], references: [id], onDelete: Cascade)
  requester  User               @relation("StockRequestRequestedBy", fields: [requesterUserId], references: [id], onDelete: Restrict)
  declinedBy User?              @relation("StockRequestDeclinedBy", fields: [declinedByUserId], references: [id], onDelete: SetNull)
  approvedBy User?              @relation("StockRequestApprovedBy", fields: [approvedByUserId], references: [id], onDelete: SetNull)
  items      StockRequestItem[]
  transfer   StockTransfer?
  dispatches StockDispatch[]

  @@index([orgId])
  @@index([branchId])
  @@index([status])
  @@index([requesterUserId])
  @@map("stock_requests")
}

model StockRequestItem {
  id             Int      @id @default(autoincrement())
  stockRequestId Int
  productId      Int
  variantId      Int
  requestedQty   Int
  note           String?  @db.VarChar(500)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  stockRequest StockRequest   @relation(fields: [stockRequestId], references: [id], onDelete: Cascade)
  product      Product        @relation(fields: [productId], references: [id], onDelete: Restrict)
  variant      ProductVariant @relation(fields: [variantId], references: [id], onDelete: Restrict)

  @@index([stockRequestId])
  @@index([productId])
  @@index([variantId])
  @@map("stock_request_items")
}

// === Batch-wise inventory (StockLot) - separate from authenticity Batch ===
model StockLot {
  id              Int      @id @default(autoincrement())
  orgId           Int
  variantId       Int
  lotCode         String
  mfgDate         DateTime
  expDate         DateTime
  createdByUserId Int?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  org       Organization   @relation(fields: [orgId], references: [id], onDelete: Cascade)
  variant   ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)
  createdBy User?          @relation("StockLotCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)

  stockLedgers            StockLedger[]
  stockLotBalances        StockLotBalance[]
  transferItems           StockTransferItem[]
  stockDispatchItems      StockDispatchItem[]
  stockDiscrepancies      StockDiscrepancy[]
  stockAdjustmentRequests StockAdjustmentRequest[]
  stockReturnItems        StockReturnItem[]
  grnLines                GrnLine[]
  stockCountLines         StockCountLine[]
  vialInstances           VialInstance[]
  vialSessions            VialSession[]
  consumptionItems        ConsumptionItem[]

  @@unique([orgId, variantId, lotCode])
  @@index([orgId])
  @@index([variantId])
  @@index([expDate])
  @@map("stock_lots")
}

model StockLotBalance {
  locationId  Int
  lotId       Int
  onHandQty   Int      @default(0)
  reservedQty Int      @default(0)
  updatedAt   DateTime @updatedAt

  location InventoryLocation @relation(fields: [locationId], references: [id], onDelete: Cascade)
  lot      StockLot          @relation(fields: [lotId], references: [id], onDelete: Cascade)

  @@id([locationId, lotId])
  @@index([lotId])
  @@map("stock_lot_balances")
}

model StockDiscrepancy {
  id               Int                    @id @default(autoincrement())
  transferId       Int
  transferItemId   Int?
  variantId        Int
  lotId            Int?
  expectedQty      Int
  receivedQty      Int
  damagedQty       Int                    @default(0)
  missingQty       Int                    @default(0)
  notes            String?                @db.Text
  evidenceMediaIds Json?
  status           StockDiscrepancyStatus @default(PENDING)
  resolvedByUserId Int?
  resolvedAt       DateTime?
  resolutionNote   String?                @db.Text
  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @updatedAt

  transfer   StockTransfer  @relation(fields: [transferId], references: [id], onDelete: Cascade)
  variant    ProductVariant @relation(fields: [variantId], references: [id], onDelete: Restrict)
  lot        StockLot?      @relation(fields: [lotId], references: [id], onDelete: SetNull)
  resolvedBy User?          @relation("StockDiscrepancyResolvedBy", fields: [resolvedByUserId], references: [id], onDelete: SetNull)

  @@index([transferId])
  @@index([status])
  @@map("stock_discrepancies")
}

model StockAdjustmentRequest {
  id                 Int                   @id @default(autoincrement())
  orgId              Int
  locationId         Int
  variantId          Int
  lotId              Int?
  quantityDelta      Int // positive = add, negative = deduct
  reason             String?               @db.Text
  adjustmentCategory String?               @db.VarChar(32) // DAMAGE | LOSS | CORRECTION → ledger type
  payload            Json?
  status             StockAdjustmentStatus @default(PENDING)
  requestedByUserId  Int
  reviewedByUserId   Int?
  reviewedAt         DateTime?
  reviewNote         String?               @db.Text
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt

  org         Organization      @relation(fields: [orgId], references: [id], onDelete: Cascade)
  location    InventoryLocation @relation(fields: [locationId], references: [id], onDelete: Cascade)
  variant     ProductVariant    @relation(fields: [variantId], references: [id], onDelete: Restrict)
  lot         StockLot?         @relation(fields: [lotId], references: [id], onDelete: SetNull)
  requestedBy User              @relation("StockAdjustmentRequestedBy", fields: [requestedByUserId], references: [id], onDelete: Restrict)
  reviewedBy  User?             @relation("StockAdjustmentReviewedBy", fields: [reviewedByUserId], references: [id], onDelete: SetNull)

  @@index([orgId, status])
  @@index([locationId])
  @@map("stock_adjustment_requests")
}

model StockCountSession {
  id              Int                     @id @default(autoincrement())
  orgId           Int
  locationId      Int
  status          StockCountSessionStatus @default(DRAFT)
  note            String?                 @db.Text
  createdByUserId Int?
  frozenAt        DateTime?
  postedAt        DateTime?
  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @updatedAt

  org       Organization      @relation(fields: [orgId], references: [id], onDelete: Cascade)
  location  InventoryLocation @relation(fields: [locationId], references: [id], onDelete: Cascade)
  createdBy User?             @relation("StockCountSessionCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  lines     StockCountLine[]

  @@index([orgId])
  @@index([locationId])
  @@index([status])
  @@map("stock_count_sessions")
}

model StockCountLine {
  id          Int      @id @default(autoincrement())
  sessionId   Int
  variantId   Int
  lotId       Int? // optional for lot-level count later; variant-level uses null
  systemQty   Int      @default(0)
  countedQty  Int      @default(0)
  varianceQty Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  session StockCountSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  variant ProductVariant    @relation(fields: [variantId], references: [id], onDelete: Restrict)
  lot     StockLot?         @relation(fields: [lotId], references: [id], onDelete: SetNull)

  @@unique([sessionId, variantId])
  @@index([sessionId])
  @@index([variantId])
  @@map("stock_count_lines")
}

model ReturnRequest {
  id                Int                 @id @default(autoincrement())
  orderId           Int? // Can reference Order or other sale ref
  status            ReturnRequestStatus @default(PENDING)
  requestedByUserId Int?
  approvedByUserId  Int?
  receivedAt        DateTime?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt

  requestedBy   User?          @relation("ReturnRequestedBy", fields: [requestedByUserId], references: [id], onDelete: SetNull)
  approvedBy    User?          @relation("ReturnApprovedBy", fields: [approvedByUserId], references: [id], onDelete: SetNull)
  items         ReturnItem[]
  posCreditNote PosCreditNote?

  @@index([orderId])
  @@index([status])
  @@map("return_requests")
}

model ReturnItem {
  id              Int             @id @default(autoincrement())
  returnRequestId Int
  variantId       Int
  quantity        Int
  condition       ReturnCondition
  locationId      Int? // For restock location
  createdAt       DateTime        @default(now())

  returnRequest ReturnRequest      @relation(fields: [returnRequestId], references: [id], onDelete: Cascade)
  variant       ProductVariant     @relation(fields: [variantId], references: [id], onDelete: Restrict)
  location      InventoryLocation? @relation(fields: [locationId], references: [id], onDelete: SetNull)

  @@index([returnRequestId])
  @@index([variantId])
  @@map("return_items")
}

model PosCreditNote {
  id              Int      @id @default(autoincrement())
  returnRequestId Int      @unique
  orderId         Int
  branchId        Int
  creditNumber    String   @unique
  amount          Decimal  @db.Decimal(12, 2)
  createdAt       DateTime @default(now())

  returnRequest ReturnRequest @relation(fields: [returnRequestId], references: [id], onDelete: Cascade)

  @@index([branchId])
  @@index([orderId])
  @@map("pos_credit_notes")
}

// === POS Retail-Grade: Cash drawer shift ===
enum PosShiftStatus {
  OPEN
  CLOSED
}

model PosShift {
  id                    Int            @id @default(autoincrement())
  branchId              Int
  openedByUserId        Int
  openedAt              DateTime       @default(now())
  closedAt              DateTime?
  status                PosShiftStatus @default(OPEN)
  startingCash          Decimal        @default(0) @db.Decimal(12, 2)
  closingCash           Decimal?       @db.Decimal(12, 2)
  variance              Decimal?       @db.Decimal(12, 2)
  closedByUserId        Int?
  managerOverrideReason String?        @db.Text
  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt

  branch   Branch  @relation(fields: [branchId], references: [id], onDelete: Cascade)
  openedBy User    @relation("PosShiftOpenedBy", fields: [openedByUserId], references: [id], onDelete: Restrict)
  closedBy User?   @relation("PosShiftClosedBy", fields: [closedByUserId], references: [id], onDelete: SetNull)
  orders   Order[]

  @@index([branchId, status])
  @@index([branchId, openedAt])
  @@map("pos_shifts")
}

// === Stock Return (branch → warehouse): damaged, wrong item, near-expiry, overstock ===
enum StockReturnReason {
  DAMAGED
  WRONG_ITEM
  NEAR_EXPIRY
  OVERSTOCK
  OTHER
}

enum StockReturnStatus {
  CREATED
  IN_TRANSIT
  RECEIVED
  CANCELLED
}

model StockReturn {
  id               Int               @id @default(autoincrement())
  orgId            Int
  fromLocationId   Int // branch
  toLocationId     Int // warehouse
  reason           StockReturnReason
  status           StockReturnStatus @default(CREATED)
  note             String?           @db.Text
  createdByUserId  Int?
  receivedAt       DateTime?
  receivedByUserId Int?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  org          Organization      @relation(fields: [orgId], references: [id], onDelete: Cascade)
  fromLocation InventoryLocation @relation("StockReturnFrom", fields: [fromLocationId], references: [id], onDelete: Restrict)
  toLocation   InventoryLocation @relation("StockReturnTo", fields: [toLocationId], references: [id], onDelete: Restrict)
  createdBy    User?             @relation("StockReturnCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  receivedBy   User?             @relation("StockReturnReceivedBy", fields: [receivedByUserId], references: [id], onDelete: SetNull)
  items        StockReturnItem[]

  @@index([orgId])
  @@index([fromLocationId])
  @@index([toLocationId])
  @@index([status])
  @@index([createdAt])
  @@map("stock_returns")
}

model StockReturnItem {
  id               Int      @id @default(autoincrement())
  stockReturnId    Int
  variantId        Int
  lotId            Int?
  quantityReturned Int
  quantityReceived Int      @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  stockReturn StockReturn    @relation(fields: [stockReturnId], references: [id], onDelete: Cascade)
  variant     ProductVariant @relation(fields: [variantId], references: [id], onDelete: Restrict)
  lot         StockLot?      @relation(fields: [lotId], references: [id], onDelete: SetNull)

  @@index([stockReturnId])
  @@index([variantId])
  @@index([lotId])
  @@map("stock_return_items")
}

// === Vendor Module (enterprise) ===
enum VendorType {
  DISTRIBUTOR
  WHOLESALER
  IMPORTER
  LOCAL
  MANUFACTURER
  OTHER
}

enum VendorStatus {
  ACTIVE
  INACTIVE
  BLACKLISTED
}

enum VendorAttachmentType {
  TRADE_LICENSE
  INVOICE
  CHALLAN
  OTHER
}

enum VendorLedgerSourceType {
  PURCHASE_ORDER
  GRN
  PAYMENT
  ADJUSTMENT
  RETURN
}

model Vendor {
  id                      Int          @id @default(autoincrement())
  orgId                   Int
  code                    String? // unique per org, human-friendly e.g. VEN-0001
  name                    String
  phone                   String?
  email                   String?
  addressLine1            String?
  addressLine2            String?
  district                String?
  city                    String?
  country                 String?
  vendorType              VendorType?  @default(OTHER)
  status                  VendorStatus @default(ACTIVE)
  defaultPaymentTermsDays Int?
  creditLimit             Decimal?     @db.Decimal(12, 2)
  openingBalance          Decimal      @default(0) @db.Decimal(12, 2)
  notes                   String?      @db.Text
  contactJson             Json? // legacy / extra
  createdAt               DateTime     @default(now())
  updatedAt               DateTime     @updatedAt

  org               Organization           @relation(fields: [orgId], references: [id], onDelete: Cascade)
  listings          VendorProductListing[]
  payoutAccounts    PayoutAccount[]
  grns              Grn[]
  contacts          VendorContact[]
  attachments       VendorAttachment[]
  ledgerEntries     VendorLedgerEntry[]
  productsPreferred Product[]              @relation("ProductPreferredVendor")

  @@unique([orgId, code])
  @@index([orgId])
  @@index([orgId, name])
  @@map("vendors")
}

model VendorContact {
  id          Int      @id @default(autoincrement())
  vendorId    Int
  name        String?
  phone       String?
  email       String?
  designation String?
  isPrimary   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  vendor Vendor @relation(fields: [vendorId], references: [id], onDelete: Cascade)

  @@index([vendorId])
  @@map("vendor_contacts")
}

model VendorAttachment {
  id        Int                  @id @default(autoincrement())
  vendorId  Int
  orgId     Int
  fileKey   String // MinIO key
  type      VendorAttachmentType @default(OTHER)
  note      String?              @db.Text
  createdAt DateTime             @default(now())
  updatedAt DateTime             @updatedAt

  vendor Vendor       @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  org    Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([vendorId])
  @@index([orgId])
  @@map("vendor_attachments")
}

model VendorLedgerEntry {
  id           Int                    @id @default(autoincrement())
  vendorId     Int
  orgId        Int
  sourceType   VendorLedgerSourceType
  sourceId     String? // reference to GRN id, payment id, etc.
  debit        Decimal                @default(0) @db.Decimal(12, 2)
  credit       Decimal                @default(0) @db.Decimal(12, 2)
  balanceAfter Decimal?               @db.Decimal(12, 2)
  createdAt    DateTime               @default(now())

  vendor Vendor       @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  org    Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([vendorId])
  @@index([orgId])
  @@index([vendorId, createdAt])
  @@map("vendor_ledger_entries")
}

model VendorProductListing {
  id               Int                 @id @default(autoincrement())
  vendorId         Int
  productId        Int
  variantId        Int?
  status           VendorListingStatus @default(DRAFT)
  commissionRuleId Int?
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt

  vendor         Vendor          @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  product        Product         @relation(fields: [productId], references: [id], onDelete: Restrict)
  variant        ProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)
  commissionRule CommissionRule? @relation(fields: [commissionRuleId], references: [id], onDelete: SetNull)

  @@index([vendorId])
  @@index([productId])
  @@index([status])
  @@map("vendor_product_listings")
}

model CommissionRule {
  id        Int                @id @default(autoincrement())
  name      String
  type      CommissionRuleType
  value     Decimal            @db.Decimal(10, 2)
  orgId     Int?
  isDefault Boolean            @default(false)
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt

  org      Organization?          @relation(fields: [orgId], references: [id], onDelete: SetNull)
  listings VendorProductListing[]

  @@index([orgId])
  @@index([isDefault])
  @@map("commission_rules")
}

model PayoutAccount {
  id          Int               @id @default(autoincrement())
  vendorId    Int
  type        PayoutAccountType
  detailsJson Json
  isDefault   Boolean           @default(false)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  vendor Vendor @relation(fields: [vendorId], references: [id], onDelete: Cascade)

  @@index([vendorId])
  @@index([isDefault])
  @@map("payout_accounts")
}

// === GRN (Goods Received Note) - stock-in to location via vendor invoice ===
enum GrnStatus {
  DRAFT
  RECEIVED
}

model Grn {
  id               Int       @id @default(autoincrement())
  orgId            Int
  vendorId         Int? // Null when GRN is for transfer receive (stockDispatchId set)
  stockDispatchId  Int? // Set when receiving a stock dispatch at branch
  idempotencyKey   String?   @db.VarChar(64) // Optional: duplicate receive with same key returns 409
  locationId       Int
  status           GrnStatus @default(DRAFT)
  invoiceNo        String?   @db.VarChar(120) // Enterprise: vendor invoice number
  invoiceDate      DateTime? // Enterprise: vendor invoice date
  notes            String?   @db.Text
  receivedAt       DateTime?
  receivedByUserId Int?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  org           Organization      @relation(fields: [orgId], references: [id], onDelete: Cascade)
  vendor        Vendor?           @relation(fields: [vendorId], references: [id], onDelete: SetNull)
  stockDispatch StockDispatch?    @relation(fields: [stockDispatchId], references: [id], onDelete: SetNull)
  location      InventoryLocation @relation(fields: [locationId], references: [id], onDelete: Restrict)
  receivedBy    User?             @relation("GrnReceivedBy", fields: [receivedByUserId], references: [id], onDelete: SetNull)
  lines         GrnLine[]

  @@unique([stockDispatchId, idempotencyKey])
  @@index([orgId])
  @@index([vendorId])
  @@index([stockDispatchId])
  @@index([locationId])
  @@index([status])
  @@index([createdAt])
  @@map("grns")
}

model GrnLine {
  id              Int       @id @default(autoincrement())
  grnId           Int
  variantId       Int
  quantity        Int // received qty (good)
  quantityDamaged Int       @default(0) // discrepancy: damaged (DAMAGE ledger)
  quantityShort   Int       @default(0) // discrepancy: short (no stock movement, audit only)
  unitCost        Decimal?  @db.Decimal(12, 4) // Enterprise: cost per unit at receive
  lotId           Int? // set when received (created or existing)
  lotCode         String? // optional: for new lot at receive
  mfgDate         DateTime?
  expDate         DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  grn     Grn            @relation(fields: [grnId], references: [id], onDelete: Cascade)
  variant ProductVariant @relation(fields: [variantId], references: [id], onDelete: Restrict)
  lot     StockLot?      @relation(fields: [lotId], references: [id], onDelete: SetNull)

  @@index([grnId])
  @@index([variantId])
  @@index([lotId])
  @@map("grn_lines")
}

// === Catalog Enable Request: branch asks to enable product/variant for selling (no stock movement) ===
enum CatalogEnableRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

model CatalogEnableRequest {
  id                Int                        @id @default(autoincrement())
  orgId             Int
  branchId          Int
  productId         Int
  variantId         Int
  locationId        Int? // optional: specific location; else branch default
  requestedPrice    Decimal?                   @db.Decimal(10, 2)
  status            CatalogEnableRequestStatus @default(PENDING)
  requestedByUserId Int
  reviewedByUserId  Int?
  reviewedAt        DateTime?
  reviewNote        String?                    @db.Text
  createdAt         DateTime                   @default(now())
  updatedAt         DateTime                   @updatedAt

  org         Organization       @relation(fields: [orgId], references: [id], onDelete: Cascade)
  branch      Branch             @relation(fields: [branchId], references: [id], onDelete: Cascade)
  product     Product            @relation(fields: [productId], references: [id], onDelete: Restrict)
  variant     ProductVariant     @relation(fields: [variantId], references: [id], onDelete: Restrict)
  location    InventoryLocation? @relation(fields: [locationId], references: [id], onDelete: SetNull)
  requestedBy User               @relation("CatalogEnableRequestedBy", fields: [requestedByUserId], references: [id], onDelete: Restrict)
  reviewedBy  User?              @relation("CatalogEnableReviewedBy", fields: [reviewedByUserId], references: [id], onDelete: SetNull)

  @@index([orgId])
  @@index([branchId])
  @@index([status])
  @@index([createdAt])
  @@map("catalog_enable_requests")
}

// ============================
// Producer/Auth Authentication System (Separate schema)
// ============================

enum ProducerOrgStatus {
  PENDING
  VERIFIED
  REJECTED
  SUSPENDED
}

enum AuthProductStatus {
  DRAFT
  SUBMITTED
  UNDER_REVIEW
  CHANGES_REQUESTED
  APPROVED
  REJECTED
  ACTIVE
  INACTIVE
  ARCHIVED
}

enum AuthBatchStatus {
  DRAFT
  SUBMITTED
  UNDER_REVIEW
  APPROVED
  REJECTED
  GENERATED
  CODES_ALLOCATED
  PRINTED
  VOIDED
  ARCHIVED
}

enum AuthCodeStatus {
  UNUSED
  VERIFIED
  SOLD
  BLOCKED
  EXPIRED
}

enum AuthVerifyResult {
  GENUINE
  ALREADY_VERIFIED
  INVALID
  BLOCKED
}

model ProducerOrg {
  id             Int               @id @default(autoincrement())
  ownerUserId    Int
  name           String
  countryCode    String?
  docsJson       Json? // deprecated: use VerificationCase + ProducerOrgDocument; kept for backward compat
  legacyDocsJson Json? // migrated from docsJson when using legacy submitKyc; do not rely on file refs
  status         ProducerOrgStatus @default(PENDING)
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  owner                User                     @relation("ProducerOrgOwner", fields: [ownerUserId], references: [id], onDelete: Cascade)
  products             AuthProduct[]
  factories            ProducerFactory[]
  staff                ProducerOrgStaff[]
  staffInvites         ProducerStaffInvite[]
  documents            ProducerOrgDocument[]
  auditLogs            ProducerAuditLog[]
  approvals            ProducerApproval[]
  printEmailRecipients ProducerEmailRecipient[]
  featureFlags         OrgFeatureFlag[]
  quotas               OrgQuota[]
  governanceIncidents  GovernanceIncident[]
  complaintCases       ComplaintCase[]
  supportTickets       SupportTicket[]

  @@index([ownerUserId])
  @@map("producer_orgs")
}

// Governance incidents (Phase 4: enforcement audit trail)
model GovernanceIncident {
  id               Int       @id @default(autoincrement())
  entityType       String    @db.VarChar(64)
  entityId         Int
  producerOrgId    Int
  incidentType     String    @db.VarChar(64)
  severity         String    @db.VarChar(16)
  actionTaken      String    @db.VarChar(64)
  reason           String    @db.Text
  ticketId         String?   @db.VarChar(128)
  createdByUserId  Int
  resolvedAt       DateTime?
  resolvedByUserId Int?
  resolutionNote   String?   @db.Text
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  producerOrg ProducerOrg @relation(fields: [producerOrgId], references: [id], onDelete: Cascade)

  @@index([producerOrgId])
  @@index([entityType, entityId])
  @@index([incidentType])
  @@map("governance_incidents")
}

// Trust & Safety / Enforcement: case-centric complaint and enforcement
model ComplaintCase {
  id               Int       @id @default(autoincrement())
  caseNo           String    @unique @db.VarChar(32)
  source           String    @db.VarChar(32) // CONSUMER | ADMIN | PARTNER | AUTO
  entityType       String    @db.VarChar(32) // CODE | BATCH | PRODUCT | ORG
  entityId         String    @db.VarChar(128)
  producerOrgId    Int
  status           String    @default("OPEN") @db.VarChar(32)
  severity         String    @default("MEDIUM") @db.VarChar(16)
  summary          String    @db.VarChar(256)
  details          String?   @db.Text
  assignedToUserId Int?
  resolvedAt       DateTime?
  resolvedByUserId Int?
  resolutionNote   String?   @db.Text
  createdByUserId  Int
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  producerOrg      ProducerOrg         @relation(fields: [producerOrgId], references: [id])
  evidence         CaseEvidence[]
  actions          EnforcementAction[]
  escalatedTickets SupportTicket[]     @relation("TicketEscalatedToCase")

  @@index([producerOrgId])
  @@index([entityType, entityId])
  @@index([status])
  @@index([severity])
  @@index([caseNo])
  @@map("complaint_cases")
}

model CaseEvidence {
  id              Int      @id @default(autoincrement())
  caseId          Int
  type            String   @db.VarChar(16)
  url             String?  @db.Text
  note            String?  @db.Text
  createdByUserId Int
  createdAt       DateTime @default(now())

  case ComplaintCase @relation(fields: [caseId], references: [id], onDelete: Cascade)

  @@index([caseId])
  @@map("case_evidence")
}

model EnforcementAction {
  id               Int       @id @default(autoincrement())
  caseId           Int
  targetType       String    @db.VarChar(32)
  targetId         String    @db.VarChar(128)
  actionType       String    @db.VarChar(64)
  reason           String    @db.Text
  meta             Json?
  status           String    @default("APPLIED") @db.VarChar(16)
  appliedByUserId  Int
  appliedAt        DateTime  @default(now())
  revertedByUserId Int?
  revertedAt       DateTime?
  revertNote       String?   @db.Text

  case ComplaintCase @relation(fields: [caseId], references: [id])

  @@index([caseId])
  @@index([targetType, targetId])
  @@index([actionType])
  @@map("enforcement_actions")
}

// Support ticketing (Phase 1 MVP)
enum TicketCategory {
  BATCH_CODE
  PRODUCT_GOVERNANCE
  ACCOUNT_KYC
  PAYMENT
  TECHNICAL
  FRAUD_ABUSE
  OTHER
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  WAITING_ON_PRODUCER
  RESOLVED
  CLOSED
  ESCALATED
}

enum TicketMessageSenderType {
  PRODUCER
  ADMIN
  SYSTEM
}

enum TicketAuditEventType {
  STATUS_CHANGED
  ASSIGNED
  PRIORITY_CHANGED
  CATEGORY_CHANGED
  ESCALATED
  CLOSED
  REOPENED
}

model SupportTicket {
  id                Int            @id @default(autoincrement())
  ticketNo          String         @unique @db.VarChar(32)
  producerOrgId     Int
  createdByUserId   Int
  category          TicketCategory
  priority          TicketPriority
  subject           String         @db.VarChar(512)
  description       String         @db.Text
  status            TicketStatus   @default(OPEN)
  assignedToUserId  Int?
  relatedEntityType String?        @db.VarChar(32)
  relatedEntityId   String?        @db.VarChar(128)
  consentToViewData Boolean        @default(false)
  slaBreachedAt     DateTime?
  escalatedCaseId   Int?
  closedAt          DateTime?
  resolvedAt        DateTime?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  producerOrg   ProducerOrg        @relation(fields: [producerOrgId], references: [id], onDelete: Cascade)
  createdBy     User               @relation("SupportTicketCreatedBy", fields: [createdByUserId], references: [id], onDelete: Restrict)
  assignedTo    User?              @relation("SupportTicketAssignedTo", fields: [assignedToUserId], references: [id], onDelete: SetNull)
  escalatedCase ComplaintCase?     @relation("TicketEscalatedToCase", fields: [escalatedCaseId], references: [id], onDelete: SetNull)
  messages      TicketMessage[]
  auditEvents   TicketAuditEvent[]

  @@index([producerOrgId])
  @@index([status, priority])
  @@index([ticketNo])
  @@index([relatedEntityType, relatedEntityId])
  @@index([assignedToUserId])
  @@map("support_tickets")
}

model TicketMessage {
  id           Int                     @id @default(autoincrement())
  ticketId     Int
  senderType   TicketMessageSenderType
  senderUserId Int?
  message      String                  @db.Text
  isInternal   Boolean                 @default(false)
  createdAt    DateTime                @default(now())

  ticket      SupportTicket      @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  sender      User?              @relation(fields: [senderUserId], references: [id], onDelete: SetNull)
  attachments TicketAttachment[]

  @@index([ticketId])
  @@map("ticket_messages")
}

model TicketAttachment {
  id               Int      @id @default(autoincrement())
  ticketMessageId  Int
  fileKey          String   @db.VarChar(512)
  fileName         String   @db.VarChar(255)
  mimeType         String?  @db.VarChar(128)
  fileSize         Int?
  uploadedByUserId Int?
  createdAt        DateTime @default(now())

  ticketMessage TicketMessage @relation(fields: [ticketMessageId], references: [id], onDelete: Cascade)
  uploadedBy    User?         @relation(fields: [uploadedByUserId], references: [id], onDelete: SetNull)

  @@index([ticketMessageId])
  @@map("ticket_attachments")
}

model TicketAuditEvent {
  id          Int                  @id @default(autoincrement())
  ticketId    Int
  eventType   TicketAuditEventType
  meta        Json?
  actorUserId Int?
  createdAt   DateTime             @default(now())

  ticket SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  actor  User?         @relation(fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([ticketId])
  @@index([actorUserId])
  @@map("ticket_audit_events")
}

// Saved email recipients for Producer Print (Email CSV export)
model ProducerEmailRecipient {
  id              Int      @id @default(autoincrement())
  producerOrgId   Int
  email           String
  label           String?
  createdByUserId Int?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  producerOrg ProducerOrg @relation(fields: [producerOrgId], references: [id], onDelete: Cascade)
  createdBy   User?       @relation("ProducerEmailRecipientCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)

  @@unique([producerOrgId, email])
  @@index([producerOrgId])
  @@map("producer_email_recipients")
}

// Producer-scoped factory (verified manufacturing facility for product approval)
model ProducerFactory {
  id            Int      @id @default(autoincrement())
  producerOrgId Int
  name          String
  addressJson   Json?
  countryCode   String?
  isVerified    Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  producerOrg  ProducerOrg   @relation(fields: [producerOrgId], references: [id], onDelete: Cascade)
  authProducts AuthProduct[]

  @@index([producerOrgId])
  @@map("producer_factories")
}

// Producer KYC: formal document model (unified with VerificationCase + VerificationDocument)
model ProducerOrgDocument {
  id            Int            @id @default(autoincrement())
  producerOrgId Int
  type          DocumentType
  status        DocumentStatus @default(SUBMITTED)

  mediaId Int
  media   Media @relation(fields: [mediaId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  producerOrg ProducerOrg @relation(fields: [producerOrgId], references: [id], onDelete: Cascade)

  @@index([producerOrgId])
  @@index([type])
  @@map("producer_org_documents")
}

enum ProducerOrgStaffStatus {
  INVITED
  ACTIVE
  SUSPENDED
  DISABLED
  REMOVED
}

model ProducerOrgStaff {
  id            Int                    @id @default(autoincrement())
  producerOrgId Int
  userId        Int
  roleId        Int
  invitedBy     Int?
  status        ProducerOrgStaffStatus @default(ACTIVE)
  createdAt     DateTime               @default(now())
  updatedAt     DateTime               @updatedAt

  producerOrg ProducerOrg @relation(fields: [producerOrgId], references: [id], onDelete: Cascade)
  user        User        @relation("ProducerStaffUser", fields: [userId], references: [id], onDelete: Cascade)
  role        Role        @relation("ProducerStaffRole", fields: [roleId], references: [id])
  inviter     User?       @relation("ProducerStaffInviter", fields: [invitedBy], references: [id], onDelete: SetNull)

  @@unique([producerOrgId, userId])
  @@index([userId])
  @@index([roleId])
  @@index([status])
  @@map("producer_org_staff")
}

// Producer staff invitation (email/phone; registered → notification accept, unregistered → token link → register → accept)
enum ProducerStaffInviteStatus {
  PENDING
  SENT
  ACCEPTED
  DECLINED
  EXPIRED
  CANCELLED
  DELETED
}

model ProducerStaffInvite {
  id               Int                       @id @default(autoincrement())
  producerOrgId    Int
  invitedByUserId  Int
  email            String?
  phone            String?
  roleId           Int
  status           ProducerStaffInviteStatus @default(PENDING)
  tokenHash        String?                   @db.VarChar(255)
  expiresAt        DateTime
  acceptedByUserId Int?
  createdAt        DateTime                  @default(now())
  updatedAt        DateTime                  @updatedAt

  producerOrg ProducerOrg                   @relation(fields: [producerOrgId], references: [id], onDelete: Cascade)
  invitedBy   User                          @relation("ProducerStaffInviteInvitedBy", fields: [invitedByUserId], references: [id], onDelete: Restrict)
  role        Role                          @relation(fields: [roleId], references: [id], onDelete: Restrict)
  acceptedBy  User?                         @relation("ProducerStaffInviteAcceptedBy", fields: [acceptedByUserId], references: [id], onDelete: SetNull)
  deliveries  ProducerStaffInviteDelivery[]

  @@unique([producerOrgId, email], map: "producer_staff_invite_producer_org_email_unique")
  @@unique([producerOrgId, phone], map: "producer_staff_invite_producer_org_phone_unique")
  @@index([producerOrgId, status])
  @@index([email])
  @@index([phone])
  @@index([expiresAt])
  @@map("producer_staff_invites")
}

model ProducerStaffInviteDelivery {
  id           Int       @id @default(autoincrement())
  inviteId     Int
  channel      String    @db.VarChar(32)
  to           String    @db.VarChar(255)
  provider     String?   @db.VarChar(64)
  status       String    @db.VarChar(32)
  attemptCount Int       @default(0)
  lastError    String?   @db.Text
  messageId    String?   @db.VarChar(255)
  sentAt       DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  invite ProducerStaffInvite @relation(fields: [inviteId], references: [id], onDelete: Cascade)

  @@index([inviteId])
  @@index([status])
  @@map("producer_staff_invite_deliveries")
}

model ProducerAuditLog {
  id            Int      @id @default(autoincrement())
  producerOrgId Int
  actorType     String // OWNER | STAFF
  actorId       Int
  action        String
  entityType    String
  entityId      String?
  createdAt     DateTime @default(now())

  producerOrg ProducerOrg @relation(fields: [producerOrgId], references: [id], onDelete: Cascade)

  @@index([producerOrgId])
  @@index([producerOrgId, action, createdAt])
  @@index([actorId])
  @@index([createdAt])
  @@map("producer_audit_logs")
}

enum ProducerApprovalEntityType {
  PRODUCT
  BATCH
}

enum ProducerApprovalStatus {
  SUBMITTED
  APPROVED
  REJECTED
}

model ProducerApproval {
  id                Int                        @id @default(autoincrement())
  producerOrgId     Int
  entityType        ProducerApprovalEntityType
  entityId          Int
  status            ProducerApprovalStatus     @default(SUBMITTED)
  submittedByUserId Int
  reviewedByUserId  Int?
  assignedToUserId  Int?
  assignedAt        DateTime?
  slaDeadline       DateTime?
  stage             String?                    @db.VarChar(32)
  note              String?                    @db.Text
  reviewedAt        DateTime?
  overrideNote      String?                    @db.Text // Phase 3: compliance override note
  overrideAt        DateTime?
  overrideByUserId  Int?
  createdAt         DateTime                   @default(now())
  updatedAt         DateTime                   @updatedAt

  producerOrg ProducerOrg @relation(fields: [producerOrgId], references: [id], onDelete: Cascade)

  @@unique([producerOrgId, entityType, entityId], map: "producer_approvals_unique_entity")
  @@index([producerOrgId, status])
  @@index([producerOrgId, entityType])
  @@index([assignedToUserId])
  @@index([slaDeadline])
  @@index([stage])
  @@map("producer_approvals")
}

// Producer Governance (Phase 1): audit, feature flags, quotas
enum OrgQuotaResetPeriod {
  DAILY
  MONTHLY
}

model AuditEvent {
  id          Int      @id @default(autoincrement())
  actorUserId Int?
  actorRole   String   @db.VarChar(64)
  actionKey   String   @db.VarChar(128)
  entityType  String   @db.VarChar(64)
  entityId    String?  @db.VarChar(128)
  orgId       Int?
  metadata    Json?
  traceId     String?  @db.VarChar(128)
  ip          String?  @db.VarChar(64)
  createdAt   DateTime @default(now())

  @@index([orgId, createdAt])
  @@index([entityType, entityId])
  @@index([actorUserId, createdAt])
  @@index([actionKey, createdAt])
  @@index([traceId])
  @@map("audit_events")
}

model OrgFeatureFlag {
  id              Int      @id @default(autoincrement())
  producerOrgId   Int
  key             String   @db.VarChar(128)
  enabled         Boolean  @default(true)
  updatedByUserId Int?
  updatedAt       DateTime @updatedAt
  createdAt       DateTime @default(now())

  producerOrg ProducerOrg @relation(fields: [producerOrgId], references: [id], onDelete: Cascade)
  updatedBy   User?       @relation("OrgFeatureFlagUpdatedBy", fields: [updatedByUserId], references: [id], onDelete: SetNull)

  @@unique([producerOrgId, key], map: "org_feature_flags_org_key_unique")
  @@index([producerOrgId])
  @@index([key])
  @@map("org_feature_flags")
}

model OrgQuota {
  id              Int                 @id @default(autoincrement())
  producerOrgId   Int
  key             String              @db.VarChar(128)
  limit           Int
  used            Int                 @default(0)
  resetPeriod     OrgQuotaResetPeriod @default(DAILY)
  updatedByUserId Int?
  updatedAt       DateTime            @updatedAt
  createdAt       DateTime            @default(now())

  producerOrg ProducerOrg @relation(fields: [producerOrgId], references: [id], onDelete: Cascade)
  updatedBy   User?       @relation("OrgQuotaUpdatedBy", fields: [updatedByUserId], references: [id], onDelete: SetNull)

  @@unique([producerOrgId, key], map: "org_quotas_org_key_unique")
  @@index([producerOrgId])
  @@index([key])
  @@index([resetPeriod])
  @@map("org_quotas")
}

model AuthProduct {
  id                             Int               @id @default(autoincrement())
  producerOrgId                  Int
  factoryId                      Int?
  brandName                      String
  productName                    String
  productType                    String? // PET_FOOD, MEDICINE, SUPPLEMENT, ACCESSORY, LIVE_ANIMAL, OTHER
  sku                            String
  packSize                       String?
  description                    String?
  specJson                       Json? // net weight/volume, ingredients, shelf-life, country of origin, HS code, etc.
  status                         AuthProductStatus @default(DRAFT)
  submittedAt                    DateTime?
  reviewedAt                     DateTime?
  reviewedByAdminId              Int?
  reviewNotes                    String?           @db.Text // rejection reason / admin notes
  ownershipDeclarationAcceptedAt DateTime?
  createdByUserId                Int?
  createdAt                      DateTime          @default(now())
  updatedAt                      DateTime          @updatedAt

  producerOrg ProducerOrg        @relation(fields: [producerOrgId], references: [id], onDelete: Cascade)
  factory     ProducerFactory?   @relation(fields: [factoryId], references: [id], onDelete: SetNull)
  createdBy   User?              @relation("AuthProductCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  batches     AuthBatch[]
  proofs      AuthProductProof[]
  revisions   ProductRevision[]

  @@unique([producerOrgId, sku])
  @@index([producerOrgId])
  @@index([factoryId])
  @@index([status])
  @@map("auth_products")
}

model ProductRevision {
  id                Int      @id @default(autoincrement())
  authProductId     Int
  revisionNumber    Int
  snapshotJson      Json
  submittedByUserId Int
  approvalId        Int?
  createdAt         DateTime @default(now())

  authProduct AuthProduct @relation(fields: [authProductId], references: [id], onDelete: Cascade)

  @@unique([authProductId, revisionNumber])
  @@index([authProductId])
  @@index([approvalId])
  @@map("product_revisions")
}

// Proof pack and fingerprints for verification & anti-copy
model AuthProductProof {
  id              Int      @id @default(autoincrement())
  authProductId   Int
  proofType       String // LABEL_FRONT, LABEL_BACK, MANUFACTURING_LICENSE, etc. (align with DocumentType or freeform)
  mediaId         Int
  metadataJson    Json? // docNumber, issueDate, expiryDate, issuing authority
  labelHash       String? // image/content hash for duplicate detection
  textFingerprint String?  @db.Text
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  authProduct AuthProduct @relation(fields: [authProductId], references: [id], onDelete: Cascade)
  media       Media       @relation(fields: [mediaId], references: [id], onDelete: Cascade)

  @@index([authProductId])
  @@index([proofType])
  @@map("auth_product_proofs")
}

model AuthBatch {
  id                Int             @id @default(autoincrement())
  authProductId     Int
  batchNo           String
  mfgDate           DateTime?
  expDate           DateTime?
  qtyPlanned        Int
  qtyGenerated      Int             @default(0)
  status            AuthBatchStatus @default(DRAFT)
  createdByUserId   Int?
  submittedAt       DateTime?
  reviewedAt        DateTime?
  reviewedByAdminId Int?
  reviewNotes       String?         @db.Text
  voidedAt          DateTime?
  voidedByUserId    Int?
  voidReason        String?         @db.Text
  frozenAt          DateTime? // Phase 4: block print/export when set
  quarantinedAt     DateTime? // Trust & Safety: block verifications when set
  printedAt         DateTime?
  printedByUserId   Int?
  printCount        Int             @default(0)
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  authProduct    AuthProduct                @relation(fields: [authProductId], references: [id], onDelete: Cascade)
  createdBy      User?                      @relation("AuthBatchCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  printedBy      User?                      @relation("AuthBatchPrintedBy", fields: [printedByUserId], references: [id], onDelete: SetNull)
  codes          AuthCode[]
  serialState    BatchSerialState?
  allocationLogs BatchSerialAllocationLog[]

  @@index([authProductId])
  @@index([status])
  @@map("auth_batches")
}

enum BatchSerialAllocationActionType {
  PRINT
  DOWNLOAD_EXPORT
  EMAIL_EXPORT
}

enum BatchSerialAllocationFileType {
  CSV
  XLSX
}

enum BatchSerialAllocationStatus {
  ISSUED
  REVOKED
}

model BatchSerialState {
  id                  Int      @id @default(autoincrement())
  batchId             Int      @unique
  lastAllocatedSerial Int      @default(0)
  allocatedCount      Int      @default(0)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  batch AuthBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)

  @@map("batch_serial_states")
}

model BatchSerialAllocationLog {
  id                Int                             @id @default(autoincrement())
  batchId           Int
  startSerial       Int
  endSerial         Int
  quantity          Int
  actionType        BatchSerialAllocationActionType
  fileType          BatchSerialAllocationFileType?
  targetEmail       String?
  allocatedByUserId Int?
  status            BatchSerialAllocationStatus     @default(ISSUED)
  revokedAt         DateTime?
  revokedByUserId   Int?
  revokeReason      String?
  createdAt         DateTime                        @default(now())

  batch       AuthBatch  @relation(fields: [batchId], references: [id], onDelete: Cascade)
  allocatedBy User?      @relation("BatchSerialAllocationAllocatedBy", fields: [allocatedByUserId], references: [id], onDelete: SetNull)
  revokedBy   User?      @relation("BatchSerialAllocationRevokedBy", fields: [revokedByUserId], references: [id], onDelete: SetNull)
  codes       AuthCode[]

  @@index([batchId])
  @@index([allocatedByUserId])
  @@index([revokedByUserId])
  @@map("batch_serial_allocation_logs")
}

model AuthCode {
  id                    Int                              @id @default(autoincrement())
  batchId               Int
  codeHash              String                           @unique
  codeLength            Int                              @default(12)
  customPrefix          String?
  customSuffix          String?
  codeCipher            String
  codeIv                String
  codeTag               String
  status                AuthCodeStatus                   @default(UNUSED)
  printedAt             DateTime?
  exportedAt            DateTime?
  verifyCount           Int                              @default(0)
  firstVerifiedAt       DateTime?
  firstVerifiedIp       String?
  firstVerifiedCountry  String?
  generatedByUserId     Int?
  issuedAt              DateTime?
  issuedByUserId        Int?
  issuedMethod          BatchSerialAllocationActionType?
  issuedToEmail         String?
  issuedAllocationLogId Int?
  createdAt             DateTime                         @default(now())

  batch               AuthBatch                 @relation(fields: [batchId], references: [id], onDelete: Cascade)
  generatedBy         User?                     @relation("AuthCodeGeneratedBy", fields: [generatedByUserId], references: [id], onDelete: SetNull)
  issuedBy            User?                     @relation("AuthCodeIssuedBy", fields: [issuedByUserId], references: [id], onDelete: SetNull)
  issuedAllocationLog BatchSerialAllocationLog? @relation(fields: [issuedAllocationLogId], references: [id], onDelete: SetNull)
  logs                AuthVerificationLog[]

  @@index([batchId])
  @@index([status])
  @@index([issuedAllocationLogId])
  @@map("auth_codes")
}

model AuthVerificationLog {
  id               Int              @id @default(autoincrement())
  codeId           Int?
  publicCodeMasked String
  deviceId         String?
  ip               String?
  country          String?
  userId           Int?
  result           AuthVerifyResult
  createdAt        DateTime         @default(now())

  code AuthCode? @relation(fields: [codeId], references: [id], onDelete: SetNull)
  user User?     @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([codeId])
  @@map("auth_verification_logs")
}

// ============================
// Product Authenticity + Serial Issuance (MVP)
// ============================

enum ProductVersionStatus {
  DRAFT
  PENDING
  APPROVED
  REJECTED
}

enum BatchStatus {
  PENDING
  APPROVED
  ISSUED
  CLOSED
}

enum SerialStatus {
  ISSUED
  ACTIVATED
  SOLD
  VOID
  RECALLED
}

enum ScanAction {
  PRODUCED
  SHIPPED
  RECEIVED
  SOLD
  VERIFY
}

enum ScanActorRole {
  FACTORY
  DISTRIBUTOR
  RETAILER
  CUSTOMER
  ADMIN
}

enum LocationPrecisionLevel {
  COARSE
  MEDIUM
  PRECISE
}

enum LocationConsentLevel {
  NONE
  COARSE
  PRECISE_WHEN_USING
  ALWAYS
}

enum LocationSource {
  GPS
  IP
  MANUAL
  WIFI
  CELL
}

enum LocationEventType {
  PING
  SIGNIFICANT_MOVE
  MANUAL_SET
  HOME_SET
}

model Factory {
  id          Int      @id @default(autoincrement())
  orgId       Int
  name        String
  countryCode String?
  addressJson Json?
  isVerified  Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  org     Organization     @relation(fields: [orgId], references: [id], onDelete: Cascade)
  lines   ProductionLine[]
  batches Batch[]

  @@index([orgId])
  @@map("factories")
}

model ProductionLine {
  id        Int      @id @default(autoincrement())
  factoryId Int
  lineCode  String
  deviceId  String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  factory Factory @relation(fields: [factoryId], references: [id], onDelete: Cascade)
  batches Batch[]

  @@unique([factoryId, lineCode])
  @@index([factoryId])
  @@map("production_lines")
}

model ProductVersion {
  id              Int                  @id @default(autoincrement())
  productId       Int
  version         Int
  status          ProductVersionStatus @default(DRAFT)
  description     String?
  specJson        Json?
  createdByUserId Int?
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt

  product     Product             @relation(fields: [productId], references: [id], onDelete: Cascade)
  packaging   PackagingTemplate?
  fingerprint ProductFingerprint?
  batches     Batch[]
  createdBy   User?               @relation("ProductVersionCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)

  @@unique([productId, version])
  @@index([productId, status])
  @@map("product_versions")
}

model PackagingTemplate {
  id               Int      @id @default(autoincrement())
  productVersionId Int      @unique
  templateJson     Json
  status           String   @default("DRAFT")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  productVersion ProductVersion @relation(fields: [productVersionId], references: [id], onDelete: Cascade)

  @@map("packaging_templates")
}

model ProductFingerprint {
  id               Int      @id @default(autoincrement())
  productVersionId Int      @unique
  textHash         String?
  imageHash        String?
  specHash         String?
  similarityScore  Decimal? @db.Decimal(5, 2)
  createdAt        DateTime @default(now())

  productVersion ProductVersion @relation(fields: [productVersionId], references: [id], onDelete: Cascade)

  @@map("product_fingerprints")
}

model Contract {
  id               Int       @id @default(autoincrement())
  orgId            Int
  startDate        DateTime?
  endDate          DateTime?
  allowedCountries Json?
  channels         Json?
  status           String    @default("ACTIVE")
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  org        Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  quotaPlans QuotaPlan[]

  @@index([orgId])
  @@map("contracts")
}

model QuotaPlan {
  id         Int      @id @default(autoincrement())
  contractId Int
  productId  Int
  perMonth   Int?
  perBatch   Int?
  createdAt  DateTime @default(now())

  contract Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)
  product  Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([contractId])
  @@index([productId])
  @@map("quota_plans")
}

model QuotaUsage {
  id           Int      @id @default(autoincrement())
  batchId      Int      @unique
  issuedQty    Int      @default(0)
  remainingQty Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  batch Batch @relation(fields: [batchId], references: [id], onDelete: Cascade)

  @@map("quota_usages")
}

model Batch {
  id               Int         @id @default(autoincrement())
  productVersionId Int
  factoryId        Int
  lineId           Int?
  status           BatchStatus @default(PENDING)
  requestedQty     Int
  approvedQty      Int?
  mfgDate          DateTime?
  expDate          DateTime?
  createdByUserId  Int?
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  productVersion ProductVersion  @relation(fields: [productVersionId], references: [id], onDelete: Cascade)
  factory        Factory         @relation(fields: [factoryId], references: [id], onDelete: Restrict)
  line           ProductionLine? @relation(fields: [lineId], references: [id], onDelete: SetNull)
  createdBy      User?           @relation("BatchCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  serialRanges   SerialRange[]
  serials        Serial[]
  quotaUsage     QuotaUsage?

  @@index([productVersionId])
  @@index([factoryId])
  @@index([status])
  @@map("batches")
}

model SerialRange {
  id             Int      @id @default(autoincrement())
  batchId        Int
  qty            Int
  issuedAt       DateTime @default(now())
  issuedByUserId Int?
  status         String   @default("ISSUED")

  batch    Batch @relation(fields: [batchId], references: [id], onDelete: Cascade)
  issuedBy User? @relation("SerialRangeIssuedBy", fields: [issuedByUserId], references: [id], onDelete: SetNull)

  @@index([batchId])
  @@map("serial_ranges")
}

model Serial {
  id               Int          @id @default(autoincrement())
  batchId          Int
  serialCode       String       @unique
  signature        String
  status           SerialStatus @default(ISSUED)
  firstScanAt      DateTime?
  firstScanCountry String?
  firstScanDevice  String?
  createdAt        DateTime     @default(now())

  batch      Batch       @relation(fields: [batchId], references: [id], onDelete: Cascade)
  scanEvents ScanEvent[]

  @@index([batchId])
  @@map("serials")
}

model ScanEvent {
  id          Int           @id @default(autoincrement())
  serialId    Int
  actorRole   ScanActorRole
  action      ScanAction
  countryCode String?
  deviceId    String?
  metaJson    Json?
  createdAt   DateTime      @default(now())

  serial Serial @relation(fields: [serialId], references: [id], onDelete: Cascade)

  @@index([serialId, createdAt])
  @@map("scan_events")
}

// ============================
// OWNER DELEGATION & TEAM MANAGEMENT
// ============================
// Extends owner capabilities: teams, delegated scopes, overview/audit.
// No modifications to existing tables. Backward compatible.

model OwnerTeam {
  id          Int      @id @default(autoincrement())
  ownerUserId Int
  name        String   @db.VarChar(255)
  description String?  @db.Text
  scopes      Json? // optional array of scope keys: products, inventory, staff, branches, etc.
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  owner           User              @relation(fields: [ownerUserId], references: [id], onDelete: Cascade)
  members         OwnerTeamMember[]
  delegations     OwnerDelegation[]
  teamInvitations TeamInvitation[]
  userContexts    UserContext[]

  @@unique([ownerUserId, name])
  @@index([ownerUserId])
  @@map("owner_teams")
}

model OwnerTeamMember {
  id         Int      @id @default(autoincrement())
  teamId     Int
  userId     Int
  roleInTeam String?  @db.VarChar(64) // LEAD, MEMBER, etc. (optional)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  team OwnerTeam @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([teamId, userId])
  @@index([userId])
  @@index([teamId])
  @@map("owner_team_members")
}

/// Reference table for delegation scopes: products, clinics, inventory, staff, branches, finance_read
model OwnerPermissionScope {
  id         Int      @id @default(autoincrement())
  key        String   @unique @db.VarChar(64)
  label      String   @db.VarChar(255)
  isReadOnly Boolean  @default(false) // finance_read is read-only
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("owner_permission_scopes")
}

model OwnerDelegation {
  id              Int      @id @default(autoincrement())
  ownerUserId     Int
  delegatedUserId Int
  scopeKey        String   @db.VarChar(64) // products, clinics, inventory, staff, branches, finance_read
  orgId           Int? // null = all orgs under owner
  branchId        Int? // null = all branches in org
  teamId          Int? // optional: which team this delegation belongs to
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  owner         User          @relation("OwnerDelegationOwner", fields: [ownerUserId], references: [id], onDelete: Cascade)
  delegatedUser User          @relation("OwnerDelegationDelegate", fields: [delegatedUserId], references: [id], onDelete: Cascade)
  org           Organization? @relation(fields: [orgId], references: [id], onDelete: Cascade)
  branch        Branch?       @relation(fields: [branchId], references: [id], onDelete: Cascade)
  team          OwnerTeam?    @relation(fields: [teamId], references: [id], onDelete: SetNull)

  @@unique([ownerUserId, delegatedUserId, scopeKey, orgId, branchId])
  @@index([ownerUserId])
  @@index([delegatedUserId])
  @@index([scopeKey])
  @@map("owner_delegations")
}

model OwnerOverviewLog {
  id          Int      @id @default(autoincrement())
  ownerUserId Int
  actorUserId Int?
  action      String   @db.VarChar(128) // DELEGATION_ASSIGNED, DELEGATION_REVOKED, TEAM_CREATED, etc.
  meta        Json?
  createdAt   DateTime @default(now())

  owner User  @relation("OwnerOverviewLogOwner", fields: [ownerUserId], references: [id], onDelete: Cascade)
  actor User? @relation("OwnerOverviewLogActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([ownerUserId])
  @@index([actorUserId])
  @@index([createdAt])
  @@map("owner_overview_logs")
}

// Multi-context: user's active contexts (branch, team, owner, roles, scopes)
model UserContext {
  id               Int      @id @default(autoincrement())
  userId           Int
  ownerUserId      Int? // null = user is the owner; set when delegate
  branchId         Int?
  teamId           Int?
  roles            Json? // string[] e.g. ["BRANCH_MANAGER", "STAFF"]
  scopes           Json? // string[] e.g. ["products", "inventory"]
  defaultDashboard String?  @db.VarChar(64) // owner | branch | staff
  isDefault        Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user   User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  owner  User?      @relation("UserContextOwner", fields: [ownerUserId], references: [id], onDelete: Cascade)
  branch Branch?    @relation(fields: [branchId], references: [id], onDelete: Cascade)
  team   OwnerTeam? @relation(fields: [teamId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([ownerUserId])
  @@index([branchId])
  @@map("user_contexts")
}

enum TeamInvitationStatus {
  PENDING
  ACCEPTED
  REVOKED
  EXPIRED
}

// Team email invitation: owner invites by email to a team; token one-time use, hashed
model TeamInvitation {
  id               Int                  @id @default(autoincrement())
  ownerUserId      Int
  teamId           Int
  email            String               @db.VarChar(255)
  tokenHash        String               @unique
  status           TeamInvitationStatus @default(PENDING)
  expiresAt        DateTime
  scopes           Json? // string[] scope keys to assign on accept
  branchIds        Json? // number[] optional branch IDs to link
  invitedByUserId  Int
  acceptedByUserId Int?
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt

  owner      User      @relation("TeamInvitationOwner", fields: [ownerUserId], references: [id], onDelete: Cascade)
  team       OwnerTeam @relation(fields: [teamId], references: [id], onDelete: Cascade)
  invitedBy  User      @relation("TeamInvitationInvitedBy", fields: [invitedByUserId], references: [id], onDelete: Restrict)
  acceptedBy User?     @relation("TeamInvitationAcceptedBy", fields: [acceptedByUserId], references: [id], onDelete: SetNull)

  @@index([ownerUserId])
  @@index([teamId])
  @@index([email])
  @@index([status])
  @@map("team_invitations")
}

// ============================
// Clinic Medicine Leakage Control (CCMLPA) — Smart Vial Control & Audit
// ============================

enum MedicineDestructionRule {
  AFTER_RETENTION
  IMMEDIATE_ON_EXPIRY
  MANUAL_APPROVAL_ONLY
}

enum VialStatus {
  SEALED
  ISSUED
  OPENED
  PARTIALLY_USED
  EXHAUSTED
  RETURNED
  QUARANTINED
  DESTROYED
}

enum VialHolderType {
  PHARMACY
  ROOM
  STAFF
  AUDIT_BIN
}

enum DispenseStatus {
  PENDING
  APPROVED
  ISSUED
  PARTIALLY_ISSUED
  REJECTED
  CANCELLED
}

enum DispenseUrgencyLevel {
  NORMAL
  URGENT
  EMERGENCY
}

enum VialSessionStatus {
  ACTIVE
  PARTIALLY_USED
  EXHAUSTED
  EXPIRED
  RETURNED
  QUARANTINED
  DESTROYED
}

enum VialEventType {
  OPENED
  DOSE_USED
  RETURNED
  EXPIRED
  DESTROYED
  TRANSFERRED
  QUARANTINED
}

model MedicinePolicy {
  id                         Int                    @id @default(autoincrement())
  variantId                  Int                    @unique
  orgId                      Int
  reusableAfterOpen          Boolean                @default(false)
  openVialValidityHours      Int?                   // null = not reusable
  mixedSolutionValidityHours Int?
  returnRequired             Boolean                @default(true)
  retentionDays              Int                    @default(7)
  highRisk                   Boolean                @default(false)
  weightCheckRequired        Boolean                @default(false)
  photoRequiredOnReturn      Boolean                @default(false)
  dualApprovalRequired       Boolean                @default(false)
  destructionRule            MedicineDestructionRule @default(AFTER_RETENTION)
  maxDosePerAdministration   Decimal?               @db.Decimal(12, 4)
  createdAt                  DateTime               @default(now())
  updatedAt                  DateTime               @updatedAt

  variant ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)
  org     Organization   @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId])
  @@map("medicine_policies")
}

model VialInstance {
  id                Int            @id @default(autoincrement())
  variantId         Int
  lotId             Int?
  batchCode         String?        @db.VarChar(64)
  serialCode        String?        @unique @db.VarChar(128) // QR/barcode
  branchId          Int
  locationId         Int
  orgId             Int?
  status            VialStatus     @default(SEALED)
  currentHolderType VialHolderType @default(PHARMACY)
  currentHolderId   String?        @db.VarChar(64) // room id, user id, or bin id
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  variant  ProductVariant    @relation(fields: [variantId], references: [id], onDelete: Cascade)
  lot      StockLot?         @relation(fields: [lotId], references: [id], onDelete: SetNull)
  branch   Branch            @relation(fields: [branchId], references: [id], onDelete: Cascade)
  location InventoryLocation @relation(fields: [locationId], references: [id], onDelete: Restrict)
  org      Organization?     @relation(fields: [orgId], references: [id], onDelete: SetNull)
  dispenseRequestItems DispenseRequestItem[]
  vialSessions        VialSession[]

  @@index([branchId])
  @@index([variantId])
  @@index([lotId])
  @@index([locationId])
  @@index([status])
  @@map("vial_instances")
}

model DispenseRequest {
  id               Int                 @id @default(autoincrement())
  orgId            Int
  branchId         Int
  requestedByUserId Int
  patientId        Int?                // owner (User)
  visitId          Int?
  surgeryCaseId    Int?                // future Phase 3
  treatmentCourseId Int?              // Phase 2
  status           DispenseStatus      @default(PENDING)
  urgencyLevel     DispenseUrgencyLevel @default(NORMAL)
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt

  org       Organization    @relation(fields: [orgId], references: [id], onDelete: Cascade)
  branch    Branch          @relation(fields: [branchId], references: [id], onDelete: Cascade)
  requestedBy User          @relation("DispenseRequestRequestedBy", fields: [requestedByUserId], references: [id], onDelete: Restrict)
  patient   User?           @relation("DispenseRequestPatient", fields: [patientId], references: [id], onDelete: SetNull)
  visit     Visit?          @relation(fields: [visitId], references: [id], onDelete: SetNull)
  items     DispenseRequestItem[]

  @@index([branchId])
  @@index([orgId])
  @@index([visitId])
  @@index([status])
  @@index([requestedByUserId])
  @@map("dispense_requests")
}

model DispenseRequestItem {
  id               Int      @id @default(autoincrement())
  dispenseRequestId Int
  variantId        Int
  requestedQty     Int
  issuedQty        Int      @default(0)
  unit             String?  @db.VarChar(32)
  vialInstanceId   Int?
  reason           String?  @db.Text
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  dispenseRequest DispenseRequest @relation(fields: [dispenseRequestId], references: [id], onDelete: Cascade)
  variant        ProductVariant   @relation(fields: [variantId], references: [id], onDelete: Restrict)
  vialInstance   VialInstance?    @relation(fields: [vialInstanceId], references: [id], onDelete: SetNull)

  @@index([dispenseRequestId])
  @@index([variantId])
  @@map("dispense_request_items")
}

model VialSession {
  id              Int               @id @default(autoincrement())
  vialInstanceId  Int?
  variantId       Int
  lotId           Int?
  branchId        Int
  roomId          Int?
  openedByUserId  Int
  openedAt        DateTime          @default(now())
  validUntil      DateTime?
  openPhotoUrl    String?           @db.Text
  initialQty      Int               // in smallest unit (e.g. ml)
  remainingQty    Int
  status          VialSessionStatus @default(ACTIVE)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  vialInstance VialInstance?  @relation(fields: [vialInstanceId], references: [id], onDelete: SetNull)
  variant     ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)
  lot         StockLot?      @relation(fields: [lotId], references: [id], onDelete: SetNull)
  branch      Branch         @relation(fields: [branchId], references: [id], onDelete: Cascade)
  room        BranchRoom?    @relation(fields: [roomId], references: [id], onDelete: SetNull)
  openedBy    User           @relation("VialSessionOpenedBy", fields: [openedByUserId], references: [id], onDelete: Restrict)
  events      VialSessionEvent[]
  medicationAdministrations MedicationAdministration[]
  treatmentCourseDoses TreatmentCourseDose[]
  vialReturns VialReturn[]

  @@index([branchId])
  @@index([variantId])
  @@index([vialInstanceId])
  @@index([status])
  @@index([validUntil])
  @@map("vial_sessions")
}

model VialSessionEvent {
  id             Int          @id @default(autoincrement())
  vialSessionId  Int
  eventType      VialEventType
  quantityDelta  Int?         // negative for dose used
  performedByUserId Int?
  witnessUserId  Int?
  photoUrl       String?      @db.Text
  notes          String?      @db.Text
  createdAt      DateTime     @default(now())

  vialSession  VialSession @relation(fields: [vialSessionId], references: [id], onDelete: Cascade)
  performedBy  User?        @relation("VialSessionEventPerformedBy", fields: [performedByUserId], references: [id], onDelete: SetNull)

  @@index([vialSessionId])
  @@index([eventType])
  @@map("vial_session_events")
}

// ============================
// Phase 2: Dose consumption, treatment course, return & audit bin
// ============================

enum VialReturnCondition {
  EMPTY
  PARTIAL
  EXPIRED
  CONTAMINATED
  SUSPICIOUS
}

enum VialReturnVerificationStatus {
  PENDING
  VERIFIED
  QUARANTINED
  REJECTED
}

enum AuditBinType {
  EMPTY_VIAL
  PARTIAL_RETURN
  EXPIRED_MIXED
  QUARANTINE
}

enum AuditBinStatus {
  OPEN
  SEALED
  UNDER_REVIEW
  DESTROYED
}

enum AuditBinItemStatus {
  HELD
  VERIFIED
  DESTROYED
  ESCALATED
}

model MedicationAdministration {
  id                 Int       @id @default(autoincrement())
  patientId          Int
  visitId            Int?
  surgeryCaseId      Int?
  variantId          Int
  vialSessionId      Int?
  prescribedDose     Decimal?  @db.Decimal(12, 4)
  administeredDose   Decimal   @db.Decimal(12, 4)
  unit               String?   @db.VarChar(32)
  route              String?   @db.VarChar(64)
  administeredByUserId Int?
  witnessedByUserId  Int?
  administeredAt     DateTime  @default(now())
  createdAt          DateTime  @default(now())

  patient     User           @relation("MedicationAdminPatient", fields: [patientId], references: [id], onDelete: Restrict)
  visit       Visit?         @relation(fields: [visitId], references: [id], onDelete: SetNull)
  variant     ProductVariant @relation(fields: [variantId], references: [id], onDelete: Restrict)
  vialSession VialSession?   @relation(fields: [vialSessionId], references: [id], onDelete: SetNull)
  administeredBy User?      @relation("MedicationAdminBy", fields: [administeredByUserId], references: [id], onDelete: SetNull)

  @@index([patientId])
  @@index([visitId])
  @@index([variantId])
  @@index([vialSessionId])
  @@index([administeredAt])
  @@map("medication_administrations")
}

model SurgeryPackageTemplate {
  id          Int      @id @default(autoincrement())
  orgId       Int
  serviceId   Int?
  packageName String  @db.VarChar(128)
  surgeryType String? @db.VarChar(64)
  itemsJson   Json     // [{ variantId, minDose, maxDose, unit, weightBand? }]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  org     Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  service Service?     @relation(fields: [serviceId], references: [id], onDelete: SetNull)
  consumptions SurgeryPackageConsumption[]

  @@index([orgId])
  @@index([serviceId])
  @@map("surgery_package_templates")
}

model SurgeryPackageConsumption {
  id         Int     @id @default(autoincrement())
  visitId    Int
  templateId Int
  variantId  Int
  expectedDose Decimal? @db.Decimal(12, 4)
  actualDose   Decimal? @db.Decimal(12, 4)
  createdAt  DateTime @default(now())

  visit    Visit               @relation(fields: [visitId], references: [id], onDelete: Cascade)
  template SurgeryPackageTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  variant  ProductVariant      @relation(fields: [variantId], references: [id], onDelete: Restrict)

  @@index([visitId])
  @@index([templateId])
  @@map("surgery_package_consumptions")
}

// ============================
// Enterprise: Surgery Package + Discount + Doctor Settlement
// ============================

model SurgeryPackage {
  id                    Int          @id @default(autoincrement())
  orgId                 Int
  branchId              Int
  serviceId             Int
  packageCode           String       @unique @db.VarChar(32)
  packageName           String       @db.VarChar(128)
  packageType           PackageType  @default(STANDARD)
  baseSellingPrice      Decimal      @db.Decimal(12, 2)
  validFrom             DateTime?   @db.Date
  validTo               DateTime?   @db.Date
  doctorFeeAmount      Decimal?     @db.Decimal(12, 2)
  clinicFeeAmount      Decimal?     @db.Decimal(12, 2)
  consumableBlockAmount Decimal?     @db.Decimal(12, 2)
  medicationBlockAmount Decimal?     @db.Decimal(12, 2)
  supportFeeAmount      Decimal?     @db.Decimal(12, 2)
  estimatedCost         Decimal?     @db.Decimal(12, 2)
  emergencySurchargeRule Json?
  addOnAllowed          Boolean      @default(true)
  discountable          Boolean      @default(true)
  speciesCondition      Json?       // species/type filter
  status                String       @default("ACTIVE") @db.VarChar(16)
  createdAt             DateTime     @default(now())
  updatedAt             DateTime     @updatedAt

  // Enterprise: eligibility, availability, pricing control
  eligibilityRuleJson   Json?       // species, weight, age, sex, channels, emergency, inpatient, repeatable, consent, fasting, preCheckup
  availabilityRuleJson  Json?       // onlineVisible, internalOnly, staffQuickBooking, doctorRecommendation, posDirectSale, timeOfDay, dayOfWeek
  minSellingPrice       Decimal?    @db.Decimal(12, 2)
  maxDiscountPct        Decimal?    @db.Decimal(5, 2)
  maxDiscountAmount     Decimal?    @db.Decimal(12, 2)
  taxApplicable         Boolean     @default(false)
  branchOverrideAllowed Boolean     @default(false)
  description           String?     @db.Text
  publicDescription    String?     @db.Text
  internalNotes         String?     @db.Text
  department            String?     @db.VarChar(64)
  breedNote             String?     @db.VarChar(256)
  updatedByUserId       Int?
  effectiveFrom         DateTime?   @db.Date
  effectiveTo           DateTime?   @db.Date

  org            Organization     @relation(fields: [orgId], references: [id], onDelete: Cascade)
  branch         Branch           @relation(fields: [branchId], references: [id], onDelete: Cascade)
  service        Service          @relation(fields: [serviceId], references: [id], onDelete: Restrict)
  updatedBy      User?            @relation("SurgeryPackageUpdatedBy", fields: [updatedByUserId], references: [id], onDelete: SetNull)
  items          PackageItem[]
  priceRules     PackagePriceRule[]
  priceChangeLogs PackagePriceChangeLog[]
  auditLogs      PackageAuditLog[]
  procedureOrders ProcedureOrder[]
  clinicalCases   ClinicalCase[]
  clinicInvoices  ClinicInvoice[]
  doctorSettlementLedger DoctorSettlementLedger[]

  @@index([orgId, branchId])
  @@index([branchId, serviceId])
  @@index([packageCode])
  @@index([status])
  @@map("surgery_packages")
}

model PackageItem {
  id                   Int              @id @default(autoincrement())
  surgeryPackageId     Int
  itemType             PackageItemType
  productId            Int?
  variantId            Int?
  clinicalItemId       Int?
  clinicalItemVariantId Int?
  estimatedQty         Decimal?         @db.Decimal(12, 4)
  estimatedCost        Decimal?         @db.Decimal(12, 2)
  displayLabel         String?          @db.VarChar(128)
  sortOrder            Int              @default(0)
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt

  surgeryPackage   SurgeryPackage        @relation(fields: [surgeryPackageId], references: [id], onDelete: Cascade)
  product          Product?              @relation(fields: [productId], references: [id], onDelete: SetNull)
  variant          ProductVariant?       @relation(fields: [variantId], references: [id], onDelete: SetNull)
  clinicalItem     ClinicalItem?        @relation(fields: [clinicalItemId], references: [id], onDelete: SetNull)
  clinicalItemVariant ClinicalItemVariant? @relation(fields: [clinicalItemVariantId], references: [id], onDelete: SetNull)

  @@index([surgeryPackageId])
  @@map("package_items")
}

model PackagePriceRule {
  id               Int      @id @default(autoincrement())
  surgeryPackageId Int
  branchId         Int?
  species          String?  @db.VarChar(32)
  weightBandJson   Json?    // e.g. { minKg, maxKg }
  isEmergency      Boolean  @default(false)
  priceOverride    Decimal  @db.Decimal(12, 2)
  validFrom        DateTime? @db.Date
  validTo          DateTime? @db.Date
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  surgeryPackage SurgeryPackage @relation(fields: [surgeryPackageId], references: [id], onDelete: Cascade)
  branch         Branch?        @relation(fields: [branchId], references: [id], onDelete: SetNull)

  @@index([surgeryPackageId])
  @@index([branchId])
  @@map("package_price_rules")
}

model PackagePriceChangeLog {
  id               Int      @id @default(autoincrement())
  surgeryPackageId Int
  oldPrice         Decimal  @db.Decimal(12, 2)
  newPrice         Decimal  @db.Decimal(12, 2)
  changedByUserId  Int
  reason           String?  @db.VarChar(256)
  createdAt        DateTime @default(now())

  surgeryPackage SurgeryPackage @relation(fields: [surgeryPackageId], references: [id], onDelete: Cascade)
  changedBy      User          @relation("PackagePriceChangeLogBy", fields: [changedByUserId], references: [id], onDelete: Restrict)

  @@index([surgeryPackageId])
  @@map("package_price_change_logs")
}

// Enterprise: full audit trail for package lifecycle
model PackageAuditLog {
  id               Int      @id @default(autoincrement())
  surgeryPackageId Int
  action           String   @db.VarChar(32) // CREATE, UPDATE, ITEM_ADD, ITEM_REMOVE, PUBLISH, ARCHIVE, PRICE_CHANGE, STATUS_CHANGE
  userId           Int?
  meta             Json?    // { field, oldValue, newValue, itemId, etc. }
  createdAt        DateTime @default(now())

  surgeryPackage SurgeryPackage @relation(fields: [surgeryPackageId], references: [id], onDelete: Cascade)
  user            User?         @relation("PackageAuditLogBy", fields: [userId], references: [id], onDelete: SetNull)

  @@index([surgeryPackageId])
  @@index([createdAt])
  @@map("package_audit_logs")
}

model BranchOverheadRule {
  id          Int      @id @default(autoincrement())
  orgId       Int
  branchId    Int
  ruleType    String   @db.VarChar(32) // RENT, ELECTRICITY, STAFF, ADMIN, etc.
  amountType  String   @db.VarChar(16) // PERCENTAGE | FIXED
  amount      Decimal  @db.Decimal(12, 2)
  applicableFrom DateTime? @db.Date
  applicableTo   DateTime? @db.Date
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  org    Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  branch Branch       @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@index([branchId])
  @@map("branch_overhead_rules")
}

model DiscountPolicy {
  id                 Int                    @id @default(autoincrement())
  orgId              Int
  branchId           Int
  name               String                 @db.VarChar(128)
  discountType       DiscountType
  scope              DiscountScope
  calcType           DiscountCalcType
  maxPercent         Decimal?               @db.Decimal(5, 2)
  maxAmount          Decimal?                @db.Decimal(12, 2)
  absorptionMode     DiscountAbsorptionMode
  requiresApproval   Boolean                @default(true)
  serviceIds         Json?                  // array of service ids; null = all
  packageIds         Json?                  // array of package ids; null = all
  validFrom          DateTime?              @db.Date
  validTo            DateTime?             @db.Date
  status             String                 @default("ACTIVE") @db.VarChar(16)
  createdAt          DateTime               @default(now())
  updatedAt          DateTime               @updatedAt

  org    Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  branch Branch       @relation(fields: [branchId], references: [id], onDelete: Cascade)
  appliedDiscounts AppliedDiscount[]

  @@index([branchId])
  @@map("discount_policies")
}

model DiscountApprovalRule {
  id           Int      @id @default(autoincrement())
  orgId        Int
  branchId     Int
  roleKey      String   @db.VarChar(64) // e.g. BRANCH_MANAGER, CLINIC_STAFF
  maxPercent   Decimal  @db.Decimal(5, 2)
  maxAmount    Decimal? @db.Decimal(12, 2)
  appliesToScope String? @db.VarChar(32) // SERVICE, PACKAGE, INVOICE
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  org    Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  branch Branch       @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@unique([branchId, roleKey, appliesToScope])
  @@index([branchId])
  @@map("discount_approval_rules")
}

model ClinicalCase {
  id                Int                 @id @default(autoincrement())
  orgId             Int
  branchId          Int
  appointmentId     Int?                @unique
  visitId           Int?                @unique
  patientId         Int
  petId             Int
  surgeryPackageId  Int?
  status            ClinicalCaseStatus @default(OPEN)
  totalCharges      Decimal?            @db.Decimal(12, 2)
  totalCollected    Decimal?            @db.Decimal(12, 2)
  primaryDoctorId   Int?                // BranchMember.id
  openedAt          DateTime            @default(now())
  completedAt       DateTime?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt

  org              Organization     @relation(fields: [orgId], references: [id], onDelete: Cascade)
  branch           Branch          @relation(fields: [branchId], references: [id], onDelete: Cascade)
  appointment      Appointment?     @relation(fields: [appointmentId], references: [id], onDelete: SetNull)
  visit            Visit?          @relation(fields: [visitId], references: [id], onDelete: SetNull)
  patient          User            @relation("ClinicalCasePatient", fields: [patientId], references: [id], onDelete: Restrict)
  pet              Pet             @relation(fields: [petId], references: [id], onDelete: Restrict)
  surgeryPackage   SurgeryPackage? @relation(fields: [surgeryPackageId], references: [id], onDelete: SetNull)
  primaryDoctor    BranchMember?   @relation("ClinicalCasePrimaryDoctor", fields: [primaryDoctorId], references: [id], onDelete: SetNull)
  procedureOrders  ProcedureOrder[]
  caseCostSheets   CaseCostSheet[]
  inventoryConsumptions InventoryConsumption[]
  clinicInvoices   ClinicInvoice[]
  doctorSettlementLedger DoctorSettlementLedger[]
  appliedDiscounts AppliedDiscount[]
  vialReturnControls VialReturnControl[]

  @@index([branchId, status])
  @@index([patientId])
  @@index([visitId])
  @@index([appointmentId])
  @@map("clinical_cases")
}

model ProcedureOrder {
  id                Int                  @id @default(autoincrement())
  clinicalCaseId    Int
  surgeryPackageId  Int?
  doctorId         Int                  // BranchMember.id
  status           ProcedureOrderStatus @default(DRAFT)
  scheduledAt       DateTime?
  startedAt        DateTime?
  completedAt      DateTime?
  actualCostRecorded Decimal?            @db.Decimal(12, 2)
  notes            String?              @db.Text
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt

  clinicalCase   ClinicalCase    @relation(fields: [clinicalCaseId], references: [id], onDelete: Cascade)
  surgeryPackage SurgeryPackage? @relation(fields: [surgeryPackageId], references: [id], onDelete: SetNull)
  doctor         BranchMember    @relation("ProcedureOrderDoctor", fields: [doctorId], references: [id], onDelete: Restrict)
  inventoryConsumptions InventoryConsumption[]
  vialReturnControls VialReturnControl[]

  @@index([clinicalCaseId])
  @@index([doctorId])
  @@index([status])
  @@map("procedure_orders")
}

model AppliedDiscount {
  id               Int      @id @default(autoincrement())
  orderId          Int?
  clinicalCaseId   Int?
  discountPolicyId Int
  discountType     DiscountType
  calcType         DiscountCalcType
  amount           Decimal  @db.Decimal(12, 2)
  percentApplied   Decimal? @db.Decimal(5, 2)
  absorptionBreakdown Json?  // { doctorShare, clinicShare, supportShare }
  approvedByUserId Int?
  approvedAt       DateTime?
  reason           String?  @db.VarChar(256)
  createdAt        DateTime @default(now())

  order           Order?          @relation(fields: [orderId], references: [id], onDelete: SetNull)
  clinicalCase    ClinicalCase?   @relation(fields: [clinicalCaseId], references: [id], onDelete: SetNull)
  discountPolicy  DiscountPolicy @relation(fields: [discountPolicyId], references: [id], onDelete: Restrict)
  approvedBy      User?           @relation("AppliedDiscountApprovedBy", fields: [approvedByUserId], references: [id], onDelete: SetNull)

  @@index([orderId])
  @@index([clinicalCaseId])
  @@map("applied_discounts")
}

model DiscountAuditLog {
  id             Int      @id @default(autoincrement())
  branchId       Int
  action         String   @db.VarChar(64) // REQUESTED, APPROVED, REJECTED, APPLIED
  discountPolicyId Int?
  orderId        Int?
  caseId         Int?
  amount         Decimal? @db.Decimal(12, 2)
  byUserId       Int?
  roleKey        String?  @db.VarChar(64)
  reason         String?  @db.Text
  meta           Json?
  createdAt      DateTime @default(now())

  branch Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@index([branchId])
  @@index([createdAt])
  @@map("discount_audit_logs")
}

model CaseCostSheet {
  id                Int      @id @default(autoincrement())
  clinicalCaseId    Int
  directCost        Decimal  @db.Decimal(12, 2)
  semiDirectCost    Decimal?  @db.Decimal(12, 2)
  overheadAllocated Decimal? @db.Decimal(12, 2)
  distributableMargin Decimal @db.Decimal(12, 2)
  doctorShare       Decimal? @db.Decimal(12, 2)
  clinicShare       Decimal? @db.Decimal(12, 2)
  supportShare      Decimal? @db.Decimal(12, 2)
  snapshotJson      Json?    // full breakdown snapshot
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  clinicalCase ClinicalCase @relation(fields: [clinicalCaseId], references: [id], onDelete: Cascade)

