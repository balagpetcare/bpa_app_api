  createdBy       User?                  @relation("SettlementAdjustmentBy", fields: [createdByUserId], references: [id], onDelete: SetNull)

  @@index([settlementBatchId])
  @@map("settlement_adjustments")
}

model SettlementAuditLog {
  id                Int      @id @default(autoincrement())
  orgId             Int
  branchId          Int
  action            String   @db.VarChar(64) // ACCRUED | BATCH_CREATED | APPROVED | PAID | REVERSED
