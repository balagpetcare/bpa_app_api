  createdBy   User?               @relation("ProductVersionCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)

  @@unique([productId, version])
  @@index([productId, status])
  @@map("product_versions")
}

model PackagingTemplate {
  id               Int      @id @default(autoincrement())
  productVersionId Int      @unique
  templateJson     Json
  status           String   @default("DRAFT")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  productVersion ProductVersion @relation(fields: [productVersionId], references: [id], onDelete: Cascade)

  @@map("packaging_templates")
}

model ProductFingerprint {
  id               Int      @id @default(autoincrement())
  productVersionId Int      @unique
  textHash         String?
  imageHash        String?
  specHash         String?
  similarityScore  Decimal? @db.Decimal(5, 2)
  createdAt        DateTime @default(now())

  productVersion ProductVersion @relation(fields: [productVersionId], references: [id], onDelete: Cascade)

  @@map("product_fingerprints")
}

model Contract {
  id               Int       @id @default(autoincrement())
  orgId            Int
  startDate        DateTime?
  endDate          DateTime?
  allowedCountries Json?
  channels         Json?
  status           String    @default("ACTIVE")
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  org        Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  quotaPlans QuotaPlan[]

  @@index([orgId])
  @@map("contracts")
}

model QuotaPlan {
  id         Int      @id @default(autoincrement())
  contractId Int
  productId  Int
  perMonth   Int?
  perBatch   Int?
  createdAt  DateTime @default(now())

  contract Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)
  product  Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([contractId])
  @@index([productId])
  @@map("quota_plans")
}

model QuotaUsage {
  id           Int      @id @default(autoincrement())
  batchId      Int      @unique
  issuedQty    Int      @default(0)
  remainingQty Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  batch Batch @relation(fields: [batchId], references: [id], onDelete: Cascade)

  @@map("quota_usages")
}

model Batch {
  id               Int         @id @default(autoincrement())
  productVersionId Int
  factoryId        Int
  lineId           Int?
  status           BatchStatus @default(PENDING)
  requestedQty     Int
  approvedQty      Int?
  mfgDate          DateTime?
  expDate          DateTime?
  createdByUserId  Int?
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  productVersion ProductVersion  @relation(fields: [productVersionId], references: [id], onDelete: Cascade)
  factory        Factory         @relation(fields: [factoryId], references: [id], onDelete: Restrict)
  line           ProductionLine? @relation(fields: [lineId], references: [id], onDelete: SetNull)
  createdBy      User?           @relation("BatchCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  serialRanges   SerialRange[]
  serials        Serial[]
  quotaUsage     QuotaUsage?

  @@index([productVersionId])
  @@index([factoryId])
  @@index([status])
  @@map("batches")
}

model SerialRange {
  id             Int      @id @default(autoincrement())
  batchId        Int
  qty            Int
  issuedAt       DateTime @default(now())
  issuedByUserId Int?
  status         String   @default("ISSUED")

  batch    Batch @relation(fields: [batchId], references: [id], onDelete: Cascade)
  issuedBy User? @relation("SerialRangeIssuedBy", fields: [issuedByUserId], references: [id], onDelete: SetNull)

  @@index([batchId])
  @@map("serial_ranges")
}

model Serial {
  id               Int          @id @default(autoincrement())
  batchId          Int
  serialCode       String       @unique
  signature        String
  status           SerialStatus @default(ISSUED)
  firstScanAt      DateTime?
  firstScanCountry String?
  firstScanDevice  String?
  createdAt        DateTime     @default(now())

  batch      Batch       @relation(fields: [batchId], references: [id], onDelete: Cascade)
  scanEvents ScanEvent[]

  @@index([batchId])
  @@map("serials")
}

model ScanEvent {
  id          Int           @id @default(autoincrement())
  serialId    Int
  actorRole   ScanActorRole
  action      ScanAction
  countryCode String?
  deviceId    String?
  metaJson    Json?
  createdAt   DateTime      @default(now())

  serial Serial @relation(fields: [serialId], references: [id], onDelete: Cascade)

  @@index([serialId, createdAt])
  @@map("scan_events")
}

// ============================
// OWNER DELEGATION & TEAM MANAGEMENT
// ============================
// Extends owner capabilities: teams, delegated scopes, overview/audit.
// No modifications to existing tables. Backward compatible.

model OwnerTeam {
  id          Int      @id @default(autoincrement())
  ownerUserId Int
  name        String   @db.VarChar(255)
  description String?  @db.Text
  scopes      Json? // optional array of scope keys: products, inventory, staff, branches, etc.
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  owner           User              @relation(fields: [ownerUserId], references: [id], onDelete: Cascade)
  members         OwnerTeamMember[]
  delegations     OwnerDelegation[]
  teamInvitations TeamInvitation[]
  userContexts    UserContext[]

  @@unique([ownerUserId, name])
  @@index([ownerUserId])
  @@map("owner_teams")
}

model OwnerTeamMember {
  id         Int      @id @default(autoincrement())
  teamId     Int
  userId     Int
  roleInTeam String?  @db.VarChar(64) // LEAD, MEMBER, etc. (optional)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  team OwnerTeam @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([teamId, userId])
  @@index([userId])
  @@index([teamId])
  @@map("owner_team_members")
}

/// Reference table for delegation scopes: products, clinics, inventory, staff, branches, finance_read
model OwnerPermissionScope {
  id         Int      @id @default(autoincrement())
  key        String   @unique @db.VarChar(64)
  label      String   @db.VarChar(255)
  isReadOnly Boolean  @default(false) // finance_read is read-only
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("owner_permission_scopes")
}

model OwnerDelegation {
  id              Int      @id @default(autoincrement())
  ownerUserId     Int
  delegatedUserId Int
  scopeKey        String   @db.VarChar(64) // products, clinics, inventory, staff, branches, finance_read
  orgId           Int? // null = all orgs under owner
  branchId        Int? // null = all branches in org
  teamId          Int? // optional: which team this delegation belongs to
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  owner         User          @relation("OwnerDelegationOwner", fields: [ownerUserId], references: [id], onDelete: Cascade)
  delegatedUser User          @relation("OwnerDelegationDelegate", fields: [delegatedUserId], references: [id], onDelete: Cascade)
  org           Organization? @relation(fields: [orgId], references: [id], onDelete: Cascade)
  branch        Branch?       @relation(fields: [branchId], references: [id], onDelete: Cascade)
  team          OwnerTeam?    @relation(fields: [teamId], references: [id], onDelete: SetNull)

  @@unique([ownerUserId, delegatedUserId, scopeKey, orgId, branchId])
  @@index([ownerUserId])
  @@index([delegatedUserId])
  @@index([scopeKey])
  @@map("owner_delegations")
}

model OwnerOverviewLog {
  id          Int      @id @default(autoincrement())
  ownerUserId Int
  actorUserId Int?
  action      String   @db.VarChar(128) // DELEGATION_ASSIGNED, DELEGATION_REVOKED, TEAM_CREATED, etc.
  meta        Json?
  createdAt   DateTime @default(now())

  owner User  @relation("OwnerOverviewLogOwner", fields: [ownerUserId], references: [id], onDelete: Cascade)
  actor User? @relation("OwnerOverviewLogActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([ownerUserId])
  @@index([actorUserId])
  @@index([createdAt])
  @@map("owner_overview_logs")
}

// Multi-context: user's active contexts (branch, team, owner, roles, scopes)
model UserContext {
  id               Int      @id @default(autoincrement())
  userId           Int
  ownerUserId      Int? // null = user is the owner; set when delegate
  branchId         Int?
  teamId           Int?
  roles            Json? // string[] e.g. ["BRANCH_MANAGER", "STAFF"]
  scopes           Json? // string[] e.g. ["products", "inventory"]
  defaultDashboard String?  @db.VarChar(64) // owner | branch | staff
  isDefault        Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user   User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  owner  User?      @relation("UserContextOwner", fields: [ownerUserId], references: [id], onDelete: Cascade)
  branch Branch?    @relation(fields: [branchId], references: [id], onDelete: Cascade)
  team   OwnerTeam? @relation(fields: [teamId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([ownerUserId])
  @@index([branchId])
  @@map("user_contexts")
}

enum TeamInvitationStatus {
  PENDING
  ACCEPTED
  REVOKED
  EXPIRED
}

// Team email invitation: owner invites by email to a team; token one-time use, hashed
model TeamInvitation {
  id               Int                  @id @default(autoincrement())
  ownerUserId      Int
  teamId           Int
  email            String               @db.VarChar(255)
  tokenHash        String               @unique
  status           TeamInvitationStatus @default(PENDING)
  expiresAt        DateTime
  scopes           Json? // string[] scope keys to assign on accept
  branchIds        Json? // number[] optional branch IDs to link
  invitedByUserId  Int
  acceptedByUserId Int?
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt

  owner      User      @relation("TeamInvitationOwner", fields: [ownerUserId], references: [id], onDelete: Cascade)
  team       OwnerTeam @relation(fields: [teamId], references: [id], onDelete: Cascade)
  invitedBy  User      @relation("TeamInvitationInvitedBy", fields: [invitedByUserId], references: [id], onDelete: Restrict)
  acceptedBy User?     @relation("TeamInvitationAcceptedBy", fields: [acceptedByUserId], references: [id], onDelete: SetNull)

  @@index([ownerUserId])
  @@index([teamId])
  @@index([email])
  @@index([status])
  @@map("team_invitations")
}

// ============================
// Clinic Medicine Leakage Control (CCMLPA) — Smart Vial Control & Audit
// ============================

enum MedicineDestructionRule {
  AFTER_RETENTION
  IMMEDIATE_ON_EXPIRY
  MANUAL_APPROVAL_ONLY
}

enum VialStatus {
  SEALED
  ISSUED
  OPENED
  PARTIALLY_USED
  EXHAUSTED
  RETURNED
  QUARANTINED
  DESTROYED
}

enum VialHolderType {
  PHARMACY
  ROOM
  STAFF
  AUDIT_BIN
}

enum DispenseStatus {
  PENDING
  APPROVED
  ISSUED
  PARTIALLY_ISSUED
  REJECTED
  CANCELLED
}

enum DispenseUrgencyLevel {
  NORMAL
  URGENT
  EMERGENCY
}

enum VialSessionStatus {
  ACTIVE
  PARTIALLY_USED
  EXHAUSTED
  EXPIRED
  RETURNED
  QUARANTINED
  DESTROYED
}

enum VialEventType {
  OPENED
  DOSE_USED
  RETURNED
  EXPIRED
  DESTROYED
  TRANSFERRED
  QUARANTINED
}

enum InjectionTokenStatus {
  PENDING
  USED
  EXPIRED
  CANCELLED
}

enum MedicineSource {
  INTERNAL_CLINIC
  CLINIC_PROVIDED_MEDICINE
  OUTSIDE_PRESCRIPTION_PATIENT_BROUGHT
}

enum InjectionEncounterKind {
  INTERNAL_VISIT
  EXTERNAL_WALK_IN
}

model MedicinePolicy {
  id                         Int                     @id @default(autoincrement())
  variantId                  Int                     @unique
  orgId                      Int
  reusableAfterOpen          Boolean                 @default(false)
  openVialValidityHours      Int? // null = not reusable
  mixedSolutionValidityHours Int?
  returnRequired             Boolean                 @default(true)
  retentionDays              Int                     @default(7)
  highRisk                   Boolean                 @default(false)
  weightCheckRequired        Boolean                 @default(false)
  photoRequiredOnReturn      Boolean                 @default(false)
  dualApprovalRequired       Boolean                 @default(false)
  destructionRule            MedicineDestructionRule @default(AFTER_RETENTION)
  maxDosePerAdministration   Decimal?                @db.Decimal(12, 4)
  minRemainingPercent        Int? // e.g. 10 = block use when remaining < 10% of initial
  createdAt                  DateTime                @default(now())
  updatedAt                  DateTime                @updatedAt

  variant ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)
  org     Organization   @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId])
  @@map("medicine_policies")
}

model VialInstance {
  id                Int            @id @default(autoincrement())
  variantId         Int
  lotId             Int?
  batchCode         String?        @db.VarChar(64)
  serialCode        String?        @unique @db.VarChar(128) // QR/barcode
  branchId          Int
  locationId        Int
  orgId             Int?
  status            VialStatus     @default(SEALED)
  currentHolderType VialHolderType @default(PHARMACY)
  currentHolderId   String?        @db.VarChar(64) // room id, user id, or bin id
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  variant              ProductVariant        @relation(fields: [variantId], references: [id], onDelete: Cascade)
  lot                  StockLot?             @relation(fields: [lotId], references: [id], onDelete: SetNull)
  branch               Branch                @relation(fields: [branchId], references: [id], onDelete: Cascade)
  location             InventoryLocation     @relation(fields: [locationId], references: [id], onDelete: Restrict)
  org                  Organization?         @relation(fields: [orgId], references: [id], onDelete: SetNull)
  dispenseRequestItems DispenseRequestItem[]
  vialSessions         VialSession[]

  @@index([branchId])
  @@index([variantId])
  @@index([lotId])
  @@index([locationId])
  @@index([status])
  @@map("vial_instances")
}

model DispenseRequest {
  id                 Int                  @id @default(autoincrement())
  orgId              Int
  branchId           Int
  requestedByUserId  Int
  patientId          Int? // owner (User)
  visitId            Int?
  prescriptionId     Int? // prescription-linked dispense (Clinic Pharmacy)
  surgeryCaseId      Int? // future Phase 3
  treatmentCourseId  Int? // Phase 2
  requestType        String?              @db.VarChar(64) // OPEN_NEW_VIAL, ADDITIONAL_VIAL, REPLACEMENT_VIAL, EXPIRED_VIAL_REPLACEMENT, STANDARD
  requestReason      String?              @db.Text
  tokenId            Int? // InjectionToken that triggered this internal order
  treatmentDayItemId Int? // which day-item triggered this
  transactionType    String?              @db.VarChar(32) // TAKE_HOME | CLINIC_USE | INTERNAL_ORDER
  status             DispenseStatus       @default(PENDING)
  urgencyLevel       DispenseUrgencyLevel @default(NORMAL)
  receivedByUserId   Int?
  receivedAt         DateTime?
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt

  org                   Organization          @relation(fields: [orgId], references: [id], onDelete: Cascade)
  branch                Branch                @relation(fields: [branchId], references: [id], onDelete: Cascade)
  requestedBy           User                  @relation("DispenseRequestRequestedBy", fields: [requestedByUserId], references: [id], onDelete: Restrict)
  receivedBy            User?                 @relation("DispenseRequestReceivedBy", fields: [receivedByUserId], references: [id], onDelete: SetNull)
  patient               User?                 @relation("DispenseRequestPatient", fields: [patientId], references: [id], onDelete: SetNull)
  visit                 Visit?                @relation(fields: [visitId], references: [id], onDelete: SetNull)
  prescription          Prescription?         @relation(fields: [prescriptionId], references: [id], onDelete: SetNull)
  surgeryCase           SurgeryCase?          @relation(fields: [surgeryCaseId], references: [id], onDelete: SetNull)
  token                 InjectionToken?       @relation("DispenseRequestTriggeredByToken", fields: [tokenId], references: [id], onDelete: SetNull)
  treatmentDayItem      TreatmentDayItem?     @relation(fields: [treatmentDayItemId], references: [id], onDelete: SetNull)
  items                 DispenseRequestItem[]
  vialSessionsActivated VialSession[]         @relation("VialSessionActivatedFromDispenseRequest")

  @@index([branchId])
  @@index([orgId])
  @@index([visitId])
  @@index([prescriptionId])
  @@index([status])
  @@index([requestedByUserId])
  @@index([requestType])
  @@index([transactionType])
  @@map("dispense_requests")
}

model DispenseRequestItem {
  id                    Int      @id @default(autoincrement())
  dispenseRequestId     Int
  variantId             Int
  clinicalItemVariantId Int? // when dispense is from clinical catalog (Clinic Pharmacy)
  requestedQty          Int
  issuedQty             Int      @default(0)
  unit                  String?  @db.VarChar(32)
  vialInstanceId        Int?
  reason                String?  @db.Text
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  dispenseRequest     DispenseRequest      @relation(fields: [dispenseRequestId], references: [id], onDelete: Cascade)
  variant             ProductVariant       @relation(fields: [variantId], references: [id], onDelete: Restrict)
  clinicalItemVariant ClinicalItemVariant? @relation(fields: [clinicalItemVariantId], references: [id], onDelete: SetNull)
  vialInstance        VialInstance?        @relation(fields: [vialInstanceId], references: [id], onDelete: SetNull)

  @@index([dispenseRequestId])
  @@index([variantId])
  @@index([clinicalItemVariantId])
  @@map("dispense_request_items")
}

// Outside medicine: pharmacy verification before injection (batch/expiry); cannot merge with clinic vial
model OutsideMedicineReceive {
  id               Int       @id @default(autoincrement())
  branchId         Int
  variantId        Int
  batchCode        String?   @db.VarChar(128)
  expiryDate       DateTime? @db.Date
  receivedByUserId Int
  receivedAt       DateTime  @default(now())
  createdAt        DateTime  @default(now())

  branch     Branch         @relation(fields: [branchId], references: [id], onDelete: Cascade)
  variant    ProductVariant @relation(fields: [variantId], references: [id], onDelete: Restrict)
  receivedBy User           @relation("OutsideMedicineReceiveBy", fields: [receivedByUserId], references: [id], onDelete: Restrict)

  @@index([branchId])
  @@index([variantId])
  @@index([receivedAt])
  @@index([expiryDate])
  @@map("outside_medicine_receives")
}

model InjectionToken {
  id                       Int                    @id @default(autoincrement())
  tokenCode                String                 @unique @db.VarChar(32)
  branchId                 Int
  visitId                  Int
  prescriptionId           Int?
  orderId                  Int?
  patientId                Int
  petId                    Int
  /// Legacy primary variant; null when token is multi-line outside-only (see medicationLines).
  variantId                Int?
  treatmentCourseId        Int?
  treatmentDayId           Int?
  selectedVialSessionId    Int? // pre-assigned vial from billing screen
  /// Legacy primary dose; mirrors first line when using medicationLines.
  expectedDose             Decimal?               @db.Decimal(12, 4)
  unit                     String?                @db.VarChar(32)
  medicineSource           MedicineSource         @default(INTERNAL_CLINIC)
  encounterKind            InjectionEncounterKind @default(INTERNAL_VISIT)
  externalPrescriberName   String?                @db.VarChar(256)
  externalPrescriberClinic String?                @db.VarChar(256)
  externalRxNotes          String?                @db.Text
  externalRxEvidenceUrl    String?                @db.Text
  serviceChargeAmount      Decimal?               @db.Decimal(12, 2)
  medicineChargeAmount     Decimal?               @db.Decimal(12, 2)
  consumablesChargeAmount  Decimal?               @db.Decimal(12, 2)
  status                   InjectionTokenStatus   @default(PENDING)
  generatedByUserId        Int
  validatedByUserId        Int?
  validatedAt              DateTime?
  usedByUserId             Int?
  usedAt                   DateTime?
  cancelledByUserId        Int?
  cancelledAt              DateTime?
  cancelReason             String?                @db.Text
  expiresAt                DateTime?
  createdAt                DateTime               @default(now())
  updatedAt                DateTime               @updatedAt

  branch                    Branch                         @relation(fields: [branchId], references: [id], onDelete: Cascade)
  visit                     Visit                          @relation(fields: [visitId], references: [id], onDelete: Cascade)
  prescription              Prescription?                  @relation(fields: [prescriptionId], references: [id], onDelete: SetNull)
  order                     Order?                         @relation(fields: [orderId], references: [id], onDelete: SetNull)
  patient                   User                           @relation("InjectionTokenPatient", fields: [patientId], references: [id], onDelete: Restrict)
  pet                       Pet                            @relation(fields: [petId], references: [id], onDelete: Restrict)
  variant                   ProductVariant?                @relation(fields: [variantId], references: [id], onDelete: Restrict)
  treatmentCourse           TreatmentCourse?               @relation(fields: [treatmentCourseId], references: [id], onDelete: SetNull)
  treatmentDay              TreatmentDay?                  @relation(fields: [treatmentDayId], references: [id], onDelete: SetNull)
  selectedVialSession       VialSession?                   @relation("InjectionTokenSelectedVial", fields: [selectedVialSessionId], references: [id], onDelete: SetNull)
  generatedBy               User                           @relation("InjectionTokenGeneratedBy", fields: [generatedByUserId], references: [id], onDelete: Restrict)
  validatedBy               User?                          @relation("InjectionTokenValidatedBy", fields: [validatedByUserId], references: [id], onDelete: SetNull)
  usedBy                    User?                          @relation("InjectionTokenUsedBy", fields: [usedByUserId], references: [id], onDelete: SetNull)
  cancelledBy               User?                          @relation("InjectionTokenCancelledBy", fields: [cancelledByUserId], references: [id], onDelete: SetNull)
  medicationAdministration  MedicationAdministration?
  dispenseRequestsTriggered DispenseRequest[]              @relation("DispenseRequestTriggeredByToken")
  medicationLines           InjectionTokenMedicationLine[]

  @@index([branchId])
  @@index([visitId])
  @@index([prescriptionId])
  @@index([orderId])
  @@index([patientId])
  @@index([petId])
  @@index([variantId])
  @@index([status])
  @@index([createdAt])
  @@index([expiresAt])
  @@index([treatmentCourseId])
  @@index([treatmentDayId])
  @@map("injection_tokens")
}

/// One administration/medicine row on a multi-line injection token (enterprise intake).
model InjectionTokenMedicationLine {
  id                    Int            @id @default(autoincrement())
  injectionTokenId      Int
  lineIndex             Int
  medicineSource        MedicineSource
  variantId             Int?
  manualMedicineName    String?        @db.VarChar(512)
  manualStrength        String?        @db.VarChar(256)
  manualBatch           String?        @db.VarChar(256)
  manualManufacturer    String?        @db.VarChar(256)
  route                 String         @db.VarChar(64)
  expectedDose          Decimal        @db.Decimal(12, 4)
  unit                  String?        @db.VarChar(32)
  durationText          String?        @db.VarChar(128)
  frequencyText         String?        @db.VarChar(128)
  longevityNote         String?        @db.Text
  lineNote              String?        @db.Text
  selectedVialSessionId Int?
  medicineFeeSnapshot   Decimal?       @db.Decimal(12, 2)
  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt

  injectionToken      InjectionToken  @relation(fields: [injectionTokenId], references: [id], onDelete: Cascade)
  variant             ProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)
  selectedVialSession VialSession?    @relation("InjectionTokenLineSelectedVial", fields: [selectedVialSessionId], references: [id], onDelete: SetNull)

  @@unique([injectionTokenId, lineIndex])
  @@index([injectionTokenId])
  @@index([variantId])
  @@map("injection_token_medication_lines")
}

model VialSession {
  id                             Int               @id @default(autoincrement())
  vialInstanceId                 Int?
  variantId                      Int
  lotId                          Int?
  branchId                       Int
  roomId                         Int?
  openedByUserId                 Int
  openedAt                       DateTime          @default(now())
  validUntil                     DateTime?
  openPhotoUrl                   String?           @db.Text
  initialQty                     Int // in smallest unit (e.g. ml)
  remainingQty                   Int
  status                         VialSessionStatus @default(ACTIVE)
  activatedFromDispenseRequestId Int? // which internal order activated this vial
  createdAt                      DateTime          @default(now())
  updatedAt                      DateTime          @updatedAt

  vialInstance                 VialInstance?                  @relation(fields: [vialInstanceId], references: [id], onDelete: SetNull)
  variant                      ProductVariant                 @relation(fields: [variantId], references: [id], onDelete: Cascade)
  lot                          StockLot?                      @relation(fields: [lotId], references: [id], onDelete: SetNull)
  branch                       Branch                         @relation(fields: [branchId], references: [id], onDelete: Cascade)
  room                         BranchRoom?                    @relation(fields: [roomId], references: [id], onDelete: SetNull)
  openedBy                     User                           @relation("VialSessionOpenedBy", fields: [openedByUserId], references: [id], onDelete: Restrict)
  activatedFromDispenseRequest DispenseRequest?               @relation("VialSessionActivatedFromDispenseRequest", fields: [activatedFromDispenseRequestId], references: [id], onDelete: SetNull)
  events                       VialSessionEvent[]
  medicationAdministrations    MedicationAdministration[]
  treatmentCourseDoses         TreatmentCourseDose[]
  vialReturns                  VialReturn[]
  injectionTokensSelected      InjectionToken[]               @relation("InjectionTokenSelectedVial")
  injectionTokenLinePicks      InjectionTokenMedicationLine[] @relation("InjectionTokenLineSelectedVial")

  @@index([branchId])
  @@index([variantId])
  @@index([vialInstanceId])
  @@index([status])
  @@index([validUntil])
