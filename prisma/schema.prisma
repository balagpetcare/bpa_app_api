enum ProductVersionStatus {
  DRAFT
  PENDING
  APPROVED
  REJECTED
}

enum BatchStatus {
  PENDING
  APPROVED
  ISSUED
  CLOSED
}

enum SerialStatus {
  ISSUED
  ACTIVATED
  SOLD
  VOID
  RECALLED
}

enum ScanAction {
  PRODUCED
  SHIPPED
  RECEIVED
  SOLD
  VERIFY
}

enum ScanActorRole {
  FACTORY
  DISTRIBUTOR
  RETAILER
  CUSTOMER
  ADMIN
}

enum LocationPrecisionLevel {
  COARSE
  MEDIUM
  PRECISE
}

enum LocationConsentLevel {
  NONE
  COARSE
  PRECISE_WHEN_USING
  ALWAYS
}

enum LocationSource {
  GPS
  IP
  MANUAL
  WIFI
  CELL
