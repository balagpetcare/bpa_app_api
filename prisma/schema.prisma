  user        User        @relation("ProducerStaffUser", fields: [userId], references: [id], onDelete: Cascade)
  role        Role        @relation("ProducerStaffRole", fields: [roleId], references: [id])
  inviter     User?       @relation("ProducerStaffInviter", fields: [invitedBy], references: [id], onDelete: SetNull)

  @@unique([producerOrgId, userId])
  @@index([userId])
  @@index([roleId])
  @@index([status])
  @@map("producer_org_staff")
}

// Producer staff invitation (email/phone; registered → notification accept, unregistered → token link → register → accept)
enum ProducerStaffInviteStatus {
  PENDING
  SENT
  ACCEPTED
  DECLINED
  EXPIRED
  CANCELLED
  DELETED
}

model ProducerStaffInvite {
  id               Int                       @id @default(autoincrement())
  producerOrgId    Int
  invitedByUserId  Int
  email            String?
  phone            String?
  roleId           Int
  status           ProducerStaffInviteStatus @default(PENDING)
  tokenHash        String?                   @db.VarChar(255)
  expiresAt        DateTime
  acceptedByUserId Int?
  createdAt        DateTime                  @default(now())
  updatedAt        DateTime                  @updatedAt

  producerOrg ProducerOrg                   @relation(fields: [producerOrgId], references: [id], onDelete: Cascade)
  invitedBy   User                          @relation("ProducerStaffInviteInvitedBy", fields: [invitedByUserId], references: [id], onDelete: Restrict)
  role        Role                          @relation(fields: [roleId], references: [id], onDelete: Restrict)
  acceptedBy  User?                         @relation("ProducerStaffInviteAcceptedBy", fields: [acceptedByUserId], references: [id], onDelete: SetNull)
  deliveries  ProducerStaffInviteDelivery[]

  @@unique([producerOrgId, email], map: "producer_staff_invite_producer_org_email_unique")
  @@unique([producerOrgId, phone], map: "producer_staff_invite_producer_org_phone_unique")
  @@index([producerOrgId, status])
  @@index([email])
  @@index([phone])
  @@index([expiresAt])
  @@map("producer_staff_invites")
}

model ProducerStaffInviteDelivery {
  id           Int       @id @default(autoincrement())
  inviteId     Int
  channel      String    @db.VarChar(32)
  to           String    @db.VarChar(255)
  provider     String?   @db.VarChar(64)
  status       String    @db.VarChar(32)
  attemptCount Int       @default(0)
  lastError    String?   @db.Text
  messageId    String?   @db.VarChar(255)
  sentAt       DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  invite ProducerStaffInvite @relation(fields: [inviteId], references: [id], onDelete: Cascade)

  @@index([inviteId])
  @@index([status])
  @@map("producer_staff_invite_deliveries")
}

model ProducerAuditLog {
  id            Int      @id @default(autoincrement())
  producerOrgId Int
  actorType     String // OWNER | STAFF
  actorId       Int
  action        String
  entityType    String
  entityId      String?
  createdAt     DateTime @default(now())

  producerOrg ProducerOrg @relation(fields: [producerOrgId], references: [id], onDelete: Cascade)

  @@index([producerOrgId])
  @@index([producerOrgId, action, createdAt])
  @@index([actorId])
  @@index([createdAt])
  @@map("producer_audit_logs")
}

enum ProducerApprovalEntityType {
  PRODUCT
  BATCH
}

enum ProducerApprovalStatus {
  SUBMITTED
  APPROVED
  REJECTED
}

model ProducerApproval {
  id                Int                        @id @default(autoincrement())
  producerOrgId     Int
  entityType        ProducerApprovalEntityType
  entityId          Int
  status            ProducerApprovalStatus     @default(SUBMITTED)
  submittedByUserId Int
  reviewedByUserId  Int?
  assignedToUserId  Int?
  assignedAt        DateTime?
  slaDeadline       DateTime?
  stage             String?                    @db.VarChar(32)
  note              String?                    @db.Text
  reviewedAt        DateTime?
  overrideNote      String?                    @db.Text // Phase 3: compliance override note
  overrideAt        DateTime?
  overrideByUserId  Int?
  createdAt         DateTime                   @default(now())
  updatedAt         DateTime                   @updatedAt

  producerOrg ProducerOrg @relation(fields: [producerOrgId], references: [id], onDelete: Cascade)

  @@unique([producerOrgId, entityType, entityId], map: "producer_approvals_unique_entity")
  @@index([producerOrgId, status])
  @@index([producerOrgId, entityType])
  @@index([assignedToUserId])
  @@index([slaDeadline])
  @@index([stage])
  @@map("producer_approvals")
}

// Producer Governance (Phase 1): audit, feature flags, quotas
enum OrgQuotaResetPeriod {
  DAILY
  MONTHLY
}

model AuditEvent {
  id          Int      @id @default(autoincrement())
  actorUserId Int?
  actorRole   String   @db.VarChar(64)
  actionKey   String   @db.VarChar(128)
  entityType  String   @db.VarChar(64)
  entityId    String?  @db.VarChar(128)
  orgId       Int?
  metadata    Json?
  traceId     String?  @db.VarChar(128)
  ip          String?  @db.VarChar(64)
  createdAt   DateTime @default(now())

  @@index([orgId, createdAt])
  @@index([entityType, entityId])
  @@index([actorUserId, createdAt])
  @@index([actionKey, createdAt])
  @@index([traceId])
  @@map("audit_events")
}

model OrgFeatureFlag {
  id              Int      @id @default(autoincrement())
  producerOrgId   Int
  key             String   @db.VarChar(128)
  enabled         Boolean  @default(true)
  updatedByUserId Int?
  updatedAt       DateTime @updatedAt
  createdAt       DateTime @default(now())

  producerOrg ProducerOrg @relation(fields: [producerOrgId], references: [id], onDelete: Cascade)
  updatedBy   User?       @relation("OrgFeatureFlagUpdatedBy", fields: [updatedByUserId], references: [id], onDelete: SetNull)

  @@unique([producerOrgId, key], map: "org_feature_flags_org_key_unique")
  @@index([producerOrgId])
  @@index([key])
  @@map("org_feature_flags")
}

model OrgQuota {
  id              Int                 @id @default(autoincrement())
  producerOrgId   Int
  key             String              @db.VarChar(128)
  limit           Int
  used            Int                 @default(0)
  resetPeriod     OrgQuotaResetPeriod @default(DAILY)
  updatedByUserId Int?
  updatedAt       DateTime            @updatedAt
  createdAt       DateTime            @default(now())

  producerOrg ProducerOrg @relation(fields: [producerOrgId], references: [id], onDelete: Cascade)
  updatedBy   User?       @relation("OrgQuotaUpdatedBy", fields: [updatedByUserId], references: [id], onDelete: SetNull)

  @@unique([producerOrgId, key], map: "org_quotas_org_key_unique")
  @@index([producerOrgId])
  @@index([key])
  @@index([resetPeriod])
  @@map("org_quotas")
}

model AuthProduct {
  id                             Int               @id @default(autoincrement())
  producerOrgId                  Int
  factoryId                      Int?
  brandName                      String
  productName                    String
  productType                    String? // PET_FOOD, MEDICINE, SUPPLEMENT, ACCESSORY, LIVE_ANIMAL, OTHER
  sku                            String
  packSize                       String?
  description                    String?
  specJson                       Json? // net weight/volume, ingredients, shelf-life, country of origin, HS code, etc.
  status                         AuthProductStatus @default(DRAFT)
  submittedAt                    DateTime?
  reviewedAt                     DateTime?
  reviewedByAdminId              Int?
  reviewNotes                    String?           @db.Text // rejection reason / admin notes
  ownershipDeclarationAcceptedAt DateTime?
  createdByUserId                Int?
  createdAt                      DateTime          @default(now())
  updatedAt                      DateTime          @updatedAt

  producerOrg ProducerOrg        @relation(fields: [producerOrgId], references: [id], onDelete: Cascade)
  factory     ProducerFactory?   @relation(fields: [factoryId], references: [id], onDelete: SetNull)
  createdBy   User?              @relation("AuthProductCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  batches     AuthBatch[]
  proofs      AuthProductProof[]
  revisions   ProductRevision[]

  @@unique([producerOrgId, sku])
  @@index([producerOrgId])
  @@index([factoryId])
  @@index([status])
  @@map("auth_products")
}

model ProductRevision {
  id                Int      @id @default(autoincrement())
  authProductId     Int
  revisionNumber    Int
  snapshotJson      Json
  submittedByUserId Int
  approvalId        Int?
  createdAt         DateTime @default(now())

  authProduct AuthProduct @relation(fields: [authProductId], references: [id], onDelete: Cascade)

  @@unique([authProductId, revisionNumber])
  @@index([authProductId])
  @@index([approvalId])
  @@map("product_revisions")
}

// Proof pack and fingerprints for verification & anti-copy
model AuthProductProof {
  id              Int      @id @default(autoincrement())
  authProductId   Int
  proofType       String // LABEL_FRONT, LABEL_BACK, MANUFACTURING_LICENSE, etc. (align with DocumentType or freeform)
  mediaId         Int
  metadataJson    Json? // docNumber, issueDate, expiryDate, issuing authority
  labelHash       String? // image/content hash for duplicate detection
  textFingerprint String?  @db.Text
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  authProduct AuthProduct @relation(fields: [authProductId], references: [id], onDelete: Cascade)
  media       Media       @relation(fields: [mediaId], references: [id], onDelete: Cascade)

  @@index([authProductId])
  @@index([proofType])
  @@map("auth_product_proofs")
}

model AuthBatch {
  id                Int             @id @default(autoincrement())
  authProductId     Int
  batchNo           String
  mfgDate           DateTime?
  expDate           DateTime?
  qtyPlanned        Int
  qtyGenerated      Int             @default(0)
  status            AuthBatchStatus @default(DRAFT)
  createdByUserId   Int?
  submittedAt       DateTime?
  reviewedAt        DateTime?
  reviewedByAdminId Int?
  reviewNotes       String?         @db.Text
  voidedAt          DateTime?
  voidedByUserId    Int?
  voidReason        String?         @db.Text
  frozenAt          DateTime? // Phase 4: block print/export when set
  quarantinedAt     DateTime? // Trust & Safety: block verifications when set
  printedAt         DateTime?
  printedByUserId   Int?
  printCount        Int             @default(0)
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  authProduct    AuthProduct                @relation(fields: [authProductId], references: [id], onDelete: Cascade)
  createdBy      User?                      @relation("AuthBatchCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  printedBy      User?                      @relation("AuthBatchPrintedBy", fields: [printedByUserId], references: [id], onDelete: SetNull)
  codes          AuthCode[]
  serialState    BatchSerialState?
  allocationLogs BatchSerialAllocationLog[]

  @@index([authProductId])
  @@index([status])
  @@map("auth_batches")
}

enum BatchSerialAllocationActionType {
  PRINT
  DOWNLOAD_EXPORT
  EMAIL_EXPORT
}

enum BatchSerialAllocationFileType {
  CSV
  XLSX
}

enum BatchSerialAllocationStatus {
  ISSUED
  REVOKED
}

model BatchSerialState {
  id                  Int      @id @default(autoincrement())
  batchId             Int      @unique
  lastAllocatedSerial Int      @default(0)
  allocatedCount      Int      @default(0)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  batch AuthBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)

  @@map("batch_serial_states")
}

model BatchSerialAllocationLog {
  id                Int                             @id @default(autoincrement())
  batchId           Int
  startSerial       Int
  endSerial         Int
  quantity          Int
  actionType        BatchSerialAllocationActionType
  fileType          BatchSerialAllocationFileType?
  targetEmail       String?
  allocatedByUserId Int?
  status            BatchSerialAllocationStatus     @default(ISSUED)
  revokedAt         DateTime?
  revokedByUserId   Int?
  revokeReason      String?
  createdAt         DateTime                        @default(now())

  batch       AuthBatch  @relation(fields: [batchId], references: [id], onDelete: Cascade)
  allocatedBy User?      @relation("BatchSerialAllocationAllocatedBy", fields: [allocatedByUserId], references: [id], onDelete: SetNull)
  revokedBy   User?      @relation("BatchSerialAllocationRevokedBy", fields: [revokedByUserId], references: [id], onDelete: SetNull)
  codes       AuthCode[]

  @@index([batchId])
  @@index([allocatedByUserId])
  @@index([revokedByUserId])
  @@map("batch_serial_allocation_logs")
}

model AuthCode {
  id                    Int                              @id @default(autoincrement())
  batchId               Int
  codeHash              String                           @unique
  codeLength            Int                              @default(12)
  customPrefix          String?
  customSuffix          String?
  codeCipher            String
  codeIv                String
  codeTag               String
  status                AuthCodeStatus                   @default(UNUSED)
  printedAt             DateTime?
  exportedAt            DateTime?
  verifyCount           Int                              @default(0)
  firstVerifiedAt       DateTime?
  firstVerifiedIp       String?
  firstVerifiedCountry  String?
  generatedByUserId     Int?
  issuedAt              DateTime?
  issuedByUserId        Int?
  issuedMethod          BatchSerialAllocationActionType?
  issuedToEmail         String?
  issuedAllocationLogId Int?
  createdAt             DateTime                         @default(now())

  batch               AuthBatch                 @relation(fields: [batchId], references: [id], onDelete: Cascade)
  generatedBy         User?                     @relation("AuthCodeGeneratedBy", fields: [generatedByUserId], references: [id], onDelete: SetNull)
  issuedBy            User?                     @relation("AuthCodeIssuedBy", fields: [issuedByUserId], references: [id], onDelete: SetNull)
  issuedAllocationLog BatchSerialAllocationLog? @relation(fields: [issuedAllocationLogId], references: [id], onDelete: SetNull)
  logs                AuthVerificationLog[]

  @@index([batchId])
  @@index([status])
  @@index([issuedAllocationLogId])
  @@map("auth_codes")
}

model AuthVerificationLog {
  id               Int              @id @default(autoincrement())
  codeId           Int?
  publicCodeMasked String
  deviceId         String?
  ip               String?
  country          String?
  userId           Int?
  result           AuthVerifyResult
  createdAt        DateTime         @default(now())

  code AuthCode? @relation(fields: [codeId], references: [id], onDelete: SetNull)
  user User?     @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([codeId])
  @@map("auth_verification_logs")
}

// ============================
// Product Authenticity + Serial Issuance (MVP)
