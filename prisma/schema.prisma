  REJECTED
}

enum AuditBinType {
  EMPTY_VIAL
  PARTIAL_RETURN
  EXPIRED_MIXED
  QUARANTINE
}

enum AuditBinStatus {
  OPEN
  SEALED
  UNDER_REVIEW
  DESTROYED
}

enum AuditBinItemStatus {
  HELD
  VERIFIED
  DESTROYED
  ESCALATED
}

model MedicationAdministration {
