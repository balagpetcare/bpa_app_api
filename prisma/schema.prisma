  variants          ProductVariant[]
  inventory         Inventory[]
  orderItems        OrderItem[]
  media             ProductMedia[]
  vendorListings    VendorProductListing[]
  stockRequestItems StockRequestItem[]
  importRows        ProductImportRow[]
  catalogEnableRequests CatalogEnableRequest[]

  // === Product Authenticity (MVP) ===
