  name                     String   @db.VarChar(128)
  code                     String?  @db.VarChar(32) // unique per branch, e.g. R1, CON-1
  roomType                 String   @db.VarChar(32)
  floor                    String?  @db.VarChar(32)
  zone                     String?  @db.VarChar(64)
  capacity                 Int?
  status                   String   @db.VarChar(16) // ACTIVE | INACTIVE (lifecycle)
  operationalStatus        String   @default("AVAILABLE") @db.VarChar(24) // AVAILABLE | RESERVED | OCCUPIED | CLEANING | MAINTENANCE | BLOCKED
  notes                    String?  @db.Text
  bookable                 Boolean  @default(true)
  cleaningBufferMinutes    Int? // minutes after visit end before next booking
  maintenanceBufferMinutes Int?
  supportsWalkIns          Boolean  @default(true)
  emergencyOverrideAllowed Boolean  @default(false)
  preferredDoctorIds       Json?    @default("[]") // [branchMemberId]
  allowedServiceIds        Json?    @default("[]") // [serviceId]
  allowedPackageIds        Json?    @default("[]") // [surgeryPackageId]
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt

  org                   Organization           @relation(fields: [orgId], references: [id], onDelete: Cascade)
  branch                Branch                 @relation(fields: [branchId], references: [id], onDelete: Cascade)
  roomScheduleTemplates RoomScheduleTemplate[]
  vialSessions          VialSession[]
  auditBins             AuditBin[]
  appointments          Appointment[]
  surgeryCases          SurgeryCase[]
  clinicRoomBlocks      ClinicRoomBlock[]

  @@unique([branchId, name])
  @@unique([branchId, code])
  @@index([orgId, branchId])
  @@index([branchId, status])
  @@index([branchId, operationalStatus])
  @@map("branch_rooms")
}

// Temporary block: cleaning, maintenance, manual block, emergency unavailable
model ClinicRoomBlock {
  id              Int      @id @default(autoincrement())
  branchId        Int
  roomId          Int
  type            String   @db.VarChar(32) // CLEANING | MAINTENANCE | BLOCKED | EMERGENCY_UNAVAILABLE
  startAt         DateTime @db.Timestamptz
  endAt           DateTime @db.Timestamptz
  reason          String?  @db.Text
  createdByUserId Int?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  branch    Branch     @relation(fields: [branchId], references: [id], onDelete: Cascade)
  room      BranchRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
  createdBy User?      @relation("ClinicRoomBlockCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)

  @@index([branchId, roomId])
  @@index([roomId, startAt, endAt])
  @@map("clinic_room_blocks")
}

// Branch Manager Control: owner-defined limits per branch
model BranchPolicy {
  id                    Int      @id @default(autoincrement())
  orgId                 Int
  branchId              Int
  maxDiscountPercent    Float    @default(30)
  maxRefundAmount       Float    @default(5000)
  maxPurchaseAmount     Float    @default(50000)
  requireOwnerApproval  Json     @default("[]") // e.g. ["STAFF_HIRE","PRICE_CHANGE","LARGE_PURCHASE","HIGH_DISCOUNT"]
  autoApproveStockBelow Float    @default(10000)
  allowManagerPricing   Boolean  @default(false)
  allowManagerRefund    Boolean  @default(true)
  shiftManagement       Boolean  @default(true)
  leaveApproval         Boolean  @default(true)
  customPoliciesJson    Json     @default("{}")
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  org    Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  branch Branch       @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@unique([branchId])
  @@index([orgId])
  @@map("branch_policies")
}

// Branch Manager Control: threshold-based approval escalation to owner
model ManagerApprovalEscalation {
  id                Int       @id @default(autoincrement())
  orgId             Int
  branchId          Int
  type              String // DISCOUNT, REFUND, PURCHASE, STAFF_HIRE, PRICE_CHANGE, SERVICE_TOGGLE
  triggerCondition  Json // e.g. {"field":"discountPercent","operator":">","value":30}
  status            String    @default("PENDING") // PENDING, APPROVED, REJECTED
  requestedByUserId Int
  payload           Json
  decidedByUserId   Int?
  decidedAt         DateTime?
  rejectReason      String?   @db.Text
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  org         Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  branch      Branch       @relation(fields: [branchId], references: [id], onDelete: Cascade)
  requestedBy User         @relation("EscalationRequester", fields: [requestedByUserId], references: [id], onDelete: Restrict)
  decidedBy   User?        @relation("EscalationDecider", fields: [decidedByUserId], references: [id], onDelete: SetNull)

  @@index([branchId, status])
  @@index([orgId, status])
  @@index([requestedByUserId])
  @@map("manager_approval_escalations")
}

