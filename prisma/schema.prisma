enum AuditEntityType {
  ORGANIZATION
  BRANCH
  OWNER_KYC
  // Global-Ready Phase 2: donation/transaction audit
  DONATION
  TRANSACTION
  // Owner control over branch managers (audit actions by owner on manager userId)
  USER
  // Workspace system (task, alert, approval audit)
  WORKSPACE_TASK
  WORKSPACE_ALERT
  WORKSPACE_APPROVAL
}

enum AuditActorRole {
  OWNER
  ADMIN
  SUPER_ADMIN
  STAFF
  USER
}

model AuditLog {
  id         Int             @id @default(autoincrement())
  actorId    String
  actorRole  AuditActorRole
  action     String
  entityType AuditEntityType
  entityId   String

  before Json?
  after  Json?

  ip        String?
