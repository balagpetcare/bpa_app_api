  @@index([surgeryPackageId])
  @@map("package_price_change_logs")
}

// Enterprise: full audit trail for package lifecycle
model PackageAuditLog {
  id               Int      @id @default(autoincrement())
  surgeryPackageId Int
  action           String   @db.VarChar(32) // CREATE, UPDATE, ITEM_ADD, ITEM_REMOVE, PUBLISH, ARCHIVE, PRICE_CHANGE, STATUS_CHANGE
  userId           Int?
  meta             Json? // { field, oldValue, newValue, itemId, etc. }
  createdAt        DateTime @default(now())

  surgeryPackage SurgeryPackage @relation(fields: [surgeryPackageId], references: [id], onDelete: Cascade)
  user           User?          @relation("PackageAuditLogBy", fields: [userId], references: [id], onDelete: SetNull)

  @@index([surgeryPackageId])
  @@index([createdAt])
  @@map("package_audit_logs")
}

model BranchOverheadRule {
