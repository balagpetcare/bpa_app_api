model ApprovalActionLog {
  id          Int      @id @default(autoincrement())
  orgId       Int
  branchId    Int
  entityType  String   @db.VarChar(32) // DISCOUNT | SETTLEMENT | PACKAGE
  entityId    Int
  action      String   @db.VarChar(32) // APPROVE | REJECT | REQUEST
  byUserId    Int
  roleKey     String?  @db.VarChar(64)
  reason      String?  @db.Text
  meta        Json?
  createdAt   DateTime @default(now())

  org    Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  branch Branch       @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@index([branchId, entityType])
  @@map("approval_action_logs")
}

model ClinicFinanceConfig {
  id                      Int      @id @default(autoincrement())
  branchId                Int      @unique
  settlementCycle          SettlementCycle @default(MONTHLY)
  discountLimitDefaultPct Decimal? @db.Decimal(5, 2)
  overheadAllocationMethod String? @db.VarChar(32)
  caseCompletionRule      String?  @db.VarChar(64)
  vialReturnDays          Int?     @default(7)
  stockIssueAuditLock     Boolean  @default(false)
  billEditRestrictionAfterClose Boolean @default(true)
  doctorFeeEditRestricted Boolean  @default(true)
  configJson              Json?
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  branch Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@map("clinic_finance_configs")
}

model TreatmentCourse {
  id                   Int       @id @default(autoincrement())
  patientId            Int
  visitId              Int?
  variantId             Int
  totalPrescribedDoses  Int
  expectedDatesJson     Json?     // array of date strings
  status                String    @db.VarChar(32) // ACTIVE, COMPLETED, DISCONTINUED
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  patient User   @relation("TreatmentCoursePatient", fields: [patientId], references: [id], onDelete: Restrict)
  visit   Visit? @relation(fields: [visitId], references: [id], onDelete: SetNull)
  variant ProductVariant @relation(fields: [variantId], references: [id], onDelete: Restrict)
  doses   TreatmentCourseDose[]

  @@index([patientId])
  @@index([visitId])
  @@index([variantId])
  @@index([status])
  @@map("treatment_courses")
}

model TreatmentCourseDose {
  id              Int      @id @default(autoincrement())
  courseId        Int
  vialSessionId   Int?
  doseQty         Decimal  @db.Decimal(12, 4)
  administeredAt  DateTime @default(now())
  administeredByUserId Int?

  course        TreatmentCourse @relation(fields: [courseId], references: [id], onDelete: Cascade)
  vialSession   VialSession?     @relation(fields: [vialSessionId], references: [id], onDelete: SetNull)

  @@index([courseId])
  @@index([vialSessionId])
  @@map("treatment_course_doses")
}

model VialReturn {
  id                  Int                        @id @default(autoincrement())
  vialSessionId       Int
  returnedAt          DateTime                   @default(now())
  returnedByUserId    Int
  condition           VialReturnCondition
  approxRemainingQty  Int?
  returnPhotoUrl      String?                    @db.Text
  receivedByUserId    Int?
  verificationStatus  VialReturnVerificationStatus @default(PENDING)
  createdAt           DateTime                   @default(now())
  updatedAt           DateTime                   @updatedAt

  vialSession  VialSession   @relation(fields: [vialSessionId], references: [id], onDelete: Cascade)
  returnedBy   User          @relation("VialReturnReturnedBy", fields: [returnedByUserId], references: [id], onDelete: Restrict)
  receivedBy   User?         @relation("VialReturnReceivedBy", fields: [receivedByUserId], references: [id], onDelete: SetNull)
  auditBinItems AuditBinItem[]

  @@index([vialSessionId])
  @@index([returnedAt])
  @@index([verificationStatus])
  @@map("vial_returns")
}

model AuditBin {
  id               Int           @id @default(autoincrement())
  branchId         Int
  roomId           Int?
  binType          AuditBinType
  sealNo           String?       @db.VarChar(64)
  startDate        DateTime      @default(now())
  closeDate        DateTime?
  retentionUntil   DateTime?
  currentItemCount Int           @default(0)
  status           AuditBinStatus @default(OPEN)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  branch Branch       @relation(fields: [branchId], references: [id], onDelete: Cascade)
  room   BranchRoom?  @relation(fields: [roomId], references: [id], onDelete: SetNull)
  items  AuditBinItem[]
  destructionRecords DestructionRecord[]

  @@index([branchId])
  @@index([binType])
  @@index([status])
  @@map("audit_bins")
}

model AuditBinItem {
  id             Int              @id @default(autoincrement())
  auditBinId     Int
  vialReturnId   Int
  storedAt       DateTime         @default(now())
  retentionUntil DateTime?
  itemStatus     AuditBinItemStatus @default(HELD)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  auditBin   AuditBin   @relation(fields: [auditBinId], references: [id], onDelete: Cascade)
  vialReturn VialReturn @relation(fields: [vialReturnId], references: [id], onDelete: Cascade)

  @@unique([vialReturnId])
  @@index([auditBinId])
  @@index([retentionUntil])
  @@map("audit_bin_items")
}

model DestructionRecord {
  id                Int      @id @default(autoincrement())
  auditBinId        Int
  destroyedAt       DateTime  @default(now())
  destroyedByUserId Int
  witnessUserId     Int?
  approvalRequestId Int?
  itemCount         Int      @default(0)
  photoUrl          String?  @db.Text
  createdAt         DateTime @default(now())

  auditBin       AuditBin @relation(fields: [auditBinId], references: [id], onDelete: Cascade)
  destroyedBy    User     @relation("DestructionRecordBy", fields: [destroyedByUserId], references: [id], onDelete: Restrict)
  witness         User?    @relation("DestructionRecordWitness", fields: [witnessUserId], references: [id], onDelete: SetNull)

  @@index([auditBinId])
  @@index([destroyedAt])
  @@map("destruction_records")
}

// ============================
// Phase 3: Approval & Incident governance
// ============================

enum MedicineApprovalRequestType {
  NO_RETURN_OVERRIDE
  BREAKAGE
  EMERGENCY_ISSUE
  STOCK_VARIANCE
  SUSPICIOUS_RETURN
  DESTRUCTION
}

enum MedicineApprovalStatus {
  PENDING
  APPROVED
  REJECTED
  ESCALATED
}

enum MedicineApprovalActionType {
  APPROVE
  REJECT
  ESCALATE
  COMMENT
}

enum MedicineIncidentType {
  MISSING_VIAL
  SUSPECTED_THEFT
  TAMPERED_RETURN
  STOCK_VARIANCE
  EXCESSIVE_BREAKAGE
}

enum MedicineIncidentSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum MedicineIncidentStatus {
  OPEN
  INVESTIGATING
  RESOLVED
  CLOSED
}

model MedicineApprovalRequest {
  id               Int                      @id @default(autoincrement())
  orgId            Int
  branchId         Int
  requestType      MedicineApprovalRequestType
  relatedEntityType String?                 @db.VarChar(64)
  relatedEntityId  String?                  @db.VarChar(64)
  reason           String?                  @db.Text
  evidenceUrls     Json?                    // string[]
  requestedByUserId Int
  status           MedicineApprovalStatus   @default(PENDING)
  createdAt        DateTime                 @default(now())
  updatedAt        DateTime                 @updatedAt

  org          Organization            @relation(fields: [orgId], references: [id], onDelete: Cascade)
  branch       Branch                  @relation(fields: [branchId], references: [id], onDelete: Cascade)
  requestedBy  User                    @relation("MedicineApprovalRequestedBy", fields: [requestedByUserId], references: [id], onDelete: Restrict)
  actions      MedicineApprovalAction[]

  @@index([branchId])
  @@index([status])
  @@index([requestType])
  @@map("medicine_approval_requests")
}

model MedicineApprovalAction {
  id               Int                      @id @default(autoincrement())
  approvalRequestId Int
  actionByUserId   Int
  action           MedicineApprovalActionType
  comments         String?                  @db.Text
  actionAt         DateTime                 @default(now())

  approvalRequest MedicineApprovalRequest @relation(fields: [approvalRequestId], references: [id], onDelete: Cascade)
  actionBy         User                   @relation("MedicineApprovalActionBy", fields: [actionByUserId], references: [id], onDelete: Restrict)

  @@index([approvalRequestId])
  @@map("medicine_approval_actions")
}

model MedicineIncident {
  id               Int                    @id @default(autoincrement())
  orgId            Int
  branchId         Int
  incidentType     MedicineIncidentType
  relatedEntityType String?               @db.VarChar(64)
  relatedEntityId  String?                @db.VarChar(64)
  severity         MedicineIncidentSeverity @default(MEDIUM)
  status           MedicineIncidentStatus @default(OPEN)
  assignedToUserId Int?
  resolutionNotes   String?                @db.Text
  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @updatedAt

  org         Organization         @relation(fields: [orgId], references: [id], onDelete: Cascade)
  branch      Branch               @relation(fields: [branchId], references: [id], onDelete: Cascade)
  assignedTo  User?                @relation("MedicineIncidentAssignedTo", fields: [assignedToUserId], references: [id], onDelete: SetNull)
  discrepancies MedicineDiscrepancy[]

  @@index([branchId])
  @@index([status])
  @@index([incidentType])
  @@map("medicine_incidents")
}

model MedicineDiscrepancy {
  id             Int      @id @default(autoincrement())
  branchId       Int
  variantId      Int
  expectedQty    Int
  actualQty      Int
  varianceQty    Int
  detectedAt     DateTime @default(now())
  detectedByUserId Int?
  status         String   @db.VarChar(32)
  incidentId     Int?

  branch    Branch          @relation(fields: [branchId], references: [id], onDelete: Cascade)
  variant   ProductVariant  @relation(fields: [variantId], references: [id], onDelete: Restrict)
  incident  MedicineIncident? @relation(fields: [incidentId], references: [id], onDelete: SetNull)

  @@index([branchId])
  @@index([incidentId])
  @@map("medicine_discrepancies")
}

// ============================
// Phase 4: Analytics
// ============================

model DailyMedicineVariance {
  id           Int     @id @default(autoincrement())
  branchId     Int
  variantId    Int
  date         DateTime @db.Date
  issuedQty    Int      @default(0)
  consumedQty  Int      @default(0)
  returnedQty  Int      @default(0)
  varianceQty  Int      @default(0)
  variancePct  Decimal? @db.Decimal(8, 2)
  createdAt    DateTime @default(now())

  branch  Branch         @relation(fields: [branchId], references: [id], onDelete: Cascade)
  variant ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@unique([branchId, variantId, date])
  @@index([branchId])
  @@index([date])
  @@map("daily_medicine_variances")
}

model UserMedicineRiskScore {
  id                 Int      @id @default(autoincrement())
  userId             Int
  branchId           Int
  overrideCount      Int      @default(0)
  missingReturnCount Int      @default(0)
  breakageCount      Int      @default(0)
  riskScore          Decimal  @db.Decimal(5, 2)
  lastCalculatedAt   DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  branch Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@unique([userId, branchId])
  @@index([branchId])
  @@map("user_medicine_risk_scores")
}

model BranchComplianceScore {
  id                   Int      @id @default(autoincrement())
  branchId             Int
  period               String   @db.VarChar(32) // e.g. "2026-03"
  returnCompliancePct  Decimal? @db.Decimal(5, 2)
  varianceScore        Decimal? @db.Decimal(5, 2)
  overrideFrequency    Int      @default(0)
  overallScore         Decimal? @db.Decimal(5, 2)
  createdAt            DateTime @default(now())

  branch Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@unique([branchId, period])
  @@index([branchId])
  @@map("branch_compliance_scores")
}

// ============================
// Clinic Master Catalog (global; install copies to org ClinicalItem/ClinicalItemCategory)
// ============================

model MasterClinicalCatalogCategory {
  id                    Int       @id @default(autoincrement())
  name                  String    @db.VarChar(128)
  slug                  String    @unique @db.VarChar(128)
  parentId              Int?
  domainType            ClinicalItemDomain?
  sortOrder             Int       @default(0)
  description           String?   @db.Text
  isEssential           Boolean   @default(false)
  inventoryTracked      Boolean   @default(true)
  packageEligible       Boolean   @default(true)
  prescriptionEligible  Boolean   @default(false)
  supplyRequestable     Boolean   @default(true)
  procedureUsable        Boolean   @default(true)
  branchVisible         Boolean   @default(true)
  pharmacyVisible       Boolean   @default(true)
  otVisible             Boolean   @default(true)
  isActive              Boolean   @default(true)
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  parent   MasterClinicalCatalogCategory?  @relation("MasterCategoryTree", fields: [parentId], references: [id], onDelete: SetNull)
  children MasterClinicalCatalogCategory[] @relation("MasterCategoryTree")
  items    MasterClinicalCatalogItem[]
  clinicCategories      ClinicalItemCategory[]
  templateCategoryItems TemplateCategoryItem[]

  @@index([parentId])
  @@map("master_clinical_catalog_categories")
}

model MasterClinicalCatalogItem {
  id                  Int                 @id @default(autoincrement())
  categoryId          Int
  itemCode            String              @db.VarChar(32)
  name                String              @db.VarChar(256)
  slug                String              @db.VarChar(256)
  domainType          ClinicalItemDomain
  baseUnit            String?             @db.VarChar(32)
  description         String?             @db.Text
  isActive            Boolean             @default(true)
  isPackageEligible   Boolean             @default(true)
  isInventoryTracked  Boolean             @default(true)
  requiresBatch       Boolean             @default(false)
  requiresExpiry      Boolean             @default(false)
  isReusable          Boolean             @default(false)
  defaultReorderLevel Decimal?            @db.Decimal(12, 4)
  defaultMinStock     Decimal?            @db.Decimal(12, 4)
  defaultMaxStock     Decimal?            @db.Decimal(12, 4)
  coldChainRequired    Boolean             @default(false)
  controlledItem      Boolean             @default(false)
  usageNoteTemplate   String?             @db.VarChar(256)
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt

  category    MasterClinicalCatalogCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  clinicItems ClinicalItem[]
  templateCategoryItems TemplateCategoryItem[]

  @@unique([categoryId, itemCode])
  @@unique([categoryId, slug])
  @@index([categoryId])
  @@index([domainType])
  @@map("master_clinical_catalog_items")
}

model MasterClinicalCatalogTemplate {
  id          Int      @id @default(autoincrement())
  name        String   @db.VarChar(128)
  slug        String   @unique @db.VarChar(128)
  description String?  @db.Text
  version     String   @default("1.0.0") @db.VarChar(32)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  templateCategoryItems TemplateCategoryItem[]
  installBatches        ClinicCatalogInstallBatch[]

  @@map("master_clinical_catalog_templates")
}

model TemplateCategoryItem {
  id                  Int  @id @default(autoincrement())
  templateId          Int
  masterCategoryId    Int?
  masterItemId        Int?
  sortOrder           Int  @default(0)
  includeSubcategories Boolean @default(false)
  createdAt           DateTime @default(now())

  template MasterClinicalCatalogTemplate  @relation(fields: [templateId], references: [id], onDelete: Cascade)
  masterCategory MasterClinicalCatalogCategory? @relation(fields: [masterCategoryId], references: [id], onDelete: Cascade)
  masterItem    MasterClinicalCatalogItem?     @relation(fields: [masterItemId], references: [id], onDelete: Cascade)

  @@index([templateId])
  @@index([masterCategoryId])
  @@index([masterItemId])
  @@map("template_category_items")
}

model ClinicCatalogInstallBatch {
  id              Int      @id @default(autoincrement())
  orgId           Int
  templateId      Int
  templateVersion String?  @db.VarChar(32)
  installedByUserId Int
  status          String   @default("COMPLETED") @db.VarChar(32)
  categoryCount   Int      @default(0)
  itemCount       Int      @default(0)
  optionsJson     Json?
  createdAt       DateTime @default(now())

  org    Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  template MasterClinicalCatalogTemplate @relation(fields: [templateId], references: [id], onDelete: Restrict)
  installedBy User @relation("ClinicCatalogInstallBatchInstalledBy", fields: [installedByUserId], references: [id], onDelete: Restrict)

  @@index([orgId])
  @@index([templateId])
  @@index([createdAt])
  @@map("clinic_catalog_install_batches")
}

// ============================
// Clinical Item Master (separate from Product)
// ============================

model ClinicalItem {
  id                  Int                 @id @default(autoincrement())
  orgId                Int
  itemCode             String              @db.VarChar(32)
  name                 String              @db.VarChar(256)
  slug                 String              @db.VarChar(256)
  domainType           ClinicalItemDomain
  categoryId           Int?
  baseUnit             String?             @db.VarChar(32)
  description         String?             @db.Text
  brandName            String?             @db.VarChar(128)
  manufacturerName     String?             @db.VarChar(128)
  isActive             Boolean             @default(true)
  isClinicUse          Boolean             @default(true)
  isSellable           Boolean             @default(false)
  isPackageEligible    Boolean             @default(true)
  isInventoryTracked   Boolean             @default(true)
  requiresBatch        Boolean             @default(false)
  requiresExpiry       Boolean             @default(false)
  isReusable           Boolean             @default(false)
  isHighRisk           Boolean             @default(false)
  defaultCost          Decimal?            @db.Decimal(12, 2)
  defaultSalePrice     Decimal?            @db.Decimal(12, 2)
  lifecycleState       ClinicalItemLifecycleState @default(ACTIVE)
  deprecatedAt         DateTime?           @db.Timestamptz
  replacementItemId    Int?
  masterCatalogItemId  Int?
  createdByUserId      Int?
  updatedByUserId      Int?
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt

  org                  Organization              @relation(fields: [orgId], references: [id], onDelete: Cascade)
  category             ClinicalItemCategory?     @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  replacementItem      ClinicalItem?              @relation("ClinicalItemReplacement", fields: [replacementItemId], references: [id], onDelete: SetNull)
  replacementFor       ClinicalItem[]             @relation("ClinicalItemReplacement")
  masterCatalogItem    MasterClinicalCatalogItem? @relation(fields: [masterCatalogItemId], references: [id], onDelete: SetNull)
  variants             ClinicalItemVariant[]
  medicineProfile      MedicineItemProfile?
  consumableProfile    ConsumableItemProfile?
  instrumentProfile    InstrumentItemProfile?
  branchConfigs        ClinicalItemBranchConfig[]
  branchStocks             BranchItemStock[]
  branchBatches            BranchItemBatch[]
  auditLogs                ClinicalItemAuditLog[]
  approvalLogs             ClinicalItemApprovalLog[]
  media                    ClinicalItemMedia[]
  packageItems             PackageItem[]
  consumptionItems         ConsumptionItem[]
  clinicalStockLedgerEntries ClinicalStockLedger[]
  clinicalSupplyRequestItems ClinicalSupplyRequestItem[]
  clinicalStockTransferItems ClinicalStockTransferItem[]
  sterilizationCycleItems   SterilizationCycleItem[]
  instrumentInstances       InstrumentInstance[]
  clinicalStockAuditLines   ClinicalStockAuditLine[]
  clinicalWastageLogs       ClinicalWastageLog[]
  replenishmentRecommendations ReplenishmentRecommendation[]

  @@unique([orgId, itemCode])
  @@unique([orgId, slug])
  @@index([orgId])
  @@index([categoryId])
  @@index([domainType])
  @@index([masterCatalogItemId])
  @@index([lifecycleState])
  @@map("clinical_items")
}

model ClinicalItemCategory {
  id          Int                  @id @default(autoincrement())
  orgId       Int
  name        String               @db.VarChar(128)
  parentId    Int?
  domainType  ClinicalItemDomain?
  sortOrder   Int                  @default(0)
  isActive    Boolean              @default(true)
  description String?              @db.Text
  isEssential Boolean             @default(false)
  // Category-level policy (inherit to items or override at item level)
  inventoryTracked    Boolean?    @default(true)
  packageEligible     Boolean?    @default(true)
  prescriptionEligible Boolean?  @default(false)
  supplyRequestable   Boolean?    @default(true)
  procedureUsable     Boolean?    @default(true)
  branchVisible       Boolean?    @default(true)
  pharmacyVisible     Boolean?    @default(true)
  otVisible           Boolean?    @default(true)
  masterCatalogCategoryId Int?
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt

  org        Organization          @relation(fields: [orgId], references: [id], onDelete: Cascade)
  parent     ClinicalItemCategory? @relation("CategoryTree", fields: [parentId], references: [id], onDelete: SetNull)
  children   ClinicalItemCategory[] @relation("CategoryTree")
  items      ClinicalItem[]
  masterCatalogCategory MasterClinicalCatalogCategory? @relation(fields: [masterCatalogCategoryId], references: [id], onDelete: SetNull)

  @@index([orgId])
  @@index([parentId])
  @@index([masterCatalogCategoryId])
  @@map("clinical_item_categories")
}

model ClinicalItemVariant {
  id               Int       @id @default(autoincrement())
  itemId            Int
  variantName       String    @db.VarChar(128)
  sku               String?   @db.VarChar(64)
  barcode           String?   @db.VarChar(64)
  unitLabel         String?   @db.VarChar(32)
  packSize          String?   @db.VarChar(64)
  strengthOrSpec    String?   @db.VarChar(128)
  defaultCost       Decimal?  @db.Decimal(12, 2)
  defaultSalePrice  Decimal?  @db.Decimal(12, 2)
  isActive          Boolean   @default(true)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  item                      ClinicalItem      @relation(fields: [itemId], references: [id], onDelete: Cascade)
  branchStocks              BranchItemStock[]
  branchBatches             BranchItemBatch[]
  packageItems              PackageItem[]
  consumptionItems          ConsumptionItem[]
  clinicalStockLedgerEntries ClinicalStockLedger[]
  clinicalSupplyRequestItems ClinicalSupplyRequestItem[]
  clinicalStockTransferItems ClinicalStockTransferItem[]
  clinicalStockAuditLines    ClinicalStockAuditLine[]
  clinicalWastageLogs        ClinicalWastageLog[]
  replenishmentRecommendations ReplenishmentRecommendation[]

  @@index([itemId])
  @@unique([itemId, sku])
  @@map("clinical_item_variants")
}

model MedicineItemProfile {
  id                    Int     @id @default(autoincrement())
  itemId                Int     @unique
  genericName           String? @db.VarChar(256)
  dosageForm            String? @db.VarChar(64)
  strength              String? @db.VarChar(128)
  route                 String? @db.VarChar(64)
  pharmacologyClass     String? @db.VarChar(128)
  requiresPrescription  Boolean @default(false)
  controlledSubstance   Boolean @default(false)
  dispenseUnit          String? @db.VarChar(32)
  batchMandatory        Boolean @default(true)
  expiryMandatory       Boolean @default(true)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  item ClinicalItem @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@map("medicine_item_profiles")
}

model ConsumableItemProfile {
  id                  Int             @id @default(autoincrement())
  itemId              Int             @unique
  consumableType      ConsumableType  @default(OTHER)
  sterileRequired     Boolean         @default(false)
  singleUseOnly       Boolean         @default(true)
  procedureLinked     Boolean         @default(false)
  wastageTrackRequired Boolean        @default(false)
  issueUnit           String?        @db.VarChar(32)
  usageNoteTemplate   String?         @db.VarChar(256)
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt

  item ClinicalItem @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@map("consumable_item_profiles")
}

model InstrumentItemProfile {
  id                      Int     @id @default(autoincrement())
  itemId                  Int     @unique
  instrumentType          InstrumentType @default(OTHER)
  sterilizationRequired   Boolean @default(true)
  maintenanceRequired     Boolean @default(false)
  assetTrackingRequired   Boolean @default(false)
  issueReturnRequired     Boolean @default(true)
  serviceCycleDays        Int?
  serialTracking          Boolean @default(false)
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  item ClinicalItem @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@map("instrument_item_profiles")
}

model BranchItemStock {
  id              Int      @id @default(autoincrement())
  branchId         Int
  itemId           Int
  variantId        Int
  currentQty       Decimal  @default(0) @db.Decimal(12, 4)
  reservedQty     Decimal  @default(0) @db.Decimal(12, 4)
  availableQty     Decimal  @default(0) @db.Decimal(12, 4)
  reorderLevel     Decimal? @db.Decimal(12, 4)
  maxLevel         Decimal? @db.Decimal(12, 4)
  avgCost          Decimal? @db.Decimal(12, 2)
  lastPurchaseCost Decimal? @db.Decimal(12, 2)
  lastUpdatedAt    DateTime @updatedAt

  branch   Branch              @relation(fields: [branchId], references: [id], onDelete: Cascade)
  item     ClinicalItem        @relation(fields: [itemId], references: [id], onDelete: Cascade)
  variant  ClinicalItemVariant  @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@unique([branchId, itemId, variantId])
  @@index([branchId])
  @@index([itemId])
  @@map("branch_item_stocks")
}

model BranchItemBatch {
  id           Int       @id @default(autoincrement())
  branchId     Int
  itemId       Int
  variantId    Int
  batchNo      String    @db.VarChar(64)
  expiryDate   DateTime? @db.Date
  receivedQty  Decimal   @db.Decimal(12, 4)
  usedQty      Decimal   @default(0) @db.Decimal(12, 4)
  remainingQty Decimal   @db.Decimal(12, 4)
  purchaseCost Decimal?  @db.Decimal(12, 2)
  status       String    @default("ACTIVE") @db.VarChar(16)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  branch   Branch              @relation(fields: [branchId], references: [id], onDelete: Cascade)
  item     ClinicalItem        @relation(fields: [itemId], references: [id], onDelete: Cascade)
  variant  ClinicalItemVariant  @relation(fields: [variantId], references: [id], onDelete: Cascade)
  consumptionItems         ConsumptionItem[]
  clinicalStockLedgerEntries ClinicalStockLedger[]

  @@index([branchId])
  @@index([itemId])
  @@index([variantId])
  @@index([expiryDate])
  @@map("branch_item_batches")
}

model ClinicalStockLedger {
  id              Int       @id @default(autoincrement())
  orgId           Int
  branchId        Int
  clinicalItemId  Int
  variantId       Int
  batchId         Int?
  txnType         String    @db.VarChar(48)
  quantityDelta   Int
  balanceAfter    Int
  unitCost        Decimal?  @db.Decimal(12, 2)
  refType         String?   @db.VarChar(32)
  refId           String?   @db.VarChar(64)
  note            String?   @db.VarChar(512)
  actorId         Int
  createdAt       DateTime  @default(now())

  org             Organization        @relation(fields: [orgId], references: [id], onDelete: Cascade)
  branch          Branch              @relation(fields: [branchId], references: [id], onDelete: Cascade)
  clinicalItem    ClinicalItem        @relation(fields: [clinicalItemId], references: [id], onDelete: Cascade)
  variant         ClinicalItemVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)
  batch           BranchItemBatch?    @relation(fields: [batchId], references: [id], onDelete: SetNull)
  actor           User                @relation("ClinicalStockLedgerActor", fields: [actorId], references: [id], onDelete: Restrict)

  @@index([orgId])
  @@index([branchId])
  @@index([clinicalItemId])
  @@index([variantId])
  @@index([createdAt])
  @@map("clinical_stock_ledger")
}

model ClinicalSupplyRequest {
  id              Int       @id @default(autoincrement())
  orgId           Int
  branchId        Int
  requestNo       String    @unique @db.VarChar(32)
  requestedById   Int
  priority        String    @default("ROUTINE") @db.VarChar(24)
  status          String    @default("DRAFT") @db.VarChar(24)
  note            String?   @db.VarChar(512)
  requestedAt     DateTime  @default(now())
  reviewedById    Int?
  reviewedAt      DateTime?
  reviewNote      String?   @db.VarChar(512)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  items           ClinicalSupplyRequestItem[]
  transfers       ClinicalStockTransfer[]
  org             Organization  @relation(fields: [orgId], references: [id], onDelete: Cascade)
  branch          Branch        @relation(fields: [branchId], references: [id], onDelete: Cascade)
  requestedBy     User          @relation("ClinicalSupplyRequestRequestedBy", fields: [requestedById], references: [id], onDelete: Restrict)
  reviewedBy      User?         @relation("ClinicalSupplyRequestReviewedBy", fields: [reviewedById], references: [id], onDelete: SetNull)

  @@index([orgId])
  @@index([branchId])
  @@index([status])
  @@map("clinical_supply_requests")
}

model ClinicalSupplyRequestItem {
  id              Int       @id @default(autoincrement())
  requestId       Int
  clinicalItemId  Int
  variantId       Int?
  requestedQty    Int
  approvedQty     Int?
  fulfilledQty    Int       @default(0)
  note            String?   @db.VarChar(256)

  request         ClinicalSupplyRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  clinicalItem    ClinicalItem          @relation(fields: [clinicalItemId], references: [id], onDelete: Cascade)
  variant         ClinicalItemVariant?  @relation(fields: [variantId], references: [id], onDelete: SetNull)

  @@index([requestId])
  @@map("clinical_supply_request_items")
}

model ClinicalStockTransfer {
  id                Int       @id @default(autoincrement())
  orgId             Int
  transferNo        String    @unique @db.VarChar(32)
  supplyRequestId   Int?
  fromBranchId      Int
  toBranchId        Int
  status            String    @default("CREATED") @db.VarChar(24)
  dispatchedById    Int?
  receivedById      Int?
  dispatchedAt      DateTime?
  receivedAt        DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  items             ClinicalStockTransferItem[]
  supplyRequest     ClinicalSupplyRequest? @relation(fields: [supplyRequestId], references: [id], onDelete: SetNull)
  org               Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  fromBranch        Branch     @relation("ClinicalTransferFrom", fields: [fromBranchId], references: [id], onDelete: Cascade)
  toBranch          Branch     @relation("ClinicalTransferTo", fields: [toBranchId], references: [id], onDelete: Cascade)

  @@index([orgId])
  @@index([fromBranchId])
  @@index([toBranchId])
  @@index([supplyRequestId])
  @@index([status])
  @@map("clinical_stock_transfers")
}

model ClinicalStockTransferItem {
  id              Int       @id @default(autoincrement())
  transferId      Int
  clinicalItemId  Int
  variantId       Int?
  batchNo         String?   @db.VarChar(64)
  expiryDate      DateTime? @db.Date
  qtySent         Int
  qtyReceived     Int?
  qtyDamaged      Int?

  transfer        ClinicalStockTransfer @relation(fields: [transferId], references: [id], onDelete: Cascade)
  clinicalItem    ClinicalItem          @relation(fields: [clinicalItemId], references: [id], onDelete: Cascade)
  variant         ClinicalItemVariant?  @relation(fields: [variantId], references: [id], onDelete: SetNull)

  @@index([transferId])
  @@map("clinical_stock_transfer_items")
}

model ClinicalStockAudit {
  id              Int       @id @default(autoincrement())
  orgId           Int
  branchId        Int
  auditNo         String    @unique @db.VarChar(32)
  auditScope      String    @db.VarChar(24)
  status          String    @default("DRAFT") @db.VarChar(24)
  initiatedById   Int
  approvedById    Int?
  startedAt       DateTime?
  completedAt     DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  lines           ClinicalStockAuditLine[]
  org             Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  branch          Branch       @relation(fields: [branchId], references: [id], onDelete: Cascade)
  initiatedBy     User         @relation("ClinicalStockAuditInitiatedBy", fields: [initiatedById], references: [id], onDelete: Restrict)
  approvedBy      User?        @relation("ClinicalStockAuditApprovedBy", fields: [approvedById], references: [id], onDelete: SetNull)

  @@index([orgId])
  @@index([branchId])
  @@index([status])
  @@map("clinical_stock_audits")
}

model ClinicalStockAuditLine {
  id               Int       @id @default(autoincrement())
  auditId          Int
  clinicalItemId   Int
  variantId        Int?
  batchNo          String?   @db.VarChar(64)
  systemQty        Int
  physicalQty      Int?
  varianceQty      Int?
  varianceReason   String?   @db.VarChar(256)
  resolutionStatus String?   @db.VarChar(24)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  audit          ClinicalStockAudit @relation(fields: [auditId], references: [id], onDelete: Cascade)
  clinicalItem   ClinicalItem        @relation(fields: [clinicalItemId], references: [id], onDelete: Cascade)
  variant        ClinicalItemVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)

  @@index([auditId])
  @@index([clinicalItemId])
  @@map("clinical_stock_audit_lines")
}

model ClinicalWastageLog {
  id              Int       @id @default(autoincrement())
  orgId           Int
  branchId        Int
  clinicalItemId  Int
  variantId       Int?
  batchNo         String?   @db.VarChar(64)
  wastageType     String    @db.VarChar(32)
  qty             Int
  reason          String?   @db.VarChar(512)
  reportedById    Int
  approvedById    Int?
  status          String    @default("PENDING") @db.VarChar(24)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

