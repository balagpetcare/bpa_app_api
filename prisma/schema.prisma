// Country/State admin/staff invite (non-branch scope)
model AccessInvite {
  id        Int                @id @default(autoincrement())
  scopeType AccessInviteScope
  countryId Int?
  stateId   Int?
  roleId    Int
  status    AccessInviteStatus @default(PENDING)

