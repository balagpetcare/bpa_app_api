model ClinicalCase {
  id               Int                @id @default(autoincrement())
  orgId            Int
  branchId         Int
  appointmentId    Int?               @unique
  visitId          Int?               @unique
  patientId        Int
  petId            Int
  surgeryPackageId Int?
  status           ClinicalCaseStatus @default(OPEN)
  totalCharges     Decimal?           @db.Decimal(12, 2)
  totalCollected   Decimal?           @db.Decimal(12, 2)
  primaryDoctorId  Int? // BranchMember.id
  openedAt         DateTime           @default(now())
  completedAt      DateTime?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  org                    Organization             @relation(fields: [orgId], references: [id], onDelete: Cascade)
  branch                 Branch                   @relation(fields: [branchId], references: [id], onDelete: Cascade)
  appointment            Appointment?             @relation(fields: [appointmentId], references: [id], onDelete: SetNull)
  visit                  Visit?                   @relation(fields: [visitId], references: [id], onDelete: SetNull)
  patient                User                     @relation("ClinicalCasePatient", fields: [patientId], references: [id], onDelete: Restrict)
  pet                    Pet                      @relation(fields: [petId], references: [id], onDelete: Restrict)
  surgeryPackage         SurgeryPackage?          @relation(fields: [surgeryPackageId], references: [id], onDelete: SetNull)
  primaryDoctor          BranchMember?            @relation("ClinicalCasePrimaryDoctor", fields: [primaryDoctorId], references: [id], onDelete: SetNull)
