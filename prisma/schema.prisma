model UserWallet {
  id     Int  @id @default(autoincrement())
  userId Int  @unique // ✅ প্রতি ইউজারের শুধু ১টি ওয়ালেট
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  // NOTE:
  // balance = availableBalance + pendingBalance + lockedBalance
  // Keep balance for backward-compatibility and quick reads.
  balance Decimal @default(0.00) @db.Decimal(10, 2)

  // V1 split balances
  availableBalance Decimal  @default(0.00) @db.Decimal(10, 2)
  pendingBalance   Decimal  @default(0.00) @db.Decimal(10, 2)
  lockedBalance    Decimal  @default(0.00) @db.Decimal(10, 2)
  currency         String   @default("BDT")
  points           Int      @default(0)
  tier             String   @default("Bronze")
  isActive         Boolean  @default(true)
  updatedAt        DateTime @updatedAt

  transactions WalletTransaction[]

  withdrawRequests WalletWithdrawRequest[]

  @@map("user_wallets")
}

model WalletTransaction {
  id       Int        @id @default(autoincrement())
  walletId Int
  wallet   UserWallet @relation(fields: [walletId], references: [id], onDelete: Cascade)

  type   TransactionType
  status TransactionStatus @default(PENDING)

  amount    Decimal        @db.Decimal(10, 2)
  method    PaymentMethod?
  reference String?

  // V1: link a transaction to its source entity
