// ============================
// Admin — Global Medicine Catalog Import (staging + core + country listings)
// ============================

enum MedicineImportBatchStatus {
  UPLOADED
  PARSED
  PREVIEW_READY
  CONFIRMED
  APPLYING
  APPLIED
  PARTIALLY_APPLIED
  FAILED
  CANCELLED
}

enum MedicineImportRowClassification {
  INVALID
  DUPLICATE_IN_FILE
  EXISTS_IN_DB
  NEW
  NEEDS_REVIEW
}

enum MedicineImportRowApplyStatus {
  PENDING
  APPLIED
  SKIPPED
  FAILED
}

model MedicineImportBatch {
  id                 Int                       @id @default(autoincrement())
  countryId          Int
  filename           String                    @db.VarChar(512)
  fileSha256         String                    @db.VarChar(64)
  fileSizeBytes      Int
  /// When raw files move to object storage (S3/Blob), set this key; v1 often null (in-memory/DB staging only).
  rawStorageKey      String?                   @db.VarChar(512)
  /// ADMIN today; MANUFACTURER (or similar) reserved for future submitter workflows before apply.
  uploadSource       String                    @default("ADMIN") @db.VarChar(32)
  provider           String                    @default("admin_csv") @db.VarChar(64)
  status             MedicineImportBatchStatus @default(UPLOADED)
  totalRows          Int                       @default(0)
  previewVersion     Int                       @default(0)
  previewSummaryJson Json?
  confirmedAt        DateTime?
  confirmedByUserId  Int?
  appliedAt          DateTime?
  appliedByUserId    Int?
  applySummaryJson   Json?
  errorMessage       String?                   @db.Text
  uploadedByUserId   Int
  createdAt          DateTime                  @default(now())
  updatedAt          DateTime                  @updatedAt

  country            Country                     @relation(fields: [countryId], references: [id], onDelete: Restrict)
  uploadedBy         User                        @relation("MedicineImportBatchUploadedBy", fields: [uploadedByUserId], references: [id], onDelete: Restrict)
  confirmedBy        User?                       @relation("MedicineImportBatchConfirmedBy", fields: [confirmedByUserId], references: [id], onDelete: SetNull)
  appliedBy          User?                       @relation("MedicineImportBatchAppliedBy", fields: [appliedByUserId], references: [id], onDelete: SetNull)
  rows               MedicineImportRow[]
  entityTouches      MedicineImportEntityTouch[]
  firstCountryBrands CountryMedicineBrand[]      @relation("CountryMedicineBrandFirstBatch")
  lastCountryBrands  CountryMedicineBrand[]      @relation("CountryMedicineBrandLastBatch")

  @@index([countryId, status, createdAt])
  @@index([fileSha256])
  @@index([uploadedByUserId])
  @@map("medicine_import_batches")
}

model MedicineImportRow {
  id                     Int                             @id @default(autoincrement())
  batchId                Int
  rowNumber              Int
  rawPayloadJson         Json
  normalizedPayloadJson  Json?
  issuesJson             Json?
  rowFingerprint         String                          @db.VarChar(64)
  classification         MedicineImportRowClassification @default(INVALID)
  duplicateOfRowNumber   Int?
  applyStatus            MedicineImportRowApplyStatus    @default(PENDING)
  applyDetailJson        Json?
  countryMedicineBrandId Int?
  createdAt              DateTime                        @default(now())
  updatedAt              DateTime                        @updatedAt

  batch                MedicineImportBatch   @relation(fields: [batchId], references: [id], onDelete: Cascade)
  countryMedicineBrand CountryMedicineBrand? @relation(fields: [countryMedicineBrandId], references: [id], onDelete: SetNull)

  @@index([batchId, classification])
  @@index([batchId, applyStatus])
  @@index([batchId, rowNumber])
  @@index([rowFingerprint])
  @@map("medicine_import_rows")
}

model MedicineImportEntityTouch {
  id           Int      @id @default(autoincrement())
  batchId      Int
  entityType   String   @db.VarChar(32)
  entityId     Int
  action       String   @db.VarChar(16)
  snapshotJson Json?
  createdAt    DateTime @default(now())

  batch MedicineImportBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)

  @@index([batchId])
  @@index([entityType, entityId])
  @@map("medicine_import_entity_touches")
}

/// Append-only audit for admin medicine workspace CRUD / toggles (separate from import entity touches).
model MedicineMasterAuditLog {
  id         Int      @id @default(autoincrement())
  entityType String   @db.VarChar(64)
  entityId   Int
  action     String   @db.VarChar(32)
  beforeJson Json?
  afterJson  Json?
  userId     Int
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@index([entityType, entityId])
  @@index([userId, createdAt])
  @@map("medicine_master_audit_logs")
}

