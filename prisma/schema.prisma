// AUTO-SPLIT from original schema.prisma
// Module: base

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// AUTO-SPLIT from original schema.prisma
// Module: core

enum Gender {
  MALE
  FEMALE
  UNKNOWN
}

enum PetStatus {
  ACTIVE
  DECEASED
  LOST
  ADOPTED
}

enum FamilyRelation {
  OWNER
  DAD
  MOM
  BROTHER
  SISTER
  OTHER
}

enum UserStatus {
  ACTIVE
  BLOCKED
  DELETED
}

enum ProfileVisibility {
  PUBLIC
  PRIVATE
  FOLLOWERS_ONLY
}

enum AuthProvider {
  LOCAL
  GOOGLE
  FACEBOOK
  APPLE
}

enum FriendRequestStatus {
  PENDING
  ACCEPTED
  REJECTED
  CANCELED
}

enum PostType {
  TEXT
  IMAGE
  VIDEO
  REEL
}

enum PostCategory {
  GENERAL
  FUNDRAISING
  FUNDRAISING_UPDATE
}

// Enterprise animal taxonomy: category -> type -> breed -> sub-breed; standalone: color, coat pattern, size
model AnimalCategory {
  id           Int          @id @default(autoincrement())
  code         String       @unique
  name         String
  displayOrder Int          @default(0)
  isActive     Boolean      @default(true)
  animalTypes  AnimalType[]

  @@map("animal_categories")
}

model AnimalType {
  id             Int             @id @default(autoincrement())
  name           String          @unique
  categoryId     Int?
  category       AnimalCategory? @relation(fields: [categoryId], references: [id])
  code           String?         @unique
  scientificName String?         @db.VarChar(128)
  icon           String?         @db.VarChar(64)
  displayOrder   Int?            @default(0)
  isActive       Boolean?        @default(true)
  breeds         Breed[]
  pets           Pet[]
  vaccineTypes   VaccineType[]

  @@map("animal_types")
}

model AnimalSize {
  id            Int     @id @default(autoincrement())
  code          String  @unique
  name          String
  minWeightKg   Float?
  maxWeightKg   Float?
  displayOrder  Int     @default(0)
  isActive      Boolean @default(true)
  breedsDefault Breed[]
  pets          Pet[]

  @@map("animal_sizes")
}

model AnimalColor {
  id           Int     @id @default(autoincrement())
  code         String  @unique
  name         String
  hexPreview   String? @db.VarChar(16)
  displayOrder Int     @default(0)
  isActive     Boolean @default(true)
  pets         Pet[]

  @@map("animal_colors")
}

model CoatPattern {
  id           Int     @id @default(autoincrement())
  code         String  @unique
  name         String
  displayOrder Int     @default(0)
  isActive     Boolean @default(true)
  pets         Pet[]

  @@map("coat_patterns")
}

model Breed {
  id            Int         @id @default(autoincrement())
  name          String
  animalTypeId  Int
  animalType    AnimalType  @relation(fields: [animalTypeId], references: [id])
  code          String?     @db.VarChar(64)
  aliasNames    Json? // e.g. ["Deshi","Local"] for search
  originCountry String?     @db.VarChar(64)
  defaultSizeId Int?
  defaultSize   AnimalSize? @relation(fields: [defaultSizeId], references: [id])
  isMixed       Boolean     @default(false)
  isOther       Boolean     @default(false)
  displayOrder  Int?        @default(0)
  isActive      Boolean?    @default(true)
  pets          Pet[]
  subBreeds     SubBreed[]

  @@unique([name, animalTypeId])
  @@map("breeds")
}

model SubBreed {
  id           Int     @id @default(autoincrement())
  breedId      Int
  breed        Breed   @relation(fields: [breedId], references: [id])
  code         String  @db.VarChar(64)
  name         String
  displayOrder Int     @default(0)
  isActive     Boolean @default(true)
  pets         Pet[]

  @@unique([breedId, code])
  @@map("sub_breeds")
}

model UserAuth {
  id     Int  @id @default(autoincrement())
  userId Int  @unique
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  provider AuthProvider @default(LOCAL)

  email        String? @unique
  phone        String? @unique
  passwordHash String? // LOCAL only

  passwordUpdatedAt DateTime?
  emailVerifiedAt   DateTime?
  phoneVerifiedAt   DateTime?

  lastLoginAt    DateTime?
  failedAttempts Int       @default(0)
  lockedUntil    DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email])
  @@index([phone])
  @@map("user_auth")
}

model UserProfile {
  id     Int  @id @default(autoincrement())
  userId Int  @unique
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  displayName String
  username    String  @unique
  bio         String? @db.Text

  visibility ProfileVisibility @default(PUBLIC)

  // privacy flags
  showEmail Boolean @default(false)
  showPhone Boolean @default(false)

  // Media: avatar & cover
  avatarMediaId Int?
  avatarMedia   Media? @relation("UserAvatar", fields: [avatarMediaId], references: [id])

  coverMediaId Int?
  coverMedia   Media? @relation("UserCover", fields: [coverMediaId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([username])
  @@map("user_profiles")
}

model UserStatsCache {
  userId Int  @id
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  followersCount Int @default(0)
  followingCount Int @default(0)
  petsCount      Int @default(0)

  // Mirror/cache for fast profile reads (source of truth: UserWallet.points)
  pawPoints Int @default(0)

  // Cached rank (optional)
  rankGlobal Int?

  updatedAt DateTime @updatedAt

  @@map("user_stats_cache")
}

model UserSession {
  id     Int  @id @default(autoincrement())
  userId Int
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Store hash only (never store raw refresh token)
  refreshTokenHash String @unique

  deviceId  String?
  userAgent String?
  ip        String?

  createdAt DateTime  @default(now())
  expiresAt DateTime
  revokedAt DateTime?

  @@index([userId])
  @@index([expiresAt])
  @@map("user_sessions")
}

model UserFollow {
  id          Int      @id @default(autoincrement())
  followerId  Int
  followingId Int
  createdAt   DateTime @default(now())

  follower  User @relation("UserFollowing", fields: [followerId], references: [id], onDelete: Cascade)
  following User @relation("UserFollowers", fields: [followingId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId])
  @@index([followingId])
  @@index([followerId])
  @@map("user_follows")
}

model UserProfileLike {
  id        Int      @id @default(autoincrement())
  userId    Int
  likedById Int
  createdAt DateTime @default(now())

  user    User @relation("UserProfileLiked", fields: [userId], references: [id], onDelete: Cascade)
  likedBy User @relation("UserProfileLiker", fields: [likedById], references: [id], onDelete: Cascade)

  @@unique([userId, likedById])
  @@index([userId])
  @@index([likedById])
  @@map("user_profile_likes")
}

model UserFriendRequest {
  id         Int                 @id @default(autoincrement())
  fromUserId Int
  toUserId   Int
  status     FriendRequestStatus @default(PENDING)
  createdAt  DateTime            @default(now())
  updatedAt  DateTime            @updatedAt

  fromUser User @relation("FriendRequestFrom", fields: [fromUserId], references: [id], onDelete: Cascade)
  toUser   User @relation("FriendRequestTo", fields: [toUserId], references: [id], onDelete: Cascade)

  @@unique([fromUserId, toUserId])
  @@index([toUserId])
  @@index([fromUserId])
  @@map("user_friend_requests")
}

model UserFriend {
  id        Int      @id @default(autoincrement())
  userAId   Int
  userBId   Int
  createdAt DateTime @default(now())

  userA User @relation("UserFriendA", fields: [userAId], references: [id], onDelete: Cascade)
  userB User @relation("UserFriendB", fields: [userBId], references: [id], onDelete: Cascade)

  @@unique([userAId, userBId])
  @@index([userAId])
  @@index([userBId])
  @@map("user_friends")
}

model Achievement {
  id             Int     @id @default(autoincrement())
  code           String  @unique
  title          String
  description    String?
  requiredPoints Int     @default(0)
  pointsReward   Int     @default(0)
  howTo          String?

  iconMediaId Int?
  iconMedia   Media? @relation("AchievementIcon", fields: [iconMediaId], references: [id])

  createdAt DateTime @default(now())

  users UserAchievement[]

  @@map("achievements")
}

model UserAchievement {
  id            Int      @id @default(autoincrement())
  userId        Int
  achievementId Int
  unlockedAt    DateTime @default(now())

  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  achievement Achievement @relation(fields: [achievementId], references: [id], onDelete: Cascade)

  @@unique([userId, achievementId])
  @@index([userId])
  @@map("user_achievements")
}

model UserGalleryItem {
  id     Int  @id @default(autoincrement())
  userId Int
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  mediaId Int
  media   Media @relation("UserGalleryMedia", fields: [mediaId], references: [id], onDelete: Cascade)

  caption   String?
  createdAt DateTime @default(now())
  deleted   Boolean  @default(false)

  @@index([userId, createdAt])
  @@map("user_gallery_items")
}

model User {
  id           Int        @id @default(autoincrement())
  status       UserStatus @default(ACTIVE)
  tokenVersion Int        @default(0)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  // Split tables (keep User thin)
  auth     UserAuth?
  profile  UserProfile?
  stats    UserStatsCache?
  sessions UserSession[]

  // Social graph
  followsFollowing UserFollow[] @relation("UserFollowing")
  followsFollowers UserFollow[] @relation("UserFollowers")

  profileLikesReceived UserProfileLike[] @relation("UserProfileLiked")
  profileLikesGiven    UserProfileLike[] @relation("UserProfileLiker")

  friendRequestsSent     UserFriendRequest[] @relation("FriendRequestFrom")
  friendRequestsReceived UserFriendRequest[] @relation("FriendRequestTo")

  friendsA UserFriend[] @relation("UserFriendA")
  friendsB UserFriend[] @relation("UserFriendB")

  // Existing relations
  pets                   Pet[]
  appointmentsAsPatient  Appointment[]           @relation("AppointmentPatient")
  visitsAsPatient        Visit[]                 @relation("VisitPatient")
  wallet                 UserWallet?
  walletWithdrawRequests WalletWithdrawRequest[]
  rewardHistories        RewardHistory[]

  // Home feed / posts
  posts                               Post[]
  postLikes                           PostLike[]
  postComments                        PostComment[]
  // postComments     PostComment[]
  postCommentLikes                    PostCommentLike[]
  // NEW: opposite side of Media.owner
  uploadedMedia                       Media[]                       @relation("UserUploadedMedia")
  fundraisingAccountStatusLogsAsAdmin FundraisingAccountStatusLog[] @relation("FundraisingAccountStatusLogAdminUser")
  fundraisingWithdrawRequestsAsAdmin  FundraisingWithdrawRequest[]  @relation("FundraisingWithdrawAdminUser")
  walletWithdrawRequestsAsAdmin       WalletWithdrawRequest[]       @relation("WalletWithdrawAdminUser")

  // Premium profile features
  achievements UserAchievement[]
  galleryItems UserGalleryItem[]

  // FUNDRAISING (Phase A) - opposite relation fields
  fundraisingAccount FundraisingAccount?
  donations          Donation[]

  // REPORTS (Phase B) - opposite relation field
  reports Report[] @relation("UserReports")

  // PARTNER ONBOARDING (Org/Branch)
  partnerApplications PartnerApplication[]
  ownedOrganizations  Organization[]
  ownerProfile        OwnerProfile?

  // PHASE-1 KYC / Verification
  ownerKyc                   OwnerKyc?
  ownerKycReviewed           OwnerKyc[]                 @relation("OwnerKycReviewedBy")
  doctorVerification         DoctorVerification?
  doctorVerificationReviewed DoctorVerification[]       @relation("DoctorVerificationReviewedBy")
  orgLegalProfilesReviewed   OrganizationLegalProfile[] @relation("OrgKycReviewedBy")
  branchProfilesReviewed     BranchProfileDetails[]     @relation("BranchKycReviewedBy")
  verificationLogsAsAdmin    VerificationLog[]          @relation("VerificationLogAdmin")

  // ============================
  // V3 VERIFICATION (opposites)
  // ============================

  verificationCasesReviewed   VerificationCase[]      @relation("VerificationCaseReviewedBy")
  verificationDocsChecked     VerificationDocument[]  @relation("VerificationDocCheckedBy")
  verificationCaseEventsAdmin VerificationCaseEvent[] @relation("VerificationCaseEventAdmin")

  notifications              Notification[]
  notificationsSent          Notification[]                    @relation("NotificationSender")
  notificationReads          NotificationRead[]
  notificationPrefs          UserNotificationPrefs?
  verificationLockedAttempts VerificationLockedUpdateAttempt[]

  // === BPA PATCH: memberships + product approval ===
  orgMemberships              OrgMember[]
  branchMemberships           BranchMember[]
  productsCreated             Product[]              @relation("ProductCreatedBy")
  productImportBatchesCreated ProductImportBatch[]   @relation("ProductImportBatchCreatedBy")
  productCRRequested          ProductChangeRequest[] @relation("ProductCRRequestedBy")
  productCRReviewed           ProductChangeRequest[] @relation("ProductCRReviewedBy")

  grnsReceived                   Grn[]                  @relation("GrnReceivedBy")
  grnsVoided                     Grn[]                  @relation("GrnVoidedBy")
  vendorReceiveSessionsCreated   VendorReceiveSession[] @relation("VendorReceiveSessionCreatedBy")
  vendorReceiveSessionsSubmitted VendorReceiveSession[] @relation("VendorReceiveSessionSubmittedBy")
  vendorReceiveSessionsConfirmed VendorReceiveSession[] @relation("VendorReceiveSessionConfirmedBy")
  dispatchReceiveSessionsVerified DispatchReceiveSession[] @relation("DispatchReceiveSessionVerifiedBy")
  dispatchReceiveSessionsSubmitted DispatchReceiveSession[] @relation("DispatchReceiveSessionSubmittedBy")
  dispatchReceiveSessionsConfirmed DispatchReceiveSession[] @relation("DispatchReceiveSessionConfirmedBy")
  catalogEnableRequestsRequested CatalogEnableRequest[] @relation("CatalogEnableRequestedBy")
  catalogEnableRequestsReviewed  CatalogEnableRequest[] @relation("CatalogEnableReviewedBy")

  // === BPA PATCH: staff invites (token-based) ===
  staffInvitesSent      StaffInvite[]  @relation("StaffInviteInvitedBy")
  staffInvitesAccepted  StaffInvite[]  @relation("StaffInviteAcceptedBy")
  accessInvitesSent     AccessInvite[] @relation("AccessInviteInvitedBy")
  accessInvitesAccepted AccessInvite[] @relation("AccessInviteAcceptedBy")

  // === Doctor requests (doctor → clinic approval) ===
  doctorRequestsCreated  DoctorRequest[] @relation("DoctorRequestCreatedBy")
  doctorRequestsApproved DoctorRequest[] @relation("DoctorRequestApprovedBy")

  // ✅ invitedBy opposite relations
  orgMembersInvited    OrgMember[]    @relation("OrgMemberInvitedBy")
  branchMembersInvited BranchMember[] @relation("BranchMemberInvitedBy")

  // === MVP: Inventory & Orders ===
  stockTransactionsCreated       StockTransaction[]      @relation("StockTransactionCreatedBy")
  ordersCreated                  Order[]                 @relation("OrderCreatedBy")
  ordersAsCustomer               Order[]                 @relation("OrderCustomer")
  servicesCreated                Service[]               @relation("ServiceCreatedBy")
  clinicalCasesAsPatient         ClinicalCase[]          @relation("ClinicalCasePatient")
  packagePriceChangeLogs         PackagePriceChangeLog[] @relation("PackagePriceChangeLogBy")
  surgeryPackagesUpdatedBy       SurgeryPackage[]        @relation("SurgeryPackageUpdatedBy")
  packageAuditLogs               PackageAuditLog[]       @relation("PackageAuditLogBy")
  appliedDiscountsApprovedBy     AppliedDiscount[]       @relation("AppliedDiscountApprovedBy")
  settlementPaymentsPaidBy       SettlementPayment[]     @relation("SettlementPaymentBy")
  settlementAdjustmentsCreatedBy SettlementAdjustment[]  @relation("SettlementAdjustmentBy")
  posShiftsOpened                PosShift[]              @relation("PosShiftOpenedBy")
  posShiftsClosed                PosShift[]              @relation("PosShiftClosedBy")

  // === Products Module: Stock Ledger & Transfers ===
  stockLedgersCreated                     StockLedger[]                        @relation("StockLedgerCreatedBy")
  stockTransfersCreated                   StockTransfer[]                      @relation("StockTransferCreatedBy")
  stockDispatchesCreated                  StockDispatch[]                      @relation("StockDispatchCreatedBy")
  stockReturnsCreated                     StockReturn[]                        @relation("StockReturnCreatedBy")
  stockReturnsReceived                    StockReturn[]                        @relation("StockReturnReceivedBy")
  returnRequestsCreated                   ReturnRequest[]                      @relation("ReturnRequestedBy")
  stockLotsCreated                        StockLot[]                           @relation("StockLotCreatedBy")
  stockAdjustmentRequestsRequested        StockAdjustmentRequest[]             @relation("StockAdjustmentRequestedBy")
  stockAdjustmentRequestsReviewed         StockAdjustmentRequest[]             @relation("StockAdjustmentReviewedBy")
  stockCountSessionsCreated               StockCountSession[]                  @relation("StockCountSessionCreatedBy")
  stockDiscrepanciesResolved              StockDiscrepancy[]                   @relation("StockDiscrepancyResolvedBy")
  stockDispatchDiscrepanciesResolved      StockDispatchDiscrepancy[]           @relation("StockDispatchDiscrepancyResolvedBy")
  stockRequestsRequested                  StockRequest[]                       @relation("StockRequestRequestedBy")
  stockRequestsDeclined                   StockRequest[]                       @relation("StockRequestDeclinedBy")
  stockRequestsApproved                   StockRequest[]                       @relation("StockRequestApprovedBy")
  stockRequestItemsCancelled              StockRequestItem[]                   @relation("StockRequestItemCancelledBy")
  clinicalStockLedgerEntries              ClinicalStockLedger[]                @relation("ClinicalStockLedgerActor")
  clinicalSupplyRequestsRequested         ClinicalSupplyRequest[]              @relation("ClinicalSupplyRequestRequestedBy")
  clinicalSupplyRequestsReviewed          ClinicalSupplyRequest[]              @relation("ClinicalSupplyRequestReviewedBy")
  clinicalSupplyRequestStatusHistoryActed ClinicalSupplyRequestStatusHistory[] @relation("ClinicalSupplyRequestStatusHistoryActor")
  clinicCatalogInstallBatches             ClinicCatalogInstallBatch[]          @relation("ClinicCatalogInstallBatchInstalledBy")
  sterilizationCyclesOperated             SterilizationCycle[]                 @relation("SterilizationCycleOperator")
  clinicalStockAuditsInitiated            ClinicalStockAudit[]                 @relation("ClinicalStockAuditInitiatedBy")
  clinicalStockAuditsApproved             ClinicalStockAudit[]                 @relation("ClinicalStockAuditApprovedBy")
  clinicalWastageLogsReported             ClinicalWastageLog[]                 @relation("ClinicalWastageReportedBy")

  // === Enterprise Extensions ===
  ownerDiscountCards          OwnerDiscountCard[]       @relation("OwnerDiscountCardUser")
  ownerDiscountCardsIssued    OwnerDiscountCard[]       @relation("OwnerDiscountCardIssuer")
  emergencyApprovalsRequested EmergencyDoctorApproval[] @relation("EmergencyApprovalRequester")
  emergencyApprovalsApproved  EmergencyDoctorApproval[] @relation("EmergencyApprovalApprover")
  clinicalWastageLogsApproved ClinicalWastageLog[]      @relation("ClinicalWastageApprovedBy")
  clinicRoomBlocksCreated     ClinicRoomBlock[]         @relation("ClinicRoomBlockCreatedBy")

  // === Product Authenticity (MVP) ===
  productVersionsCreated ProductVersion[] @relation("ProductVersionCreatedBy")
  batchesCreated         Batch[]          @relation("BatchCreatedBy")
  serialRangesIssued     SerialRange[]    @relation("SerialRangeIssuedBy")

  // === Producer Auth (separate schema) ===
  producerOrgsOwned                ProducerOrg[]              @relation("ProducerOrgOwner")
  producerStaffRoles               ProducerOrgStaff[]         @relation("ProducerStaffUser")
  producerStaffInvited             ProducerOrgStaff[]         @relation("ProducerStaffInviter")
  producerStaffInvitesSent         ProducerStaffInvite[]      @relation("ProducerStaffInviteInvitedBy")
  producerStaffInvitesAccepted     ProducerStaffInvite[]      @relation("ProducerStaffInviteAcceptedBy")
  authProductsCreated              AuthProduct[]              @relation("AuthProductCreatedBy")
  authBatchesCreated               AuthBatch[]                @relation("AuthBatchCreatedBy")
  authBatchesPrinted               AuthBatch[]                @relation("AuthBatchPrintedBy")
  authCodesGenerated               AuthCode[]                 @relation("AuthCodeGeneratedBy")
  authCodesIssued                  AuthCode[]                 @relation("AuthCodeIssuedBy")
  authVerifyLogs                   AuthVerificationLog[]
  batchSerialAllocationLogs        BatchSerialAllocationLog[] @relation("BatchSerialAllocationAllocatedBy")
  batchSerialAllocationLogsRevoked BatchSerialAllocationLog[] @relation("BatchSerialAllocationRevokedBy")
  producerEmailRecipientsCreated   ProducerEmailRecipient[]   @relation("ProducerEmailRecipientCreatedBy")
  orgFeatureFlagsUpdated           OrgFeatureFlag[]           @relation("OrgFeatureFlagUpdatedBy")
  orgQuotasUpdated                 OrgQuota[]                 @relation("OrgQuotaUpdatedBy")
  returnRequestsApproved           ReturnRequest[]            @relation("ReturnApprovedBy")

  // === Multi-Branch Staff Permission System ===
  branchAccessPermissions          BranchAccessPermission[] @relation("BranchAccessPermissionUser")
  branchAccessPermissionsApproved  BranchAccessPermission[] @relation("BranchAccessPermissionApprovedBy")
  branchAccessPermissionsRevoked   BranchAccessPermission[] @relation("BranchAccessPermissionRevokedBy")
  branchAccessPermissionsRequested BranchAccessPermission[] @relation("BranchAccessPermissionRequestedBy")

  // Phase 4: Global + Country RBAC
  globalRoles  UserGlobalRole[]
  countryRoles UserCountryRole[]
  stateRoles   UserStateRole[]

  // === Owner Delegation & Team Management ===
  ownerTeamsOwned          OwnerTeam[]
  ownerTeamMemberships     OwnerTeamMember[]
  ownerDelegationsGranted  OwnerDelegation[]  @relation("OwnerDelegationOwner")
  ownerDelegationsReceived OwnerDelegation[]  @relation("OwnerDelegationDelegate")
  ownerOverviewLogs        OwnerOverviewLog[] @relation("OwnerOverviewLogOwner")
  ownerOverviewLogsAsActor OwnerOverviewLog[] @relation("OwnerOverviewLogActor")
  userContexts             UserContext[]
  userContextsAsOwner      UserContext[]      @relation("UserContextOwner")
  teamInvitationsSent      TeamInvitation[]   @relation("TeamInvitationInvitedBy")
  teamInvitationsAccepted  TeamInvitation[]   @relation("TeamInvitationAcceptedBy")
  teamInvitationsAsOwner   TeamInvitation[]   @relation("TeamInvitationOwner")
  aiRecommendationOverrides AiRecommendationOverride[]

  // Wave-5: executive control tower & decision assist
  decisionPackagesCreated   DecisionPackage[]         @relation("DecisionPackageCreatedBy")
  decisionPackagesApproved  DecisionPackage[]         @relation("DecisionPackageApprovedBy")
  decisionApprovalEvents    DecisionApprovalEvent[]   @relation("DecisionApprovalActor")
  scenarioRunsCreated       ScenarioRun[]             @relation("ScenarioRunCreatedBy")

  // === Workspace System ===
  workspaceTasksAssignedTo           WorkspaceTask[]            @relation("WorkspaceTaskAssignedTo")
  workspaceTasksCreatedBy            WorkspaceTask[]            @relation("WorkspaceTaskCreatedBy")
  workspaceTasksAssignedBy           WorkspaceTask[]            @relation("WorkspaceTaskAssignedBy")
  workspaceTasksLastUpdatedBy        WorkspaceTask[]            @relation("WorkspaceTaskLastUpdatedBy")
  workspaceTaskComments              WorkspaceTaskComment[]
  workspaceAlertsAcknowledged        WorkspaceAlert[]
  workspaceApprovalRequestsRequested WorkspaceApprovalRequest[] @relation("WorkspaceApprovalRequester")
  workspaceApprovalRequestsDecidedBy WorkspaceApprovalRequest[] @relation("WorkspaceApprovalDecidedBy")

  // Support tickets
  supportTicketsCreated     SupportTicket[]    @relation("SupportTicketCreatedBy")
  supportTicketsAssigned    SupportTicket[]    @relation("SupportTicketAssignedTo")
  operationalExceptionsAssigned OperationalExceptionIndex[] @relation("OpsExceptionAssignee")
  operationalExceptionRcaCreated OperationalExceptionRca[] @relation("OpsExceptionRcaAuthor")
  ticketMessagesSent        TicketMessage[]
  ticketAttachmentsUploaded TicketAttachment[]
  ticketAuditEventsActed    TicketAuditEvent[]

  // Location: user's saved place (lat/lng-first; optional)
  currentPlaceId Int?
  currentPlace   Place? @relation(fields: [currentPlaceId], references: [id], onDelete: SetNull)

  // Location profile and events
  locationProfile UserLocationProfile?
  locationEvents  UserLocationEvent[]

  // === Clinic Medicine Control (CCMLPA) ===
  dispenseRequestsRequested          DispenseRequest[]          @relation("DispenseRequestRequestedBy")
  dispenseRequestsReceived           DispenseRequest[]          @relation("DispenseRequestReceivedBy")
  dispenseRequestsAsPatient          DispenseRequest[]          @relation("DispenseRequestPatient")
  injectionTokensAsPatient           InjectionToken[]           @relation("InjectionTokenPatient")
  injectionTokensGenerated           InjectionToken[]           @relation("InjectionTokenGeneratedBy")
  injectionTokensValidated           InjectionToken[]           @relation("InjectionTokenValidatedBy")
  injectionTokensUsed                InjectionToken[]           @relation("InjectionTokenUsedBy")
  injectionTokensCancelled           InjectionToken[]           @relation("InjectionTokenCancelledBy")
  vialSessionsOpenedBy               VialSession[]              @relation("VialSessionOpenedBy")
  vialSessionEventsPerformedBy       VialSessionEvent[]         @relation("VialSessionEventPerformedBy")
  medicationAdministrationsAsPatient MedicationAdministration[] @relation("MedicationAdminPatient")
  medicationAdministrationsBy        MedicationAdministration[] @relation("MedicationAdminBy")
  vialReturnsReturnedBy              VialReturn[]               @relation("VialReturnReturnedBy")
  outsideMedicineReceivesReceived    OutsideMedicineReceive[]   @relation("OutsideMedicineReceiveBy")
  vialReturnsReceivedBy              VialReturn[]               @relation("VialReturnReceivedBy")
  treatmentCoursesAsPatient          TreatmentCourse[]          @relation("TreatmentCoursePatient")
  treatmentCoursesPrescribed         TreatmentCourse[]          @relation("TreatmentCoursePrescribedBy")
  treatmentRevisionsChanged          TreatmentRevision[]        @relation("TreatmentRevisionChangedBy")
  destructionRecordsBy               DestructionRecord[]        @relation("DestructionRecordBy")
  destructionRecordsWitness          DestructionRecord[]        @relation("DestructionRecordWitness")
  medicineApprovalRequestsRequested  MedicineApprovalRequest[]  @relation("MedicineApprovalRequestedBy")
  medicineApprovalRequestsApproved   MedicineApprovalRequest[]  @relation("MedicineApprovalApprovedBy")
  medicineApprovalActionsBy          MedicineApprovalAction[]   @relation("MedicineApprovalActionBy")
  medicineIncidentsAssignedTo        MedicineIncident[]         @relation("MedicineIncidentAssignedTo")
  userMedicineRiskScores             UserMedicineRiskScore[]
  dailyReconciliationsAcknowledged   DailyReconciliation[]      @relation("DailyReconciliationBy")
  medicineControlDayClosesClosed     MedicineControlDayClose[]  @relation("MedicineControlDayCloseBy")

  // Branch Manager Control: escalation request/decide
  managerApprovalEscalationsRequested ManagerApprovalEscalation[] @relation("EscalationRequester")
  managerApprovalEscalationsDecided   ManagerApprovalEscalation[] @relation("EscalationDecider")

  // Clinic Approval Workflow: manager request → owner approve
  clinicApprovalRequestsRequested ClinicApprovalRequest[] @relation("ClinicApprovalRequester")
  clinicApprovalRequestsApproved  ClinicApprovalRequest[] @relation("ClinicApprovalApprover")

  doctorLeaveRequestsRequested DoctorLeaveRequest[] @relation("DoctorLeaveRequestedBy")
  doctorLeaveRequestsApproved  DoctorLeaveRequest[] @relation("DoctorLeaveApprovedBy")
  doctorCredentialsReviewed    DoctorCredential[]   @relation("DoctorCredentialReviewedBy")

  // Enterprise Surgery Module
  surgeryCasesAsPatient            SurgeryCase[]          @relation("SurgeryCasePatient")
  surgeryCasesCreatedBy            SurgeryCase[]          @relation("SurgeryCaseCreatedBy")
  surgeryCasesUpdatedBy            SurgeryCase[]          @relation("SurgeryCaseUpdatedBy")
  surgeryCaseStatusLogsChangedBy   SurgeryCaseStatusLog[] @relation("SurgeryCaseStatusLogChangedBy")
  surgeryCaseChecklistsCompletedBy SurgeryCaseChecklist[] @relation("SurgeryCaseChecklistCompletedBy")

  // Owner Onboarding State (step wizard draft/resume)
  ownerOnboardingState OwnerOnboardingState?

  // Admin — global medicine catalog CSV import
  medicineImportBatchesUploaded  MedicineImportBatch[]    @relation("MedicineImportBatchUploadedBy")
  medicineImportBatchesConfirmed MedicineImportBatch[]    @relation("MedicineImportBatchConfirmedBy")
  medicineImportBatchesApplied   MedicineImportBatch[]    @relation("MedicineImportBatchAppliedBy")
  medicineMasterAuditLogs        MedicineMasterAuditLog[]

  // === Medicine Requisition (Pharmacy Supply Chain) ===
  medicineRequisitionsRequested      MedicineRequisition[]         @relation("MedicineRequisitionRequestedBy")
  medicineRequisitionsReviewed       MedicineRequisition[]         @relation("MedicineRequisitionReviewedBy")
  medicineRequisitionsApproved       MedicineRequisition[]         @relation("MedicineRequisitionApprovedBy")
  medicineRequisitionsRejected       MedicineRequisition[]         @relation("MedicineRequisitionRejectedBy")
  medicineRequisitionsCancelled      MedicineRequisition[]         @relation("MedicineRequisitionCancelledBy")
