{
  "name": "bpa_app_api",
  "version": "10.0.0.6",
  "private": true,
  "main": "dist/index.js",
  "scripts": {
    "prepare": "husky",
    "start": "node dist/index.js",
    "dev": "cross-env TS_NODE_TRANSPILE_ONLY=1 nodemon --watch src --ext ts,json --exec \"node -r ts-node/register src/index.ts\"",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate deploy",
    "seed": "npx prisma db seed",
    "db:reset": "prisma migrate reset --force",
    "db:seed": "prisma db seed",
    "db:deploy": "prisma migrate deploy && prisma db seed",
    "minio:init": "node -r ts-node/register scripts/init-minio.ts",
    "generate:bd-pet-csv": "npx ts-node scripts/generate-bd-pet-master-csv.ts",
    "cleanup:categories": "npx ts-node scripts/cleanup-incorrect-categories.ts",
    "build": "rimraf dist && tsc -p tsconfig.json && node -e \"require('fs').copyFileSync('src/api/v1/services/ownerDelegation.service.js','dist/api/v1/services/ownerDelegation.service.js')\"",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "prisma:check": "prisma validate && prisma generate && prisma format",
    "verify": "npm run prisma:check && npm run typecheck",
    "conflict:check": "node scripts/conflict-check.js",
    "test": "jest --config jest.config.js",
    "test:watch": "jest --config jest.config.js --watch",
    "migrate:branch-access": "npx prisma generate && npx prisma migrate deploy && npx ts-node scripts/backfill-branch-access-permissions.ts",
    "backfill:branch-access": "npx ts-node scripts/backfill-branch-access-permissions.ts",
    "worker:notifications": "node -r ts-node/register src/common/jobs/notificationWorker.ts",
    "worker:email": "node -r ts-node/register src/common/queue/workers/email.worker.ts",
    "job:owners-automation": "node -r ts-node/register -e \"require('./src/common/jobs/ownersTeamAutomation.job').runOwnersTeamAutomationOnce().then(()=>process.exit(0)).catch(e=>{console.error(e);process.exit(1)})\"",
    "test:invite-roles": "npx ts-node src/api/v1/constants/branchRoleMatrix.test.ts",
    "verify:clone-auth": "npx ts-node scripts/verify-clone-auth.ts",
    "dev:infra": "docker compose up -d bpa_db bpa-redis bpa-storage",
    "dev:api": "npm run dev",
    "dev:full": "docker compose up",
    "dev:down": "docker compose down",
    "dev:down:all": "docker compose down -v --rmi all",
    "dev:down:volumes": "docker compose down -v",
    "dev:down:rmi": "docker compose down -v --rmi",
    "dev:down:volumes:rmi": "docker compose down -v --rmi all",
    "dev:down:volumes:rmi:all": "docker compose down -v --rmi all",
    "dev:down:volumes:rmi:all:volumes": "docker compose down -v --rmi all",
    "dev:down:volumes:rmi:all:volumes:all": "docker compose down -v --rmi all",
    "check:migrations": "node scripts/check-migration-collisions.js",
    "smoke:governance": "npx ts-node scripts/governance_smoke.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.700.0",
    "@aws-sdk/s3-request-presigner": "^3.971.0",
    "@prisma/client": "5.22.0",
    "axios": "^1.7.7",
    "bcrypt": "^5.1.1",
    "bullmq": "^5.67.2",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "csv-parse": "^5.6.0",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-list-endpoints": "^6.0.0",
    "express-rate-limit": "^7.4.1",
    "ffmpeg-static": "^5.2.0",
    "fluent-ffmpeg": "^2.1.3",
    "google-auth-library": "^9.14.1",
    "helmet": "^7.1.0",
    "ioredis": "^5.4.1",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^6.9.16",
    "otplib": "^12.0.1",
    "react-easy-crop": "^5.5.6",
    "sharp": "^0.33.5",
    "socket.io": "^4.8.3",
    "ws": "^8.19.0",
    "zod": "^4.3.5"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,json,prisma}": [
      "npm run conflict:check"
    ]
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/jest": "^29.5.14",
    "@types/node": "^25.0.9",
    "cross-env": "^7.0.3",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "lint-staged": "^15.4.3",
    "nodemon": "^3.1.7",
    "prisma": "5.22.0",
    "rimraf": "^6.0.1",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "typescript": "5.9.3"
  },
  "prisma": {
    "seed": "ts-node --compiler-options {\"module\":\"CommonJS\"} prisma/seed.ts"
  }
}
